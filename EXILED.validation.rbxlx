          <Item class="ModuleScript" referent="133">
            <Properties>
              <string name="Name">RoundController</string>
              <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")

local GamePhase = require(ReplicatedStorage.Shared.Enums.GamePhase)
local RemoteNames = require(ReplicatedStorage.Shared.Constants.RemoteNames)
local WorldModeResolver = require(ReplicatedStorage.Shared.Utility.WorldModeResolver)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local RoundController = {}
RoundController.Name = "RoundController"

function RoundController:Init()
	local defaultPhase = WorldModeResolver.IsWeaponLab() and GamePhase.Preparation or "Unknown"
	self.CurrentState = {
		Phase = defaultPhase,
		TimeLeft = 0,
		Outcome = "None",
	}
end

function RoundController:Start()
	local roundStateChanged = self.World.Remotes:WaitForChild(RemoteNames.RoundStateChanged)
	local roundTimerUpdated = self.World.Remotes:WaitForChild(RemoteNames.RoundTimerUpdated)

	roundStateChanged.OnClientEvent:Connect(function(state)
		self.CurrentState = {
			Phase = state.Phase or "Unknown",
			TimeLeft = state.TimeLeft or 0,
			Outcome = state.Outcome or "None",
		}
		
		DebugLog:Log("ClientRound", "[RoundController] Received state:", state.Phase, state.TimeLeft)
	end)
	
	roundTimerUpdated.OnClientEvent:Connect(function(state)
		self.CurrentState = {
			Phase = state.Phase or self.CurrentState.Phase,
			TimeLeft = state.TimeLeft or 0,
			Outcome = state.Outcome or self.CurrentState.Outcome,
		}
	end)

	DebugLog:Log("ClientRound", "[RoundController] Started")
end

function RoundController:GetState()
	return self.CurrentState
end

return RoundController
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="134">
            <Properties>
              <string name="Name">StaminaController</string>
              <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")

local GamePhase = require(ReplicatedStorage.Shared.Enums.GamePhase)
local RemoteNames = require(ReplicatedStorage.Shared.Constants.RemoteNames)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local StaminaController = {}
StaminaController.Name = "StaminaController"

function StaminaController:Init()
	self.Player = self.World.Player
	self.PlayerGui = self.World.PlayerGui
	self.Remotes = self.World.Remotes
	self.Remote = self.Remotes:WaitForChild(RemoteNames.StaminaStateChanged)
	self.State = {
		Current = 100,
		Max = 100,
		MovementState = "Walk",
		RunDurationBeforeFatigue = 6,
	}
	self.Character = nil
	self.Humanoid = nil
	self.Health = 100
	self.MaxHealth = 100
end

function StaminaController:Start()
	self:_createUI()
	self:_hookCharacter(self.World:GetCharacter())

	self.Player.CharacterAdded:Connect(function(character)
		self:_hookCharacter(character)
	end)

	self.Remote.OnClientEvent:Connect(function(state)
		self.State = state or self.State
		self:_refresh()
	end)

	task.spawn(function()
		while true do
			self:_refresh()
			task.wait(0.1)
		end
	end)

	DebugLog:Log("ClientMovement", "[StaminaController] Started")
end

function StaminaController:_createUI()
	local screenGui = Instance.new("ScreenGui")
	screenGui.Name = "StaminaUI"
	screenGui.ResetOnSpawn = false
	screenGui.Parent = self.PlayerGui

	local frame = Instance.new("Frame")
	frame.Name = "Container"
	frame.AnchorPoint = Vector2.new(0, 1)
	frame.Position = UDim2.new(0, 18, 1, -18)
	frame.Size = UDim2.new(0, 300, 0, 96)
	frame.BackgroundTransparency = 1
	frame.Parent = screenGui

	local portrait = Instance.new("Frame")
	portrait.Name = "Portrait"
	portrait.Position = UDim2.new(0, 0, 0, 12)
	portrait.Size = UDim2.new(0, 74, 0, 74)
	portrait.BackgroundColor3 = Color3.fromRGB(20, 22, 28)
	portrait.BackgroundTransparency = 0.08
	portrait.BorderSizePixel = 0
	portrait.Parent = frame

	local portraitCorner = Instance.new("UICorner")
	portraitCorner.CornerRadius = UDim.new(0, 12)
	portraitCorner.Parent = portrait

	local portraitLabel = Instance.new("TextLabel")
	portraitLabel.Name = "PortraitLabel"
	portraitLabel.AnchorPoint = Vector2.new(0.5, 0.5)
	portraitLabel.Position = UDim2.fromScale(0.5, 0.5)
	portraitLabel.Size = UDim2.new(1, -12, 1, -12)
	portraitLabel.BackgroundTransparency = 1
	portraitLabel.Font = Enum.Font.GothamBlack
	portraitLabel.TextScaled = true
	portraitLabel.TextColor3 = Color3.fromRGB(238, 240, 245)
	portraitLabel.Text = ":)"
	portraitLabel.Parent = portrait

	local vitals = Instance.new("Frame")
	vitals.Name = "Vitals"
	vitals.Position = UDim2.new(0, 84, 0, 18)
	vitals.Size = UDim2.new(0, 216, 0, 64)
	vitals.BackgroundTransparency = 1
	vitals.Parent = frame

	local healthLabel = Instance.new("TextLabel")
	healthLabel.Name = "HealthLabel"
	healthLabel.BackgroundTransparency = 1
	healthLabel.Position = UDim2.new(0, 0, 0, 0)
	healthLabel.Size = UDim2.new(1, 0, 0, 14)
	healthLabel.Font = Enum.Font.GothamBold
	healthLabel.TextSize = 11
	healthLabel.TextColor3 = Color3.fromRGB(255, 226, 226)
	healthLabel.TextXAlignment = Enum.TextXAlignment.Left
	healthLabel.Text = "Health 100/100"
	healthLabel.Parent = vitals

	local healthBarBackground = Instance.new("Frame")
	healthBarBackground.Name = "HealthBarBackground"
	healthBarBackground.Position = UDim2.new(0, 0, 0, 16)
	healthBarBackground.Size = UDim2.new(1, 0, 0, 10)
	healthBarBackground.BackgroundColor3 = Color3.fromRGB(58, 38, 40)
	healthBarBackground.BorderSizePixel = 0
	healthBarBackground.Parent = vitals

	local healthBarCorner = Instance.new("UICorner")
	healthBarCorner.CornerRadius = UDim.new(0, 999)
	healthBarCorner.Parent = healthBarBackground

	local healthBar = Instance.new("Frame")
	healthBar.Name = "HealthBar"
	healthBar.Size = UDim2.new(1, 0, 1, 0)
	healthBar.BackgroundColor3 = Color3.fromRGB(207, 66, 66)
	healthBar.BorderSizePixel = 0
	healthBar.Parent = healthBarBackground

	local healthBarFillCorner = Instance.new("UICorner")
	healthBarFillCorner.CornerRadius = UDim.new(0, 999)
	healthBarFillCorner.Parent = healthBar

	local label = Instance.new("TextLabel")
	label.Name = "Label"
	label.BackgroundTransparency = 1
	label.Position = UDim2.new(0, 0, 0, 32)
	label.Size = UDim2.new(0.62, 0, 0, 12)
	label.Font = Enum.Font.GothamBold
	label.TextSize = 11
	label.TextColor3 = Color3.fromRGB(180, 214, 255)
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.Text = "Stamina"
	label.Parent = vitals

	local stateLabel = Instance.new("TextLabel")
	stateLabel.Name = "State"
	stateLabel.BackgroundTransparency = 1
	stateLabel.AnchorPoint = Vector2.new(1, 0)
	stateLabel.Position = UDim2.new(1, 0, 0, 32)
	stateLabel.Size = UDim2.new(0.34, 0, 0, 12)
	stateLabel.Font = Enum.Font.GothamBold
	stateLabel.TextSize = 11
	stateLabel.TextColor3 = Color3.fromRGB(180, 214, 255)
	stateLabel.TextXAlignment = Enum.TextXAlignment.Right
	stateLabel.Text = "WALK"
	stateLabel.Parent = vitals

	local barBackground = Instance.new("Frame")
	barBackground.Name = "BarBackground"
	barBackground.Position = UDim2.new(0, 0, 0, 48)
	barBackground.Size = UDim2.new(1, 0, 0, 10)
	barBackground.BackgroundColor3 = Color3.fromRGB(46, 46, 56)
	barBackground.BorderSizePixel = 0
	barBackground.Parent = vitals

	local barCorner = Instance.new("UICorner")
	barCorner.CornerRadius = UDim.new(0, 999)
	barCorner.Parent = barBackground

	local bar = Instance.new("Frame")
	bar.Name = "Bar"
	bar.Size = UDim2.new(1, 0, 1, 0)
	bar.BackgroundColor3 = Color3.fromRGB(109, 180, 255)
	bar.BorderSizePixel = 0
	bar.Parent = barBackground

	local barFillCorner = Instance.new("UICorner")
	barFillCorner.CornerRadius = UDim.new(0, 999)
	barFillCorner.Parent = bar

	self.UI = {
		Root = screenGui,
		Frame = frame,
		PortraitLabel = portraitLabel,
		HealthLabel = healthLabel,
		HealthBar = healthBar,
		Label = label,
		StateLabel = stateLabel,
		Bar = bar,
	}

	self:_refresh()
end

function StaminaController:_hookCharacter(character)
	self.Character = character
	self.Humanoid = nil

	if not character then
		return
	end

	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if not humanoid then
		return
	end

	self.Humanoid = humanoid
	self.Health = humanoid.Health
	self.MaxHealth = humanoid.MaxHealth

	humanoid.HealthChanged:Connect(function(health)
		self.Health = health
		self.MaxHealth = humanoid.MaxHealth
		self:_refresh()
	end)

	self:_refresh()
end

function StaminaController:_refresh()
	if not self.UI then
		return
	end

	local roundState = self.World:GetRoundState()
	local phase = roundState and roundState.Phase or "Unknown"
	local shouldShow = phase == GamePhase.Preparation or phase == GamePhase.Reception
	self.UI.Root.Enabled = shouldShow
	if not shouldShow then
		return
	end

	local current = self.State.Current or 0
	local max = math.max(1, self.State.Max or 100)
	local ratio = math.clamp(current / max, 0, 1)
	local health = self.Humanoid and self.Humanoid.Health or self.Health or 100
	local maxHealth = math.max(1, self.Humanoid and self.Humanoid.MaxHealth or self.MaxHealth or 100)
	local healthRatio = math.clamp(health / maxHealth, 0, 1)
	local movementState = tostring(self.State.MovementState or "Walk")
	self.UI.Bar.Size = UDim2.new(ratio, 0, 1, 0)
	self.UI.HealthBar.Size = UDim2.new(healthRatio, 0, 1, 0)
	self.UI.HealthLabel.Text = string.format("Health %.0f/%.0f", health, maxHealth)
	self.UI.Label.Text = string.format("Stamina %.1f/%.0f", current, max)
	self.UI.StateLabel.Text = string.upper(movementState)
	self.UI.PortraitLabel.Text = maxHealth > 0 and (health / maxHealth <= 0.35 and ":(" or ":)") or ":|"

	if healthRatio <= 0.25 then
		self.UI.HealthBar.BackgroundColor3 = Color3.fromRGB(214, 92, 92)
	elseif healthRatio <= 0.5 then
		self.UI.HealthBar.BackgroundColor3 = Color3.fromRGB(229, 123, 88)
	else
		self.UI.HealthBar.BackgroundColor3 = Color3.fromRGB(207, 66, 66)
	end

	if movementState == "Fatigue" then
		self.UI.StateLabel.TextColor3 = Color3.fromRGB(255, 156, 92)
		self.UI.Bar.BackgroundColor3 = Color3.fromRGB(255, 156, 92)
	elseif movementState == "Run" then
		self.UI.StateLabel.TextColor3 = Color3.fromRGB(242, 212, 103)
		self.UI.Bar.BackgroundColor3 = Color3.fromRGB(242, 212, 103)
	elseif movementState == "Sprint" then
		self.UI.StateLabel.TextColor3 = Color3.fromRGB(132, 224, 255)
		self.UI.Bar.BackgroundColor3 = Color3.fromRGB(109, 180, 255)
	elseif ratio <= 0.25 then
		self.UI.StateLabel.TextColor3 = Color3.fromRGB(214, 92, 92)
		self.UI.Bar.BackgroundColor3 = Color3.fromRGB(214, 92, 92)
	elseif ratio <= 0.5 then
		self.UI.StateLabel.TextColor3 = Color3.fromRGB(242, 212, 103)
		self.UI.Bar.BackgroundColor3 = Color3.fromRGB(242, 212, 103)
	else
		self.UI.StateLabel.TextColor3 = Color3.fromRGB(180, 214, 255)
		self.UI.Bar.BackgroundColor3 = Color3.fromRGB(109, 180, 255)
	end
end

return StaminaController
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="135">
            <Properties>
              <string name="Name">StatusEffectController</string>
              <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")

local RemoteNames = require(ReplicatedStorage.Shared.Constants.RemoteNames)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local StatusEffectController = {}
StatusEffectController.Name = "StatusEffectController"

function StatusEffectController:Init()
	self.Player = self.World.Player
	self.PlayerGui = self.World.PlayerGui
	self.Shared = self.World.Shared
	self.Remotes = self.Shared:WaitForChild("Remotes")
	self.Remote = self.Remotes:WaitForChild(RemoteNames.StatusEffectsChanged)
	self.ActiveStatuses = {}
	self.StatusFrames = {}
end

function StatusEffectController:Start()
	self:_createUI()

	self.Remote.OnClientEvent:Connect(function(snapshot)
		self.ActiveStatuses = snapshot or {}
		self:_renderStatuses()
	end)

	task.spawn(function()
		while true do
			self:_updateDurations()
			task.wait(0.1)
		end
	end)

	DebugLog:Log("ClientStatus", "[StatusEffectController] Started")
end

function StatusEffectController:_createUI()
	local screenGui = Instance.new("ScreenGui")
	screenGui.Name = "StatusEffectsUI"
	screenGui.ResetOnSpawn = false
	screenGui.Parent = self.PlayerGui

	local container = Instance.new("Frame")
	container.Name = "Container"
	container.AnchorPoint = Vector2.new(1, 0.5)
	container.Position = UDim2.new(1, -24, 0.5, 0)
	container.Size = UDim2.new(0, 150, 0, 360)
	container.BackgroundTransparency = 1
	container.Parent = screenGui

	local layout = Instance.new("UIListLayout")
	layout.Padding = UDim.new(0, 6)
	layout.HorizontalAlignment = Enum.HorizontalAlignment.Right
	layout.VerticalAlignment = Enum.VerticalAlignment.Center
	layout.Parent = container

	self.UI = {
		Root = screenGui,
		Container = container,
	}
end

function StatusEffectController:_renderStatuses()
	local seen = {}

	for _, status in ipairs(self.ActiveStatuses) do
		if type(status) ~= "table" or not status.Id then
			continue
		end

		local frame = self.StatusFrames[status.Id]
		if not frame then
			frame = self:_createStatusFrame(status)
			self.StatusFrames[status.Id] = frame
		end

		seen[status.Id] = true
		frame.Visible = true
		local iconLabel = frame:FindFirstChild("IconLabel")
		local nameLabel = frame:FindFirstChild("NameLabel")
		local metaLabel = frame:FindFirstChild("MetaLabel")
		local durationLabel = frame:FindFirstChild("DurationLabel")

		if iconLabel then
			iconLabel.Text = status.ShortLabel or "???"
			iconLabel.BackgroundColor3 = status.IsBuff and Color3.fromRGB(214, 180, 64) or Color3.fromRGB(168, 57, 57)
		end

		if nameLabel then
			nameLabel.Text = status.DisplayName or status.Id
		end

		if metaLabel then
			metaLabel.Text = self:_formatMeta(status)
		end

		if durationLabel then
			durationLabel.Text = string.format("%.1fs", status.Duration or 0)
		end

		local currentDuration = status.Duration or 0
		local maxDuration = frame:GetAttribute("MaxDuration")
		if maxDuration == nil or currentDuration > maxDuration then
			frame:SetAttribute("MaxDuration", currentDuration)
		end
	end

	for statusId, frame in pairs(self.StatusFrames) do
		if not seen[statusId] then
			frame.Visible = false
		end
	end
end

function StatusEffectController:_createStatusFrame(status)
	local frame = Instance.new("Frame")
	frame.Name = status.Id
	frame.Size = UDim2.new(1, 0, 0, 46)
	frame.BackgroundColor3 = Color3.fromRGB(22, 22, 28)
	frame.BackgroundTransparency = 0.15
	frame.BorderSizePixel = 0
	frame.Parent = self.UI.Container

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 8)
	corner.Parent = frame

	local iconLabel = Instance.new("TextLabel")
	iconLabel.Name = "IconLabel"
	iconLabel.Position = UDim2.new(0, 2, 0, 2)
	iconLabel.Size = UDim2.new(0, 42, 0, 42)
	iconLabel.BorderSizePixel = 0
	iconLabel.BackgroundColor3 = Color3.fromRGB(214, 180, 64)
	iconLabel.Font = Enum.Font.GothamBold
	iconLabel.TextColor3 = Color3.new(1, 1, 1)
	iconLabel.TextScaled = true
	iconLabel.Parent = frame

	local iconCorner = Instance.new("UICorner")
	iconCorner.CornerRadius = UDim.new(0, 8)
	iconCorner.Parent = iconLabel

	local nameLabel = Instance.new("TextLabel")
	nameLabel.Name = "NameLabel"
	nameLabel.Position = UDim2.new(0, 50, 0, 4)
	nameLabel.Size = UDim2.new(1, -94, 0, 16)
	nameLabel.BackgroundTransparency = 1
	nameLabel.Font = Enum.Font.GothamBold
	nameLabel.TextColor3 = Color3.fromRGB(240, 240, 240)
	nameLabel.TextSize = 12
	nameLabel.TextXAlignment = Enum.TextXAlignment.Left
	nameLabel.Parent = frame

	local metaLabel = Instance.new("TextLabel")
	metaLabel.Name = "MetaLabel"
	metaLabel.Position = UDim2.new(0, 50, 0, 20)
	metaLabel.Size = UDim2.new(1, -94, 0, 12)
	metaLabel.BackgroundTransparency = 1
	metaLabel.Font = Enum.Font.Gotham
	metaLabel.TextColor3 = Color3.fromRGB(185, 185, 185)
	metaLabel.TextSize = 11
	metaLabel.TextXAlignment = Enum.TextXAlignment.Left
	metaLabel.Parent = frame

	local durationLabel = Instance.new("TextLabel")
	durationLabel.Name = "DurationLabel"
	durationLabel.Position = UDim2.new(1, -40, 0, 6)
	durationLabel.Size = UDim2.new(0, 34, 0, 14)
	durationLabel.BackgroundTransparency = 1
	durationLabel.Font = Enum.Font.GothamBold
	durationLabel.TextColor3 = Color3.fromRGB(230, 230, 230)
	durationLabel.TextSize = 11
	durationLabel.TextXAlignment = Enum.TextXAlignment.Right
	durationLabel.Parent = frame

	local timerBarBackground = Instance.new("Frame")
	timerBarBackground.Name = "TimerBarBackground"
	timerBarBackground.Position = UDim2.new(0, 50, 1, -8)
	timerBarBackground.Size = UDim2.new(1, -58, 0, 4)
	timerBarBackground.BackgroundColor3 = Color3.fromRGB(46, 46, 56)
	timerBarBackground.BorderSizePixel = 0
	timerBarBackground.Parent = frame

	local timerBar = Instance.new("Frame")
	timerBar.Name = "TimerBar"
	timerBar.Size = UDim2.new(1, 0, 1, 0)
	timerBar.BackgroundColor3 = Color3.fromRGB(220, 220, 220)
	timerBar.BorderSizePixel = 0
	timerBar.Parent = timerBarBackground

	return frame
end

function StatusEffectController:_updateDurations()
	for _, status in ipairs(self.ActiveStatuses) do
		if type(status) ~= "table" or not status.Id then
			continue
		end

		local frame = self.StatusFrames[status.Id]
		if frame and frame.Visible then
			status.Duration = math.max(0, (status.Duration or 0) - 0.1)
			local durationLabel = frame:FindFirstChild("DurationLabel")
			if durationLabel then
				durationLabel.Text = string.format("%.1fs", status.Duration)
			end

			local maxDuration = frame:GetAttribute("MaxDuration") or status.Duration
			local fillRatio = maxDuration > 0 and math.clamp(status.Duration / maxDuration, 0, 1) or 0
			local timerBarBackground = frame:FindFirstChild("TimerBarBackground")
			local timerBar = timerBarBackground and timerBarBackground:FindFirstChild("TimerBar")
			if timerBar then
				timerBar.Size = UDim2.new(fillRatio, 0, 1, 0)
			end

			if status.Duration <= 0 then
				frame:SetAttribute("MaxDuration", nil)
			end
		end
	end
end

function StatusEffectController:_formatMeta(status)
	if type(status) ~= "table" then
		return ""
	end

	local fragments = {}
	if (status.Tier or 1) > 1 then
		table.insert(fragments, string.format("T%d", status.Tier))
	end
	if (status.Stacks or 1) > 1 then
		table.insert(fragments, string.format("x%d", status.Stacks))
	end
	if (status.Magnitude or 0) > 0 then
		table.insert(fragments, string.format("%d%%", math.floor((status.Magnitude * 100) + 0.5)))
	end

	return #fragments > 0 and table.concat(fragments, "  ") or ""
end

return StatusEffectController
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="136">
            <Properties>
              <string name="Name">StruggleController</string>
              <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")

local RemoteNames = require(ReplicatedStorage.Shared.Constants.RemoteNames)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local StruggleController = {}
StruggleController.Name = "StruggleController"

function StruggleController:Init()
	self.Active = false
	self.Progress = 0
	self.MaxProgress = 1
	self.RemainingDuration = 0
	self.LastPressAt = 0
	self.Remote = self.World.Remotes:WaitForChild(RemoteNames.StruggleStateChanged)
end

function StruggleController:Start()
	self:_createUI()

	self.Remote.OnClientEvent:Connect(function(payload)
		self:_handleRemote(payload)
	end)

	task.spawn(function()
		while true do
			self:_updateUiState(0.05)
			task.wait(0.05)
		end
	end)

	DebugLog:Log("ClientInteraction", "[StruggleController] Started")
end

function StruggleController:IsActive()
	return self.Active
end

function StruggleController:RegisterLocalPress()
	if not self.Active then
		return
	end

	self.LastPressAt = os.clock()
	self.UI.KeyLabel.BackgroundColor3 = Color3.fromRGB(242, 212, 103)
	self.UI.KeyLabel.TextColor3 = Color3.fromRGB(20, 22, 28)
end

function StruggleController:_handleRemote(payload)
	local state = payload and payload.State
	if state == "Start" or state == "Update" then
		self.Active = true
		self.Progress = payload.Progress or 0
		self.MaxProgress = payload.Max or 1
		self.RemainingDuration = payload.Duration or 0
		self.UI.Root.Enabled = true
		self.UI.Label.Text = payload.Prompt or "Struggle"
		self.UI.SubLabel.Text = payload.SubPrompt or "Break free before Jiangshi finishes feeding"
		self.UI.KeyLabel.Text = payload.RequiredKey or "SPACE"
		self:_refreshProgress()
	else
		self.Active = false
		self.Progress = 0
		self.MaxProgress = 1
		self.RemainingDuration = 0
		self.UI.Root.Enabled = false
	end
end

function StruggleController:_updateUiState(deltaTime)
	if not self.Active or not self.UI then
		return
	end

	self.RemainingDuration = math.max(0, self.RemainingDuration - deltaTime)
	self.UI.Duration.Text = string.format("%.1fs", self.RemainingDuration)

	if os.clock() - self.LastPressAt > 0.08 then
		self.UI.KeyLabel.BackgroundColor3 = Color3.fromRGB(56, 49, 38)
		self.UI.KeyLabel.TextColor3 = Color3.fromRGB(242, 212, 103)
	end

	local urgency = self.RemainingDuration <= 2
	self.UI.Duration.TextColor3 = urgency and Color3.fromRGB(228, 112, 112) or Color3.fromRGB(240, 240, 240)
	self.UI.Bar.BackgroundColor3 = urgency and Color3.fromRGB(232, 132, 132) or Color3.fromRGB(214, 180, 64)
end

function StruggleController:_refreshProgress()
	local ratio = self.MaxProgress > 0 and math.clamp(self.Progress / self.MaxProgress, 0, 1) or 0
	self.UI.Bar.Size = UDim2.new(ratio, 0, 1, 0)
	self.UI.ProgressLabel.Text = string.format("%d%%", math.floor((ratio * 100) + 0.5))
	self.UI.Duration.Text = string.format("%.1fs", self.RemainingDuration)
end

function StruggleController:_createUI()
	local screenGui = Instance.new("ScreenGui")
	screenGui.Name = "SkillCheckUI"
	screenGui.Enabled = false
	screenGui.ResetOnSpawn = false
	screenGui.Parent = self.World.PlayerGui

	local container = Instance.new("Frame")
	container.Name = "Container"
	container.AnchorPoint = Vector2.new(0.5, 0.75)
	container.Position = UDim2.new(0.5, 0, 0.75, 0)
	container.Size = UDim2.new(0, 360, 0, 108)
	container.BackgroundColor3 = Color3.fromRGB(18, 19, 24)
	container.BackgroundTransparency = 0.05
	container.BorderSizePixel = 0
	container.Parent = screenGui

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 10)
	corner.Parent = container

	local label = Instance.new("TextLabel")
	label.Name = "Label"
	label.Position = UDim2.new(0, 14, 0, 10)
	label.Size = UDim2.new(1, -28, 0, 20)
	label.BackgroundTransparency = 1
	label.Font = Enum.Font.GothamBold
	label.TextColor3 = Color3.fromRGB(240, 240, 240)
	label.TextSize = 17
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.Text = "Struggle"
	label.Parent = container

	local subLabel = Instance.new("TextLabel")
	subLabel.Name = "SubLabel"
	subLabel.Position = UDim2.new(0, 14, 0, 32)
	subLabel.Size = UDim2.new(1, -120, 0, 18)
	subLabel.BackgroundTransparency = 1
	subLabel.Font = Enum.Font.Gotham
	subLabel.TextColor3 = Color3.fromRGB(182, 182, 190)
	subLabel.TextSize = 12
	subLabel.TextXAlignment = Enum.TextXAlignment.Left
	subLabel.Text = "Break free before the grapple finishes"
	subLabel.Parent = container

	local duration = Instance.new("TextLabel")
	duration.Name = "Duration"
	duration.Position = UDim2.new(1, -78, 0, 12)
	duration.Size = UDim2.new(0, 64, 0, 20)
	duration.BackgroundTransparency = 1
	duration.Font = Enum.Font.GothamBold
	duration.TextColor3 = Color3.fromRGB(240, 240, 240)
	duration.TextSize = 14
	duration.TextXAlignment = Enum.TextXAlignment.Right
	duration.Text = "0.0s"
	duration.Parent = container

	local keyLabel = Instance.new("TextLabel")
	keyLabel.Name = "KeyLabel"
	keyLabel.Position = UDim2.new(0, 14, 0, 58)
	keyLabel.Size = UDim2.new(0, 82, 0, 28)
	keyLabel.BackgroundColor3 = Color3.fromRGB(56, 49, 38)
	keyLabel.BorderSizePixel = 0
	keyLabel.Font = Enum.Font.GothamBold
	keyLabel.TextColor3 = Color3.fromRGB(242, 212, 103)
	keyLabel.TextSize = 16
	keyLabel.Text = "SPACE"
	keyLabel.Parent = container

	local keyCorner = Instance.new("UICorner")
	keyCorner.CornerRadius = UDim.new(0, 8)
	keyCorner.Parent = keyLabel

	local progressLabel = Instance.new("TextLabel")
	progressLabel.Name = "ProgressLabel"
	progressLabel.Position = UDim2.new(1, -74, 0, 60)
	progressLabel.Size = UDim2.new(0, 60, 0, 18)
	progressLabel.BackgroundTransparency = 1
	progressLabel.Font = Enum.Font.GothamBold
	progressLabel.TextColor3 = Color3.fromRGB(242, 212, 103)
	progressLabel.TextSize = 13
	progressLabel.TextXAlignment = Enum.TextXAlignment.Right
	progressLabel.Text = "0%"
	progressLabel.Parent = container

	local barBackground = Instance.new("Frame")
	barBackground.Name = "BarBackground"
	barBackground.Position = UDim2.new(0, 104, 0, 66)
	barBackground.Size = UDim2.new(1, -118, 0, 12)
	barBackground.BackgroundColor3 = Color3.fromRGB(48, 51, 60)
	barBackground.BorderSizePixel = 0
	barBackground.Parent = container

	local barBackgroundCorner = Instance.new("UICorner")
	barBackgroundCorner.CornerRadius = UDim.new(0, 6)
	barBackgroundCorner.Parent = barBackground

	local bar = Instance.new("Frame")
	bar.Name = "Bar"
	bar.Size = UDim2.new(0, 0, 1, 0)
	bar.BackgroundColor3 = Color3.fromRGB(214, 180, 64)
	bar.BorderSizePixel = 0
	bar.Parent = barBackground

	local barCorner = Instance.new("UICorner")
	barCorner.CornerRadius = UDim.new(0, 6)
	barCorner.Parent = bar

	self.UI = {
		Root = screenGui,
		Label = label,
		SubLabel = subLabel,
		Duration = duration,
		KeyLabel = keyLabel,
		ProgressLabel = progressLabel,
		Bar = bar,
	}
end

return StruggleController
]]></string>
