function DevMenuController:_refreshUi()
	if not self.UI then
		return
	end

	local weaponId = self:_getSelectedWeaponId()
	local itemId = self:_getSelectedItemId()
	local entityId = self:_getSelectedEntityId()
	self.UI.WeaponName.Text = weaponId and (WeaponDefinitions[weaponId].DisplayName or weaponId) or "-"
	self.UI.ItemName.Text = itemId and (ItemDefinitions[itemId].DisplayName or itemId) or "-"
	self.UI.EntityName.Text = entityId or "-"
	self.UI.StateLabel.Text = string.format("Phase: %s  |  Time: %ss", tostring(self.DevState.Phase or "Unknown"), tostring(self.DevState.TimeLeft or 0))
	local placementText = self.PlacementMode and string.format("Click ground to place: %s", self.PlacementMode) or ""
	local message = self.DevState.Message or ""
	if placementText ~= "" and message ~= "" then
		self.UI.MessageLabel.Text = placementText .. "\n" .. message
	elseif placementText ~= "" then
		self.UI.MessageLabel.Text = placementText
	else
		self.UI.MessageLabel.Text = message
	end
	self.UI.EscapeButton.Text = (self.DevState.EscapeEnabled and "Disable Escape" or "Enable Escape")
	self.UI.EscapeButton.BackgroundColor3 = self.DevState.EscapeEnabled and Color3.fromRGB(168, 57, 57) or Color3.fromRGB(58, 86, 68)
	self.UI.GodModeButton.Text = (self.DevState.GodMode and "Disable God" or "Enable God")
	self.UI.GodModeButton.BackgroundColor3 = self.DevState.GodMode and Color3.fromRGB(88, 122, 206) or Color3.fromRGB(54, 58, 70)
	self.UI.DebugUiButton.Text = (self.DevState.DebugUiEnabled ~= false and "Disable Debug UI" or "Enable Debug UI")
	self.UI.DebugUiButton.BackgroundColor3 = (self.DevState.DebugUiEnabled ~= false) and Color3.fromRGB(88, 122, 206) or Color3.fromRGB(54, 58, 70)

	local labStatus = self.ViewmodelController and self.ViewmodelController.GetLabStatus and self.ViewmodelController:GetLabStatus() or nil
	local labEnabled = labStatus and labStatus.Enabled == true
	local labFrozen = labStatus and labStatus.Frozen == true
	local loopAction = labStatus and labStatus.LoopAction or "Idle"
	local lastAction = labStatus and labStatus.LastAction or "Idle"
	local labWeaponId = labStatus and labStatus.WeaponId or nil
	local labSnapshotWeaponId = labStatus and labStatus.SnapshotWeaponId or nil
	local labShowSourceRig = labStatus and labStatus.ShowSourceRig == true
	local labWeaponLabel = labWeaponId or labSnapshotWeaponId or "Live"
	self.UI.LabStatus.Text = string.format("Lab: %s  |  Freeze: %s  |  Weapon: %s  |  Loop: %s  |  Last: %s", labEnabled and "On" or "Off", labFrozen and "On" or "Off", tostring(labWeaponLabel), tostring(loopAction), tostring(lastAction))
	self.UI.LabToggleButton.Text = labEnabled and "Disable Lab" or "Enable Lab"
	self.UI.LabToggleButton.BackgroundColor3 = labEnabled and Color3.fromRGB(88, 122, 206) or Color3.fromRGB(54, 58, 70)
	self.UI.LabFreezeButton.Text = labFrozen and "Unfreeze Lab" or "Freeze Lab"
	self.UI.LabFreezeButton.BackgroundColor3 = labFrozen and Color3.fromRGB(168, 57, 57) or Color3.fromRGB(54, 58, 70)
	self.UI.LabUseSelectedButton.BackgroundColor3 = labWeaponId and Color3.fromRGB(88, 122, 206) or Color3.fromRGB(54, 58, 70)
	self.UI.LabUseLiveButton.BackgroundColor3 = labWeaponId and Color3.fromRGB(54, 58, 70) or Color3.fromRGB(88, 122, 206)
	self.UI.LabShowLiveButton.Text = labShowSourceRig and "Hide Live Rig" or "Show Live Rig"
	self.UI.LabShowLiveButton.BackgroundColor3 = labShowSourceRig and Color3.fromRGB(88, 122, 206) or Color3.fromRGB(54, 58, 70)
	self:_applyDebugUiState()
end

return DevMenuController
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="124">
            <Properties>
              <string name="Name">EntityAbilityVisualController</string>
              <string name="Source"><![CDATA[local Debris = game:GetService("Debris")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

local RemoteNames = require(ReplicatedStorage.Shared.Constants.RemoteNames)
local DebugFlags = require(ReplicatedStorage.Shared.Data.DebugFlags)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local EntityAbilityVisualController = {}
EntityAbilityVisualController.Name = "EntityAbilityVisualController"

local function _setModelLocalTransparency(model, transparency)
	for _, descendant in ipairs(model:GetDescendants()) do
		if descendant:IsA("BasePart") then
			descendant.LocalTransparencyModifier = transparency
		end
	end
end

local function _createVisualClone(model)
	local clone = model:Clone()
	clone.Name = model.Name .. "_BlindHungerVisual"

	for _, descendant in ipairs(clone:GetDescendants()) do
		if descendant:IsA("Script") or descendant:IsA("LocalScript") then
			descendant:Destroy()
		elseif descendant:IsA("BasePart") then
			descendant.Anchored = true
			descendant.CanCollide = false
			descendant.CanTouch = false
			descendant.CanQuery = false
			descendant.CastShadow = false
		end
	end

	return clone
end

local function _resolveEntityModel(payload)
	local entityModel = payload.EntityModel
	if typeof(entityModel) == "Instance" and entityModel:IsA("Model") then
		return entityModel
	end

	local entitiesFolder = Workspace:FindFirstChild("Entities")
	local startPosition = payload.StartPosition
	if not entitiesFolder or typeof(startPosition) ~= "Vector3" then
		return nil
	end

	local wantedEntityId = payload.EntityId
	local closestModel = nil
	local closestDistance = math.huge

	for _, candidate in ipairs(entitiesFolder:GetChildren()) do
		if candidate:IsA("Model") then
			local root = candidate.PrimaryPart or candidate:FindFirstChild("HumanoidRootPart")
			if root then
				local candidateEntityId = candidate:GetAttribute("EntityId") or candidate.Name
				if not wantedEntityId or candidateEntityId == wantedEntityId then
					local distance = (root.Position - startPosition).Magnitude
					if distance < closestDistance then
						closestDistance = distance
						closestModel = candidate
					end
				end
			end
		end
	end

	if closestDistance <= 12 then
		return closestModel
	end

	return nil
end

function EntityAbilityVisualController:Init()
	self.Remotes = self.World.Remotes
	self.VisualRemote = self.Remotes:WaitForChild(RemoteNames.EntityAbilityVisual)
	self.ActiveLunges = {}
end

function EntityAbilityVisualController:Start()
	self.VisualRemote.OnClientEvent:Connect(function(payload)
		self:_handleVisual(payload)
	end)

	RunService:BindToRenderStep("EntityAbilityVisualController.BlindHunger", Enum.RenderPriority.Camera.Value + 2, function(deltaTime)
		self:_updateLunges(deltaTime)
	end)

	DebugLog:Log("ClientCombat", "[EntityAbilityVisualController] Started")
end

function EntityAbilityVisualController:_handleVisual(payload)
	if type(payload) ~= "table" then
		return
	end

	if payload.Type == "BlindHungerLunge" then
		self:_startBlindHungerLunge(payload)
	end
end

function EntityAbilityVisualController:_startBlindHungerLunge(payload)
	local startPosition = payload.StartPosition
	local endPosition = payload.EndPosition
	local duration = tonumber(payload.Duration)
	local leapHeight = tonumber(payload.LeapHeight) or 0
	if typeof(startPosition) ~= "Vector3" or typeof(endPosition) ~= "Vector3" or not duration or duration <= 0 then
		return
	end

	local dashOffset = endPosition - startPosition
	if dashOffset.Magnitude <= 0.05 then
		return
	end

	self:_spawnBlindHungerDashOrb(startPosition, endPosition, duration, leapHeight)

	local entityModel = _resolveEntityModel(payload)
	if not entityModel or not entityModel:IsA("Model") then
		return
	end

	local rootPart = entityModel.PrimaryPart or entityModel:FindFirstChild("HumanoidRootPart")
	if not rootPart then
		return
	end

	if self.ActiveLunges[entityModel] then
		self:_finishLunge(entityModel)
	end

	local visualClone = _createVisualClone(entityModel)
	local cloneRoot = visualClone.PrimaryPart or visualClone:FindFirstChild("HumanoidRootPart")
	if not cloneRoot then
		visualClone:Destroy()
		return
	end

	visualClone.Parent = Workspace
	visualClone:PivotTo(rootPart.CFrame)
	_setModelLocalTransparency(entityModel, 1)

	self.ActiveLunges[entityModel] = {
		Model = entityModel,
		RootPart = rootPart,
		VisualClone = visualClone,
		VisualRoot = cloneRoot,
		StartPosition = startPosition,
		EndPosition = endPosition,
		Direction = dashOffset.Unit,
		Duration = duration,
		Elapsed = 0,
		LeapHeight = leapHeight,
	}

	if DebugFlags.Enabled and DebugFlags.Entity and Workspace:GetAttribute("DebugUiEnabled") ~= false then
		self:_spawnBlindHungerDebugVisual(startPosition, endPosition, tonumber(payload.ContactRadius) or 0)
	end
end

function EntityAbilityVisualController:_spawnBlindHungerDashOrb(startPosition, endPosition, duration, leapHeight)
	local orb = Instance.new("Part")
	orb.Name = "BlindHungerDashOrb"
	orb.Anchored = true
	orb.CanCollide = false
	orb.CanQuery = false
	orb.CanTouch = false
	orb.CastShadow = false
	orb.Shape = Enum.PartType.Ball
	orb.Material = Enum.Material.Neon
	orb.Color = Color3.fromRGB(255, 166, 84)
	orb.Transparency = 0.08
	orb.Size = Vector3.new(1.1, 1.1, 1.1)
	orb.Position = startPosition
	orb.Parent = Workspace

	local elapsed = 0
	local connection
	connection = RunService.RenderStepped:Connect(function(deltaTime)
		if not orb.Parent then
			if connection then
				connection:Disconnect()
			end
			return
		end

		elapsed += deltaTime
		local alpha = math.clamp(elapsed / math.max(duration, 0.01), 0, 1)
		local blendedPosition = startPosition:Lerp(endPosition, alpha)
		if leapHeight > 0 then
			local arcAlpha = math.sin(alpha * math.pi)
			blendedPosition += Vector3.new(0, math.pow(arcAlpha, 0.75) * leapHeight, 0)
		end
		orb.Position = blendedPosition

		if alpha >= 1 then
			if connection then
				connection:Disconnect()
			end
			orb:Destroy()
		end
	end)

	Debris:AddItem(orb, math.max(duration + 0.2, 0.6))
end

function EntityAbilityVisualController:_updateLunges(deltaTime)
	for model, lunge in pairs(self.ActiveLunges) do
		if not model.Parent or not lunge.RootPart or not lunge.RootPart.Parent or not lunge.VisualClone or not lunge.VisualClone.Parent then
			self:_finishLunge(model)
			continue
		end

		lunge.Elapsed += deltaTime
		local alpha = math.clamp(lunge.Elapsed / lunge.Duration, 0, 1)
		local flatPosition = lunge.StartPosition:Lerp(lunge.EndPosition, alpha)
		local blendedPosition = flatPosition
		if lunge.LeapHeight > 0 then
			local arcAlpha = math.sin(alpha * math.pi)
			blendedPosition += Vector3.new(0, math.pow(arcAlpha, 0.75) * lunge.LeapHeight, 0)
		end

		local lookTarget = blendedPosition + Vector3.new(lunge.Direction.X, 0, lunge.Direction.Z)
		lunge.VisualClone:PivotTo(CFrame.lookAt(blendedPosition, lookTarget))

		if alpha >= 1 then
			self:_finishLunge(model)
		end
	end
end

function EntityAbilityVisualController:_finishLunge(model)
	local lunge = self.ActiveLunges[model]
	if not lunge then
		return
	end

	if lunge.Model and lunge.Model.Parent then
		_setModelLocalTransparency(lunge.Model, 0)
	end

	if lunge.VisualClone and lunge.VisualClone.Parent then
		lunge.VisualClone:Destroy()
	end

	self.ActiveLunges[model] = nil
end

function EntityAbilityVisualController:_spawnBlindHungerDebugVisual(startPosition, endPosition, contactRadius)
	local dashOffset = endPosition - startPosition
	local dashDistance = dashOffset.Magnitude
	if dashDistance <= 0.05 then
		return
	end

	local visualsFolder = Workspace:FindFirstChild("EntityDebugVisuals")
	if not visualsFolder then
		visualsFolder = Instance.new("Folder")
		visualsFolder.Name = "EntityDebugVisuals"
		visualsFolder.Parent = Workspace
	end

	local linePart = Instance.new("Part")
	linePart.Name = "BlindHungerPath"
	linePart.Anchored = true
	linePart.CanCollide = false
	linePart.CanQuery = false
	linePart.CanTouch = false
	linePart.Material = Enum.Material.Neon
	linePart.Color = Color3.fromRGB(255, 168, 76)
	linePart.Transparency = 0.05
	linePart.Size = Vector3.new(0.7, 0.7, dashDistance)
	linePart.CFrame = CFrame.lookAt(startPosition, endPosition) * CFrame.new(0, 0, -(dashDistance * 0.5))
	linePart.Parent = visualsFolder

	local radiusPart = Instance.new("Part")
	radiusPart.Name = "BlindHungerRadius"
	radiusPart.Anchored = true
	radiusPart.CanCollide = false
	radiusPart.CanQuery = false
	radiusPart.CanTouch = false
	radiusPart.Shape = Enum.PartType.Ball
	radiusPart.Material = Enum.Material.Neon
	radiusPart.Color = Color3.fromRGB(255, 225, 125)
	radiusPart.Transparency = 0.45
	radiusPart.Size = Vector3.new(contactRadius * 2, contactRadius * 2, contactRadius * 2)
	radiusPart.Position = endPosition
	radiusPart.Parent = visualsFolder

	Debris:AddItem(linePart, 2.5)
	Debris:AddItem(radiusPart, 2.5)
end

return EntityAbilityVisualController
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="125">
            <Properties>
              <string name="Name">EntityDebugController</string>
              <string name="Source"><![CDATA[local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local DebugFlags = require(ReplicatedStorage.Shared.Data.DebugFlags)
local GamePhase = require(ReplicatedStorage.Shared.Enums.GamePhase)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local EntityDebugController = {}
EntityDebugController.Name = "EntityDebugController"

local function _clampText(text, maxLength)
	text = tostring(text or "")
	if #text <= maxLength then
		return text
	end

	return string.sub(text, 1, math.max(0, maxLength - 3)) .. "..."
end

function EntityDebugController:Init()
	self.EntitiesFolder = Workspace:WaitForChild("Entities")
	self.Overlays = {}
	self.Player = self.World.Player
	self.PlayerGui = self.World.PlayerGui
	self.DebugUiEnabled = true
end

function EntityDebugController:SetDebugUiEnabled(enabled)
	self.DebugUiEnabled = enabled ~= false

	for _, overlay in pairs(self.Overlays) do
		if overlay.Billboard then
			overlay.Billboard.Enabled = self.DebugUiEnabled
		end
	end
end

function EntityDebugController:Start()
	if not DebugFlags.Enabled or not DebugFlags.EntityDebugOverlay then
		return
	end

	for _, model in ipairs(self.EntitiesFolder:GetChildren()) do
		self:_trackEntity(model)
	end

	self.EntitiesFolder.ChildAdded:Connect(function(child)
		self:_trackEntity(child)
	end)

	self.EntitiesFolder.ChildRemoved:Connect(function(child)
		self:_untrackEntity(child)
	end)

	if self.Player then
		self.Player.CharacterAdded:Connect(function()
			task.defer(function()
				self:_rebuildOverlays()
			end)
		end)
	end

	task.spawn(function()
		while true do
			self:_refreshOverlays()
			task.wait(0.05)
		end
	end)

	DebugLog:Log("ClientCombat", "[EntityDebugController] Started")
end

function EntityDebugController:_trackEntity(model)
	if not model:IsA("Model") then
		return
	end

	local adornee = model.PrimaryPart or model:FindFirstChild("HumanoidRootPart")
	if not adornee then
		return
	end

	if self.Overlays[model] then
		return
	end

	local billboard = Instance.new("BillboardGui")
	billboard.Name = "EntityDebugOverlay"
	billboard.Size = UDim2.new(0, 270, 0, 136)
	billboard.StudsOffset = Vector3.new(0, 5.55, 0)
	billboard.AlwaysOnTop = true
	billboard.Adornee = adornee
	billboard.Parent = self.World.PlayerGui

	local frame = Instance.new("Frame")
	frame.Size = UDim2.fromScale(1, 1)
	frame.BackgroundColor3 = Color3.fromRGB(16, 18, 24)
	frame.BackgroundTransparency = 0.18
	frame.BorderSizePixel = 0
	frame.Parent = billboard

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 10)
	corner.Parent = frame

	local nameLabel = Instance.new("TextLabel")
	nameLabel.Name = "NameLabel"
	nameLabel.Position = UDim2.new(0, 10, 0, 6)
	nameLabel.Size = UDim2.new(1, -20, 0, 16)
	nameLabel.BackgroundTransparency = 1
	nameLabel.Font = Enum.Font.GothamBold
	nameLabel.TextColor3 = Color3.fromRGB(240, 240, 240)
	nameLabel.TextSize = 13
	nameLabel.TextXAlignment = Enum.TextXAlignment.Left
	nameLabel.Parent = frame

	local stateLabel = Instance.new("TextLabel")
	stateLabel.Name = "StateLabel"
	stateLabel.Position = UDim2.new(0, 10, 0, 24)
	stateLabel.Size = UDim2.new(1, -20, 0, 12)
	stateLabel.BackgroundTransparency = 1
	stateLabel.Font = Enum.Font.Gotham
	stateLabel.TextColor3 = Color3.fromRGB(199, 205, 216)
	stateLabel.TextSize = 10
	stateLabel.TextXAlignment = Enum.TextXAlignment.Left
	stateLabel.Parent = frame

	local intentLabel = Instance.new("TextLabel")
	intentLabel.Name = "IntentLabel"
	intentLabel.Position = UDim2.new(0, 10, 0, 39)
	intentLabel.Size = UDim2.new(1, -20, 0, 12)
	intentLabel.BackgroundTransparency = 1
	intentLabel.Font = Enum.Font.Gotham
	intentLabel.TextColor3 = Color3.fromRGB(214, 180, 64)
	intentLabel.TextSize = 10
	intentLabel.TextXAlignment = Enum.TextXAlignment.Left
	intentLabel.Parent = frame

	local stimulusLabel = Instance.new("TextLabel")
	stimulusLabel.Name = "StimulusLabel"
	stimulusLabel.Position = UDim2.new(0, 10, 0, 54)
	stimulusLabel.Size = UDim2.new(1, -20, 0, 24)
	stimulusLabel.BackgroundTransparency = 1
	stimulusLabel.Font = Enum.Font.Gotham
	stimulusLabel.TextColor3 = Color3.fromRGB(164, 208, 250)
	stimulusLabel.TextSize = 10
	stimulusLabel.TextWrapped = true
	stimulusLabel.TextYAlignment = Enum.TextYAlignment.Top
	stimulusLabel.TextXAlignment = Enum.TextXAlignment.Left
	stimulusLabel.Parent = frame

	local memoryLabel = Instance.new("TextLabel")
	memoryLabel.Name = "MemoryLabel"
	memoryLabel.Position = UDim2.new(0, 10, 0, 80)
	memoryLabel.Size = UDim2.new(1, -20, 0, 12)
	memoryLabel.BackgroundTransparency = 1
	memoryLabel.Font = Enum.Font.Gotham
	memoryLabel.TextColor3 = Color3.fromRGB(224, 192, 138)
	memoryLabel.TextSize = 10
	memoryLabel.TextXAlignment = Enum.TextXAlignment.Left
	memoryLabel.Parent = frame

	local abilityLabel = Instance.new("TextLabel")
	abilityLabel.Name = "AbilityLabel"
	abilityLabel.Position = UDim2.new(0, 10, 0, 94)
	abilityLabel.Size = UDim2.new(1, -20, 0, 12)
	abilityLabel.BackgroundTransparency = 1
	abilityLabel.Font = Enum.Font.Gotham
	abilityLabel.TextColor3 = Color3.fromRGB(214, 180, 64)
	abilityLabel.TextSize = 10
	abilityLabel.TextXAlignment = Enum.TextXAlignment.Left
	abilityLabel.Parent = frame

	local healthLabel = Instance.new("TextLabel")
	healthLabel.Name = "HealthLabel"
	healthLabel.Position = UDim2.new(0, 10, 0, 108)
	healthLabel.Size = UDim2.new(1, -20, 0, 12)
	healthLabel.BackgroundTransparency = 1
	healthLabel.Font = Enum.Font.Gotham
	healthLabel.TextColor3 = Color3.fromRGB(178, 228, 196)
	healthLabel.TextSize = 10
	healthLabel.TextXAlignment = Enum.TextXAlignment.Left
	healthLabel.Parent = frame

	local hitLabel = Instance.new("TextLabel")
	hitLabel.Name = "HitLabel"
	hitLabel.Position = UDim2.new(0, 10, 0, 121)
	hitLabel.Size = UDim2.new(1, -20, 0, 12)
	hitLabel.BackgroundTransparency = 1
	hitLabel.Font = Enum.Font.GothamBold
	hitLabel.TextColor3 = Color3.fromRGB(132, 232, 156)
	hitLabel.TextSize = 10
	hitLabel.TextXAlignment = Enum.TextXAlignment.Left
	hitLabel.Parent = frame

	self.Overlays[model] = {
		Billboard = billboard,
		Frame = frame,
		NameLabel = nameLabel,
		StateLabel = stateLabel,
		IntentLabel = intentLabel,
		StimulusLabel = stimulusLabel,
		MemoryLabel = memoryLabel,
		AbilityLabel = abilityLabel,
		HealthLabel = healthLabel,
		HitLabel = hitLabel,
	}
end

function EntityDebugController:_untrackEntity(model)
	local overlay = self.Overlays[model]
	if not overlay then
		return
	end

	if overlay.Billboard then
		overlay.Billboard:Destroy()
	end

	self.Overlays[model] = nil
end

function EntityDebugController:_rebuildOverlays()
	for model, _ in pairs(self.Overlays) do
		self:_untrackEntity(model)
	end

	for _, model in ipairs(self.EntitiesFolder:GetChildren()) do
		self:_trackEntity(model)
	end
end

function EntityDebugController:_refreshOverlays()
	local now = Workspace:GetServerTimeNow()
	local roundState = self.World:GetRoundState()
	local phase = roundState and roundState.Phase or "Unknown"
	local debugUiEnabled = self.DebugUiEnabled and phase == GamePhase.Reception

	for _, model in ipairs(self.EntitiesFolder:GetChildren()) do
		if not self.Overlays[model] then
			self:_trackEntity(model)
		end
	end

	for model, overlay in pairs(self.Overlays) do
		if not model.Parent then
			self:_untrackEntity(model)
			continue
		end

		local name = model:GetAttribute("DebugEntityName") or model.Name
		local state = model:GetAttribute("DebugState") or "Unknown"
		local intent = model:GetAttribute("DebugIntent") or "None"
		local intentConfidence = model:GetAttribute("DebugIntentConfidence") or "0.00"
		local intentReason = model:GetAttribute("DebugIntentReason") or "None"
		local topStimuli = model:GetAttribute("DebugTopStimuli") or "None"
		local searchCenter = model:GetAttribute("DebugSearchCenter") or ""
		local memoryAge = model:GetAttribute("DebugMemoryAge") or ""
		local health = model:GetAttribute("DebugHealth") or 0
		local maxHealth = model:GetAttribute("DebugMaxHealth") or 0
		local target = model:GetAttribute("DebugTarget") or ""
		local lastAbility = model:GetAttribute("DebugLastAbility") or "None"
		local absorbed = model:GetAttribute("DebugAbsorbedCount") or 0
		local hitDamage = model:GetAttribute("DebugRecentHitDamage")
		local hitSource = model:GetAttribute("DebugRecentHitSource")
		local hitExpiresAt = model:GetAttribute("DebugRecentHitExpiresAt") or 0
		local hitActive = hitDamage ~= nil and now <= hitExpiresAt

		overlay.Billboard.Enabled = debugUiEnabled
		overlay.NameLabel.Text = _clampText(name, 32)
		overlay.StateLabel.Text = string.format("State: %s%s", _clampText(state, 12), target ~= "" and ("  Target: " .. _clampText(target, 14)) or "")
		overlay.IntentLabel.Text = string.format("Intent: %s (%s)  via %s", _clampText(intent, 12), _clampText(intentConfidence, 4), _clampText(intentReason, 16))
		overlay.StimulusLabel.Text = string.format("Stimuli: %s", _clampText(topStimuli, 96))
		overlay.MemoryLabel.Text = string.format("Memory: %s%s", memoryAge ~= "" and memoryAge or "None", searchCenter ~= "" and ("  Search: " .. searchCenter) or "")
		overlay.AbilityLabel.Text = string.format("Last: %s%s", _clampText(lastAbility, 18), absorbed > 0 and ("  Absorbed: " .. tostring(absorbed)) or "")
		overlay.HealthLabel.Text = string.format("HP: %d / %d", health, maxHealth)
		overlay.HitLabel.Text = hitActive and string.format("HIT %s (%s)", tostring(hitDamage), _clampText(hitSource or "Unknown", 18)) or ""
		overlay.Frame.BackgroundColor3 = hitActive and Color3.fromRGB(23, 40, 30) or Color3.fromRGB(16, 18, 24)
	end
end

return EntityDebugController
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="126">
            <Properties>
              <string name="Name">FirearmPresentationController</string>
              <string name="Source"><![CDATA[local Debris = game:GetService("Debris")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local Workspace = game:GetService("Workspace")

local FirearmAim = require(ReplicatedStorage.Shared.Utility.FirearmAim)
local RemoteNames = require(ReplicatedStorage.Shared.Constants.RemoteNames)
local WeaponDefinitions = require(ReplicatedStorage.Shared.Data.WeaponDefinitions)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local FirearmPresentationController = {}
FirearmPresentationController.Name = "FirearmPresentationController"
FirearmPresentationController.Dependencies = {
	"CameraInputController",
	"CombatController",
	"ViewmodelController",
}

function FirearmPresentationController:Init()
	self.PlayerGui = self.World.PlayerGui
	self.Remotes = self.World.Remotes
	self.CombatShotVisualRemote = self.Remotes:WaitForChild(RemoteNames.CombatShotVisual)
	self.ReticleExpansion = 0
end

function FirearmPresentationController:Start()
	self.CombatShotVisualRemote.OnClientEvent:Connect(function(payload)
		self:_playShotPresentation(payload)
	end)

	RunService:BindToRenderStep("FirearmPresentationController.Update", Enum.RenderPriority.Last.Value, function(deltaTime)
		self.ReticleExpansion = math.max(0, self.ReticleExpansion - (deltaTime * 3.4))
	end)

	DebugLog:Log("ClientCombat", "[FirearmPresentationController] Started")
end

function FirearmPresentationController:GetReticleExpansion()
	return self.ReticleExpansion or 0
end

function FirearmPresentationController:_tweenAndCleanup(instance, tweenInfo, properties, lifetime)
	local tween = TweenService:Create(instance, tweenInfo, properties)
	tween:Play()
	Debris:AddItem(instance, lifetime)
end

function FirearmPresentationController:_createBillowedPart(name, color, size, cframe, material)
	local part = Instance.new("Part")
	part.Name = name
	part.Anchored = true
	part.CanCollide = false
	part.CanTouch = false
	part.CanQuery = false
	part.CastShadow = false
	part.Material = material or Enum.Material.Neon
	part.Color = color
	part.Size = size
	part.CFrame = cframe
	part.Parent = Workspace
	return part
end

function FirearmPresentationController:_playShotPresentation(payload)
	if type(payload) ~= "table" or typeof(payload.Origin) ~= "Vector3" or typeof(payload.EndPosition) ~= "Vector3" then
		return
	end

	local weaponDefinition = WeaponDefinitions[payload.WeaponId]
	local handling = FirearmAim.GetHandlingData(weaponDefinition)
	local color = handling.FireVisualColor
	local origin = (self.ViewmodelController and self.ViewmodelController:GetVisualMuzzleOrigin(payload.WeaponId)) or payload.Origin
	local endPosition = payload.EndPosition
	local isAiming = payload.IsAiming == true
	local hit = payload.Hit == true
	local direction = endPosition - origin
	local distance = direction.Magnitude
	if distance <= 0.05 then
		return
	end

	local tracerWidth = handling.TracerWidth * (isAiming and 0.9 or 1.15)
	local tracer = self:_createBillowedPart(
		"FirearmTracer",
		hit and Color3.fromRGB(136, 236, 170) or color,
		Vector3.new(tracerWidth, tracerWidth, distance),
		CFrame.lookAt(origin, endPosition) * CFrame.new(0, 0, -(distance * 0.5))
	)
	tracer.Transparency = 0.04
	self:_tweenAndCleanup(tracer, TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Transparency = 1,
	}, 0.14)

	local muzzleFlash = self:_createBillowedPart(
		"MuzzleFlash",
		color,
		Vector3.new(handling.MuzzleFlashSize, handling.MuzzleFlashSize, handling.MuzzleFlashSize),
		CFrame.new(origin)
	)
	muzzleFlash.Shape = Enum.PartType.Ball
	muzzleFlash.Transparency = 0.02
	self:_tweenAndCleanup(muzzleFlash, TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Size = muzzleFlash.Size * 1.8,
		Transparency = 1,
	}, 0.1)

	local shellBurst = self:_createBillowedPart(
		"ShellBurst",
		Color3.fromRGB(255, 196, 105),
		Vector3.new(0.15, 0.15, 0.55),
		CFrame.lookAt(origin, origin + Vector3.new(1, 0.2, 0))
	)
	shellBurst.Transparency = 0.1
	self:_tweenAndCleanup(shellBurst, TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		CFrame = shellBurst.CFrame * CFrame.new(0.55, 0.12, -0.2),
		Transparency = 1,
	}, 0.12)

	local impactFlash = self:_createBillowedPart(
		"ImpactFlash",
		hit and Color3.fromRGB(145, 234, 181) or Color3.fromRGB(186, 214, 255),
		Vector3.new(handling.ImpactFlashSize, handling.ImpactFlashSize, handling.ImpactFlashSize),
		CFrame.new(endPosition)
	)
	impactFlash.Shape = Enum.PartType.Ball
	impactFlash.Transparency = 0.08
	self:_tweenAndCleanup(impactFlash, TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Size = impactFlash.Size * 1.65,
		Transparency = 1,
	}, 0.12)

	if self.CameraInputController then
		self.CameraInputController:AddFirearmKick(
			(handling.CameraKickPitch or handling.RecoilKick) * (isAiming and 0.85 or 1),
			handling.CameraKickYaw or 0,
			handling.RecoilRecovery or 11
		)
	end
	if self.ViewmodelController then
		self.ViewmodelController:PlayAction("Fire")
	end

	self.ReticleExpansion = math.min(1.4, math.max(self.ReticleExpansion, 0) + (isAiming and 0.22 or 0.5))
end

return FirearmPresentationController
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="127">
            <Properties>
              <string name="Name">InputController</string>
              <string name="Source"><![CDATA[local UserInputService = game:GetService("UserInputService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local ActionName = require(ReplicatedStorage.Shared.Enums.ActionName)
local ActionToken = require(ReplicatedStorage.Shared.Enums.ActionToken)
local DefaultKeybinds = require(ReplicatedStorage.Shared.Data.DefaultKeybinds)
local RemoteNames = require(ReplicatedStorage.Shared.Constants.RemoteNames)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local InputController = {}
InputController.Name = "InputController"
InputController.Dependencies = {
	"QTEController",
	"BreathHoldController",
	"RemnantController",
	"CameraInputController",
}

function InputController:Init(controllers)
	self.Controllers = controllers
	self.Shared = ReplicatedStorage:WaitForChild("Shared")
	self.RemotesFolder = self.Shared:WaitForChild("Remotes")
	self.RequestInteractRemote = self.RemotesFolder:WaitForChild(RemoteNames.RequestInteract)
	self.RequestMovementStateRemote = self.RemotesFolder:WaitForChild(RemoteNames.RequestMovementState)
	self.RequestBreathHoldStateRemote = self.RemotesFolder:WaitForChild(RemoteNames.RequestBreathHoldState)
	self.RequestRemnantAbilityRemote = self.RemotesFolder:WaitForChild(RemoteNames.RequestRemnantAbility)
	self.Keybinds = DefaultKeybinds.Keyboard or {}
end

