        <Item class="ModuleScript" referent="90">
          <Properties>
            <string name="Name">InteractionService</string>
            <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")

local RemoteNames = require(ReplicatedStorage.Shared.Constants.RemoteNames)
local InteractableType = require(ReplicatedStorage.Shared.Enums.InteractableType)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local InteractionService = {}
InteractionService.Name = "InteractionService"
InteractionService.Dependencies = {
	"RemoteRegistry",
	"RoundManager",
	"StatusEffectService",
	"QTEService",
	"CharacterService",
	"ObjectiveService",
	"WeaponPickupService",
	"ItemPickupService",
	"EnvironmentalHazardService",
	"StruggleService",
}

function InteractionService:Init(services)
	self.Services = services
	self.ActiveInteractions = {}
end

function InteractionService:Start()
	self.InteractionStateRemote = self.RemoteRegistry:GetRemote(RemoteNames.InteractionStateChanged)
	self.UpdateInterval = 0.1
	
	local requestInteract = self.RemoteRegistry:GetRemote(RemoteNames.RequestInteract)
	
	requestInteract.OnServerEvent:Connect(function(player, isStarting)
		DebugLog:Log("Interaction", string.format("[InteractionService] Remote received from %s (start=%s)", player.Name, tostring(isStarting)))
		if isStarting then
			self:StartInteraction(player)
		else
			self:StopInteraction(player)
		end
	end)
	
	task.spawn(function()
		self:_runInteractionLoop()
	end)
	
	DebugLog:Log("Interaction", "[InteractionService] Started")
end

function InteractionService:StartInteraction(player)
	local roundManager = self.RoundManager
	if not roundManager or not roundManager:IsReceptionActive() then
		DebugLog:Log("Interaction", string.format("[InteractionService] Ignored start for %s: reception inactive", player.Name))
		return
	end

	local statusService = self.StatusEffectService
	if statusService and not statusService:CanInteract(player) then
		if self.QTEService and self.QTEService:IsSessionActive(player) then
			self.QTEService:HandleInput(player, {
				Kind = "Press",
				Key = "Space",
			})
			DebugLog:Log("Interaction", string.format("[InteractionService] Routed interact press from %s into active QTE", player.Name))
			return
		end

		DebugLog:Log("Interaction", string.format("[InteractionService] Ignored start for %s: status blocked", player.Name))
		return
	end
	
	local target = self:FindBestInteractable(player)
	if not target then
		DebugLog:Log("Interaction", string.format("[InteractionService] Ignored start for %s: no valid target", player.Name))
		return
	end
	
	self.ActiveInteractions[player] = {
		Target = target,
	}
	
	local character = self.CharacterService:GetCharacterByPlayer(player)
	if character then
		character:SetSpeedMultiplier("InteractionSlow", 0.5)
	end
	
	self.InteractionStateRemote:FireClient(player, {
		State = "Start",
		Target = target.DisplayName,
		Progress = target.Progress or 0,
		Max = target.MaxProgress or 1,
	})
	
	DebugLog:Log("Interaction", string.format("[InteractionService] %s started interacting with %s", player.Name, target.DisplayName))
end

function InteractionService:StopInteraction(player)
	if self.ActiveInteractions[player] then
		local target = self.ActiveInteractions[player].Target
		local name = target and target.DisplayName or "Unknown"
		
		local character = self.CharacterService:GetCharacterByPlayer(player)
		if character then
			character:SetSpeedMultiplier("InteractionSlow", nil)
		end
		
		self.InteractionStateRemote:FireClient(player, {
			State = "Stop"
		})
		
		DebugLog:Log("Interaction", string.format("[InteractionService] %s stopped interacting with %s", player.Name, name))
	end
	
	self.ActiveInteractions[player] = nil
end

function InteractionService:InterruptInteraction(player, reason)
	if not self.ActiveInteractions[player] then
		return false
	end
	
	self:StopInteraction(player)
	DebugLog:Log("Interaction", string.format("[InteractionService] %s interaction interrupted (%s)", player.Name, tostring(reason or "Unknown")))
	return true
end

function InteractionService:StopAllInteractions(reason)
	for player in pairs(self.ActiveInteractions) do
		self:InterruptInteraction(player, reason or "StoppedAll")
	end
end

function InteractionService:IsInteracting(player)
	return self.ActiveInteractions[player] ~= nil
end

function InteractionService:FindBestInteractable(player)
	local character = self.CharacterService:GetCharacterByPlayer(player)
	if not character or not character.RootPart then
		return nil
	end
	
	local playerPosition = character.RootPart.Position
	local bestTarget = nil
	local bestDistance = math.huge

	local struggleService = self.StruggleService
	if struggleService then
		local peelTarget = struggleService:GetPeelInteractable(player)
		if peelTarget and peelTarget.Instance then
			local distance = (peelTarget.Instance.Position - playerPosition).Magnitude
			if distance <= 12 then
				return peelTarget
			end
		end
	end
	
	for _, objective in ipairs(self.ObjectiveService:GetObjectives()) do
		if objective.Type == InteractableType.Objective or objective.Type == "MapObjective" then
			if objective:CanInteract() and objective.Instance then
				local distance = (objective.Instance.Position - playerPosition).Magnitude
				if distance <= 12 and distance < bestDistance then
					bestTarget = objective
					bestDistance = distance
				end
			end
		end
	end

	local weaponPickupService = self.WeaponPickupService
	if weaponPickupService then
		for _, pickup in ipairs(weaponPickupService:GetAvailablePickups()) do
			local pickupInstance = pickup.Instance
			if pickupInstance then
				local distance = (pickupInstance.Position - playerPosition).Magnitude
				if distance <= 12 and distance < bestDistance then
					bestTarget = pickup
					bestDistance = distance
				end
			end
		end
	end

	local itemPickupService = self.ItemPickupService
	if itemPickupService then
		for _, pickup in ipairs(itemPickupService:GetAvailablePickups()) do
			local pickupInstance = pickup.Instance
			if pickupInstance then
				local distance = (pickupInstance.Position - playerPosition).Magnitude
				if distance <= 12 and distance < bestDistance then
					bestTarget = pickup
					bestDistance = distance
				end
			end
		end
	end

	local environmentalHazardService = self.EnvironmentalHazardService
	if environmentalHazardService then
		for _, hazard in ipairs(environmentalHazardService:GetAvailableHazards()) do
			local hazardInstance = hazard.Instance
			if hazardInstance then
				local distance = (hazardInstance.Position - playerPosition).Magnitude
				if distance <= 12 and distance < bestDistance then
					bestTarget = hazard
					bestDistance = distance
				end
			end
		end
	end

	return bestTarget
end

function InteractionService:_runInteractionLoop()
	while true do
		for player, interaction in pairs(self.ActiveInteractions) do
			self:_updateInteraction(player, interaction)
		end
		
		task.wait(self.UpdateInterval)
	end
end

function InteractionService:_updateInteraction(player, interaction)
	local target = interaction.Target

	if target and target.Type == InteractableType.WeaponPickup then
		local completed = self.WeaponPickupService and self.WeaponPickupService:CompletePickup(player, target)
		self.InteractionStateRemote:FireClient(player, {
			State = completed and "Complete" or "Stop"
		})
		self:StopInteraction(player)
		return
	end

	if target and target.Type == InteractableType.ItemPickup then
		local completed = self.ItemPickupService and self.ItemPickupService:CompletePickup(player, target)
		self.InteractionStateRemote:FireClient(player, {
			State = completed and "Complete" or "Stop"
		})
		self:StopInteraction(player)
		return
	end

	if target and target.Type == InteractableType.EnvironmentalHazard then
		local completed = self.EnvironmentalHazardService and self.EnvironmentalHazardService:CompleteHazard(player, target)
		self.InteractionStateRemote:FireClient(player, {
			State = completed and "Complete" or "Stop"
		})
		self:StopInteraction(player)
		return
	end

	if target and target.Type == InteractableType.StrugglePeel then
		local amount = target.ChargeRate * self.UpdateInterval
		local progressed, completed = self.StruggleService and self.StruggleService:ProgressPeel(player, target, amount)
		if not progressed then
			self.InteractionStateRemote:FireClient(player, {
				State = "Stop"
			})
			self:StopInteraction(player)
			return
		end

		target.Progress = self.StruggleService.ActiveStruggles[target.StruggleTargetPlayer]
			and self.StruggleService.ActiveStruggles[target.StruggleTargetPlayer].PeelProgress
			or target.Progress

		self.InteractionStateRemote:FireClient(player, {
			State = completed and "Complete" or "Update",
			Target = target.DisplayName,
			Progress = math.clamp(target.Progress or 0, 0, target.MaxProgress or 1),
			Max = target.MaxProgress or 1,
		})

		if completed then
			self:StopInteraction(player)
		end
		return
	end
	
	if target.IsComplete then
		self.InteractionStateRemote:FireClient(player, {
			State = "Complete"
		})
		self:StopInteraction(player)
		return
	end
	
	if not target or target.IsComplete then
		self:StopInteraction(player)
		return
	end
	
	local character = self.CharacterService:GetCharacterByPlayer(player)
	if not character or not character.RootPart then
		self:StopInteraction(player)
		return
	end
	
	local distance = (target.Instance.Position - character.RootPart.Position).Magnitude
	if distance > 12 then
		DebugLog:Log("Interaction", string.format("[InteractionService] %s moved too far from %s", player.Name, target.DisplayName))
		self:StopInteraction(player)
		return
	end
	
	local amount = target.ChargeRate * self.UpdateInterval
	local progressed = self.ObjectiveService:ProgressObjective(target, amount)
	
	self.InteractionStateRemote:FireClient(player, {
		State = "Update",
		Target = target.DisplayName,
		Progress = target.Progress,
		Max = target.MaxProgress or 1,
	})
	
	if not progressed or target.IsComplete then
		self:StopInteraction(player)
	end
end

return InteractionService
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="91">
          <Properties>
            <string name="Name">InventoryService</string>
            <string name="Source"><![CDATA[local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local ItemDefinitions = require(ReplicatedStorage.Shared.Data.ItemDefinitions)
local WeaponDefinitions = require(ReplicatedStorage.Shared.Data.WeaponDefinitions)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local InventoryService = {}
InventoryService.Name = "InventoryService"

local function _createWeaponEntry(weaponId)
local definition = WeaponDefinitions[weaponId]
if not definition then
	return nil
end

local entry = {
	EntryType = "Weapon",
	ItemId = weaponId,
	Durability = definition.Durability,
}

if definition.Kind == "Firearm" then
	entry.CurrentAmmo = definition.MagazineSize or 0
	entry.MaxAmmo = definition.MagazineSize or 0
	entry.ReserveAmmo = definition.ReserveAmmo or 0
end

return entry
end

local function _createItemEntry(itemId, count)
local definition = ItemDefinitions[itemId]
if not definition then
	return nil
end

return {
	EntryType = "Item",
	ItemId = itemId,
	Count = count or 1,
}
end

function InventoryService:Init()
self.PlayerInventories = {}
end

function InventoryService:Start()
for _, player in ipairs(Players:GetPlayers()) do
	self:_initializePlayer(player)
end

Players.PlayerAdded:Connect(function(player)
	self:_initializePlayer(player)
end)

Players.PlayerRemoving:Connect(function(player)
	self.PlayerInventories[player] = nil
end)

DebugLog:Log("Combat", "[InventoryService] Started")
end

function InventoryService:_initializePlayer(player)
self:ResetPlayerInventory(player)

player.CharacterAdded:Connect(function()
	self:ResetPlayerInventory(player)
end)
end

function InventoryService:ResetPlayerInventory(player)
self.PlayerInventories[player] = {
	Entries = {
		_createWeaponEntry("BushmanKnife"),
		_createItemEntry("Bandage", 1),
		_createItemEntry("TestTonic", 1),
	},
}
end

function InventoryService:CreateWeaponEntry(weaponId)
return _createWeaponEntry(weaponId)
end

function InventoryService:CreateItemEntry(itemId, count)
return _createItemEntry(itemId, count)
end

function InventoryService:GetInventory(player)
return self.PlayerInventories[player]
end

function InventoryService:GetEntries(player)
local inventory = self.PlayerInventories[player]
return inventory and inventory.Entries or nil
end

function InventoryService:GetEntry(player, slotIndex)
local entries = self:GetEntries(player)
return entries and entries[slotIndex] or nil
end

function InventoryService:AddWeapon(player, weaponId)
local inventory = self.PlayerInventories[player]
if not inventory or not WeaponDefinitions[weaponId] then
	return nil
end

for slotIndex, entry in ipairs(inventory.Entries) do
	if entry.EntryType == "Weapon" and entry.ItemId == weaponId then
		return slotIndex
	end
end

table.insert(inventory.Entries, _createWeaponEntry(weaponId))
return #inventory.Entries
end

function InventoryService:AddItem(player, itemId, count)
local inventory = self.PlayerInventories[player]
local definition = ItemDefinitions[itemId]
if not inventory or not definition then
	return nil
end

local amount = math.max(1, count or 1)
for slotIndex, entry in ipairs(inventory.Entries) do
	if entry.EntryType == "Item" and entry.ItemId == itemId then
		local maxStack = definition.MaxStack or math.huge
		entry.Count = math.clamp(entry.Count + amount, 0, maxStack)
		return slotIndex
	end
end

table.insert(inventory.Entries, _createItemEntry(itemId, amount))
return #inventory.Entries
end

function InventoryService:SetWeaponLoadout(player, weaponIds)
local inventory = self.PlayerInventories[player]
if not inventory then
	self:ResetPlayerInventory(player)
	inventory = self.PlayerInventories[player]
end

inventory.Entries = {}
for _, weaponId in ipairs(weaponIds or {}) do
	local entry = _createWeaponEntry(weaponId)
	if entry then
		table.insert(inventory.Entries, entry)
	end
end

return inventory.Entries
end

function InventoryService:ConsumeItem(player, slotIndex, amount)
local entry = self:GetEntry(player, slotIndex)
if not entry or entry.EntryType ~= "Item" then
	return nil
end

entry.Count = math.max(0, (entry.Count or 0) - math.max(1, amount or 1))
if entry.Count <= 0 then
	local entries = self:GetEntries(player)
	table.remove(entries, slotIndex)
end

return true
end

return InventoryService
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="92">
          <Properties>
            <string name="Name">ItemPickupService</string>
            <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")

local GamePhase = require(ReplicatedStorage.Shared.Enums.GamePhase)
local InteractableType = require(ReplicatedStorage.Shared.Enums.InteractableType)
local ItemDefinitions = require(ReplicatedStorage.Shared.Data.ItemDefinitions)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local ItemPickupService = {}
ItemPickupService.Name = "ItemPickupService"
ItemPickupService.Dependencies = {
	"RemoteRegistry",
	"InventoryService",
	"CombatService",
	"RoundHookService",
}

local DEFAULT_PICKUP_DURATION = 0.25
local RESTORE_HOOK_ID = "ItemPickupService.RestorePlacedPickups"

local function _resolvePickupPart(instance)
	if instance:IsA("BasePart") then
		return instance
	end

	if instance:IsA("Model") then
		return instance.PrimaryPart or instance:FindFirstChild("HumanoidRootPart") or instance:FindFirstChildWhichIsA("BasePart")
	end

	return nil
end

function ItemPickupService:Init(services)
	self.Services = services
	self.Pickups = {}
	self.PickupTemplates = {}
	self.ItemPickupsFolder = Workspace:FindFirstChild("ItemPickups")
end

function ItemPickupService:Start()
	self.UiToastRemote = self.RemoteRegistry:GetRemote("UiToastRequested")
	if self.ItemPickupsFolder then
		self:_registerExistingPickups()

		self.ItemPickupsFolder.ChildAdded:Connect(function(instance)
			self:_registerPickup(instance)
		end)

		self.ItemPickupsFolder.ChildRemoved:Connect(function(instance)
			self:_unregisterPickup(instance)
		end)
	end

	if self.RoundHookService then
		self.RoundHookService:RegisterHook({
			Id = RESTORE_HOOK_ID,
			Trigger = "PhaseChanged",
			Phase = GamePhase.Lobby,
			Callback = function()
				self:RestorePlacedPickups()
			end,
		})
	end

	DebugLog:Log("Combat", "[ItemPickupService] Started")
end

function ItemPickupService:_registerExistingPickups()
	for _, instance in ipairs(self.ItemPickupsFolder:GetChildren()) do
		self:_registerPickup(instance)
	end
end

function ItemPickupService:_registerPickup(instance)
	if self.Pickups[instance] then
		return
	end

	self:_cachePickupTemplate(instance)

	local itemId = instance:GetAttribute("ItemId") or instance.Name
	local itemDefinition = ItemDefinitions[itemId]
	if not itemDefinition then
		DebugLog:Log("Combat", string.format("[ItemPickupService] Ignored pickup '%s': unknown item '%s'", instance.Name, tostring(itemId)))
		return
	end

	local pickupPart = _resolvePickupPart(instance)
	if not pickupPart then
		DebugLog:Log("Combat", string.format("[ItemPickupService] Ignored pickup '%s': no usable part", instance.Name))
		return
	end

	local pickupDuration = tonumber(instance:GetAttribute("PickupDuration")) or DEFAULT_PICKUP_DURATION
	local quantity = math.max(1, tonumber(instance:GetAttribute("Quantity")) or 1)

	self.Pickups[instance] = {
		Type = InteractableType.ItemPickup,
		Id = instance:GetFullName(),
		DisplayName = instance:GetAttribute("DisplayName") or ("Pick Up " .. itemDefinition.DisplayName),
		Instance = pickupPart,
		Model = instance,
		ItemId = itemId,
		Quantity = quantity,
		Progress = 0,
		MaxProgress = 1,
		ChargeRate = pickupDuration > 0 and (1 / pickupDuration) or 1,
		IsComplete = false,
	}

	DebugLog:Log("Combat", string.format("[ItemPickupService] Registered pickup %s for %s x%d", instance.Name, itemId, quantity))
end

function ItemPickupService:_cachePickupTemplate(instance)
	local templateId = instance:GetAttribute("PickupTemplateId")
	if not templateId or templateId == "" then
		templateId = instance:GetFullName()
		instance:SetAttribute("PickupTemplateId", templateId)
	end

	if self.PickupTemplates[templateId] then
		return
	end

	self.PickupTemplates[templateId] = {
		TemplateId = templateId,
		Name = instance.Name,
		Clone = instance:Clone(),
	}
end

function ItemPickupService:_unregisterPickup(instance)
	self.Pickups[instance] = nil
end

function ItemPickupService:GetAvailablePickups()
	local results = {}
	for _, pickup in pairs(self.Pickups) do
		if pickup.Instance and pickup.Instance.Parent and not pickup.IsComplete then
			table.insert(results, pickup)
		end
	end

	return results
end

function ItemPickupService:CompletePickup(player, pickup)
	if not pickup or pickup.IsComplete then
		return false
	end

	local slotIndex = self.InventoryService:AddItem(player, pickup.ItemId, pickup.Quantity)
	if not slotIndex then
		return false
	end

	if self.CombatService and self.CombatService.RefreshCombatState then
		self.CombatService:RefreshCombatState(player)
	end

	pickup.IsComplete = true
	if pickup.Model and pickup.Model.Parent then
		pickup.Model:Destroy()
	end

	DebugLog:Log("Combat", string.format("[ItemPickupService] %s picked up %s x%d", player.Name, pickup.ItemId, pickup.Quantity or 1))
	if self.UiToastRemote then
		local definition = ItemDefinitions[pickup.ItemId]
		local quantity = pickup.Quantity or 1
		local itemName = definition and definition.DisplayName or pickup.ItemId
		self.UiToastRemote:FireClient(player, {
			Title = "Item Picked Up",
			Message = quantity > 1 and string.format("%s x%d", itemName, quantity) or itemName,
			Tint = "Item",
		})
	end
	return true
end

function ItemPickupService:RestorePlacedPickups()
	if not self.ItemPickupsFolder then
		return
	end

	local activeTemplateIds = {}
	for _, child in ipairs(self.ItemPickupsFolder:GetChildren()) do
		local templateId = child:GetAttribute("PickupTemplateId")
		if templateId and templateId ~= "" then
			activeTemplateIds[templateId] = true
		end
	end

	for templateId, templateData in pairs(self.PickupTemplates) do
		if not activeTemplateIds[templateId] then
			local restoredInstance = templateData.Clone:Clone()
			restoredInstance.Parent = self.ItemPickupsFolder
			DebugLog:Log("Combat", string.format("[ItemPickupService] Restored pickup %s", templateData.Name))
		end
	end
end

function ItemPickupService:CreateDevPickup(itemId, position, quantity)
	if not ItemDefinitions[itemId] or typeof(position) ~= "Vector3" then
		return nil
	end

	if not self.ItemPickupsFolder then
		self.ItemPickupsFolder = Instance.new("Folder")
		self.ItemPickupsFolder.Name = "ItemPickups"
		self.ItemPickupsFolder.Parent = Workspace
	end

	local instance = Instance.new("Part")
	instance.Name = itemId
	instance.Size = Vector3.new(2, 2, 2)
	instance.Shape = Enum.PartType.Ball
	instance.CFrame = CFrame.new(position + Vector3.new(0, 3, 0))
	instance.Anchored = true
	instance.CanCollide = false
	instance.CanQuery = false
	instance.CanTouch = false
	instance.Material = Enum.Material.Neon
	instance.Color = Color3.fromRGB(0, 143, 0)
	instance:SetAttribute("ItemId", itemId)
	instance:SetAttribute("DisplayName", "Pick Up " .. (ItemDefinitions[itemId].DisplayName or itemId))
	instance:SetAttribute("Quantity", math.max(1, tonumber(quantity) or 1))
	instance:SetAttribute("PickupDuration", DEFAULT_PICKUP_DURATION)
	instance.Parent = self.ItemPickupsFolder
	return instance
end

return ItemPickupService
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="93">
          <Properties>
            <string name="Name">MovementService</string>
            <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")

local ActionName = require(ReplicatedStorage.Shared.Enums.ActionName)
local RemoteNames = require(ReplicatedStorage.Shared.Constants.RemoteNames)
local WeaponDefinitions = require(ReplicatedStorage.Shared.Data.WeaponDefinitions)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local MovementService = {}
MovementService.Name = "MovementService"
MovementService.Dependencies = {
	"RemoteRegistry",
	"CharacterService",
	"StaminaService",
	"StatusEffectService",
	"InteractionService",
	"PlayerService",
	"InventoryService",
	"CombatService",
}

local MOVEMENT_STATE_KEYS = {
	[ActionName.Sprint] = "IsSprinting",
	[ActionName.Crouch] = "IsCrouching",
	[ActionName.Aim] = "IsAiming",
}

function MovementService:Init(services)
	self.Services = services
end

function MovementService:Start()
	local requestMovementState = self.RemoteRegistry:GetRemote(RemoteNames.RequestMovementState)
	requestMovementState.OnServerEvent:Connect(function(player, actionName, isActive)
		self:HandleMovementRequest(player, actionName, isActive)
	end)

	DebugLog:Log("Movement", "[MovementService] Started")
end

function MovementService:HandleMovementRequest(player, actionName, isActive)
	if type(actionName) ~= "string" or type(isActive) ~= "boolean" then
		return
	end

	if actionName ~= ActionName.Sprint and actionName ~= ActionName.Crouch and actionName ~= ActionName.Aim then
		return
	end

	local character = self.World:GetCharacter(player)
	if not character or not character:IsAlive() then
		return
	end

	local statusEffectService = self.StatusEffectService
	if statusEffectService and statusEffectService:HasFlag(player, "Stunned") then
		return
	end

	if actionName == ActionName.Sprint then
		if isActive and self.World:IsInteracting(player) then
			self.World:InterruptInteraction(player, "Sprint")
		end
		character:SetSprintHeld(isActive)
		if isActive then
			character:SetCrouching(false)
			character:SetAiming(false)
		end
	elseif actionName == ActionName.Crouch then
		character:SetCrouching(isActive)
		if isActive then
			character:SetSprintHeld(false)
		end
	else
		local equippedEntry = self.InventoryService and self.InventoryService:GetEntry(player, (self.CombatService and self.CombatService.PlayerCombatStates[player] and self.CombatService.PlayerCombatStates[player].EquippedSlot) or 1)
		local equippedDefinition = equippedEntry and equippedEntry.EntryType == "Weapon" and WeaponDefinitions[equippedEntry.ItemId] or nil
		if isActive and (not equippedDefinition or equippedDefinition.Kind ~= "Firearm") then
			return
		end

		character:SetAiming(isActive)
		if isActive then
			character:SetSprintHeld(false)
		end
	end

	if self.StaminaService then
		self.StaminaService:RefreshPlayer(player)
	end

	local stateKey = MOVEMENT_STATE_KEYS[actionName]
	local playerService = self.PlayerService
	if playerService and stateKey then
		playerService:SetMovementState(player, stateKey, isActive)

		if isActive then
			if actionName == ActionName.Sprint then
				playerService:SetMovementState(player, MOVEMENT_STATE_KEYS[ActionName.Crouch], false)
				playerService:SetMovementState(player, MOVEMENT_STATE_KEYS[ActionName.Aim], false)
			elseif actionName == ActionName.Crouch then
				playerService:SetMovementState(player, MOVEMENT_STATE_KEYS[ActionName.Sprint], false)
			elseif actionName == ActionName.Aim then
				playerService:SetMovementState(player, MOVEMENT_STATE_KEYS[ActionName.Sprint], false)
			end
		end
	end

	if self.CombatService then
		self.CombatService:RefreshCombatState(player)
	end

	DebugLog:Log("Movement", string.format("[MovementService] %s set %s=%s", player.Name, actionName, tostring(isActive)))
end

return MovementService
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="94">
          <Properties>
            <string name="Name">ObjectiveService</string>
            <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")
local ServerScriptService = game:GetService("ServerScriptService")

local BaseObjective = require(ServerScriptService.Server.Classes.BaseObjective)
local ObjectiveDefinitions = require(ReplicatedStorage.Shared.Data.ObjectiveDefinitions)
local ObjectivePhase = require(ReplicatedStorage.Shared.Enums.ObjectivePhase)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local ObjectiveService = {}
ObjectiveService.Name = "ObjectiveService"

function ObjectiveService:Init(services)
	self.Services = services
	self.Objectives = {}
	
	self.ObjectivesFolder = Workspace:WaitForChild("Objectives")
end

function ObjectiveService:Start()
	self:_registerExistingObjectives()
	DebugLog:Log("Objectives", "[ObjectiveService] Started")
end

function ObjectiveService:_registerExistingObjectives()
	for _, instance in ipairs(self.ObjectivesFolder:GetChildren()) do
		local definition = ObjectiveDefinitions[instance.Name]
		local objective = BaseObjective.new(instance, definition)
		
		table.insert(self.Objectives, objective)
		
		DebugLog:Log("Objectives", string.format(
			"[ObjectiveService] Registered objective: %s | Type: %s | Phase: %s",
			objective.DisplayName,
			objective.Type,
			objective.Phase
		))
	end
end

function ObjectiveService:GetObjectives()
	return self.Objectives
end

function ObjectiveService:GetObjectivesByPhase(objectivePhase)
	local results = {}
	
	for _, objective in ipairs(self.Objectives) do
		if objective.Phase == objectivePhase then
			table.insert(results, objective)
		end
	end
	
	return results
end

function ObjectiveService:SetPhaseEnabled(objectivePhase, enabled)
	for _, objective in ipairs(self.Objectives) do
		if objective.Phase == objectivePhase then
			objective:SetEnabled(enabled)
		end
	end
	
	DebugLog:Log("Objectives", string.format("[ObjectiveService] Set phase '%s' enabled = %s", objectivePhase, tostring(enabled)))
end

function ObjectiveService:ResetObjectives()
	for _, objective in ipairs(self.Objectives) do
		objective.Progress = 0
		objective.LastLoggedProgressStep = -1
		objective.IsComplete = false
		objective.IsEnabled = objective.StartsEnabled
	end
	
	DebugLog:Log("Objectives", "[ObjectiveService] Objectives reset")
end

function ObjectiveService:TryProgressObjectiveByName(name, amount)
	for _, objective in ipairs(self.Objectives) do
		if objective.Id == name or objective.DisplayName == name or (objective.Instance and objective.Instance.Name == name) then
			return self:ProgressObjective(objective, amount)
		end
	end
	
	return false
end

function ObjectiveService:ProgressObjective(objective, amount)
	if not objective or objective.IsComplete then
		return false
	end
	
	local succeeded = objective:AddProgress(amount)
	if not succeeded then
		return false
	end

	local currentProgressStep = math.floor(objective.Progress)
	if currentProgressStep > (objective.LastLoggedProgressStep or -1) then
		objective.LastLoggedProgressStep = currentProgressStep
		DebugLog:Log("ObjectiveProgress", string.format(
			"[ObjectiveService] %s progress: %1.f / %1.f",
			objective.DisplayName,
			objective.Progress,
			objective.MaxProgress
		))
	end
	
	if objective.IsComplete then
		DebugLog:Log("Objectives", "[ObjectiveService] Completed objective:", objective.DisplayName)
		
		local roundManager = self.Services.RoundManager
		if roundManager and roundManager.OnObjectiveCompleted then
			roundManager:OnObjectiveCompleted(objective)
		end
	end
	
	return true
end

return ObjectiveService
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="95">
          <Properties>
            <string name="Name">PlayerService</string>
            <string name="Source"><![CDATA[local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local PlayerService = {}
PlayerService.Name = "PlayerService"

function PlayerService:Init()
	self.PlayerStates = {}
end

function PlayerService:Start()
	for _, player in ipairs(Players:GetPlayers()) do
		self:_onPlayerAdded(player)
	end
	
	Players.PlayerAdded:Connect(function(player)
		self:_onPlayerAdded(player)
	end)
	
	Players.PlayerRemoving:Connect(function(player)
		self:_onPlayerRemoving(player)
	end)
	
	DebugLog:Log("Player", "[PlayerService] Started")
end

function PlayerService:_onPlayerAdded(player)
	self.PlayerStates[player] = {
		IsAlive = true,
		HasEscaped = false,
		IsLoaded = true,
		IsSprinting = false,
		IsCrouching = false,
		IsAiming = false,
	}
	DebugLog:Log("Player", "[PlayerService] Added", player.Name)
end

function PlayerService:_onPlayerRemoving(player)
	self.PlayerStates[player] = nil
	DebugLog:Log("Player", "[PlayerService] Removed", player.Name)
end

function PlayerService:GetPlayerState(player)
	return self.PlayerStates[player]
end

function PlayerService:GetPlayers()
	local players = {}
	
	for player in pairs(self.PlayerStates) do
		table.insert(players, player)
	end
	
	return players
end

function PlayerService:SetAlive(player, isAlive)
	local state = self.PlayerStates[player]
	if state then
		state.IsAlive = isAlive
	end
end

function PlayerService:SetMovementState(player, stateKey, value)
	local state = self.PlayerStates[player]
	if not state then
		return
	end

	state[stateKey] = value
end

return PlayerService
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="96">
          <Properties>
            <string name="Name">QTEService</string>
            <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")

local RemoteNames = require(ReplicatedStorage.Shared.Constants.RemoteNames)
local QTEType = require(ReplicatedStorage.Shared.Enums.QTEType)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local QTEService = {}
QTEService.Name = "QTEService"
QTEService.Dependencies = {
	"RemoteRegistry",
}

function QTEService:Init(services)
	self.Services = services
	self.ActiveSessions = {}
	self.UpdateInterval = 0.05
	self.SessionCounter = 0
end

function QTEService:Start()
	self.QTEStateRemote = self.RemoteRegistry:GetRemote(RemoteNames.QTEStateChanged)
	local requestQTEInput = self.RemoteRegistry:GetRemote(RemoteNames.RequestQTEInput)

	requestQTEInput.OnServerEvent:Connect(function(player, payload)
		self:HandleInput(player, payload)
	end)

	task.spawn(function()
		while true do
			self:_updateSessions()
			task.wait(self.UpdateInterval)
		end
	end)

	DebugLog:Log("Interaction", "[QTEService] Started")
end

function QTEService:StartSession(player, config)
	if not player or not config then
		return nil
	end

	if self.ActiveSessions[player] then
		self:StopSession(player, "Replaced")
	end

	self.SessionCounter += 1
	local now = os.clock()
	local session = {
		Id = string.format("QTE-%d", self.SessionCounter),
		Player = player,
		Type = config.Type or QTEType.KeyMash,
		Prompt = config.Prompt or "Quick Time Event",
		SubPrompt = config.SubPrompt or "",
		Duration = config.Duration or 5,
		StartedAt = now,
		EndsAt = now + (config.Duration or 5),
		Progress = config.Progress or 0,
		MaxProgress = config.MaxProgress or 1,
		RequiredKey = config.RequiredKey,
		Keys = config.Keys,
		CurrentKeyIndex = 1,
		ProgressPerPress = config.ProgressPerPress or 0.1,
		WrongPenalty = config.WrongPenalty or 0.05,
		TargetDistance = config.TargetDistance or 600,
		MinSliceDelta = config.MinSliceDelta or 6,
		DialAngle = config.DialAngle or Random.new():NextNumber(0, 360),
		DialSpeed = config.DialSpeed or 240,
		DialDirection = config.DialDirection or 1,
		SuccessAngle = config.SuccessAngle or Random.new():NextNumber(0, 360),
		SuccessAngleSize = config.SuccessAngleSize or 42,
		LastUpdatedAt = now,
		OnSuccess = config.OnSuccess,
		OnFail = config.OnFail,
		OnProgress = config.OnProgress,
	}

	self.ActiveSessions[player] = session
	self:_syncSession(session, "Start")
	return session
end

function QTEService:GetSession(player)
	return self.ActiveSessions[player]
end

function QTEService:IsSessionActive(player)
	return self.ActiveSessions[player] ~= nil
end

function QTEService:StopSession(player, reason)
	local session = self.ActiveSessions[player]
	if not session then
		return
	end

	self.ActiveSessions[player] = nil
	self:_syncStop(player, reason or "Ended")
end

function QTEService:HandleInput(player, payload)
	local session = self.ActiveSessions[player]
	if not session or type(payload) ~= "table" then
		return
	end

	if session.Type == QTEType.KeyMash then
		self:_handleKeyMashInput(session, payload)
	elseif session.Type == QTEType.SequenceKeys then
		self:_handleSequenceInput(session, payload)
	elseif session.Type == QTEType.MouseSlice then
		self:_handleMouseSliceInput(session, payload)
	elseif session.Type == QTEType.TimingDial then
		self:_handleTimingDialInput(session, payload)
	end
end

function QTEService:_handleKeyMashInput(session, payload)
	if payload.Kind ~= "Press" then
		return
	end

	local payloadKey = type(payload.Key) == "string" and string.lower(payload.Key) or payload.Key
	local requiredKey = type(session.RequiredKey) == "string" and string.lower(session.RequiredKey) or session.RequiredKey
	if requiredKey and payloadKey ~= requiredKey then
		return
	end

	session.Progress = math.min(session.MaxProgress, session.Progress + session.ProgressPerPress)
	self:_notifyProgress(session)
	if session.Progress >= session.MaxProgress then
		self:_completeSession(session, "Success")
	end
end

function QTEService:_handleSequenceInput(session, payload)
	if payload.Kind ~= "Press" then
		return
	end

	local expectedKey = session.Keys and session.Keys[session.CurrentKeyIndex]
	if not expectedKey then
		return
	end

	local payloadKey = type(payload.Key) == "string" and string.lower(payload.Key) or payload.Key
	local normalizedExpectedKey = type(expectedKey) == "string" and string.lower(expectedKey) or expectedKey
	if payloadKey == normalizedExpectedKey then
		session.CurrentKeyIndex += 1
		session.Progress = math.min(session.MaxProgress, session.Progress + session.ProgressPerPress)
		self:_notifyProgress(session)
		if not session.Keys[session.CurrentKeyIndex] or session.Progress >= session.MaxProgress then
			self:_completeSession(session, "Success")
		end
	else
		session.Progress = math.max(0, session.Progress - session.WrongPenalty)
		self:_notifyProgress(session)
	end
end

function QTEService:_handleMouseSliceInput(session, payload)
	if payload.Kind ~= "Slice" or typeof(payload.Delta) ~= "Vector2" then
		return
	end

	local magnitude = payload.Delta.Magnitude
	if magnitude < session.MinSliceDelta then
		return
	end

	session.Progress = math.min(session.MaxProgress, session.Progress + (magnitude / session.TargetDistance))
	self:_notifyProgress(session)
	if session.Progress >= session.MaxProgress then
		self:_completeSession(session, "Success")
	end
end

function QTEService:_handleTimingDialInput(session, payload)
	if payload.Kind ~= "Press" then
		return
	end

	local angleDelta = math.abs(((session.DialAngle - session.SuccessAngle + 180) % 360) - 180)
	local successThreshold = math.max(1, (session.SuccessAngleSize or 0) * 0.5)
	if angleDelta <= successThreshold then
		session.Progress = math.min(session.MaxProgress, session.Progress + session.ProgressPerPress)
		session.DialDirection *= -1
		session.SuccessAngle = Random.new():NextNumber(0, 360)
		self:_notifyProgress(session)
		if session.Progress >= session.MaxProgress then
			self:_completeSession(session, "Success")
		end
	else
		session.Progress = math.max(0, session.Progress - session.WrongPenalty)
		self:_notifyProgress(session)
	end
end

function QTEService:_notifyProgress(session)
	if session.OnProgress then
		session.OnProgress(session.Player, session)
	end

	self:_syncSession(session, "Update")
end

function QTEService:_updateSessions()
	local now = os.clock()
	for player, session in pairs(self.ActiveSessions) do
		if session.Type == QTEType.TimingDial then
			local deltaTime = math.max(0, now - (session.LastUpdatedAt or now))
			session.DialAngle = (session.DialAngle + ((session.DialSpeed or 0) * (session.DialDirection or 1) * deltaTime)) % 360
			session.LastUpdatedAt = now
		end

		if now >= session.EndsAt then
			self:_failSession(session, "Expired")
		else
			self:_syncSession(session, "Update")
		end
	end
end

function QTEService:_completeSession(session, reason)
	if self.ActiveSessions[session.Player] ~= session then
		return
	end

	self.ActiveSessions[session.Player] = nil
	self:_syncStop(session.Player, reason or "Success")
	if session.OnSuccess then
		session.OnSuccess(session.Player, session)
	end
end

function QTEService:_failSession(session, reason)
	if self.ActiveSessions[session.Player] ~= session then
		return
	end

	self.ActiveSessions[session.Player] = nil
	self:_syncStop(session.Player, reason or "Failed")
	if session.OnFail then
		session.OnFail(session.Player, session, reason or "Failed")
	end
end

function QTEService:_syncSession(session, state)
	if not self.QTEStateRemote then
		return
	end

	local expectedKey = session.Keys and session.Keys[session.CurrentKeyIndex] or nil
	self.QTEStateRemote:FireClient(session.Player, {
		State = state,
		Id = session.Id,
		Type = session.Type,
		Prompt = session.Prompt,
		SubPrompt = session.SubPrompt,
		Duration = math.max(0, session.EndsAt - os.clock()),
		Progress = session.Progress,
		Max = session.MaxProgress,
		RequiredKey = session.RequiredKey,
		ExpectedKey = expectedKey,
		KeysRemaining = session.Keys and math.max(0, (#session.Keys - session.CurrentKeyIndex) + 1) or nil,
		DialAngle = session.DialAngle,
		SuccessAngle = session.SuccessAngle,
		SuccessAngleSize = session.SuccessAngleSize,
	})
end

function QTEService:_syncStop(player, reason)
	if not self.QTEStateRemote then
		return
	end

	self.QTEStateRemote:FireClient(player, {
		State = "Stop",
		Reason = reason or "Ended",
	})
end

return QTEService
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="97">
          <Properties>
            <string name="Name">RemnantService</string>
            <string name="Source"><![CDATA[local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")

local RemoteNames = require(ReplicatedStorage.Shared.Constants.RemoteNames)
local RemnantDefinitions = require(ReplicatedStorage.Shared.Data.RemnantDefinitions)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local RemnantService = {}
RemnantService.Name = "RemnantService"
RemnantService.Dependencies = {
	"RemoteRegistry",
	"RoundManager",
	"CharacterService",
	"ObjectiveService",
	"WeaponPickupService",
	"ItemPickupService",
	"EntityService",
	"CombatService",
}

function RemnantService:Init(services)
	self.Services = services
	self.PlayerStates = {}
	self.ActiveWatchtowers = {}
	self.UpdateInterval = 0.15
	self.DevicesFolder = Workspace:FindFirstChild("RemnantDevices")
	if not self.DevicesFolder then
		self.DevicesFolder = Instance.new("Folder")
		self.DevicesFolder.Name = "RemnantDevices"
		self.DevicesFolder.Parent = Workspace
	end
end

function RemnantService:_createTemporaryPart(properties, duration)
	local part = Instance.new("Part")
	part.Anchored = true
	part.CanCollide = false
	part.CanQuery = false
	part.CanTouch = false
	part.CastShadow = false
	part.Material = properties.Material or Enum.Material.Neon
	part.Color = properties.Color or Color3.fromRGB(115, 208, 255)
	part.Transparency = properties.Transparency or 0.2
	part.Size = properties.Size or Vector3.new(1, 1, 1)
	part.Shape = properties.Shape or Enum.PartType.Ball
	part.CFrame = properties.CFrame or CFrame.new()
	part.Name = properties.Name or "RemnantVisual"
	part.Parent = self.DevicesFolder

	task.delay(duration or 0.2, function()
		if part.Parent then
			part:Destroy()
		end
	end)

	return part
end

function RemnantService:_spawnPulseRing(position, color, startRadius, endRadius, duration, yOffset)
	local ring = self:_createTemporaryPart({
		Name = "PulseRing",
		Shape = Enum.PartType.Cylinder,
		Size = Vector3.new(0.08, startRadius * 2, startRadius * 2),
		CFrame = CFrame.new(position + Vector3.new(0, yOffset or 0, 0)) * CFrame.Angles(0, 0, math.rad(90)),
		Color = color,
		Material = Enum.Material.ForceField,
		Transparency = 0.18,
	}, duration)

	local startedAt = os.clock()
	task.spawn(function()
		while ring.Parent do
			local alpha = math.clamp((os.clock() - startedAt) / duration, 0, 1)
			local radius = startRadius + ((endRadius - startRadius) * alpha)
			ring.Size = Vector3.new(0.08, radius * 2, radius * 2)
			ring.Transparency = 0.18 + (alpha * 0.72)
			task.wait(0.03)
		end
	end)
end

function RemnantService:_spawnWatcherEyeVisual(character)
	if not character or not character.RootPart then
		return
	end

	local eyePosition = character.RootPart.Position + Vector3.new(0, 4.3, 0)
	self:_createTemporaryPart({
		Name = "WatchersEye",
		Shape = Enum.PartType.Ball,
		Size = Vector3.new(1.1, 1.1, 1.1),
		CFrame = CFrame.new(eyePosition),
		Color = Color3.fromRGB(115, 208, 255),
		Transparency = 0.12,
	}, 0.7)
	self:_spawnPulseRing(character.RootPart.Position, Color3.fromRGB(115, 208, 255), 2, 22, 0.55, -2.8)
end

function RemnantService:_spawnWatchtowerDeployVisual(position, radius)
	self:_createTemporaryPart({
		Name = "WatchtowerFlash",
		Shape = Enum.PartType.Ball,
		Size = Vector3.new(1.25, 1.25, 1.25),
		CFrame = CFrame.new(position + Vector3.new(0, 0.7, 0)),
		Color = Color3.fromRGB(140, 226, 255),
		Transparency = 0.08,
	}, 0.35)
	self:_spawnPulseRing(position, Color3.fromRGB(90, 184, 255), 3, math.min(radius, 26), 0.45, -2.8)
end

function RemnantService:_spawnRefixtureShotFlash(position)
	self:_createTemporaryPart({
		Name = "RefixtureFlash",
		Shape = Enum.PartType.Ball,
		Size = Vector3.new(0.4, 0.4, 0.4),
		CFrame = CFrame.new(position),
		Color = Color3.fromRGB(180, 236, 255),
		Transparency = 0.04,
	}, 0.08)
end

function RemnantService:Start()
	self.RequestAbilityRemote = self.RemoteRegistry:GetRemote(RemoteNames.RequestRemnantAbility)
	self.RemnantStateRemote = self.RemoteRegistry:GetRemote(RemoteNames.RemnantStateChanged)
	self.AuraRevealStateRemote = self.RemoteRegistry:GetRemote(RemoteNames.AuraRevealStateChanged)
	self.UiToastRemote = self.RemoteRegistry:GetRemote(RemoteNames.UiToastRequested)

	for _, player in ipairs(Players:GetPlayers()) do
		self:_initializePlayer(player)
	end

	Players.PlayerAdded:Connect(function(player)
		self:_initializePlayer(player)
	end)

	Players.PlayerRemoving:Connect(function(player)
		self:_destroyWatchtower(player)
		self.PlayerStates[player] = nil
	end)

	if self.RequestAbilityRemote then
		self.RequestAbilityRemote.OnServerEvent:Connect(function(player, abilitySlot)
			self:HandleAbilityRequest(player, abilitySlot)
		end)
	end

	task.spawn(function()
		self:_runLoop()
	end)

	DebugLog:Log("Remnant", "[RemnantService] Started")
end

function RemnantService:_runLoop()
	while true do
		self:_cleanupInactiveRoundState()
		self:_updateWatchtowers()
		self:_updateRevealStates()
		task.wait(self.UpdateInterval)
	end
end

function RemnantService:_initializePlayer(player)
	local definition = RemnantDefinitions.Baam
	local abilities = {}
	for slotName, abilityDefinition in pairs(definition.Abilities or {}) do
		abilities[slotName] = {
			Id = abilityDefinition.Id,
			DisplayName = abilityDefinition.DisplayName,
			Keybind = abilityDefinition.Keybind,
			Cooldown = abilityDefinition.Cooldown or 0,
			CooldownEndsAt = 0,
			IsImplemented = abilityDefinition.IsImplemented ~= false,
		}
	end

	self.PlayerStates[player] = {
		RemnantId = definition.Id,
		Fragments = definition.DefaultFragments or 0,
		Abilities = abilities,
		Reveals = {},
	}

	self:_pushState(player)
	self:_pushRevealState(player)
end

function RemnantService:_cleanupInactiveRoundState()
	if self.RoundManager and self.RoundManager:IsReceptionActive() then
		return
	end

	for player, state in pairs(self.PlayerStates) do
		local hadChanges = false

		if self.ActiveWatchtowers[player] then
			self:_destroyWatchtower(player)
			hadChanges = true
		end

		if next(state.Reveals) ~= nil then
			table.clear(state.Reveals)
			hadChanges = true
			self:_pushRevealState(player)
		end

		for _, abilityState in pairs(state.Abilities or {}) do
			if (abilityState.CooldownEndsAt or 0) > 0 then
				abilityState.CooldownEndsAt = 0
				hadChanges = true
			end
		end

		if hadChanges then
			self:_pushState(player)
		end
	end
end

function RemnantService:GetPlayerState(player)
	return self.PlayerStates[player]
end

function RemnantService:HandleAbilityRequest(player, abilitySlot)
	if type(abilitySlot) ~= "string" then
		return false
	end

	local state = self.PlayerStates[player]
	if not state then
		return false
	end

	if not self.RoundManager or not self.RoundManager:IsReceptionActive() then
		return false
	end

	local roundState = self.RoundManager:GetRoundState(player)
	local character = self.CharacterService and self.CharacterService:GetCharacterByPlayer(player)
	if not roundState or not roundState.IsAlive or not character or not character:IsAlive() then
		return false
	end

	local abilityState = state.Abilities[abilitySlot]
	if not abilityState or not abilityState.IsImplemented then
		return false
	end

	local now = os.clock()
	if (abilityState.CooldownEndsAt or 0) > now then
		return false
	end

	local didUse = false
	if abilityState.Id == "WatchersEye" then
		didUse = self:_useWatchersEye(player, state)
	elseif abilityState.Id == "Refixture" then
		didUse = self:_useRefixture(player, state, character)
	elseif abilityState.Id == "Watchtower" then
		didUse = self:_useWatchtower(player, state, character)
	end

	if not didUse then
		return false
	end

	abilityState.CooldownEndsAt = now + (abilityState.Cooldown or 0)
	self:_pushState(player)
	if self.UiToastRemote then
		self.UiToastRemote:FireClient(player, {
			Title = "Ability Used",
			Message = abilityState.DisplayName or abilityState.Id,
			Tint = "Ability",
		})
	end
	DebugLog:Log("Remnant", string.format("[RemnantService] %s used %s", player.Name, abilityState.Id))
	return true
end

function RemnantService:_useWatchersEye(player, state)
	local fragments = state.Fragments or 0
	local duration = 2.5
	if fragments >= 5 then
		duration += 1.5
	end

	local reveals = {}

	if fragments >= 1 and self.ObjectiveService then
		for _, objective in ipairs(self.ObjectiveService:GetObjectives()) do
			if objective.Instance then
				table.insert(reveals, {
					Instance = objective.Instance,
					Type = "Objective",
					DisplayName = objective.DisplayName or objective.Id or objective.Instance.Name,
					Duration = duration,
				})
			end
		end
	end

	if fragments >= 2 and self.RoundManager and self.CharacterService then
		for _, otherPlayer in ipairs(self.RoundManager:GetActivePlayers()) do
			if otherPlayer ~= player then
				local otherCharacter = self.CharacterService:GetCharacterByPlayer(otherPlayer)
				if otherCharacter and otherCharacter.Model then
					table.insert(reveals, {
						Instance = otherCharacter.Model,
						Type = "Remnant",
						DisplayName = otherPlayer.Name,
						Duration = duration,
					})
				end
			end
		end
	end

	if fragments >= 3 and self.EntityService then
		for _, entity in ipairs(self.EntityService.Entities or {}) do
			if entity.IsActive and entity.Model then
				table.insert(reveals, {
					Instance = entity.Model,
					Type = "Entity",
					DisplayName = entity.DisplayName or entity.Id,
					Duration = duration,
				})
			end
		end
	end

	if fragments >= 4 then
		if self.WeaponPickupService then
			for _, pickup in ipairs(self.WeaponPickupService:GetAvailablePickups() or {}) do
				if pickup.Instance then
					table.insert(reveals, {
						Instance = pickup.Instance,
						Type = "Loot",
						DisplayName = pickup.DisplayName or pickup.WeaponId or pickup.Instance.Name,
						Duration = duration,
					})
				end
			end
		end

		if self.ItemPickupService then
			for _, pickup in ipairs(self.ItemPickupService:GetAvailablePickups() or {}) do
				if pickup.Instance then
					table.insert(reveals, {
						Instance = pickup.Instance,
						Type = "Loot",
						DisplayName = pickup.DisplayName or pickup.ItemId or pickup.Instance.Name,
						Duration = duration,
					})
				end
			end
		end
	end

	if #reveals == 0 then
		return false
	end

	local character = self.CharacterService and self.CharacterService:GetCharacterByPlayer(player)
	if character then
		self:_spawnWatcherEyeVisual(character)
	end

	local now = os.clock()
	local activeReveals = state.Reveals
	for _, reveal in ipairs(reveals) do
		local key = reveal.Instance
		local existing = activeReveals[key]
		local expiresAt = now + (reveal.Duration or duration)
		if existing then
			existing.ExpiresAt = math.max(existing.ExpiresAt or 0, expiresAt)
			existing.Type = reveal.Type
			existing.DisplayName = reveal.DisplayName
		else
			activeReveals[key] = {
				Instance = reveal.Instance,
				Type = reveal.Type,
				DisplayName = reveal.DisplayName,
				ExpiresAt = expiresAt,
			}
		end
	end

	self:_pushRevealState(player)
	return true
end

function RemnantService:_useRefixture(player, state, character)
	local definition = RemnantDefinitions[state.RemnantId] or RemnantDefinitions.Baam
	local abilityDefinition = definition.Abilities and definition.Abilities.Ability2
	if not abilityDefinition or not character or not character.RootPart or not self.CombatService or not self.EntityService then
		return false
	end

	local weaponDefinition = self.CombatService:GetEquippedWeaponDefinition(player)
	if not weaponDefinition or weaponDefinition.Kind ~= "Firearm" then
		return false
	end

	local origin = character.RootPart.Position + Vector3.new(0, 2.8, 0)
	local nearestEntity = nil
	local nearestDistance = math.huge
	local maxRange = abilityDefinition.Range or 160

	for _, entity in ipairs(self.EntityService.Entities or {}) do
		if entity.IsActive and entity.Health > 0 and entity.Model then
			local entityPosition = entity:GetPosition()
			if entityPosition then
				local distance = (entityPosition - origin).Magnitude
				if distance <= maxRange and distance < nearestDistance then
					nearestDistance = distance
					nearestEntity = entity
				end
			end
		end
	end

	if not nearestEntity then
		return false
	end

	local shotCount = weaponDefinition.MagazineSize or 1
	local shotInterval = abilityDefinition.ShotInterval or 0.06
	local damagePerShot = math.max(1, math.floor((weaponDefinition.Damage or 0) * (abilityDefinition.DamageMultiplier or 0.5)))
	local targetPosition = nearestEntity:GetPosition()
	if not targetPosition then
		return false
	end

	local hologram = Instance.new("Part")
	hologram.Name = string.format("%sRefixture", player.Name)
	hologram.Size = Vector3.new(0.5, 0.5, 1.4)
	hologram.Anchored = true
	hologram.CanCollide = false
	hologram.CanQuery = false
	hologram.CanTouch = false
	hologram.CastShadow = false
	hologram.Material = Enum.Material.Neon
	hologram.Color = Color3.fromRGB(115, 208, 255)
	hologram.Transparency = 0.18
	hologram.CFrame = CFrame.lookAt(origin, targetPosition + Vector3.new(0, 2, 0))
	hologram.Parent = self.DevicesFolder
	task.delay((shotCount * shotInterval) + 0.2, function()
		if hologram.Parent then
			hologram:Destroy()
		end
	end)

	for shotIndex = 1, shotCount do
		task.delay((shotIndex - 1) * shotInterval, function()
			if not character:IsAlive() then
				return
			end

			if not nearestEntity.IsActive or nearestEntity.Health <= 0 then
				return
			end

			local liveTargetPosition = nearestEntity:GetPosition()
			if not liveTargetPosition then
				return
			end

			local shotOrigin = origin
			local shotEnd = liveTargetPosition + Vector3.new(0, 2, 0)
			self:_spawnRefixtureShotFlash(shotOrigin)
			self.CombatService:EmitShotVisual(player, shotOrigin, shotEnd, true)
			self.EntityService:DamageEntity(nearestEntity, damagePerShot, {
				SourcePlayer = player,
				WeaponId = weaponDefinition.Id,
				Source = "Refixture",
			})
		end)
	end

	return true
end

function RemnantService:_useWatchtower(player, state, character)
	local definition = RemnantDefinitions[state.RemnantId] or RemnantDefinitions.Baam
	local abilityDefinition = definition.Abilities and definition.Abilities.Ability3
	if not abilityDefinition or not character or not character.RootPart then
		return false
	end

	self:_destroyWatchtower(player)

	local rootPart = character.RootPart
	local forward = rootPart.CFrame.LookVector
	local position = rootPart.Position + (forward * 4)

	local beacon = Instance.new("Part")
	beacon.Name = string.format("%sWatchtower", player.Name)
	beacon.Shape = Enum.PartType.Cylinder
	beacon.Size = Vector3.new(0.7, 2.4, 2.4)
	beacon.CFrame = CFrame.new(position) * CFrame.Angles(0, 0, math.rad(90))
	beacon.Anchored = true
	beacon.CanCollide = false
	beacon.CanQuery = false
	beacon.CanTouch = false
	beacon.Material = Enum.Material.Neon
	beacon.Color = Color3.fromRGB(102, 214, 255)
	beacon.Transparency = 0.15
	beacon.Parent = self.DevicesFolder

	local pulse = Instance.new("Part")
	pulse.Name = "Radius"
	pulse.Shape = Enum.PartType.Cylinder
	pulse.Size = Vector3.new(0.08, abilityDefinition.Radius * 2, abilityDefinition.Radius * 2)
	pulse.CFrame = CFrame.new(position + Vector3.new(0, -2.8, 0)) * CFrame.Angles(0, 0, math.rad(90))
	pulse.Anchored = true
	pulse.CanCollide = false
	pulse.CanQuery = false
	pulse.CanTouch = false
	pulse.Material = Enum.Material.ForceField
	pulse.Color = Color3.fromRGB(90, 184, 255)
	pulse.Transparency = 0.82
	pulse.Parent = self.DevicesFolder

	-- Soft center marker for the owner's stronger reveal radius.
	local innerPulse = Instance.new("Part")
	innerPulse.Name = "OwnerRadius"
	innerPulse.Shape = Enum.PartType.Cylinder
	innerPulse.Size = Vector3.new(0.05, abilityDefinition.OwnerRadius * 2, abilityDefinition.OwnerRadius * 2)
	innerPulse.CFrame = CFrame.new(position + Vector3.new(0, -2.78, 0)) * CFrame.Angles(0, 0, math.rad(90))
	innerPulse.Anchored = true
	innerPulse.CanCollide = false
	innerPulse.CanQuery = false
	innerPulse.CanTouch = false
	innerPulse.Material = Enum.Material.ForceField
	innerPulse.Color = Color3.fromRGB(160, 233, 255)
	innerPulse.Transparency = 0.93
	innerPulse.Parent = self.DevicesFolder

	self.ActiveWatchtowers[player] = {
		Player = player,
		Position = position,
		Radius = abilityDefinition.Radius or 300,
		OwnerRadius = abilityDefinition.OwnerRadius or abilityDefinition.Radius or 300,
		ExpiresAt = os.clock() + (abilityDefinition.Duration or 50),
		Beacon = beacon,
		Pulse = pulse,
		InnerPulse = innerPulse,
	}

	self:_spawnWatchtowerDeployVisual(position, abilityDefinition.Radius or 300)

	return true
end

function RemnantService:_updateWatchtowers()
	local now = os.clock()
	for player, tower in pairs(self.ActiveWatchtowers) do
		if not tower or tower.ExpiresAt <= now then
			self:_destroyWatchtower(player)
		else
			self:_tickWatchtower(tower)
		end
	end
end

function RemnantService:_tickWatchtower(tower)
	if not self.RoundManager or not self.CharacterService or not self.EntityService then
		return
	end

	local changedPlayers = {}
	for _, occupant in ipairs(self.RoundManager:GetActivePlayers()) do
		local roundState = self.RoundManager:GetRoundState(occupant)
		local character = self.CharacterService:GetCharacterByPlayer(occupant)
		if roundState and roundState.IsAlive and character and character.RootPart then
			local distanceToTower = (character.RootPart.Position - tower.Position).Magnitude
			if distanceToTower <= tower.Radius then
				local revealRadius = occupant == tower.Player and tower.OwnerRadius or tower.Radius
				for _, entity in ipairs(self.EntityService.Entities or {}) do
					if entity.IsActive and entity.Model then
						local entityPosition = entity:GetPosition()
						if entityPosition and (entityPosition - tower.Position).Magnitude <= revealRadius then
							local changed = self:_grantReveal(occupant, {
								Instance = entity.Model,
								Type = "Entity",
								DisplayName = entity.DisplayName or entity.Id,
							}, 0.35)
							if changed then
								changedPlayers[occupant] = true
							end
						end
					end
				end
			end
		end
	end

	for player in pairs(changedPlayers) do
		if self.PlayerStates[player] then
			self:_pushRevealState(player)
		end
	end
end

function RemnantService:_grantReveal(player, reveal, duration)
	local state = self.PlayerStates[player]
	if not state or not reveal or not reveal.Instance then
		return false
	end

	local activeReveals = state.Reveals
	local key = reveal.Instance
	local expiresAt = os.clock() + math.max(0, duration or 0)
	local existing = activeReveals[key]
	if existing then
		local previousExpiry = existing.ExpiresAt or 0
		existing.ExpiresAt = math.max(previousExpiry, expiresAt)
		existing.Type = reveal.Type
		existing.DisplayName = reveal.DisplayName
		return expiresAt > previousExpiry
	end

	activeReveals[key] = {
		Instance = reveal.Instance,
		Type = reveal.Type,
		DisplayName = reveal.DisplayName,
		ExpiresAt = expiresAt,
	}
	return true
end

function RemnantService:_destroyWatchtower(player)
	local tower = self.ActiveWatchtowers[player]
	if not tower then
		return
	end

	if tower.Beacon then
		tower.Beacon:Destroy()
	end
	if tower.Pulse then
		tower.Pulse:Destroy()
	end
	if tower.InnerPulse then
		tower.InnerPulse:Destroy()
	end

	self.ActiveWatchtowers[player] = nil
end

function RemnantService:_updateRevealStates()
	local now = os.clock()
	for player, state in pairs(self.PlayerStates) do
		local changed = false
		for instance, reveal in pairs(state.Reveals) do
			if reveal.ExpiresAt <= now or instance == nil or instance.Parent == nil then
				state.Reveals[instance] = nil
				changed = true
			end
		end

		if changed then
			self:_pushRevealState(player)
		end
	end
end

function RemnantService:_pushState(player)
	if not self.RemnantStateRemote then
		return
	end

	local state = self.PlayerStates[player]
	if not state then
		return
	end

	local definition = RemnantDefinitions[state.RemnantId] or RemnantDefinitions.Baam

	local abilities = {}
	local now = os.clock()
	for slotName, abilityState in pairs(state.Abilities) do
		abilities[slotName] = {
			Id = abilityState.Id,
			DisplayName = abilityState.DisplayName,
			Keybind = abilityState.Keybind,
			Cooldown = abilityState.Cooldown,
			CooldownRemaining = math.max(0, (abilityState.CooldownEndsAt or 0) - now),
			IsImplemented = abilityState.IsImplemented,
		}
	end

	self.RemnantStateRemote:FireClient(player, {
		RemnantId = state.RemnantId,
		DisplayName = definition.DisplayName or state.RemnantId,
		Fragments = state.Fragments,
		Abilities = abilities,
	})
end

function RemnantService:_pushRevealState(player)
	if not self.AuraRevealStateRemote then
		return
	end

	local state = self.PlayerStates[player]
	if not state then
		return
	end

	local now = os.clock()
	local snapshot = {}
	for _, reveal in pairs(state.Reveals) do
		if reveal.Instance and reveal.Instance.Parent then
			table.insert(snapshot, {
				Instance = reveal.Instance,
				Type = reveal.Type,
				DisplayName = reveal.DisplayName,
				Duration = math.max(0, reveal.ExpiresAt - now),
			})
		end
	end

	self.AuraRevealStateRemote:FireClient(player, snapshot)
end

return RemnantService
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="98">
          <Properties>
            <string name="Name">RemoteRegistry</string>
            <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")

local RemoteNames = require(ReplicatedStorage.Shared.Constants.RemoteNames)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local RemoteRegistry = {}
RemoteRegistry.Name = "RemoteRegistry"

function RemoteRegistry:Init()
	local sharedFolder = ReplicatedStorage:WaitForChild("Shared")
	local remotesFolder = sharedFolder:FindFirstChild("Remotes")
	if not remotesFolder then
		remotesFolder = Instance.new("Folder")
		remotesFolder.Name = "Remotes"
		remotesFolder.Parent = sharedFolder
	end
	
	for _, remoteName in pairs(RemoteNames) do
		if not remotesFolder:FindFirstChild(remoteName) then
			local remote = Instance.new("RemoteEvent")
			remote.Name = remoteName
			remote.Parent = remotesFolder
		end
	end
	
	self.RemotesFolder = remotesFolder
end

function RemoteRegistry:Start()
	DebugLog:Log("Boot", "[RemoteRegistry] Started")
end

function RemoteRegistry:GetRemote(name)
	return self.RemotesFolder:FindFirstChild(name)
end

return RemoteRegistry
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="99">
          <Properties>
            <string name="Name">RoundHookService</string>
            <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")

local GamePhase = require(ReplicatedStorage.Shared.Enums.GamePhase)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local RoundHookService = {}
RoundHookService.Name = "RoundHookService"
RoundHookService.Dependencies = {
	"RoundManager",
}

function RoundHookService:Init(services)
	self.Services = services
	self.ActiveHooks = {}
	self.TriggeredThresholds = {}
end

function RoundHookService:Start()
	DebugLog:Log("Round", "[RoundHookService] Started")
end

function RoundHookService:ResetHooks()
	self.ActiveHooks = {}
	self.TriggeredThresholds = {}
end

function RoundHookService:RegisterHook(hook)
	if not hook or not hook.Id then
		return nil
	end

	self.ActiveHooks[hook.Id] = hook
	return hook.Id
end

function RoundHookService:RemoveHook(hookId)
	self.ActiveHooks[hookId] = nil
	self.TriggeredThresholds[hookId] = nil
end

function RoundHookService:RaisePhaseChanged(phase, duration)
	if phase == GamePhase.Lobby then
		self.TriggeredThresholds = {}
	end

	for _, hook in pairs(self.ActiveHooks) do
		if hook.Trigger == "PhaseChanged" and hook.Phase == phase then
			self:_invokeHook(hook, {
				Phase = phase,
				Duration = duration,
			})
		end
	end
end

function RoundHookService:RaiseObjectiveCompleted(objective)
	for _, hook in pairs(self.ActiveHooks) do
		if hook.Trigger == "ObjectiveCompleted" then
			self:_invokeHook(hook, {
				Objective = objective,
			})
		end
	end
end

function RoundHookService:RaiseTimerTick(phase, timeLeft)
	if phase ~= GamePhase.Reception then
		return
	end

	for _, hook in pairs(self.ActiveHooks) do
		if hook.Trigger == "TimerThreshold" and hook.TimeLeft ~= nil and timeLeft <= hook.TimeLeft then
			if not self.TriggeredThresholds[hook.Id] then
				self.TriggeredThresholds[hook.Id] = true
				self:_invokeHook(hook, {
					Phase = phase,
					TimeLeft = timeLeft,
				})
			end
		end
	end
end

function RoundHookService:ExtendReceptionTime(amount, reason)
	if not amount or amount == 0 then
		return
	end

	local roundManager = self.RoundManager
	if not roundManager or not roundManager:IsReceptionActive() then
		return
	end

	roundManager.TimeLeft = math.max(0, roundManager.TimeLeft + amount)
	roundManager:BroadcastTimer()
	DebugLog:Log("Round", string.format("[RoundHookService] Extended reception by %ss (%s)", tostring(amount), tostring(reason or "Hook")))
end

function RoundHookService:SetReceptionTime(timeLeft, reason)
	if timeLeft == nil then
		return
	end

	local roundManager = self.RoundManager
	if not roundManager or not roundManager:IsReceptionActive() then
		return
	end

	roundManager.TimeLeft = math.max(0, timeLeft)
	roundManager:BroadcastTimer()
	DebugLog:Log("Round", string.format("[RoundHookService] Set reception time to %ss (%s)", tostring(timeLeft), tostring(reason or "Hook")))
end

function RoundHookService:_invokeHook(hook, context)
	if hook.Callback then
		hook.Callback(context)
	end

	DebugLog:Log("Round", string.format("[RoundHookService] Triggered hook %s", tostring(hook.Id)))
end

return RoundHookService
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="100">
          <Properties>
            <string name="Name">SpawnService</string>
            <string name="Source"><![CDATA[local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local SpawnService = {}
SpawnService.Name = "SpawnService"

function SpawnService:Init(services)
	self.Services = services
	
	local spawnsFolder = Workspace:WaitForChild("Spawns")
	self.LobbySpawn = spawnsFolder:WaitForChild("LobbySpawn")
	self.ReceptionSpawnsFolder = spawnsFolder:WaitForChild("ReceptionSpawns")
	self.EntitySpawnsFolder = spawnsFolder:FindFirstChild("EntitySpawns")
end

function SpawnService:Start()
	DebugLog:Log("Spawn", "[SpawnService] Started")
end

function SpawnService:TeleportPlayerToLobby(player)
	local character = self.Services.CharacterService:GetCharacterByPlayer(player)
	if not character or not character.RootPart then
		return
	end
	
	character.RootPart.CFrame = self.LobbySpawn.CFrame + Vector3.new(0,3,0)
end

function SpawnService:TeleportPlayerToReception(player)
	local character = self.Services.CharacterService:GetCharacterByPlayer(player)
	if not character or not character.RootPart then
		return
	end
	
	local spawnPart = self:GetRandomReceptionSpawn()
	if not spawnPart then
		warn("[SpawnService] No reception spawn found!")
		return
	end
	
	character.RootPart.CFrame = spawnPart.CFrame + Vector3.new(0, 3, 0)
end

function SpawnService:GetRandomReceptionSpawn()
	local spawns = self.ReceptionSpawnsFolder:GetChildren()
	if #spawns == 0 then
		return nil
	end
	
	return spawns[math.random(1, #spawns)]
end

function SpawnService:GetRandomEntitySpawn()
	local entitySpawnsFolder = self.EntitySpawnsFolder
	if entitySpawnsFolder and entitySpawnsFolder.Parent then
		local spawns = entitySpawnsFolder:GetChildren()
		if #spawns > 0 then
			return spawns[math.random(1, #spawns)]
		end
	end

	return self:GetRandomReceptionSpawn()
end

function SpawnService:TeleportPlayersToLobby(players)
	for _, player in ipairs(players) do
		self:TeleportPlayerToLobby(player)
	end
end

function SpawnService:TeleportPlayersToReception(players)
	for _, player in ipairs(players) do
		self:TeleportPlayerToReception(player)
	end
end

function SpawnService:TeleportAllPlayersToLobby()
	for player in pairs(self.Services.PlayerService.PlayerStates) do
		self:TeleportPlayerToLobby(player)
	end
end

function SpawnService:TeleportAllPlayersToReception()
	for player in pairs(self.Services.PlayerService.PlayerStates) do
		self:TeleportPlayerToReception(player)
	end
end

return SpawnService
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="101">
          <Properties>
            <string name="Name">StaminaService</string>
            <string name="Source"><![CDATA[local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local GamePhase = require(ReplicatedStorage.Shared.Enums.GamePhase)
local RemoteNames = require(ReplicatedStorage.Shared.Constants.RemoteNames)
local WorldModeResolver = require(ReplicatedStorage.Shared.Utility.WorldModeResolver)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local StaminaService = {}
StaminaService.Name = "StaminaService"
StaminaService.Dependencies = {
	"RemoteRegistry",
	"RoundManager",
	"CharacterService",
	"PlayerService",
}

function StaminaService:Init(services)
	self.Services = services
	self.States = {}
	self.UpdateInterval = 0.1
	self.MaxStamina = 100
	self.SprintDrainPerSecond = 16
	self.BaseRegenPerSecond = 10
	self.RegenDelay = 1.2
	self.RunDurationBeforeFatigue = 6
end

function StaminaService:_isMovementPhaseActive(character)
	local roundManager = self.RoundManager
	if not character or not character:IsAlive() then
		return false
	end

	if WorldModeResolver.IsWeaponLab() then
		return true
	end

	if not roundManager then
		return false
	end

	local phase = roundManager:GetCurrentPhase()
	return phase == GamePhase.Preparation or phase == GamePhase.Reception
end

function StaminaService:_resolveMovementState(character, state)
	if not character or not character.IsSprintHeld then
		state.ZeroStaminaAt = nil
		return "Walk"
	end

	if state.Current > 0.5 then
		state.ZeroStaminaAt = nil
		return "Sprint"
	end

	if not state.ZeroStaminaAt then
		state.ZeroStaminaAt = os.clock()
	end

	local isFatigued = (os.clock() - state.ZeroStaminaAt) >= self.RunDurationBeforeFatigue
	return isFatigued and "Fatigue" or "Run"
end

function StaminaService:Start()
	self.Remote = self.RemoteRegistry:GetRemote(RemoteNames.StaminaStateChanged)

	for _, player in ipairs(Players:GetPlayers()) do
		self:_ensureState(player)
		self:_pushState(player)
	end

	Players.PlayerAdded:Connect(function(player)
		self:_ensureState(player)
		self:_pushState(player)
	end)

	Players.PlayerRemoving:Connect(function(player)
		self.States[player] = nil
	end)

	task.spawn(function()
		self:_runLoop()
	end)

	DebugLog:Log("Movement", "[StaminaService] Started")
end

function StaminaService:_runLoop()
	while true do
		self:_updateStamina()
		task.wait(self.UpdateInterval)
	end
end

function StaminaService:_ensureState(player)
	local state = self.States[player]
	if state then
		return state
	end

	state = {
		Current = self.MaxStamina,
		Max = self.MaxStamina,
		LastDrainAt = 0,
		MovementState = "Walk",
		ZeroStaminaAt = nil,
	}
	self.States[player] = state
	return state
end

function StaminaService:_updateStamina()
	for player, state in pairs(self.States) do
		local character = self.CharacterService:GetCharacterByPlayer(player)
		local isActive = self:_isMovementPhaseActive(character)
		if not isActive then
			local changed = false
			if state.Current < state.Max then
				state.Current = state.Max
				changed = true
			end
			if character then
				character:SetSprintHeld(false)
			end
			changed = self:_setMovementState(character, state, "Walk") or changed
			state.ZeroStaminaAt = nil
			if changed then
				self:_pushState(player)
			end
			continue
		end

		local changed = false
		if character.IsSprintHeld then
			state.LastDrainAt = os.clock()
			if state.Current > 0.5 then
				changed = self:_setMovementState(character, state, self:_resolveMovementState(character, state)) or changed
				changed = self:_drainInternal(player, state, self.SprintDrainPerSecond * self.UpdateInterval) or changed
			else
				changed = self:_setMovementState(character, state, self:_resolveMovementState(character, state)) or changed
			end
		else
			state.ZeroStaminaAt = nil
			changed = self:_setMovementState(character, state, "Walk") or changed
			if (os.clock() - state.LastDrainAt) >= self.RegenDelay then
				local regenRate = self.BaseRegenPerSecond
				changed = self:_restoreInternal(player, state, regenRate * self.UpdateInterval) or changed
			end
		end

		if changed then
			self:_pushState(player)
		end
	end
end

function StaminaService:_setMovementState(character, state, movementState)
	movementState = movementState or "Walk"
	if state.MovementState == movementState then
		return false
	end

	state.MovementState = movementState
	if character then
		character:SetSprintMode(movementState)
	end
	return true
end

function StaminaService:_drainInternal(_player, state, amount)
	if amount <= 0 then
		return false
	end

	local newValue = math.max(0, state.Current - amount)
	if newValue == state.Current then
		return false
	end

	state.Current = newValue
	state.LastDrainAt = os.clock()
	return true
end

function StaminaService:_restoreInternal(_player, state, amount)
	if amount <= 0 then
		return false
	end

	local newValue = math.min(state.Max, state.Current + amount)
	if newValue == state.Current then
		return false
	end

	state.Current = newValue
	return true
end

function StaminaService:DrainStamina(player, amount, reason)
	local state = self:_ensureState(player)
	local changed = self:_drainInternal(player, state, amount or 0)
	if changed then
		self:_pushState(player)
		DebugLog:Log("Movement", string.format("[StaminaService] Drained %s by %.2f (%s)", player.Name, amount or 0, tostring(reason or "Unknown")))
	end
	return changed
end

function StaminaService:GetCurrentStamina(player)
	local state = self:_ensureState(player)
	return state.Current, state.Max
end

function StaminaService:HasSprintStamina(player)
	local state = self:_ensureState(player)
	return state.Current > 0.5
end

function StaminaService:ResetPlayer(player)
	local state = self:_ensureState(player)
	state.Current = state.Max
	state.LastDrainAt = 0
	local character = self.CharacterService:GetCharacterByPlayer(player)
	if character then
		character:SetSprintHeld(false)
	end
	self:_setMovementState(character, state, "Walk")
	state.ZeroStaminaAt = nil
	self:_pushState(player)
end

function StaminaService:RefreshPlayer(player)
	local state = self:_ensureState(player)
	local character = self.CharacterService:GetCharacterByPlayer(player)
	local movementState = self:_isMovementPhaseActive(character) and self:_resolveMovementState(character, state) or "Walk"
	self:_setMovementState(character, state, movementState)
	self:_pushState(player)
	return state.Current, state.Max
end

function StaminaService:_pushState(player)
	if not self.Remote then
		return
	end

	local state = self:_ensureState(player)
	self.Remote:FireClient(player, {
		Current = state.Current,
		Max = state.Max,
		MovementState = state.MovementState or "Walk",
		RunDurationBeforeFatigue = self.RunDurationBeforeFatigue,
	})
end

return StaminaService
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="102">
          <Properties>
            <string name="Name">StatusEffectService</string>
            <string name="Source"><![CDATA[local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local RemoteNames = require(ReplicatedStorage.Shared.Constants.RemoteNames)
local StatusEffectDefinitions = require(ReplicatedStorage.Shared.Data.StatusEffectDefinitions)
local StatusEffectId = require(ReplicatedStorage.Shared.Enums.StatusEffectId)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local StatusEffectService = {}
StatusEffectService.Name = "StatusEffectService"
StatusEffectService.Dependencies = {
	"RemoteRegistry",
	"CharacterService",
	"CombatService",
	"EntityService",
}

function StatusEffectService:Init(services)
	self.Services = services
	self.ActiveStatuses = {}
	self.UpdateInterval = 0.1
end

function StatusEffectService:Start()
	self.StatusEffectsChangedRemote = self.RemoteRegistry:GetRemote(RemoteNames.StatusEffectsChanged)

	task.spawn(function()
		self:_runLoop()
	end)

	DebugLog:Log("Status", "[StatusEffectService] Started")
end

function StatusEffectService:ApplyStatus(target, statusId, params)
	local definition = StatusEffectDefinitions[statusId]
	if not definition or not target then
		return nil
	end

	params = params or {}
	local targetType = self:_getTargetType(target)
	if not self:_statusAllowsTarget(definition, targetType) then
		return nil
	end

	local targetState = self:_getOrCreateTargetState(target)
	local instance = self:_getPrimaryStatusInstance(targetState, statusId)

	if definition.IsDamageOverTime then
		instance = self:_applyDotStatus(target, definition, params, instance)
	else
		instance = self:_applySimpleStatus(target, definition, params, instance)
	end

	self:_markTargetDirty(target)
	self:_refreshTargetGameplayState(target)

	if params.InterruptAbilities == true and targetType == "Entity" and self.EntityService then
		local actor = self:_resolveTargetActor(target)
		if actor then
			self.EntityService:InterruptEntityAbilities(actor, params.Source or statusId)
		end
	end

	DebugLog:Log("Status", string.format("[StatusEffectService] Applied %s to %s", statusId, self:_describeTarget(target)))
	return instance
end

function StatusEffectService:RemoveStatus(target, statusId)
	local targetState = self.ActiveStatuses[target]
	if not targetState then
		return false
	end

	local bucket = targetState.ById[statusId]
	if not bucket or #bucket == 0 then
		return false
	end

	targetState.ById[statusId] = nil
	for index = #targetState.List, 1, -1 do
		if targetState.List[index].Id == statusId then
			table.remove(targetState.List, index)
		end
	end

	self:_markTargetDirty(target)
	self:_refreshTargetGameplayState(target)
	return true
end

function StatusEffectService:ClearStatuses(target)
	if not self.ActiveStatuses[target] then
		return false
	end

	self.ActiveStatuses[target] = nil
	self:_syncTarget(target)
	self:_refreshTargetGameplayState(target)
	return true
end

function StatusEffectService:HasStatus(target, statusId)
	local targetState = self.ActiveStatuses[target]
	local bucket = targetState and targetState.ById[statusId]
	return bucket ~= nil and #bucket > 0
end

function StatusEffectService:GetModifier(target, modifierName)
	local targetState = self.ActiveStatuses[target]
	if not targetState then
		return 0
	end

	local total = 0
	for _, instance in ipairs(targetState.List) do
		local definition = StatusEffectDefinitions[instance.Id]
		local modifiers = definition and definition.Modifiers
		local valueSource = modifiers and modifiers[modifierName]
		if valueSource == "Magnitude" then
			total += instance.Magnitude or 0
		elseif type(valueSource) == "number" then
			total += valueSource
		end
	end

	return total
end

function StatusEffectService:HasFlag(target, flagName)
	local targetState = self.ActiveStatuses[target]
	if not targetState then
		return false
	end

	for _, instance in ipairs(targetState.List) do
		local definition = StatusEffectDefinitions[instance.Id]
		if definition and definition.Flags and definition.Flags[flagName] then
			return true
		end
	end

	return false
end

function StatusEffectService:CanUseAbilities(target)
	return not self:HasFlag(target, "BlocksAbilities") and not self:HasFlag(target, "Stunned")
end

function StatusEffectService:CanInteract(target)
	return not self:HasFlag(target, "BlocksInteraction") and not self:HasFlag(target, "Stunned")
end

function StatusEffectService:CanBeHealed(target)
	return not self:HasFlag(target, "BlocksHealing")
end

function StatusEffectService:GetSnapshotForPlayer(player)
	local targetState = self.ActiveStatuses[player]
	local snapshot = {}
	if not targetState then
		return snapshot
	end

	local now = os.clock()
	local grouped = {}
	for _, instance in ipairs(targetState.List) do
		local group = grouped[instance.Id]
		if not group then
			local definition = StatusEffectDefinitions[instance.Id]
			group = {
				Id = instance.Id,
				DisplayName = definition and definition.DisplayName or instance.Id,
				ShortLabel = definition and definition.ShortLabel or string.sub(instance.Id, 1, 3),
				IsBuff = definition and definition.IsBuff == true or false,
				Duration = 0,
				Stacks = 0,
				Tier = 1,
				Magnitude = 0,
				InstanceCount = 0,
			}
			grouped[instance.Id] = group
		end

		group.Duration = math.max(group.Duration, math.max(0, instance.ExpiresAt - now))
		group.Stacks = math.max(group.Stacks, instance.Stacks or 1)
		group.Tier = math.max(group.Tier, instance.Tier or 1)
		group.Magnitude += instance.Magnitude or 0
		group.InstanceCount += 1
	end

	for _, group in pairs(grouped) do
		if group.InstanceCount > 1 then
			group.Stacks = math.max(group.Stacks, group.InstanceCount)
		end
		table.insert(snapshot, group)
	end

	table.sort(snapshot, function(a, b)
		if a.IsBuff ~= b.IsBuff then
			return a.IsBuff and not b.IsBuff
		end
		return a.DisplayName < b.DisplayName
	end)

	return snapshot
end

function StatusEffectService:_applySimpleStatus(target, definition, params, existing)
	local duration = params.Duration or definition.DefaultDuration or 0
	local magnitude = params.Magnitude
	if magnitude == nil then
		magnitude = definition.DefaultMagnitude or 0
	end

	local now = os.clock()
	if definition.AllowMultipleInstances then
		local instance = {
			Id = definition.Id,
			AppliedAt = now,
			ExpiresAt = now + duration,
			Magnitude = magnitude,
			Stacks = params.Stacks or 1,
			Tier = params.Tier or definition.DefaultTier or 1,
			Source = params.Source,
		}

		self:_insertStatusInstance(target, instance)
		return instance
	end

	if existing then
		existing.ExpiresAt = now + duration
		existing.Magnitude = math.max(existing.Magnitude or 0, magnitude)
		existing.Stacks = math.max(existing.Stacks or 1, params.Stacks or 1)
		return existing
	end

	local instance = {
		Id = definition.Id,
		AppliedAt = now,
		ExpiresAt = now + duration,
		Magnitude = magnitude,
		Stacks = params.Stacks or 1,
		Tier = params.Tier or definition.DefaultTier or 1,
		Source = params.Source,
	}

	self:_insertStatusInstance(target, instance)
	return instance
end

function StatusEffectService:_applyDotStatus(target, definition, params, existing)
	local duration = params.Duration or definition.DefaultDuration or 0
	local tier = params.Tier or definition.DefaultTier or 1
	local maxTier = definition.MaxTier or tier
	local now = os.clock()

	if existing then
		local remainingDuration = math.max(0, existing.ExpiresAt - now)
		local newDuration = remainingDuration + duration
		local newTier = math.max(existing.Tier or 1, tier)

		while newDuration > 15 and newTier < maxTier do
			newDuration *= 0.5
			newTier += 1
		end

		existing.ExpiresAt = now + newDuration
		existing.Tier = newTier
		existing.NextTickAt = now + (definition.TickInterval or 1)

		if definition.Id == StatusEffectId.Bleed and newTier >= maxTier and newDuration > 15 then
			self:RemoveStatus(target, StatusEffectId.Bleed)
			return self:ApplyStatus(target, StatusEffectId.Hemorrhaged, {
				Duration = newDuration,
				Tier = 1,
				Source = params.Source,
			})
		end

		return existing
	end

	local instance = {
		Id = definition.Id,
		AppliedAt = now,
		ExpiresAt = now + duration,
		Magnitude = params.Magnitude or definition.DefaultMagnitude or 0,
		Stacks = 1,
		Tier = tier,
		Source = params.Source,
		NextTickAt = now + (definition.TickInterval or 1),
	}

	self:_insertStatusInstance(target, instance)
	return instance
end

function StatusEffectService:_insertStatusInstance(target, instance)
	local targetState = self:_getOrCreateTargetState(target)
	local bucket = targetState.ById[instance.Id]
	if not bucket then
		bucket = {}
		targetState.ById[instance.Id] = bucket
	end
	table.insert(bucket, instance)
	table.insert(targetState.List, instance)
end

function StatusEffectService:_getPrimaryStatusInstance(targetState, statusId)
	local bucket = targetState and targetState.ById[statusId]
	if not bucket or #bucket == 0 then
		return nil
	end

	return bucket[1]
end

function StatusEffectService:_runLoop()
	while true do
		self:_updateStatuses()
		task.wait(self.UpdateInterval)
	end
end

function StatusEffectService:_updateStatuses()
	local now = os.clock()

	for target, targetState in pairs(self.ActiveStatuses) do
		local changed = false

		for index = #targetState.List, 1, -1 do
			local instance = targetState.List[index]
			local definition = StatusEffectDefinitions[instance.Id]

			if definition and definition.IsDamageOverTime and now >= (instance.NextTickAt or 0) then
				self:_tickDotStatus(target, instance, definition)
				instance.NextTickAt = now + (definition.TickInterval or 1)
				changed = true
			end

			if instance.ExpiresAt <= now then
				local bucket = targetState.ById[instance.Id]
				if bucket then
					for bucketIndex = #bucket, 1, -1 do
						if bucket[bucketIndex] == instance then
							table.remove(bucket, bucketIndex)
							break
						end
					end

					if #bucket == 0 then
						targetState.ById[instance.Id] = nil
					end
				end
				table.remove(targetState.List, index)
				changed = true

				if instance.Id == StatusEffectId.Hemorrhaged then
					self:ApplyStatus(target, StatusEffectId.Broken, {
						Duration = 4,
						Source = "HemorrhagedExpire",
					})
				end
			end
		end

		if #targetState.List == 0 then
			self.ActiveStatuses[target] = nil
			changed = true
		end

		if changed then
			self:_refreshTargetGameplayState(target)
			self:_syncTarget(target)
		end
	end
end

function StatusEffectService:_tickDotStatus(target, instance, definition)
	local actor = self:_resolveTargetActor(target)
	if not actor then
		return
	end

	if instance.Id == StatusEffectId.Bleed then
		local tickDamage = 1
		if instance.Tier >= 3 then
			tickDamage *= 2
		end

		actor:ApplyDamage(tickDamage, {
			IsStatusEffect = true,
			CanFatal = false,
			MinimumHealth = 10,
			IgnoreInvincible = false,
		})
	elseif instance.Id == StatusEffectId.Poison then
		local applied = actor:ApplyDamage(1, {
			IsStatusEffect = true,
			CanFatal = false,
			MinimumHealth = 1,
			IgnoreInvincible = false,
		})
		if applied then
			self:ApplyStatus(target, StatusEffectId.Fragility, {
				Duration = 1,
				Magnitude = math.min(0.10 + ((instance.Tier - 1) * 0.05), 0.35),
				Source = "PoisonTick",
			})
		end
	elseif instance.Id == StatusEffectId.Hemorrhaged then
		actor:ApplyDamage(actor.MaxHealth * 0.01, {
			IsStatusEffect = true,
			CanFatal = true,
			IgnoreInvincible = false,
		})
	end
end

function StatusEffectService:_markTargetDirty(target)
	self:_syncTarget(target)
end

function StatusEffectService:_syncTarget(target)
	local player = self:_resolvePlayerForSync(target)
	if not player or not self.StatusEffectsChangedRemote then
		return
	end

	self.StatusEffectsChangedRemote:FireClient(player, self:GetSnapshotForPlayer(player))
end

function StatusEffectService:_refreshTargetGameplayState(target)
	local actor = self:_resolveTargetActor(target)
	if not actor then
		return
	end

	if actor.RefreshFromStatusEffects then
		actor:RefreshFromStatusEffects()
	end

	local player = self:_resolvePlayerForSync(target)
	if player and self.CombatService and (self:HasFlag(target, "Stunned") or self:HasFlag(target, "BlocksAbilities")) then
		self.CombatService:ForceStopAim(player)
	end
end

function StatusEffectService:_resolvePlayerForSync(target)
	if typeof(target) == "Instance" and target:IsA("Player") then
		return target
	elseif type(target) == "table" and target.Player then
		return target.Player
	end

	return nil
end

function StatusEffectService:_resolveTargetActor(target)
	if typeof(target) == "Instance" and target:IsA("Player") then
		return self.CharacterService:GetCharacterByPlayer(target)
	end

	return target
end

function StatusEffectService:_getOrCreateTargetState(target)
	if not self.ActiveStatuses[target] then
		self.ActiveStatuses[target] = {
			List = {},
			ById = {},
		}
	end

	return self.ActiveStatuses[target]
end

function StatusEffectService:_getTargetType(target)
	local actor = self:_resolveTargetActor(target)
	if not actor then
		return nil
	end

	if actor.Player then
		return "Remnant"
	end

	return "Entity"
end

function StatusEffectService:_statusAllowsTarget(definition, targetType)
	if not definition.AllowedTargets or not targetType then
		return true
	end

	for _, allowedTarget in ipairs(definition.AllowedTargets) do
		if allowedTarget == targetType then
			return true
		end
	end

	return false
end

function StatusEffectService:_describeTarget(target)
	if typeof(target) == "Instance" then
		return target.Name
	elseif type(target) == "table" then
		return target.DisplayName or target.Id or "TableTarget"
	end

	return "Unknown"
end

return StatusEffectService
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="103">
          <Properties>
            <string name="Name">StimulusService</string>
            <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")

local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local StimulusService = {}
StimulusService.Name = "StimulusService"
StimulusService.Dependencies = {
	"RoundManager",
	"CharacterService",
}

function StimulusService:Init(services)
	self.Services = services
	self.Stimuli = {}
	self.ActiveStimuliByKey = {}
	self.LastMovementStimulusByPlayer = {}
	self.NextStimulusId = 0

	self.SampleInterval = 0.4
	self.MinMoveDistance = 6
	self.DefaultLifetime = 5
	self.DefaultStimulusRadius = 140
	self.BaseFollowDistance = 10
	self.SprintMoveDistanceMultiplier = 0.75
	self.SprintStrengthMultiplier = 1.45
	self.SprintLifetimeMultiplier = 1.2
	self.SprintFollowDistanceMultiplier = 1.35
	self.CrouchMoveDistanceMultiplier = 1.75
	self.CrouchStrengthMultiplier = 0.35
	self.CrouchLifetimeMultiplier = 0.6
	self.CrouchFollowDistanceMultiplier = 0.65
end

function StimulusService:Start()
	task.spawn(function()
		self:_runLoop()
	end)

	DebugLog:Log("Entity", "[StimulusService] Started")
end

function StimulusService:_runLoop()
	while true do
		self:_cleanupExpiredStimuli()
		self:_sampleMovementNoise()
		task.wait(self.SampleInterval)
	end
end

function StimulusService:_cleanupExpiredStimuli()
	local now = os.clock()
	for index = #self.Stimuli, 1, -1 do
		local stimulus = self.Stimuli[index]
		if stimulus.ExpiresAt <= now then
			table.remove(self.Stimuli, index)
			if stimulus.Key and self.ActiveStimuliByKey[stimulus.Key] == stimulus then
				self.ActiveStimuliByKey[stimulus.Key] = nil
			end
		end
	end
end

function StimulusService:_sampleMovementNoise()
	local roundManager = self.RoundManager
	local characterService = self.CharacterService
	if not roundManager or not characterService or not roundManager:IsReceptionActive() then
		return
	end

	for _, player in ipairs(roundManager:GetActivePlayers()) do
		local roundState = roundManager:GetRoundState(player)
		if roundState and roundState.IsAlive then
			local character = characterService:GetCharacterByPlayer(player)
			if character and character.RootPart then
				self:_sampleCharacterMovementNoise(player, character)
			end
		end
	end
end

function StimulusService:_sampleCharacterMovementNoise(player, character)
	local position = character.RootPart.Position
	local lastStimulus = self.LastMovementStimulusByPlayer[player]
	local isCrouching = character.IsCrouching == true
	local isSprinting = character.IsSprinting == true
	local isRunning = character.IsRunning == true
	local moveDistanceMultiplier = 1
	local strengthMultiplier = 1
	local lifetimeMultiplier = 1
	local followDistanceMultiplier = 1
	local confidence = 0.55

	if isSprinting or isRunning then
		moveDistanceMultiplier *= self.SprintMoveDistanceMultiplier
		strengthMultiplier *= self.SprintStrengthMultiplier
		lifetimeMultiplier *= self.SprintLifetimeMultiplier
		followDistanceMultiplier *= self.SprintFollowDistanceMultiplier
		confidence = 0.8
	end

	if isCrouching then
		moveDistanceMultiplier *= self.CrouchMoveDistanceMultiplier
		strengthMultiplier *= self.CrouchStrengthMultiplier
		lifetimeMultiplier *= self.CrouchLifetimeMultiplier
		followDistanceMultiplier *= self.CrouchFollowDistanceMultiplier
		confidence *= 0.55
	end

	local minMoveDistance = self.MinMoveDistance * moveDistanceMultiplier
	if lastStimulus and (position - lastStimulus.Position).Magnitude < minMoveDistance then
		return
	end

	local direction = Vector3.zero
	if lastStimulus then
		local delta = position - lastStimulus.Position
		if delta.Magnitude > 0 then
			direction = delta.Unit
		end
	end

	local stimulus = self:PushStimulus({
		Key = string.format("MovementNoise:%d", player.UserId),
		Type = "MovementNoise",
		Position = position,
		Direction = direction,
		SourcePlayer = player,
		Strength = strengthMultiplier,
		Confidence = confidence,
		Duration = self.DefaultLifetime * lifetimeMultiplier,
		Metadata = {
			FollowDistance = self.BaseFollowDistance * followDistanceMultiplier,
			IsSprinting = isSprinting == true,
			IsRunning = isRunning == true,
			IsCrouching = isCrouching == true,
		},
		Tags = {
			Movement = true,
			Noise = true,
		},
	})

	self.LastMovementStimulusByPlayer[player] = stimulus
end

function StimulusService:PushStimulus(stimulus)
	if type(stimulus) ~= "table" or not stimulus.Position then
		return nil
	end

	local now = os.clock()
	local key = stimulus.Key or self:_makeStimulusKey(stimulus)
	local existing = key and self.ActiveStimuliByKey[key] or nil
	local duration = math.max(0.1, stimulus.Duration or ((stimulus.ExpiresAt and (stimulus.ExpiresAt - now)) or self.DefaultLifetime))
	local target = existing

	if not target then
		self.NextStimulusId += 1
		target = {
			Id = self.NextStimulusId,
			Key = key,
			CreatedAt = now,
		}
		table.insert(self.Stimuli, target)
		if key then
			self.ActiveStimuliByKey[key] = target
		end
	end

	target.Type = stimulus.Type or "Unknown"
	target.Position = stimulus.Position
	target.Direction = stimulus.Direction
	target.SourcePlayer = stimulus.SourcePlayer
	target.SourceEntity = stimulus.SourceEntity
	target.Strength = stimulus.Strength or 1
	target.Confidence = stimulus.Confidence or 0.5
	target.LastUpdatedAt = now
	target.ExpiresAt = now + duration
	target.Tags = stimulus.Tags
	target.Metadata = stimulus.Metadata

	return target
end

function StimulusService:_makeStimulusKey(stimulus)
	local typeName = tostring(stimulus.Type or "Unknown")
	if stimulus.SourcePlayer then
		return string.format("%s:Player:%d", typeName, stimulus.SourcePlayer.UserId)
	end

	if stimulus.SourceEntity then
		return string.format("%s:Entity:%s", typeName, tostring(stimulus.SourceEntity.Id or stimulus.SourceEntity.DisplayName or "Unknown"))
	end

	return nil
end

function StimulusService:GetStimuliNearPosition(position, radius, queryOptions)
	if not position then
		return {}
	end

	queryOptions = queryOptions or {}
	radius = radius or self.DefaultStimulusRadius
	local rankedStimuli = {}

	for _, stimulus in ipairs(self.Stimuli) do
		if self:_stimulusMatchesQuery(stimulus, queryOptions) then
			local offset = stimulus.Position - position
			local distance = offset.Magnitude
			if distance <= radius then
				local scoredStimulus = self:_cloneStimulusForQuery(stimulus)
				scoredStimulus.Distance = distance
				scoredStimulus.Score = self:_scoreStimulus(position, radius, scoredStimulus, queryOptions)
				table.insert(rankedStimuli, scoredStimulus)
			end
		end
	end

	table.sort(rankedStimuli, function(a, b)
		if a.Score == b.Score then
			return (a.Distance or math.huge) < (b.Distance or math.huge)
		end
		return a.Score > b.Score
	end)

	return rankedStimuli
end

function StimulusService:GetBestStimulusForEntity(entity, queryOptions)
	if not entity then
		return nil
	end

	queryOptions = queryOptions or {}
	local position = entity:GetPosition()
	local radius = queryOptions.Radius or (entity.DetectionRadius * (entity.StimulusInvestigationRadiusMultiplier or 2.5))
	local stimuli = self:GetStimuliNearPosition(position, radius, queryOptions)
	return stimuli[1]
end

function StimulusService:_stimulusMatchesQuery(stimulus, queryOptions)
	local allowedTypes = queryOptions.Types
	if allowedTypes and allowedTypes[stimulus.Type] ~= true then
		return false
	end

	local sourcePlayer = queryOptions.SourcePlayer
	if sourcePlayer and stimulus.SourcePlayer ~= sourcePlayer then
		return false
	end

	local blockedKeys = queryOptions.ExcludeKeys
	if blockedKeys and stimulus.Key and blockedKeys[stimulus.Key] then
		return false
	end

	return true
end

function StimulusService:_cloneStimulusForQuery(stimulus)
	local clone = table.clone(stimulus)
	local metadata = clone.Metadata or {}
	local followDistance = metadata.FollowDistance or self.BaseFollowDistance
	if clone.Direction and clone.Direction.Magnitude > 0 then
		clone.Destination = clone.Position + (clone.Direction.Unit * followDistance)
	else
		clone.Destination = clone.Position
	end
	return clone
end

function StimulusService:_scoreStimulus(position, radius, stimulus, queryOptions)
	local now = os.clock()
	local lifetime = math.max(0.1, (stimulus.ExpiresAt or now) - (stimulus.CreatedAt or now))
	local remainingLifetime = math.max(0, (stimulus.ExpiresAt or now) - now)
	local ageAlpha = math.clamp(remainingLifetime / lifetime, 0, 1)
	local score = (ageAlpha * 100) + math.max(0, radius - (stimulus.Distance or 0))
	score += (stimulus.Strength or 1) * 16
	score += (stimulus.Confidence or 0) * 24

	if queryOptions.WeightByDirection and stimulus.Direction and stimulus.Direction.Magnitude > 0 then
		local toStimulus = (stimulus.Position - position)
		if toStimulus.Magnitude > 0 then
			score += math.max(0, stimulus.Direction.Unit:Dot(toStimulus.Unit)) * 12
		end
	end

	if queryOptions.PreferPlayer and stimulus.SourcePlayer == queryOptions.PreferPlayer then
		score += 30
	end

	return score
end

function StimulusService:Reset()
	table.clear(self.Stimuli)
	table.clear(self.ActiveStimuliByKey)
	table.clear(self.LastMovementStimulusByPlayer)
end

return StimulusService
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="104">
          <Properties>
            <string name="Name">StruggleService</string>
            <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")

local StatusEffectId = require(ReplicatedStorage.Shared.Enums.StatusEffectId)
local QTEType = require(ReplicatedStorage.Shared.Enums.QTEType)
local InteractableType = require(ReplicatedStorage.Shared.Enums.InteractableType)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local StruggleService = {}
StruggleService.Name = "StruggleService"
StruggleService.Dependencies = {
	"QTEService",
	"CharacterService",
	"StatusEffectService",
	"InteractionService",
	"EntityService",
}

function StruggleService:Init(services)
	self.Services = services
	self.ActiveStruggles = {}
	self.UpdateInterval = 0.1
end

function StruggleService:Start()
	task.spawn(function()
		self:_runLoop()
	end)

	DebugLog:Log("Interaction", "[StruggleService] Started")
end

function StruggleService:BeginStruggle(entity, targetPlayer, params)
	if not entity or not targetPlayer then
		return false
	end

	local targetCharacter = self.CharacterService:GetCharacterByPlayer(targetPlayer)
	if not targetCharacter or not targetCharacter:IsAlive() then
		return false
	end

	local canBegin, existing = self:CanBeginStruggle(entity, targetPlayer)
	if not canBegin then
		return false
	end

	if existing then
		self:_endStruggle(targetPlayer, "Replaced")
	end

	local now = os.clock()
	local duration = params.Duration or 6
	local qteConfig = params.QTE or {}
	local struggle = {
		Entity = entity,
		TargetPlayer = targetPlayer,
		StartedAt = now,
		EndsAt = now + duration,
		Progress = 0,
		MaxProgress = params.MaxProgress or 1,
		ProgressPerPress = params.ProgressPerPress or 0.075,
		DamagePerSecond = params.DamagePerSecond or 5,
		HealPercentPerSecond = params.HealPercentPerSecond or 0.02,
		NextTickAt = now + 1,
		EntityRecoverStunDuration = params.EntityRecoverStunDuration or 1,
		TargetStatusId = params.TargetStatusId or StatusEffectId.Stunned,
		PeelDuration = params.PeelDuration or 1.2,
		PeelRange = params.PeelRange or 10,
		PeelProgress = 0,
		LungeOriginCFrame = params.LungeOriginCFrame,
		ReturnEntityOnBreakFree = params.ReturnEntityOnBreakFree == true,
	}

	self.ActiveStruggles[targetPlayer] = struggle
	self:_setGrabDebugMarker(targetPlayer, entity)

	if self.InteractionService and self.InteractionService:IsInteracting(targetPlayer) then
		self.InteractionService:InterruptInteraction(targetPlayer, "Struggle")
	end

	local statusService = self.StatusEffectService
	if statusService then
		statusService:ApplyStatus(targetPlayer, struggle.TargetStatusId, {
			Duration = duration,
			Source = entity.DisplayName,
		})
		statusService:ApplyStatus(entity, StatusEffectId.Stunned, {
			Duration = duration,
			Source = "BlindHungerChannel",
		})
	end

	self.QTEService:StartSession(targetPlayer, {
		Type = qteConfig.Type or QTEType.KeyMash,
		Duration = duration,
		Prompt = qteConfig.Prompt or "Mash Space to struggle free",
		SubPrompt = qteConfig.SubPrompt or "Break free before Jiangshi drains your Qi",
		RequiredKey = qteConfig.RequiredKey or "Space",
		Keys = qteConfig.Keys,
		Progress = 0,
		MaxProgress = struggle.MaxProgress,
		ProgressPerPress = qteConfig.ProgressPerPress or struggle.ProgressPerPress,
		WrongPenalty = qteConfig.WrongPenalty or 0.05,
		TargetDistance = qteConfig.TargetDistance,
		MinSliceDelta = qteConfig.MinSliceDelta,
		DialAngle = qteConfig.DialAngle,
		DialSpeed = qteConfig.DialSpeed,
		DialDirection = qteConfig.DialDirection,
		SuccessAngle = qteConfig.SuccessAngle,
		SuccessAngleSize = qteConfig.SuccessAngleSize,
		OnProgress = function(_, session)
			struggle.Progress = session.Progress
		end,
		OnSuccess = function(player)
			self:_breakFree(player, struggle)
		end,
		OnFail = function(player, _, reason)
			self:_endStruggle(player, reason)
		end,
	})

	DebugLog:Log("Interaction", string.format("[StruggleService] %s began struggle on %s", entity.DisplayName, targetPlayer.Name))
	return true
end

function StruggleService:CanBeginStruggle(entity, targetPlayer)
	if not entity or not targetPlayer then
		return false, nil
	end

	local existing = self.ActiveStruggles[targetPlayer]
	if not existing then
		return true, nil
	end

	if existing.Entity == entity then
		return true, existing
	end

	local incomingPriority = tonumber(entity.StarRating) or tonumber(entity.Weight) or 0
	local existingEntity = existing.Entity
	local existingPriority = existingEntity and (tonumber(existingEntity.StarRating) or tonumber(existingEntity.Weight)) or 0

	if incomingPriority > existingPriority then
		return true, existing
	end

	return false, existing
end

function StruggleService:IsPlayerStruggling(player)
	return self.ActiveStruggles[player] ~= nil
end

function StruggleService:GetPeelInteractable(helperPlayer)
	local helperCharacter = self.CharacterService:GetCharacterByPlayer(helperPlayer)
	if not helperCharacter or not helperCharacter.RootPart then
		return nil
	end

	local helperPosition = helperCharacter.RootPart.Position
	for victimPlayer, struggle in pairs(self.ActiveStruggles) do
		if victimPlayer ~= helperPlayer then
			local victimCharacter = self.CharacterService:GetCharacterByPlayer(victimPlayer)
			if victimCharacter and victimCharacter.RootPart and victimCharacter:IsAlive() then
				local distance = (victimCharacter.RootPart.Position - helperPosition).Magnitude
				if distance <= struggle.PeelRange then
					return {
						Type = InteractableType.StrugglePeel,
						DisplayName = string.format("Peel %s Off", struggle.Entity.DisplayName),
						Instance = victimCharacter.RootPart,
						Progress = struggle.PeelProgress,
						MaxProgress = 1,
						ChargeRate = 1 / struggle.PeelDuration,
						StruggleTargetPlayer = victimPlayer,
					}
				end
			end
		end
	end

	return nil
end

function StruggleService:ProgressPeel(helperPlayer, interactable, amount)
	if not interactable or interactable.Type ~= InteractableType.StrugglePeel then
		return false, false
	end

	local struggle = self.ActiveStruggles[interactable.StruggleTargetPlayer]
	if not struggle then
		return false, true
	end

	local helperCharacter = self.CharacterService:GetCharacterByPlayer(helperPlayer)
	local victimCharacter = self.CharacterService:GetCharacterByPlayer(interactable.StruggleTargetPlayer)
	if not helperCharacter or not helperCharacter.RootPart or not victimCharacter or not victimCharacter.RootPart then
		return false, true
	end

	local distance = (victimCharacter.RootPart.Position - helperCharacter.RootPart.Position).Magnitude
	if distance > struggle.PeelRange then
		return false, true
	end

	struggle.PeelProgress = math.clamp((struggle.PeelProgress or 0) + amount, 0, 1)
	if struggle.PeelProgress >= 1 then
		self:_peelFree(interactable.StruggleTargetPlayer, struggle, helperPlayer)
		return true, true
	end

	return true, false
end

function StruggleService:InterruptStrugglesForEntity(entity, reason)
	if not entity then
		return 0
	end

	local interruptedCount = 0
	for player, struggle in pairs(self.ActiveStruggles) do
		if struggle.Entity == entity then
			self:_endStruggle(player, reason or "Interrupted", {
				PreserveEntityStun = true,
			})
			interruptedCount += 1
		end
	end

	return interruptedCount
end

function StruggleService:_runLoop()
	while true do
		self:_updateStruggles()
		task.wait(self.UpdateInterval)
	end
end

function StruggleService:_updateStruggles()
	local now = os.clock()

	for player, struggle in pairs(self.ActiveStruggles) do
		local targetCharacter = self.CharacterService:GetCharacterByPlayer(player)
		if not targetCharacter or not targetCharacter:IsAlive() then
			self:_endStruggle(player, "TargetLost")
			continue
		end

		if not struggle.Entity or not struggle.Entity.IsActive or struggle.Entity.Health <= 0 then
			self:_endStruggle(player, "EntityLost")
			continue
		end

		if now >= struggle.NextTickAt then
			targetCharacter:ApplyDamage(struggle.DamagePerSecond)
			struggle.Entity:HealPercent(struggle.HealPercentPerSecond)
			if self.EntityService then
				self.EntityService:_handleTargetDowned(struggle.Entity, player, targetCharacter)
			end
			struggle.NextTickAt += 1
		end

		if now >= struggle.EndsAt then
			self:_endStruggle(player, "Expired")
		end
	end
end

function StruggleService:_breakFree(player, struggle)
	local statusService = self.StatusEffectService
	if statusService then
		statusService:RemoveStatus(player, struggle.TargetStatusId)
		statusService:RemoveStatus(struggle.Entity, StatusEffectId.Stunned)
		statusService:ApplyStatus(struggle.Entity, StatusEffectId.Stunned, {
			Duration = struggle.EntityRecoverStunDuration,
			Source = "BlindHungerBreakFree",
		})
	end

	self:_returnEntityAfterBreakFree(struggle)
	self.ActiveStruggles[player] = nil
	self:_clearGrabDebugMarker(player)
	self.QTEService:StopSession(player, "Escaped")

	DebugLog:Log("Interaction", string.format("[StruggleService] %s escaped %s", player.Name, struggle.Entity.DisplayName))
end

function StruggleService:_peelFree(player, struggle, helperPlayer)
	local statusService = self.StatusEffectService
	if statusService then
		statusService:RemoveStatus(player, struggle.TargetStatusId)
		statusService:RemoveStatus(struggle.Entity, StatusEffectId.Stunned)
		statusService:ApplyStatus(struggle.Entity, StatusEffectId.Stunned, {
			Duration = struggle.EntityRecoverStunDuration,
			Source = "BlindHungerPeeled",
		})
	end

	self:_returnEntityAfterBreakFree(struggle)
	self.ActiveStruggles[player] = nil
	self:_clearGrabDebugMarker(player)
	self.QTEService:StopSession(player, "Peeled")

	DebugLog:Log("Interaction", string.format("[StruggleService] %s peeled %s off %s", helperPlayer and helperPlayer.Name or "Unknown", struggle.Entity.DisplayName, player.Name))
end

function StruggleService:_endStruggle(player, reason, options)
	local struggle = self.ActiveStruggles[player]
	if not struggle then
		return
	end

	options = options or {}

	local statusService = self.StatusEffectService
	if statusService then
		statusService:RemoveStatus(player, struggle.TargetStatusId)
		if not options.PreserveEntityStun then
			statusService:RemoveStatus(struggle.Entity, StatusEffectId.Stunned)
		end
	end

	self.ActiveStruggles[player] = nil
	self:_clearGrabDebugMarker(player)
	self.QTEService:StopSession(player, reason or "Ended")
end

function StruggleService:_returnEntityAfterBreakFree(struggle)
	if not struggle or not struggle.ReturnEntityOnBreakFree then
		return
	end

	local entity = struggle.Entity
	if not entity or not entity.RootPart or not struggle.LungeOriginCFrame then
		return
	end

	entity.RootPart.CFrame = struggle.LungeOriginCFrame
end

function StruggleService:_setGrabDebugMarker(player, entity)
	local character = self.CharacterService:GetCharacterByPlayer(player)
	if not character or not character.Model then
		return
	end

	character.Model:SetAttribute("DebugIsGrabbed", true)
	character.Model:SetAttribute("DebugGrabbedBy", entity and entity.DisplayName or "Entity")

	local existing = character.Model:FindFirstChild("StruggleDebugHighlight")
	if existing then
		existing:Destroy()
	end

	local highlight = Instance.new("Highlight")
	highlight.Name = "StruggleDebugHighlight"
	highlight.FillColor = Color3.fromRGB(214, 92, 92)
	highlight.FillTransparency = 0.55
	highlight.OutlineColor = Color3.fromRGB(255, 208, 122)
	highlight.OutlineTransparency = 0.1
	highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
	highlight.Parent = character.Model
end

function StruggleService:_clearGrabDebugMarker(player)
	local character = self.CharacterService:GetCharacterByPlayer(player)
	if not character or not character.Model then
		return
	end

	character.Model:SetAttribute("DebugIsGrabbed", nil)
	character.Model:SetAttribute("DebugGrabbedBy", nil)

	local existing = character.Model:FindFirstChild("StruggleDebugHighlight")
	if existing then
		existing:Destroy()
	end
end

return StruggleService
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="105">
          <Properties>
            <string name="Name">VotingService</string>
            <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")

local EntityDefinitions = require(ReplicatedStorage.Shared.Data.EntityDefinitions)
local RemoteNames = require(ReplicatedStorage.Shared.Constants.RemoteNames)
local RoundConfig = require(ReplicatedStorage.Shared.Data.RoundConfig)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local VotingService = {}
VotingService.Name = "VotingService"
VotingService.Dependencies = {
	"RemoteRegistry",
	"PlayerService",
}

local function _shallowCopyArray(values)
	local copy = {}
	for index, value in ipairs(values) do
		copy[index] = value
	end
	return copy
end

function VotingService:Init()
	self.RequestVoteRemote = nil
	self.StateRemote = nil
	self.PlayCutsceneRemote = nil
	self.WeightTarget = RoundConfig.VotingWeightTarget or 5
	self.RoundDuration = RoundConfig.VotingRoundDuration or RoundConfig.VotingDuration or 10
	self.AllVotesGraceDuration = RoundConfig.VotingAllVotesGraceDuration or 3
	self.CardCount = RoundConfig.VotingCardCount or 5
	self.CurrentState = nil
	self.LastDraftResult = {
		SelectedEntityIds = {},
		TotalWeight = 0,
		TotalTimerValue = 0,
		ReceptionDuration = RoundConfig.ReceptionDuration or 90,
	}
	self.Random = Random.new()
	self.EntityPool = {}
end

function VotingService:Start()
	self.RequestVoteRemote = self.RemoteRegistry:GetRemote(RemoteNames.RequestVote)
	self.StateRemote = self.RemoteRegistry:GetRemote(RemoteNames.VotingStateChanged)
	self.PlayCutsceneRemote = self.RemoteRegistry:GetRemote(RemoteNames.PlayCutscene)
	self.EntityPool = self:_buildEntityPool()

	if self.RequestVoteRemote then
		self.RequestVoteRemote.OnServerEvent:Connect(function(player, payload)
			self:_handleVoteRequest(player, payload)
		end)
	end

	DebugLog:Log("Voting", "[VotingService] Started")
end

function VotingService:_buildEntityPool()
	local pool = {}
	local seen = {}

	for _, definition in pairs(EntityDefinitions) do
		local entityId = definition.Id
		if entityId and not seen[entityId] and definition.CanAppearInVoting ~= false then
			seen[entityId] = true
			table.insert(pool, {
				Id = entityId,
				DisplayName = definition.DisplayName or entityId,
				DirectorWeight = definition.DirectorWeight or definition.Weight or definition.StarRating or 1,
				StarRating = definition.StarRating or definition.DirectorWeight or definition.Weight or 1,
				TimerValue = definition.TimerValue or 0,
			})
		end
	end

	table.sort(pool, function(a, b)
		if a.DirectorWeight == b.DirectorWeight then
			return a.DisplayName < b.DisplayName
		end
		return a.DirectorWeight < b.DirectorWeight
	end)

	return pool
end

function VotingService:ResetDraft()
	self.CurrentState = nil
	self.LastDraftResult = {
		SelectedEntityIds = {},
		TotalWeight = 0,
		TotalTimerValue = 0,
		ReceptionDuration = RoundConfig.ReceptionDuration or 90,
	}
	self:_broadcastState()
end

function VotingService:GetRoundDuration()
	return self.RoundDuration
end

function VotingService:GetLastDraftResult()
	return self.LastDraftResult
end

function VotingService:RunDraft()
	local selectedEntityIds = {}
	local selectedSet = {}
	local totalWeight = 0
	local totalTimerValue = 0
	local roundIndex = 0

	while totalWeight < self.WeightTarget do
		local remainingWeight = self.WeightTarget - totalWeight
		local options = self:_buildOptions(remainingWeight, selectedSet)
		if #options <= 0 then
			break
		end

		roundIndex += 1
		local winner = self:_runVotingRound(roundIndex, selectedEntityIds, totalWeight, totalTimerValue, options)
		if not winner then
			break
		end

		table.insert(selectedEntityIds, winner.Id)
		selectedSet[winner.Id] = true
		totalWeight += winner.DirectorWeight
		totalTimerValue += winner.TimerValue
	end

	self.CurrentState = nil
	self.LastDraftResult = {
		SelectedEntityIds = _shallowCopyArray(selectedEntityIds),
		TotalWeight = totalWeight,
		TotalTimerValue = totalTimerValue,
		ReceptionDuration = (RoundConfig.ReceptionDuration or 90) + totalTimerValue,
	}
	self:_broadcastState()

	DebugLog:Log("Voting", string.format(
		"[VotingService] Draft complete | weight=%d | timerBonus=%d | lineup=%s",
		totalWeight,
		totalTimerValue,
		table.concat(selectedEntityIds, ", ")
	))

	return self.LastDraftResult
end

function VotingService:_buildOptions(remainingWeight, selectedSet)
	local validOptions = {}

	for _, entry in ipairs(self.EntityPool) do
		if entry.DirectorWeight <= remainingWeight and not selectedSet[entry.Id] then
			table.insert(validOptions, entry)
		end
	end

	if #validOptions <= self.CardCount then
		return validOptions
	end

	local shuffled = _shallowCopyArray(validOptions)
	for index = #shuffled, 2, -1 do
		local swapIndex = self.Random:NextInteger(1, index)
		shuffled[index], shuffled[swapIndex] = shuffled[swapIndex], shuffled[index]
	end

	local options = {}
	for index = 1, math.min(self.CardCount, #shuffled) do
		table.insert(options, shuffled[index])
	end

	table.sort(options, function(a, b)
		if a.DirectorWeight == b.DirectorWeight then
			return a.DisplayName < b.DisplayName
		end
		return a.DirectorWeight < b.DirectorWeight
	end)

	return options
end

function VotingService:_getEligiblePlayers()
	return self.PlayerService:GetPlayers()
end

function VotingService:_runVotingRound(roundIndex, selectedEntityIds, totalWeight, totalTimerValue, options)
	self.CurrentState = {
		IsActive = true,
		RoundIndex = roundIndex,
		SecondsLeft = self.RoundDuration,
		WeightTarget = self.WeightTarget,
		TotalWeight = totalWeight,
		TotalTimerValue = totalTimerValue,
		SelectedEntityIds = _shallowCopyArray(selectedEntityIds),
		Options = options,
		VotesByPlayer = {},
		AllVotesShortened = false,
	}

	local deadline = os.clock() + self.RoundDuration
	local shortened = false
	self:_playVotingCameraCue(roundIndex)
	self:_broadcastState()

	while true do
		local secondsLeft = math.max(0, math.ceil(deadline - os.clock()))
		if secondsLeft ~= self.CurrentState.SecondsLeft then
			self.CurrentState.SecondsLeft = secondsLeft
			self:_broadcastState()
		end

		if secondsLeft <= 0 then
			break
		end

		if not shortened and self:_haveAllEligiblePlayersVoted() then
			deadline = math.min(deadline, os.clock() + self.AllVotesGraceDuration)
			shortened = true
			self.CurrentState.AllVotesShortened = true
			self:_broadcastState()
		end

		task.wait(0.1)
	end

	local winner = self:_resolveRoundWinner(options)
	if winner then
		DebugLog:Log("Voting", string.format("[VotingService] Round %d winner: %s", roundIndex, winner.Id))
	end

	return winner
end

function VotingService:_playVotingCameraCue(roundIndex)
	if not self.PlayCutsceneRemote then
		return
	end

	self.PlayCutsceneRemote:FireAllClients({
		Type = "FocusTarget",
		Sequence = "VotingRoundStart",
		RoundIndex = roundIndex,
		TargetNames = {
			"VotingCameraFocus",
			"ProjectorScreen",
			"Projector",
		},
		Duration = 1.2,
		TweenTime = 0.35,
		CameraOffset = {
			X = 0,
			Y = 4.5,
			Z = 16,
		},
		LookOffset = {
			X = 0,
			Y = 1.5,
			Z = 0,
		},
	})
end

function VotingService:_haveAllEligiblePlayersVoted()
	local players = self:_getEligiblePlayers()
	if #players <= 0 then
		return false
	end

	for _, player in ipairs(players) do
		if self.CurrentState.VotesByPlayer[player.UserId] == nil then
			return false
		end
	end

	return true
end

function VotingService:_handleVoteRequest(player, payload)
	if not self.CurrentState or not self.CurrentState.IsActive then
		return
	end

	local entityId = type(payload) == "table" and payload.EntityId or payload
	if type(entityId) ~= "string" or entityId == "" then
		return
	end

	for _, option in ipairs(self.CurrentState.Options) do
		if option.Id == entityId then
			self.CurrentState.VotesByPlayer[player.UserId] = entityId
			self:_broadcastState()
			return
		end
	end
end

function VotingService:_resolveRoundWinner(options)
	if #options <= 0 then
		return nil
	end

	local countsById = {}
	local bestVoteCount = -1
	local winners = {}

	for _, entityId in pairs(self.CurrentState.VotesByPlayer) do
		countsById[entityId] = (countsById[entityId] or 0) + 1
	end

	for _, option in ipairs(options) do
		local voteCount = countsById[option.Id] or 0
		if voteCount > bestVoteCount then
			bestVoteCount = voteCount
			winners = { option }
		elseif voteCount == bestVoteCount then
			table.insert(winners, option)
		end
	end

	if #winners <= 0 then
		winners = options
	end

	return winners[self.Random:NextInteger(1, #winners)]
end

function VotingService:_buildVoteCounts()
	local counts = {}
	if not self.CurrentState then
		return counts
	end

	for _, option in ipairs(self.CurrentState.Options or {}) do
		counts[option.Id] = 0
	end

	for _, entityId in pairs(self.CurrentState.VotesByPlayer or {}) do
		if counts[entityId] ~= nil then
			counts[entityId] += 1
		end
	end

	return counts
end

function VotingService:_broadcastState()
	if not self.StateRemote then
		return
	end

	if not self.CurrentState then
		self.StateRemote:FireAllClients({
			IsActive = false,
			WeightTarget = self.WeightTarget,
			LastDraftResult = self.LastDraftResult,
		})
		return
	end

	local voteCounts = self:_buildVoteCounts()
	local options = {}
	for _, option in ipairs(self.CurrentState.Options or {}) do
		table.insert(options, {
			Id = option.Id,
			DisplayName = option.DisplayName,
			DirectorWeight = option.DirectorWeight,
			StarRating = option.StarRating,
			TimerValue = option.TimerValue,
			VoteCount = voteCounts[option.Id] or 0,
		})
	end

	local votedPlayers = 0
	for _ in pairs(self.CurrentState.VotesByPlayer or {}) do
		votedPlayers += 1
	end

	self.StateRemote:FireAllClients({
		IsActive = true,
		RoundIndex = self.CurrentState.RoundIndex or 1,
		SecondsLeft = self.CurrentState.SecondsLeft or 0,
		WeightTarget = self.CurrentState.WeightTarget or self.WeightTarget,
		TotalWeight = self.CurrentState.TotalWeight or 0,
		TotalTimerValue = self.CurrentState.TotalTimerValue or 0,
		SelectedEntityIds = _shallowCopyArray(self.CurrentState.SelectedEntityIds or {}),
		Options = options,
		VotedPlayers = votedPlayers,
		EligiblePlayers = #self:_getEligiblePlayers(),
		AllVotesShortened = self.CurrentState.AllVotesShortened == true,
	})
end

return VotingService
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="106">
          <Properties>
            <string name="Name">WeaponLabService</string>
            <string name="Source"><![CDATA[local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local GamePhase = require(ReplicatedStorage.Shared.Enums.GamePhase)
local RemoteNames = require(ReplicatedStorage.Shared.Constants.RemoteNames)
local WeaponDefinitions = require(ReplicatedStorage.Shared.Data.WeaponDefinitions)
local WorldModeResolver = require(ReplicatedStorage.Shared.Utility.WorldModeResolver)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local DEFAULT_WEAPON_ID = "Glock19G5"
local LAB_STATE_REAPPLY_INTERVAL = 5

local WeaponLabService = {}
WeaponLabService.Name = "WeaponLabService"
WeaponLabService.Dependencies = {
	"RemoteRegistry",
	"CharacterService",
	"CombatService",
	"InventoryService",
}

local function _isAllowedWeapon(weaponId)
	local definition = WeaponDefinitions[weaponId]
	return definition ~= nil and definition.Kind == "Firearm"
end

function WeaponLabService:Init(services)
	self.Services = services
	self.SelectedWeaponByPlayer = {}
	self.LabStateLoopRunning = false
end

function WeaponLabService:Start()
	if not WorldModeResolver.IsWeaponLab() then
		return
	end

	self.RequestRemote = self.RemoteRegistry:GetRemote(RemoteNames.RequestWeaponLabCommand)
	self.StateRemote = self.RemoteRegistry:GetRemote(RemoteNames.WeaponLabStateChanged)
	self.RoundStateChangedRemote = self.RemoteRegistry:GetRemote(RemoteNames.RoundStateChanged)
	self.RoundTimerUpdatedRemote = self.RemoteRegistry:GetRemote(RemoteNames.RoundTimerUpdated)

	if self.RequestRemote then
		self.RequestRemote.OnServerEvent:Connect(function(player, payload)
			self:_handleCommand(player, payload)
		end)
	end

	for _, player in ipairs(Players:GetPlayers()) do
		self:_connectPlayer(player)
	end

	Players.PlayerAdded:Connect(function(player)
		self:_connectPlayer(player)
	end)

	Players.PlayerRemoving:Connect(function(player)
		self.SelectedWeaponByPlayer[player] = nil
	end)

	self:_startLabStateLoop()

	DebugLog:Log("Boot", "[WeaponLabService] Started")
end

function WeaponLabService:_connectPlayer(player)
	if not _isAllowedWeapon(self.SelectedWeaponByPlayer[player]) then
		self.SelectedWeaponByPlayer[player] = DEFAULT_WEAPON_ID
	end

	player.CharacterAdded:Connect(function()
		task.defer(function()
			self:_applyLabState(player, "Loaded weapon lab")
		end)
	end)

	self:_sendRoundState(player)
	self:_sendState(player)

	if player.Character then
		task.defer(function()
			self:_applyLabState(player, "Loaded weapon lab")
		end)
	end
end

function WeaponLabService:_getSelectedWeaponId(player)
	local weaponId = self.SelectedWeaponByPlayer[player]
	if _isAllowedWeapon(weaponId) then
		return weaponId
	end

	return DEFAULT_WEAPON_ID
end

function WeaponLabService:_sendRoundState(player)
	local payload = {
		Phase = GamePhase.Preparation,
		TimeLeft = 0,
		Outcome = "None",
	}

	if player then
		if self.RoundStateChangedRemote then
			self.RoundStateChangedRemote:FireClient(player, payload)
		end
		if self.RoundTimerUpdatedRemote then
			self.RoundTimerUpdatedRemote:FireClient(player, payload)
		end
	else
		if self.RoundStateChangedRemote then
			self.RoundStateChangedRemote:FireAllClients(payload)
		end
		if self.RoundTimerUpdatedRemote then
			self.RoundTimerUpdatedRemote:FireAllClients(payload)
		end
	end
end

function WeaponLabService:_sendState(player, message)
	if not self.StateRemote then
		return
	end

	self.StateRemote:FireClient(player, {
		SelectedWeaponId = self:_getSelectedWeaponId(player),
		DefaultWeaponId = DEFAULT_WEAPON_ID,
		Message = message,
	})
end

function WeaponLabService:_startLabStateLoop()
	if self.LabStateLoopRunning then
		return
	end

	self.LabStateLoopRunning = true
	task.spawn(function()
		while self.LabStateLoopRunning do
			for _, player in ipairs(Players:GetPlayers()) do
				if player.Parent == Players then
					self:_maintainLabState(player)
				end
			end
			task.wait(LAB_STATE_REAPPLY_INTERVAL)
		end
	end)
end

function WeaponLabService:_maintainLabState(player)
	self:_sendRoundState(player)

	local character = self.CharacterService and self.CharacterService:GetCharacterByPlayer(player)
	if character then
		character:SetInvincible(true)
		character:Unfreeze()
		if character.Humanoid then
			character.Humanoid.Health = character.Humanoid.MaxHealth
		end
	end

	local selectedWeaponId = self:_getSelectedWeaponId(player)
	local needsLoadoutRepair = false
	local entries = self.InventoryService and self.InventoryService:GetEntries(player) or nil
	if not entries or #entries ~= 1 then
		needsLoadoutRepair = true
	else
		local onlyEntry = entries[1]
		needsLoadoutRepair = not onlyEntry
			or onlyEntry.EntryType ~= "Weapon"
			or onlyEntry.ItemId ~= selectedWeaponId
	end

	local equippedState = self.CombatService and self.CombatService:GetEquippedWeaponState(player) or nil
	if not equippedState or equippedState.ItemId ~= selectedWeaponId then
		needsLoadoutRepair = true
	end

	if needsLoadoutRepair and self.InventoryService then
		self.InventoryService:SetWeaponLoadout(player, { selectedWeaponId })
	end

	if needsLoadoutRepair and self.CombatService then
		self.CombatService:HandleEquipWeapon(player, 1)
		self.CombatService:RefreshCombatState(player)
	end
end

function WeaponLabService:_applyLabState(player, message)
	local character = self.CharacterService and self.CharacterService:GetCharacterByPlayer(player)
	if character then
		character:SetAiming(false)
	end

	self:_maintainLabState(player)

	local selectedWeaponId = self:_getSelectedWeaponId(player)
	self:_sendState(player, message or string.format("Loaded %s", selectedWeaponId))
end

function WeaponLabService:_handleCommand(player, payload)
	if type(payload) ~= "table" then
		return
	end

	local command = payload.Command
	if command == "SetWeapon" then
		local weaponId = payload.WeaponId
		if not _isAllowedWeapon(weaponId) then
			self:_sendState(player, "Invalid lab weapon")
			return
		end

		self.SelectedWeaponByPlayer[player] = weaponId
		self:_applyLabState(player, string.format("Loaded %s", WeaponDefinitions[weaponId].DisplayName or weaponId))
	elseif command == "ResetLoadout" then
		self:_applyLabState(player, "Reset weapon loadout")
	elseif command == "Refresh" then
		self:_sendRoundState(player)
		self:_sendState(player)
	end
end

return WeaponLabService
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="107">
          <Properties>
            <string name="Name">WeaponPickupService</string>
            <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")

local GamePhase = require(ReplicatedStorage.Shared.Enums.GamePhase)
local InteractableType = require(ReplicatedStorage.Shared.Enums.InteractableType)
local WeaponDefinitions = require(ReplicatedStorage.Shared.Data.WeaponDefinitions)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local WeaponPickupService = {}
WeaponPickupService.Name = "WeaponPickupService"
WeaponPickupService.Dependencies = {
	"RemoteRegistry",
	"CombatService",
	"RoundHookService",
}

local DEFAULT_PICKUP_DURATION = 0.35
local RESTORE_HOOK_ID = "WeaponPickupService.RestorePlacedPickups"

local function _resolvePickupPart(instance)
	if instance:IsA("BasePart") then
		return instance
	end

	if instance:IsA("Model") then
		return instance.PrimaryPart or instance:FindFirstChild("HumanoidRootPart") or instance:FindFirstChildWhichIsA("BasePart")
	end

	return nil
end

function WeaponPickupService:Init(services)
	self.Services = services
	self.Pickups = {}
	self.PickupTemplates = {}
	self.WeaponPickupsFolder = Workspace:FindFirstChild("WeaponPickups")
end

function WeaponPickupService:Start()
	self.UiToastRemote = self.RemoteRegistry:GetRemote("UiToastRequested")
	if self.WeaponPickupsFolder then
		self:_registerExistingPickups()

		self.WeaponPickupsFolder.ChildAdded:Connect(function(instance)
			self:_registerPickup(instance)
		end)

		self.WeaponPickupsFolder.ChildRemoved:Connect(function(instance)
			self:_unregisterPickup(instance)
		end)
	end

	if self.RoundHookService then
		self.RoundHookService:RegisterHook({
			Id = RESTORE_HOOK_ID,
			Trigger = "PhaseChanged",
			Phase = GamePhase.Lobby,
			Callback = function()
				self:RestorePlacedPickups()
			end,
		})
	end

	DebugLog:Log("Combat", "[WeaponPickupService] Started")
end

function WeaponPickupService:_registerExistingPickups()
	for _, instance in ipairs(self.WeaponPickupsFolder:GetChildren()) do
		self:_registerPickup(instance)
	end
end

function WeaponPickupService:_registerPickup(instance)
	if self.Pickups[instance] then
		return
	end

	self:_cachePickupTemplate(instance)

	local weaponId = instance:GetAttribute("WeaponId") or instance.Name
	local weaponDefinition = WeaponDefinitions[weaponId]
	if not weaponDefinition then
		DebugLog:Log("Combat", string.format("[WeaponPickupService] Ignored pickup '%s': unknown weapon '%s'", instance.Name, tostring(weaponId)))
		return
	end

	local pickupPart = _resolvePickupPart(instance)
	if not pickupPart then
		DebugLog:Log("Combat", string.format("[WeaponPickupService] Ignored pickup '%s': no usable part", instance.Name))
		return
	end

	local pickupDuration = tonumber(instance:GetAttribute("PickupDuration")) or DEFAULT_PICKUP_DURATION
	local autoEquip = instance:GetAttribute("AutoEquip")
	if autoEquip == nil then
		autoEquip = true
	end

	self.Pickups[instance] = {
		Type = InteractableType.WeaponPickup,
		Id = instance:GetFullName(),
		DisplayName = instance:GetAttribute("DisplayName") or ("Pick Up " .. weaponDefinition.DisplayName),
		Instance = pickupPart,
		Model = instance,
		WeaponId = weaponId,
		Progress = 0,
		MaxProgress = 1,
		ChargeRate = pickupDuration > 0 and (1 / pickupDuration) or 1,
		IsComplete = false,
		AutoEquip = autoEquip == true,
	}

	DebugLog:Log("Combat", string.format("[WeaponPickupService] Registered pickup %s for %s", instance.Name, weaponId))
end

function WeaponPickupService:_cachePickupTemplate(instance)
	local templateId = instance:GetAttribute("PickupTemplateId")
	if not templateId or templateId == "" then
		templateId = instance:GetFullName()
		instance:SetAttribute("PickupTemplateId", templateId)
	end

	if self.PickupTemplates[templateId] then
		return
	end

	self.PickupTemplates[templateId] = {
		TemplateId = templateId,
		Name = instance.Name,
		Clone = instance:Clone(),
	}
end

function WeaponPickupService:_unregisterPickup(instance)
	self.Pickups[instance] = nil
end

function WeaponPickupService:GetAvailablePickups()
	local results = {}
	for _, pickup in pairs(self.Pickups) do
		if pickup.Instance and pickup.Instance.Parent and not pickup.IsComplete then
			table.insert(results, pickup)
		end
	end

	return results
end

function WeaponPickupService:CompletePickup(player, pickup)
	if not pickup or pickup.IsComplete then
		return false
	end

	local slotIndex = self.CombatService:GiveWeapon(player, pickup.WeaponId)
	if not slotIndex then
		return false
	end

	if pickup.AutoEquip then
		self.CombatService:HandleEquipWeapon(player, slotIndex)
	end

	pickup.IsComplete = true
	if pickup.Model and pickup.Model.Parent then
		pickup.Model:Destroy()
	end

	DebugLog:Log("Combat", string.format("[WeaponPickupService] %s picked up %s", player.Name, pickup.WeaponId))
	if self.UiToastRemote then
		self.UiToastRemote:FireClient(player, {
			Title = "Weapon Picked Up",
			Message = WeaponDefinitions[pickup.WeaponId].DisplayName,
			Tint = "Weapon",
		})
	end
	return true
end

function WeaponPickupService:RestorePlacedPickups()
	if not self.WeaponPickupsFolder then
		return
	end

	local activeTemplateIds = {}
	for _, child in ipairs(self.WeaponPickupsFolder:GetChildren()) do
		local templateId = child:GetAttribute("PickupTemplateId")
		if templateId and templateId ~= "" then
			activeTemplateIds[templateId] = true
		end
	end

	for templateId, templateData in pairs(self.PickupTemplates) do
		if not activeTemplateIds[templateId] then
			local restoredInstance = templateData.Clone:Clone()
			restoredInstance.Parent = self.WeaponPickupsFolder
			DebugLog:Log("Combat", string.format("[WeaponPickupService] Restored pickup %s", templateData.Name))
		end
	end
end

function WeaponPickupService:CreateDevPickup(weaponId, position)
	if not WeaponDefinitions[weaponId] or typeof(position) ~= "Vector3" then
		return nil
	end

	if not self.WeaponPickupsFolder then
		self.WeaponPickupsFolder = Instance.new("Folder")
		self.WeaponPickupsFolder.Name = "WeaponPickups"
		self.WeaponPickupsFolder.Parent = Workspace
	end

	local instance = Instance.new("Part")
	instance.Name = weaponId
	instance.Size = Vector3.new(2, 2, 2)
	instance.Shape = Enum.PartType.Ball
	instance.CFrame = CFrame.new(position + Vector3.new(0, 3, 0))
	instance.Anchored = true
	instance.CanCollide = false
	instance.CanQuery = false
	instance.CanTouch = false
	instance.Material = Enum.Material.Neon
	instance.Color = Color3.fromRGB(0, 109, 163)
	instance:SetAttribute("WeaponId", weaponId)
	instance:SetAttribute("DisplayName", "Pick Up " .. (WeaponDefinitions[weaponId].DisplayName or weaponId))
	instance:SetAttribute("PickupDuration", DEFAULT_PICKUP_DURATION)
	instance:SetAttribute("AutoEquip", true)
	instance.Parent = self.WeaponPickupsFolder
	return instance
end

return WeaponPickupService
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="108">
          <Properties>
            <string name="Name">WeaponService</string>
            <string name="Source"><![CDATA[local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local RemoteNames = require(ReplicatedStorage.Shared.Constants.RemoteNames)
local WeaponDefinitions = require(ReplicatedStorage.Shared.Data.WeaponDefinitions)
local WeaponAction = require(ReplicatedStorage.Shared.Enums.WeaponAction)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local WeaponService = {}
WeaponService.Name = "WeaponService"

function WeaponService:Init(services)
	self.Services = services
	self.PlayerWeapons = {}
end

function WeaponService:Start()
	self.RequestWeaponActionRemote = self.Services.RemoteRegistry:GetRemote(RemoteNames.RequestWeaponAction)
	self.WeaponStateChangedRemote = self.Services.RemoteRegistry:GetRemote(RemoteNames.WeaponStateChanged)

	self.RequestWeaponActionRemote.OnServerEvent:Connect(function(player, actionName)
		self:HandleWeaponAction(player, actionName)
	end)

	for _, player in ipairs(Players:GetPlayers()) do
		self:EquipDefaultWeapon(player)
	end

	Players.PlayerAdded:Connect(function(player)
		self:EquipDefaultWeapon(player)
	end)

	Players.PlayerRemoving:Connect(function(player)
		self.PlayerWeapons[player] = nil
	end)

	DebugLog:Log("Weapon", "[WeaponService] Started")
end

function WeaponService:HandleWeaponAction(player, actionName)
	local weaponState = self.PlayerWeapons[player]
	if not weaponState then
		return
	end

	local playerState = self.Services.PlayerService and self.Services.PlayerService:GetPlayerState(player)
	if not playerState or not playerState.IsAlive then
		DebugLog:Log("Weapon", string.format("[WeaponService] Ignored %s from %s: player not alive", tostring(actionName), player.Name))
		return
	end

	if actionName == WeaponAction.Fire then
		self:FireWeapon(player, weaponState)
	elseif actionName == WeaponAction.Reload then
		self:ReloadWeapon(player, weaponState)
	end
end

function WeaponService:EquipDefaultWeapon(player)
	local definition = WeaponDefinitions.Glock45
	if not definition then
		return
	end

	self.PlayerWeapons[player] = {
		WeaponId = definition.Id,
		AmmoInMagazine = definition.MagazineSize,
		ReserveAmmo = definition.ReserveAmmo,
		IsReloading = false,
		LastFireTime = 0,
		ReloadToken = 0,
	}

	self:SendWeaponState(player)
	DebugLog:Log("Weapon", string.format("[WeaponService] Equipped %s for %s", definition.Id, player.Name))
end

function WeaponService:FireWeapon(player, weaponState)
	local definition = WeaponDefinitions[weaponState.WeaponId]
	if not definition then
		return
	end

	if weaponState.IsReloading then
		DebugLog:Log("Weapon", string.format("[WeaponService] Ignored fire from %s: reload in progress", player.Name))
		return
	end

	local now = os.clock()
	if now - weaponState.LastFireTime < definition.FireCooldown then
		return
	end

	if weaponState.AmmoInMagazine <= 0 then
		DebugLog:Log("Weapon", string.format("[WeaponService] Ignored fire from %s: empty magazine", player.Name))
		return
	end

	weaponState.LastFireTime = now
	weaponState.AmmoInMagazine -= 1

	-- Hit detection and damage stay server-owned and can be layered in here later.
	self:SendWeaponState(player)
	DebugLog:Log(
		"Weapon",
		string.format(
			"[WeaponService] %s fired %s (%d/%d)",
			player.Name,
			weaponState.WeaponId,
			weaponState.AmmoInMagazine,
			weaponState.ReserveAmmo
		)
	)
end

function WeaponService:ReloadWeapon(player, weaponState)
	local definition = WeaponDefinitions[weaponState.WeaponId]
	if not definition then
		return
	end

	if weaponState.IsReloading then
		return
	end

	if weaponState.AmmoInMagazine >= definition.MagazineSize then
		return
	end

	if weaponState.ReserveAmmo <= 0 then
		return
	end

	weaponState.IsReloading = true
	weaponState.ReloadToken += 1
	local reloadToken = weaponState.ReloadToken

	self:SendWeaponState(player)
	DebugLog:Log("Weapon", string.format("[WeaponService] %s started reload for %s", player.Name, weaponState.WeaponId))

	task.delay(definition.ReloadDuration, function()
		local liveWeaponState = self.PlayerWeapons[player]
		if not liveWeaponState or liveWeaponState.ReloadToken ~= reloadToken then
			return
		end

		local missingAmmo = definition.MagazineSize - liveWeaponState.AmmoInMagazine
		local ammoToLoad = math.min(missingAmmo, liveWeaponState.ReserveAmmo)
		liveWeaponState.AmmoInMagazine += ammoToLoad
		liveWeaponState.ReserveAmmo -= ammoToLoad
		liveWeaponState.IsReloading = false

		self:SendWeaponState(player)
		DebugLog:Log("Weapon", string.format("[WeaponService] %s completed reload for %s", player.Name, liveWeaponState.WeaponId))
	end)
end

function WeaponService:SendWeaponState(player)
	local weaponState = self.PlayerWeapons[player]
	if not weaponState then
		return
	end

	self.WeaponStateChangedRemote:FireClient(player, {
		WeaponId = weaponState.WeaponId,
		AmmoInMagazine = weaponState.AmmoInMagazine,
		ReserveAmmo = weaponState.ReserveAmmo,
		IsReloading = weaponState.IsReloading,
	})
end

return WeaponService
]]></string>
          </Properties>
        </Item>
      </Item>
    </Item>
  </Item>
  <Item class="SoundService" referent="109">
    <Properties>
      <string name="Name">SoundService</string>
      <bool name="RespectFilteringEnabled">true</bool>
    </Properties>
  </Item>
  <Item class="StarterPlayer" referent="110">
    <Properties>
      <string name="Name">StarterPlayer</string>
    </Properties>
    <Item class="StarterPlayerScripts" referent="111">
      <Properties>
        <string name="Name">StarterPlayerScripts</string>
      </Properties>
      <Item class="Folder" referent="112">
        <Properties>
          <string name="Name">Client</string>
        </Properties>
        <Item class="LocalScript" referent="113">
          <Properties>
            <string name="Name">Boot</string>
            <string name="Source"><![CDATA[local Players = game:GetService("Players")
local StarterGui = game:GetService("StarterGui")
local player = Players.LocalPlayer
local playerScripts = player:WaitForChild("PlayerScripts")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local WorldMode = require(ReplicatedStorage.Shared.Enums.WorldMode)
local WorldModeResolver = require(ReplicatedStorage.Shared.Utility.WorldModeResolver)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)
local RingWrapper = require(ReplicatedStorage.Shared.Utility.RingWrapper)
local ClientWorld = require(ReplicatedStorage.Shared.World.ClientWorld)

local ClientFolder = playerScripts:WaitForChild("Client")
local ControllersFolder = ClientFolder:WaitForChild("Controllers")
local UIFolder = ClientFolder:WaitForChild("UI")

local function _buildGameplayBootOrder()
	return {
		require(ControllersFolder.ContextController),
		require(ControllersFolder.ActionResolver),
		require(ControllersFolder.ActionDispatcher),
		require(ControllersFolder.QTEController),
		require(ControllersFolder.BreathHoldController),
		require(ControllersFolder.CameraInputController),
		require(ControllersFolder.CombatController),
		require(ControllersFolder.ViewmodelController),
		require(ControllersFolder.FirearmPresentationController),
		require(ControllersFolder.EntityAbilityVisualController),
		require(ControllersFolder.CrosshairController),
		require(ControllersFolder.StaminaController),
		require(ControllersFolder.SurvivabilityFeedbackController),
		require(ControllersFolder.RemnantController),
		require(ControllersFolder.NotificationController),
		require(ControllersFolder.AuraRevealController),
		require(ControllersFolder.InputController),
		require(ControllersFolder.InteractionController),
		require(ControllersFolder.InteractableDebugController),
		require(ControllersFolder.DevMenuController),
		require(ControllersFolder.RoundController),
		require(ControllersFolder.VotingController),
		require(ControllersFolder.StatusEffectController),
		require(ControllersFolder.EntityDebugController),
		require(UIFolder.UIController),
	}
end

local function _buildWeaponLabBootOrder()
	return {
		require(ControllersFolder.ContextController),
		require(ControllersFolder.ActionResolver),
		require(ControllersFolder.ActionDispatcher),
		require(ControllersFolder.RoundController),
		require(ControllersFolder.CameraInputController),
		require(ControllersFolder.CombatController),
		require(ControllersFolder.ViewmodelController),
		require(ControllersFolder.FirearmPresentationController),
		require(ControllersFolder.CrosshairController),
		require(ControllersFolder.StaminaController),
		require(ControllersFolder.InputController),
		require(ControllersFolder.WeaponLabController),
	}
end

local bootOrder = WorldModeResolver.GetWorldMode() == WorldMode.WeaponLab
	and _buildWeaponLabBootOrder()
	or _buildGameplayBootOrder()

local Controllers = RingWrapper.CreateRing(bootOrder)
RingWrapper.Attach(bootOrder, Controllers, "Controllers")

local World = ClientWorld.new(Controllers)
RingWrapper.AttachField(bootOrder, "World", World)

for _, coreGuiType in ipairs({
	Enum.CoreGuiType.Backpack,
	Enum.CoreGuiType.Chat,
	Enum.CoreGuiType.Health,
	Enum.CoreGuiType.PlayerList,
	Enum.CoreGuiType.EmotesMenu,
	Enum.CoreGuiType.SelfView,
	}) do
	pcall(function()
		StarterGui:SetCoreGuiEnabled(coreGuiType, false)
	end)
end

for _, controller in ipairs(bootOrder) do
	if controller.Init then
		controller:Init(Controllers)
	end
end

for _, controller in ipairs(bootOrder) do
	if controller.Start then
		controller:Start()
	end
end

DebugLog:Log("Boot", "[Boot] Client boot complete.")
]]></string>
          </Properties>
        </Item>
        <Item class="Folder" referent="114">
