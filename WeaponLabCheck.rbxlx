        <Item class="Folder" referent="63">
          <Properties>
            <string name="Name">UI</string>
          </Properties>
          <Item class="ModuleScript" referent="64">
            <Properties>
              <string name="Name">UIController</string>
              <string name="Source"><![CDATA[local Players = game:GetService("Players")

local UIController = {}
UIController.Name = "UIController"

local function ensureLabel(parent, name, position, text)
	local label = parent:FindFirstChild(name)
	if label then
		return label
	end

	label = Instance.new("TextLabel")
	label.Name = name
	label.BackgroundTransparency = 1
	label.Position = position
	label.Size = UDim2.new(1, 0, 0, 24)
	label.Font = Enum.Font.GothamMedium
	label.Text = text
	label.TextColor3 = Color3.fromRGB(239, 244, 248)
	label.TextSize = 18
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.Parent = parent

	return label
end

local function ensureMainHUD(playerGui)
	local mainHUD = playerGui:FindFirstChild("MainHUD")
	if not mainHUD then
		mainHUD = Instance.new("ScreenGui")
		mainHUD.Name = "MainHUD"
		mainHUD.ResetOnSpawn = false
		mainHUD.Parent = playerGui
	end

	local container = mainHUD:FindFirstChild("Container")
	if not container then
		container = Instance.new("Frame")
		container.Name = "Container"
		container.AnchorPoint = Vector2.new(0, 0)
		container.Position = UDim2.new(0, 20, 0, 20)
		container.Size = UDim2.new(0, 260, 0, 88)
		container.BackgroundColor3 = Color3.fromRGB(17, 22, 31)
		container.BackgroundTransparency = 0.2
		container.Parent = mainHUD

		local corner = Instance.new("UICorner")
		corner.CornerRadius = UDim.new(0, 12)
		corner.Parent = container
	end

	local phaseLabel = ensureLabel(container, "PhaseLabel", UDim2.new(0, 14, 0, 10), "Phase: Unknown")
	local timerLabel = ensureLabel(container, "TimerLabel", UDim2.new(0, 14, 0, 32), "Time: 0")
	local outcomeLabel = ensureLabel(container, "OutcomeLabel", UDim2.new(0, 14, 0, 54), "")

	return mainHUD, container, phaseLabel, timerLabel, outcomeLabel
end

function UIController:Init(controllers)
	self.Controllers = controllers
	self.Player = Players.LocalPlayer
	self.PlayerGui = self.Player:WaitForChild("PlayerGui")
	
	self.LastPhase = nil
	self.LastTimeLeft = nil
	self.LastOutcome = nil
end

function UIController:Start()
	local mainHUD, container, phaseLabel, timerLabel, outcomeLabel = ensureMainHUD(self.PlayerGui)
	self.Root = mainHUD
	self.Container = container
	self.PhaseLabel = phaseLabel
	self.TimerLabel = timerLabel
	self.OutcomeLabel = outcomeLabel
	
	task.spawn(function()
		while true do
			self:UpdateHUD()
			task.wait(0.1)
		end
	end)
	
	print("[UIController] Started")
end

function UIController:UpdateHUD()
	local roundController = self.Controllers.RoundController
	local state = roundController and roundController:GetState()
	
	if not state then
		return
	end
	
	local phase = state.Phase or "Unknown"
	local timeLeft = state.TimeLeft
	if timeLeft == nil then
		timeLeft = 0
	end
	local outcome = state.Outcome or "None"
	local phaseChanged = phase ~= self.LastPhase
	local timeChanged = timeLeft ~= self.LastTimeLeft
	local outcomeChanged = outcome ~= self.LastOutcome
	
	if phaseChanged then
		self.LastPhase = phase
		self.PhaseLabel.Text = "Phase: " .. tostring(phase)
	end
	
	if timeChanged then
		self.LastTimeLeft = timeLeft
		self.TimerLabel.Text = "Time: " .. tostring(timeLeft) 
	end
	
	if outcomeChanged or phaseChanged then
		self.LastOutcome = outcome
		self.OutcomeLabel.Text = self:_formatOutcomeText(phase, outcome)
		
		if self.OutcomeLabel.Text == "" then
			self.OutcomeLabel.Visible = false
		else
			self.OutcomeLabel.Visible = true
		end
	end
end

function UIController:_formatOutcomeText(phase, outcome)
	if phase ~= "Results" then
		return ""
	end
	
	if outcome == "RemnantsWin" then
		return "Remnants Win"
	elseif outcome == "EntitiesWin" then
		return "Entities Win"
	elseif outcome == "Draw" then
		return "Draw"
	end
	
	return ""
end

return UIController
]]></string>
