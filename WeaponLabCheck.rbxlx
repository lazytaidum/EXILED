  <Item class="ServerScriptService" referent="33">
    <Properties>
      <string name="Name">ServerScriptService</string>
    </Properties>
    <Item class="Folder" referent="34">
      <Properties>
        <string name="Name">Server</string>
      </Properties>
      <Item class="Script" referent="35">
        <Properties>
          <string name="Name">Boot</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[local ServerScriptService = game:GetService("ServerScriptService")

local ServerFolder = ServerScriptService:WaitForChild("Server")
local ServicesFolder = ServerFolder:WaitForChild("Services")
local ManagersFolder = ServerFolder:WaitForChild("Managers")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local bootOrder = {
	require(ServicesFolder.RemoteRegistry),
	require(ServicesFolder.PlayerService),
	require(ServicesFolder.CharacterService),
	require(ServicesFolder.WeaponService),
	require(ServicesFolder.SpawnService),
	require(ServicesFolder.ObjectiveService),
	require(ServicesFolder.InteractionService),
	require(ServicesFolder.EntityService),
	require(ServicesFolder.EscapeService),
	require(ManagersFolder.RoundManager),
}

local Services = {}

for _, service in ipairs(bootOrder) do
	Services[service.Name] = service
end

for _, service in ipairs(bootOrder) do
	if service.Init then
		service:Init(Services)
	end
end

for _, service in ipairs(bootOrder) do
	if service.Start then
		service:Start()
	end
end

DebugLog:Log("Boot", "[Boot] Server boot complete.")
]]></string>
        </Properties>
      </Item>
      <Item class="Folder" referent="36">
        <Properties>
          <string name="Name">Classes</string>
        </Properties>
        <Item class="ModuleScript" referent="37">
          <Properties>
            <string name="Name">BaseCharacter</string>
            <string name="Source"><![CDATA[local BaseCharacter = {}
BaseCharacter.__index = BaseCharacter

function BaseCharacter.new(player, model)
	local self = setmetatable({}, BaseCharacter)
	
	self.Player = player
	self.Model = model
	self.Humanoid = model:WaitForChild("Humanoid")
	self.RootPart = model:WaitForChild("HumanoidRootPart")
	
	self.IsFrozen = false
	self.DefaultWalkSpeed = self.Humanoid.WalkSpeed
	self.DefaultJumpPower = self.Humanoid.JumpPower
	self.IsInvincible = false
	
	self.SpeedMultipliers = {}
	self.SpeedModifierToken = 0
	
	return self
end

function BaseCharacter:_getCombinedSpeedMultiplier()
	local boostMultiplier = 1
	local slowMultiplier = 1
	
	for key, value in pairs(self.SpeedMultipliers) do
		if key == "OnHitHaste" and value > 1 then
			boostMultiplier = math.max(boostMultiplier, value)
		elseif value > 1 then
			boostMultiplier *= value
		else
			slowMultiplier *= value
		end
	end
	
	if self.SpeedMultipliers.OnHitHaste then
		slowMultiplier = 1
	end
	
	return boostMultiplier * slowMultiplier
end

function BaseCharacter:_refreshMovement()
	if not self.Humanoid then
		return
	end
	
	if self.IsFrozen then
		self.Humanoid.WalkSpeed = 0
		self.Humanoid.JumpPower = 0
		self.Humanoid.AutoRotate = false
		return
	end
	
	self.Humanoid.WalkSpeed = self.DefaultWalkSpeed * self:_getCombinedSpeedMultiplier()
	self.Humanoid.JumpPower = self.DefaultJumpPower
	self.Humanoid.AutoRotate = true
end

function BaseCharacter:SetWalkSpeed(speed)
	if self.Humanoid then
		self.DefaultWalkSpeed = speed
		self:_refreshMovement()
	end
end

function BaseCharacter:SetJumpPower(jumpPower)
	if self.Humanoid then
		self.DefaultJumpPower = jumpPower
		self:_refreshMovement()
	end
end

function BaseCharacter:SetSpeedMultiplier(key, multiplier)
	if multiplier == nil then
		self.SpeedMultipliers[key] = nil
	else
		self.SpeedMultipliers[key] = multiplier
	end
	
	self:_refreshMovement()
end

function BaseCharacter:ApplyTemporarySpeedMultiplier(key, multiplier, duration)
	self.SpeedModifierToken += 1
	local token = self.SpeedModifierToken
	
	self:SetSpeedMultiplier(key, multiplier)
	
	task.delay(duration, function()
		if self.SpeedModifierToken ~= token then
			return
		end
		
		self:SetSpeedMultiplier(key, nil)
	end)
end

function BaseCharacter:Freeze()
	if not self.Humanoid or self.IsFrozen then
		return
	end
	
	self.IsFrozen = true
	self:_refreshMovement()
end

function BaseCharacter:Unfreeze()
	if not self.Humanoid or not self.IsFrozen then
		return
	end

	self.IsFrozen = false
	self:_refreshMovement()
end

function BaseCharacter:IsAlive()
	return self.Humanoid and self.Humanoid.Health > 0
end

function BaseCharacter:SetInvincible(state)
	if self.IsInvincible == state then
		return
	end
	
	self.IsInvincible = state
	
	if self.Humanoid then
		if state then
			self.Humanoid.Health = self.Humanoid.MaxHealth
		end
	end
end

function BaseCharacter:ApplyDamage(amount)
	if self.IsInvincible then
		return false
	end
	
	if self.Humanoid then
		self.Humanoid:TakeDamage(amount)
		return true
	end
	
	return false
end

function BaseCharacter:Destroy()
	self.Player = nil
	self.Model = nil
	self.Humanoid = nil
	self.RootPart = nil
end

return BaseCharacter
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="38">
          <Properties>
            <string name="Name">BaseEntity</string>
            <string name="Source"><![CDATA[local BaseEntity = {}
BaseEntity.__index = BaseEntity

function BaseEntity.new(model, definition)
	local self = setmetatable({}, BaseEntity)
	
	self.Model = model
	self.Definition = definition or {}
	self.RootPart = model.PrimaryPart or model:WaitForChild("HumanoidRootPart")
	
	self.Id = self.Definition.Id or model.Name
	self.DisplayName = self.Definition.DisplayName or model.Name
	self.StarRating = self.Definition.StarRation or 1
	self.Weight = self.Definition.Weight or self.StarRating
	
	self.Attributes = self.Definition.Attributes or {}
	
	local stats = self.Definition.Stats or {}
	
	self.IsActive = false
	self.Damage = stats.Damage or 10
	self.AttackRange = stats.AttackRange or 10
	self.AttackInterval = stats.AttackInterval or 1.5
	self.MoveSpeed = stats.MoveSpeed or 10
	
	self.LastAttackTime = 0
	self.TargetPlayer = nil
	
	self.SpawnCFrame = self.RootPart.CFrame
	
	return self
end

function BaseEntity:SetActive(state)
	self.IsActive = state
	
	if not state then
		self.TargetPlayer = nil
	end
end

function BaseEntity:HasAttribute(attributeName)
	for _, value in ipairs(self.Attributes) do
		if value == attributeName then
			return true
		end
	end
	
	return false
end

function BaseEntity:CanAttack()
	return os.clock() - self.LastAttackTime >= self.AttackInterval
end

function BaseEntity:MarkAttack()
	self.LastAttackTime = os.clock()
end

function BaseEntity:GetPosition()
	if self.RootPart then
		return self.RootPart.Position
	end
	
	return nil
end

function BaseEntity:SetTarget(player)
	self.TargetPlayer = player
end

function BaseEntity:GetTarget()
	return self.TargetPlayer
end

function BaseEntity:MoveToward(position, deltaTime)
	if not self.RootPart or not position then
		return
	end
	
	local currentPosition = self.RootPart.Position
	local offset = position - currentPosition
	local distance = offset.Magnitude
	
	if distance <= 0.01 then
		return
	end
	
	local stopDistance = math.max(self.AttackRange * 0.5, 2)
	if distance <= stopDistance then
		return
	end
	
	local direction = offset.Unit
	local moveStep = math.min(distance - stopDistance, self.MoveSpeed * deltaTime)
	if moveStep <= 0 then
		return
	end
	
	local nextPosition = currentPosition + direction * moveStep
	
	self.RootPart.CFrame = CFrame.new(nextPosition, position)
end

function BaseEntity:ResetToSpawn()
	if self.RootPart then
		self.RootPart.CFrame = self.SpawnCFrame
	end
	
	self.TargetPlayer = nil
	self.LastAttackTime = 0
end

function BaseEntity:Destroy()
	self.Model = nil
	self.Definition = nil
	self.RootPart = nil
	self.TargetPlayer = nil
end

return BaseEntity
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="39">
          <Properties>
            <string name="Name">BaseObjective</string>
            <string name="Source"><![CDATA[local BaseObjective = {}
BaseObjective.__index = BaseObjective

function BaseObjective.new(instance, definition)
	local self = setmetatable({}, BaseObjective)
	
	self.Instance = instance
	self.Definition = definition or {}
	
	self.Id = self.Definition.Id or instance.Name
	self.DisplayName = self.Definition.DisplayName or instance.Name
	self.Type = self.Definition.Type or "Unknown"
	self.Phase = self.Definition.Phase or "None"
	self.Shared = self.Definition.Shared == true
	self.StartsEnabled = self.Definition.StartsEnabled == true
	self.MaxProgress = self.Definition.MaxProgress or 1
	self.ChargeRate = self.Definition.ChargeRate or 1
	
	self.Progress = 0
	self.LastLoggedProgressStep = -1
	self.IsComplete = false
	self.IsEnabled = self.StartsEnabled
	
	return self
end

function BaseObjective:SetEnabled(state)
	self.IsEnabled = state
end

function BaseObjective:CanInteract()
	return self.IsEnabled and not self.IsComplete
end

function BaseObjective:AddProgress(amount)
	if not self:CanInteract() then
		return false
	end
	
	self.Progress += amount
	
	if self.Progress >= self.MaxProgress then
		self.Progress = self.MaxProgress
		self.IsComplete = true
	end
	
	return true
end

function BaseObjective:GetProgressAlpha()
	if self.MaxProgress <= 0 then
		return 0
	end
	
	return self.Progress / self.MaxProgress
end

function BaseObjective:Destroy()
	self.Instance = nil
	self.Definition = nil
end

return BaseObjective
]]></string>
          </Properties>
        </Item>
      </Item>
      <Item class="Folder" referent="40">
        <Properties>
          <string name="Name">Managers</string>
        </Properties>
        <Item class="ModuleScript" referent="41">
          <Properties>
            <string name="Name">RoundManager</string>
            <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")

local GamePhase = require(ReplicatedStorage.Shared.Enums.GamePhase)
local RoundOutcome = require(ReplicatedStorage.Shared.Enums.RoundOutcome)
local RoundConfig = require(ReplicatedStorage.Shared.Data.RoundConfig)
local RemoteNames = require(ReplicatedStorage.Shared.Constants.RemoteNames)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local RoundManager = {}
RoundManager.Name = "RoundManager"

function RoundManager:Init(services)
	self.Services = services
	self.CurrentPhase = GamePhase.Lobby
	self.CurrentOutcome = RoundOutcome.None
	self.TimeLeft = 0
	self.IsRunning = false
	self.SkipPhase = false

	self.ActivePlayers = {}
	self.RoundStates = {}
end

function RoundManager:Start()
	DebugLog:Log("Round", "[RoundManager] Started")

	if self.IsRunning then
		return
	end

	self.IsRunning = true

	task.spawn(function()
		self:RunLoop()
	end)
end

function RoundManager:SetPhase(phase, duration)
	self.CurrentPhase = phase
	self.TimeLeft = duration or 0

	DebugLog:Log("Round", string.format("[RoundManager] Phase -> %s (%ds)", phase, self.TimeLeft))

	if phase == GamePhase.Lobby then
		if self.Services.InteractionService then
			self.Services.InteractionService:StopAllInteractions("LobbyReset")
		end
		if self.Services.ObjectiveService then
			self.Services.ObjectiveService:ResetObjectives()
		end
		self:ClearRound()
		for _, player in ipairs(self.Services.PlayerService:GetPlayers()) do
			self:ApplyCurrentPhaseStateToPlayer(player)
		end
		self.Services.SpawnService:TeleportAllPlayersToLobby()
		self.Services.EntityService:SetAllEntitiesActive(false)

	elseif phase == GamePhase.Preparation then
		self:BuildRoundRoster()
		self.Services.SpawnService:TeleportPlayersToReception(self.ActivePlayers)
		self.Services.EntityService:SetAllEntitiesActive(false)
		for _, player in ipairs(self.ActivePlayers) do
			self:ApplyCurrentPhaseStateToPlayer(player)
		end

	elseif phase == GamePhase.Reception then
		self.Services.EntityService:SetAllEntitiesActive(true)
		for _, player in ipairs(self.ActivePlayers) do
			self:ApplyCurrentPhaseStateToPlayer(player)
		end

	elseif phase == GamePhase.Results then
		if self.Services.InteractionService then
			self.Services.InteractionService:StopAllInteractions("Results")
		end
		self.Services.EntityService:SetAllEntitiesActive(false)
		for _, player in ipairs(self.ActivePlayers) do
			self:ApplyCurrentPhaseStateToPlayer(player)
		end
		
	end

	local roundStateChanged = self.Services.RemoteRegistry:GetRemote(RemoteNames.RoundStateChanged)
	if roundStateChanged then
		roundStateChanged:FireAllClients({
			Phase = self.CurrentPhase,
			TimeLeft = self.TimeLeft,
			Outcome = self.CurrentOutcome,
		})
	end

	self:BroadcastTimer()
end

function RoundManager:BroadcastTimer()
	local roundTimerUpdated = self.Services.RemoteRegistry:GetRemote(RemoteNames.RoundTimerUpdated)
	if roundTimerUpdated then
		roundTimerUpdated:FireAllClients({
			Phase = self.CurrentPhase,
			TimeLeft = self.TimeLeft,
			Outcome = self.CurrentOutcome,
		})
	end
end

function RoundManager:RunPhase(phase, duration)
	self.SkipPhase = false
	self:SetPhase(phase, duration)

	while self.TimeLeft > 0 do
		if self.SkipPhase then
			self.TimeLeft = 0
			self:BroadcastTimer()
			break
		end

		task.wait(1)
		self.TimeLeft -= 1
		self:BroadcastTimer()
	end

	if phase == GamePhase.Reception and not self.SkipPhase then
		self:OnReceptionTimerExpired()
	end
end

function RoundManager:RunLoop()
	while true do
		self:RunPhase(GamePhase.Lobby, RoundConfig.IntermissionDuration)
		self:RunPhase(GamePhase.Voting, RoundConfig.VotingDuration)
		self:RunPhase(GamePhase.Preparation, RoundConfig.PreparationDuration)
		self:RunPhase(GamePhase.Reception, RoundConfig.ReceptionDuration) -- Temporary test value!
		self:RunPhase(GamePhase.Results, RoundConfig.ResultsDuration)
	end
end

function RoundManager:BuildRoundRoster()
	table.clear(self.ActivePlayers)
	table.clear(self.RoundStates)

	local players = self.Services.PlayerService:GetPlayers()

	for _, player in ipairs(players) do
		local character = self.Services.CharacterService:GetCharacterByPlayer(player)

		if character and character:IsAlive() then
			table.insert(self.ActivePlayers, player)

			self.RoundStates[player] = {
				IsActive = true,
				IsAlive = true,
				HasEscaped = false,
				IsEliminated = false,
			}
		end
	end

	DebugLog:Log("Round", string.format("[RoundManager] Built roster with %d active players", #self.ActivePlayers))
end

function RoundManager:ClearRound()
	table.clear(self.ActivePlayers)
	table.clear(self.RoundStates)
	self.CurrentOutcome = RoundOutcome.None
end

function RoundManager:GetRoundState(player)
	return self.RoundStates[player]
end

function RoundManager:GetActivePlayers()
	return self.ActivePlayers
end

function RoundManager:IsPlayerActive(player)
	local roundState = self.RoundStates[player]
	return roundState ~= nil and roundState.IsActive == true
end

function RoundManager:IsReceptionActive()
	return self.CurrentPhase == GamePhase.Reception
end

function RoundManager:GetCurrentPhase()
	return self.CurrentPhase
end

function RoundManager:IsInvinciblePhase(phase)
	return phase == GamePhase.Preparation or phase == GamePhase.Results
end

function RoundManager:ApplyCurrentPhaseStateToPlayer(player)
	local character = self.Services.CharacterService:GetCharacterByPlayer(player)
	if not character then
		return
	end
	
	local isActivePlayer = self:IsPlayerActive(player)
	local shouldBeInvincible = isActivePlayer and self:IsInvinciblePhase(self.CurrentPhase)
	local shouldBeFrozen = isActivePlayer and (self.CurrentPhase == GamePhase.Preparation or self.CurrentPhase == GamePhase.Results)
	
	character:SetInvincible(shouldBeInvincible)
	
	if shouldBeFrozen then
		character:Freeze()
	else
		character:Unfreeze()
	end
end

function RoundManager:FreezeActivePlayers()
	for _, player in ipairs(self.ActivePlayers) do
		local character = self.Services.CharacterService:GetCharacterByPlayer(player)
		if character then
			character:Freeze()
		end
	end
end

function RoundManager:UnfreezeActivePlayers()
	for _, player in ipairs(self.ActivePlayers) do
		local character = self.Services.CharacterService:GetCharacterByPlayer(player)
		if character then
			character:Unfreeze()
		end
	end
end

function RoundManager:SetPlayerEliminated(player)
	if not self:IsReceptionActive() then
		return
	end

	local roundState = self.RoundStates[player]
	if not roundState then
		return
	end

	roundState.IsAlive = false
	roundState.IsEliminated = true

	DebugLog:Log("Round", "[RoundManager] Eliminated", player.Name)
	DebugLog:Log("Round", "[RoundManager] Alive remaining:", self:GetAliveCount())

	self:CheckRoundEnd()
end

function RoundManager:SetPlayerEscaped(player)
	if not self:IsReceptionActive() then
		return
	end
	
	local roundState = self.RoundStates[player]
	if not roundState then
		return
	end

	roundState.IsAlive = false
	roundState.HasEscaped = true

	DebugLog:Log("Round", "[RoundManager] Escaped", player.Name)
	DebugLog:Log("Round", "[RoundManager] Escaped count:", self:GetEscapedCount(), "/", self:GetRequiredEscapeCount())
	DebugLog:Log("Round", "[RoundManager] Alive remaining:", self:GetAliveCount())

	self:CheckRoundEnd()
end

function RoundManager:GetActivePlayerCount()
	return #self.ActivePlayers
end

function RoundManager:GetRequiredEscapeCount()
	local total = self:GetActivePlayerCount()
	return math.floor(total / 2) + 1
end

function RoundManager:GetAliveCount()
	local count = 0

	for _, roundState in pairs(self.RoundStates) do
		if roundState.IsAlive then
			count += 1
		end
	end

	return count
end

function RoundManager:GetEscapedCount()
	local count = 0

	for _, roundState in pairs(self.RoundStates) do
		if roundState.HasEscaped then
			count += 1
		end
	end

	return count
end

function RoundManager:GetEliminatedCount()
	local count = 0

	for _, roundState in pairs(self.RoundStates) do
		if roundState.IsEliminated then
			count += 1
		end
	end

	return count
end

function RoundManager:CheckRoundEnd()
	if not self:IsReceptionActive() then
		return
	end

	local aliveCount = self:GetAliveCount()
	local escapedCount = self:GetEscapedCount()
	local requiredEscapeCount = self:GetRequiredEscapeCount()
	
	if escapedCount >= requiredEscapeCount then
		DebugLog:Log("Round", "[RoundManager] Escape threshold reached, Remnants win")
		self:EndReception(RoundOutcome.RemnantsWin)
		return
	end

	if aliveCount <= 0 then
		local escapedCount = self:GetEscapedCount()
		local outcome = escapedCount > 0 and RoundOutcome.RemnantsWin or RoundOutcome.EntitiesWin
		DebugLog:Log("Round", "[RoundManager] No active players remain, ending round early.")
		self:EndReception(outcome)
	end
end

function RoundManager:EndReception(outcome)
	if not self:IsReceptionActive() then
		return
	end

	self.CurrentOutcome = outcome or RoundOutcome.None
	self.SkipPhase = true

	DebugLog:Log("Round", "[RoundManager] Reception ended with outcome:", self.CurrentOutcome)
end

function RoundManager:OnReceptionTimerExpired()
	DebugLog:Log("Round", "[RoundManager] Reception timer expired")

	local aliveCount = self:GetAliveCount()
	local escapedCount = self:GetEscapedCount()

	if aliveCount > 0 then
		self:EndReception(RoundOutcome.Draw)
	elseif escapedCount > 0 then
		self:EndReception(RoundOutcome.RemnantsWin)
	else
		self:EndReception(RoundOutcome.EntitiesWin)
	end
end

return RoundManager
]]></string>
          </Properties>
        </Item>
      </Item>
      <Item class="Folder" referent="42">
        <Properties>
          <string name="Name">Services</string>
        </Properties>
        <Item class="ModuleScript" referent="43">
          <Properties>
            <string name="Name">CharacterService</string>
            <string name="Source"><![CDATA[local Players = game:GetService("Players")
local ServerScriptService = game:GetService("ServerScriptService")

local BaseCharacter = require(ServerScriptService.Server.Classes.BaseCharacter)
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local CharacterService = {}
CharacterService.Name = "CharacterService"

function CharacterService:Init(services)
	self.Services = services
	self.CharactersByPlayer = {}
	self.CharactersByModel = {}
end

function CharacterService:Start()
	for _, player in ipairs(Players:GetPlayers()) do
		self:_connectPlayer(player)
		
		if player.Character then
			self:_onCharacterAdded(player, player.Character)
		end
	end
	
	Players.PlayerAdded:Connect(function(player: Player)
		self:_connectPlayer(player)
	end)
	
	Players.PlayerRemoving:Connect(function(player)
		self:_cleanupPlayer(player)
	end)
	
	DebugLog:Log("Character", "[CharacterService] Started")
end

function CharacterService:_connectPlayer(player)
	player.CharacterAdded:Connect(function(characterModel)
		self:_onCharacterAdded(player, characterModel)
	end)
	
	player.CharacterRemoving:Connect(function(characterModel)
		self:_onCharacterRemoving(player, characterModel)
	end)
end

function CharacterService:_onCharacterAdded(player, characterModel)
	local oldCharacter = self.CharactersByPlayer[player]
	if oldCharacter then
		self:_removeCharacter(player, oldCharacter.Model)
	end
	
	local character = BaseCharacter.new(player, characterModel)
	self.CharactersByPlayer[player] = character
	self.CharactersByModel[characterModel] = character
	
	local playerService = self.Services.PlayerService
	if playerService then
		playerService:SetAlive(player, true)
	end

	local roundManager = self.Services.RoundManager
	if roundManager then
		roundManager:ApplyCurrentPhaseStateToPlayer(player)
	end
	
	character.Humanoid.Died:Connect(function()
		if character.IsInvincible then
			DebugLog:Log("Character", "[CharacterService] Ignoring death for invincible character", player.Name)
			return
		end
		local livePlayerService = self.Services.PlayerService
		if livePlayerService then
			livePlayerService:SetAlive(player, false)
		end
		
		local liveRoundManager = self.Services.RoundManager
		if liveRoundManager and liveRoundManager:IsPlayerActive(player) then
			liveRoundManager:SetPlayerEliminated(player)
		end
		DebugLog:Log("Character", "[CharacterService] Character died for", player.Name)
	end)
	
	DebugLog:Log("Character", "[CharacterService] Registered character for", player.Name)
end

function CharacterService:_onCharacterRemoving(player, characterModel)
	self:_removeCharacter(player, characterModel)
end

function CharacterService:_removeCharacter(player, characterModel)
	local character = self.CharactersByPlayer[player]
	
	if character then
		character:Destroy()
	end
	
	self.CharactersByPlayer[player] = nil
	
	if characterModel then
		self.CharactersByModel[characterModel] = nil
	end
	
	local playerService = self.Services.PlayerService
	if playerService then
		playerService:SetAlive(player, false)
	end
	
	DebugLog:Log("Character", "[CharacterService] Removed character for", player.Name)
end

function CharacterService:FreezeAll()
	for _, character in pairs(self.CharactersByPlayer) do
		character:Freeze()
	end
end

function CharacterService:UnfreezeAll()
	for _, character in pairs(self.CharactersByPlayer) do
		character:Unfreeze()
	end
end

function CharacterService:_cleanupPlayer(player)
	local character = self.CharactersByPlayer[player]
	if character then
		self:_removeCharacter(player, character.Model)
	end
end

function CharacterService:GetCharacterByPlayer(player)
	return self.CharactersByPlayer[player]
end

function CharacterService:GetCharacterByModel(model)
	return self.CharactersByModel[model]
end

return CharacterService
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="44">
          <Properties>
            <string name="Name">EntityService</string>
            <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")
local ServerScriptService = game:GetService("ServerScriptService")

local BaseEntity = require(ServerScriptService.Server.Classes.BaseEntity)
local EntityDefinitions = require(ReplicatedStorage.Shared.Data.EntityDefinitions)
local EntityAttributes = require(ReplicatedStorage.Shared.Enums.EntityAttributes)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local EntityService = {}
EntityService.Name = "EntityService"

function EntityService:Init(services)
	self.Services = services
	self.Entities = {}
	self.UpdateInterval = 0.2

	self.EntitiesFolder = Workspace:WaitForChild("Entities")
end

function EntityService:Start()
	self:_registerExistingEntities()

	task.spawn(function()
		self:_runEntityLoop()
	end)

	DebugLog:Log("Entity", "[EntityService] Started")
end

function EntityService:_registerExistingEntities()
	for _,model in ipairs(self.EntitiesFolder:GetChildren()) do
		if model:IsA("Model") and model.PrimaryPart then
			local definition = EntityDefinitions[model.Name]
			local entity = BaseEntity.new(model, definition)

			table.insert(self.Entities, entity)

			DebugLog:Log("Entity", string.format(
				"[EntityService] Registered entity: %s | Stars: %d | Weight: %d",
				entity.DisplayName,
				entity.StarRating,
				entity.Weight
			))
		end
	end
end

function EntityService:_runEntityLoop()
	while true do
		for _, entity in ipairs(self.Entities) do
			if entity.IsActive then
				self:_updateEntity(entity, self.UpdateInterval)
			end
		end

		task.wait(self.UpdateInterval)
	end
end

function EntityService:_updateEntity(entity, deltaTime)
	local targetCharacter = self:_findNearestCharacter(entity)
	if targetCharacter then
		entity:SetTarget(targetCharacter.Player)
		
		if entity:HasAttribute(EntityAttributes.Chase) then
			entity:MoveToward(targetCharacter.RootPart.Position, deltaTime)
		end
		
		if entity:CanAttack() then
			local distance = (targetCharacter.RootPart.Position - entity:GetPosition()).Magnitude
			if distance <= entity.AttackRange then
				local didDamage = targetCharacter:ApplyDamage(entity.Damage)
				if didDamage then
					local targetPlayer = targetCharacter.Player
					targetCharacter:ApplyTemporarySpeedMultiplier("OnHitHaste", 1.45, 1.5)
					
					local interactionService = self.Services.InteractionService
					if interactionService and targetPlayer and interactionService:IsInteracting(targetPlayer) then
						interactionService:InterruptInteraction(targetPlayer, "Damaged")
					end
				end
				entity:MarkAttack()
				
				local player = targetCharacter.Player
				local name = player and player.Name or "Unknown"
				DebugLog:Log("Entity", string.format(
					"[EntityService] %s hit %s for %d",
					entity.Model.Name,
					name,
					entity.Damage
				))
			end
		end
	else
		entity:SetTarget(nil)
	end
end

function EntityService:_findNearestCharacter(entity)
	local roundManager = self.Services.RoundManager
	local characterService = self.Services.CharacterService

	if not roundManager or not characterService then
		return nil
	end

	local entityPosition = entity:GetPosition()
	if not entityPosition then
		return nil
	end

	local nearestCharacter = nil
	local nearestDistance = math.huge

	for _, player in ipairs(roundManager:GetActivePlayers()) do
		local roundState = roundManager:GetRoundState(player)
		if roundState and roundState.IsAlive then
			local character = characterService:GetCharacterByPlayer(player)
			if character and character.RootPart then
				local distance = (character.RootPart.Position - entityPosition).Magnitude
				if distance < nearestDistance then
					nearestDistance = distance
					nearestCharacter = character
				end
			end
		end
	end

	return nearestCharacter
end

function EntityService:SetAllEntitiesActive(state)
	for _, entity in ipairs(self.Entities) do
		entity:SetActive(state)
		
		if not state then
			entity:ResetToSpawn()
		end
	end

	DebugLog:Log("Entity", "[EntityService] Entities active:", state)
end

return EntityService
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="45">
          <Properties>
            <string name="Name">EscapeService</string>
            <string name="Source"><![CDATA[local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local EscapeService = {}
EscapeService.Name = "EscapeService"

function EscapeService:Init(services)
	self.Services = services
	self.EscapeZone = Workspace:WaitForChild("EscapeZone")
	self.TouchDebounce = {}
end

function EscapeService:Start()
	self.EscapeZone.Touched:Connect(function(hit)
		self:_onEscapeZoneTouched(hit)
	end)
	
	DebugLog:Log("Round", "[EscapeService] Started")
end

function EscapeService:_onEscapeZoneTouched(hit)
	local characterModel = hit and hit.Parent
	if not characterModel then
		return
	end
	
	local player = Players:GetPlayerFromCharacter(characterModel)
	if not player then
		return
	end
	
	if self.TouchDebounce[player] then
		return
	end
	
	self.TouchDebounce[player] = true
	
	self:TryEscapePlayer(player)
	
	task.delay(1, function()
		self.TouchDebounce[player] = nil
	end)
end

function EscapeService:TryEscapePlayer(player)
	local roundManager = self.Services.RoundManager
	if not roundManager then
		return
	end
	
	if not roundManager:IsReceptionActive() then
		return
	end
	
	if not roundManager:IsPlayerActive(player) then
		return
	end
	
	local roundState = roundManager:GetRoundState(player)
	if not roundState or not roundState.IsAlive then
		return
	end
	
	roundManager:SetPlayerEscaped(player)

	local character = self.Services.CharacterService:GetCharacterByPlayer(player)
	if character then
		character:Freeze()
		if character.RootPart then
			character.RootPart.CFrame = CFrame.new(0, -1000, 0) -- Temporary extraction method..
		end
	end

	DebugLog:Log("Round", "[EscapeService] Player escaped:", player.Name)
end

return EscapeService
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="46">
          <Properties>
            <string name="Name">InteractionService</string>
            <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")

local RemoteNames = require(ReplicatedStorage.Shared.Constants.RemoteNames)
local InteractableType = require(ReplicatedStorage.Shared.Enums.InteractableType)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local InteractionService = {}
InteractionService.Name = "InteractionService"

function InteractionService:Init(services)
	self.Services = services
	self.ActiveInteractions = {}
end

function InteractionService:Start()
	self.InteractionStateRemote = self.Services.RemoteRegistry:GetRemote(RemoteNames.InteractionStateChanged)
	self.UpdateInterval = 0.1
	
	local requestInteract = self.Services.RemoteRegistry:GetRemote(RemoteNames.RequestInteract)
	
	requestInteract.OnServerEvent:Connect(function(player, isStarting)
		DebugLog:Log("Interaction", string.format("[InteractionService] Remote received from %s (start=%s)", player.Name, tostring(isStarting)))
		if isStarting then
			self:StartInteraction(player)
		else
			self:StopInteraction(player)
		end
	end)
	
	task.spawn(function()
		self:_runInteractionLoop()
	end)
	
	DebugLog:Log("Interaction", "[InteractionService] Started")
end

function InteractionService:StartInteraction(player)
	local roundManager = self.Services.RoundManager
	if not roundManager or not roundManager:IsReceptionActive() then
		DebugLog:Log("Interaction", string.format("[InteractionService] Ignored start for %s: reception inactive", player.Name))
		return
	end
	
	local target = self:FindBestInteractable(player)
	if not target then
		DebugLog:Log("Interaction", string.format("[InteractionService] Ignored start for %s: no valid target", player.Name))
		return
	end
	
	self.ActiveInteractions[player] = {
		Target = target,
	}
	
	local character = self.Services.CharacterService:GetCharacterByPlayer(player)
	if character then
		character:SetSpeedMultiplier("InteractionSlow", 0.5)
	end
	
	self.InteractionStateRemote:FireClient(player, {
		State = "Start",
		Target = target.DisplayName,
		Progress = target.Progress or 0,
		Max = target.MaxProgress or 1,
	})
	
	DebugLog:Log("Interaction", string.format("[InteractionService] %s started interacting with %s", player.Name, target.DisplayName))
end

function InteractionService:StopInteraction(player)
	if self.ActiveInteractions[player] then
		local target = self.ActiveInteractions[player].Target
		local name = target and target.DisplayName or "Unknown"
		
		local character = self.Services.CharacterService:GetCharacterByPlayer(player)
		if character then
			character:SetSpeedMultiplier("InteractionSlow", nil)
		end
		
		self.InteractionStateRemote:FireClient(player, {
			State = "Stop"
		})
		
		DebugLog:Log("Interaction", string.format("[InteractionService] %s stopped interacting with %s", player.Name, name))
	end
	
	self.ActiveInteractions[player] = nil
end

function InteractionService:InterruptInteraction(player, reason)
	if not self.ActiveInteractions[player] then
		return false
	end
	
	self:StopInteraction(player)
	DebugLog:Log("Interaction", string.format("[InteractionService] %s interaction interrupted (%s)", player.Name, tostring(reason or "Unknown")))
	return true
end

function InteractionService:StopAllInteractions(reason)
	for player in pairs(self.ActiveInteractions) do
		self:InterruptInteraction(player, reason or "StoppedAll")
	end
end

function InteractionService:IsInteracting(player)
	return self.ActiveInteractions[player] ~= nil
end

function InteractionService:FindBestInteractable(player)
	local character = self.Services.CharacterService:GetCharacterByPlayer(player)
	if not character or not character.RootPart then
		return nil
	end
	
	local playerPosition = character.RootPart.Position
	local bestTarget = nil
	local bestDistance = math.huge
	
	for _, objective in ipairs(self.Services.ObjectiveService:GetObjectives()) do
		if objective.Type == InteractableType.Objective or objective.Type == "MapObjective" then
			if objective:CanInteract() and objective.Instance then
				local distance = (objective.Instance.Position - playerPosition).Magnitude
				if distance <= 12 and distance < bestDistance then
					bestTarget = objective
					bestDistance = distance
				end
			end
		end
	end
	
	return bestTarget
end

function InteractionService:_runInteractionLoop()
	while true do
		for player, interaction in pairs(self.ActiveInteractions) do
			self:_updateInteraction(player, interaction)
		end
		
		task.wait(self.UpdateInterval)
	end
end

function InteractionService:_updateInteraction(player, interaction)
	local target = interaction.Target
	
	if target.IsComplete then
		self.InteractionStateRemote:FireClient(player, {
			State = "Complete"
		})
		self:StopInteraction(player)
		return
	end
	
	if not target or target.IsComplete then
		self:StopInteraction(player)
		return
	end
	
	local character = self.Services.CharacterService:GetCharacterByPlayer(player)
	if not character or not character.RootPart then
		self:StopInteraction(player)
		return
	end
	
	local distance = (target.Instance.Position - character.RootPart.Position).Magnitude
	if distance > 12 then
		DebugLog:Log("Interaction", string.format("[InteractionService] %s moved too far from %s", player.Name, target.DisplayName))
		self:StopInteraction(player)
		return
	end
	
	local amount = target.ChargeRate * self.UpdateInterval
	local progressed = self.Services.ObjectiveService:ProgressObjective(target, amount)
	
	self.InteractionStateRemote:FireClient(player, {
		State = "Update",
		Target = target.DisplayName,
		Progress = target.Progress,
		Max = target.MaxProgress or 1,
	})
	
	if not progressed or target.IsComplete then
		self:StopInteraction(player)
	end
end

return InteractionService
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="47">
          <Properties>
            <string name="Name">ObjectiveService</string>
            <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")
local ServerScriptService = game:GetService("ServerScriptService")

local BaseObjective = require(ServerScriptService.Server.Classes.BaseObjective)
local ObjectiveDefinitions = require(ReplicatedStorage.Shared.Data.ObjectiveDefinitions)
local ObjectivePhase = require(ReplicatedStorage.Shared.Enums.ObjectivePhase)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local ObjectiveService = {}
ObjectiveService.Name = "ObjectiveService"

function ObjectiveService:Init(services)
	self.Services = services
	self.Objectives = {}
	
	self.ObjectivesFolder = Workspace:WaitForChild("Objectives")
end

function ObjectiveService:Start()
	self:_registerExistingObjectives()
	DebugLog:Log("Objectives", "[ObjectiveService] Started")
end

function ObjectiveService:_registerExistingObjectives()
	for _, instance in ipairs(self.ObjectivesFolder:GetChildren()) do
		local definition = ObjectiveDefinitions[instance.Name]
		local objective = BaseObjective.new(instance, definition)
		
		table.insert(self.Objectives, objective)
		
		DebugLog:Log("Objectives", string.format(
			"[ObjectiveService] Registered objective: %s | Type: %s | Phase: %s",
			objective.DisplayName,
			objective.Type,
			objective.Phase
		))
	end
end

function ObjectiveService:GetObjectives()
	return self.Objectives
end

function ObjectiveService:GetObjectivesByPhase(objectivePhase)
	local results = {}
	
	for _, objective in ipairs(self.Objectives) do
		if objective.Phase == objectivePhase then
			table.insert(results, objective)
		end
	end
	
	return results
end

function ObjectiveService:SetPhaseEnabled(objectivePhase, enabled)
	for _, objective in ipairs(self.Objectives) do
		if objective.Phase == objectivePhase then
			objective:SetEnabled(enabled)
		end
	end
	
	DebugLog:Log("Objectives", string.format("[ObjectiveService] Set phase '%s' enabled = %s", objectivePhase, tostring(enabled)))
end

function ObjectiveService:ResetObjectives()
	for _, objective in ipairs(self.Objectives) do
		objective.Progress = 0
		objective.LastLoggedProgressStep = -1
		objective.IsComplete = false
		objective.IsEnabled = objective.StartsEnabled
	end
	
	DebugLog:Log("Objectives", "[ObjectiveService] Objectives reset")
end

function ObjectiveService:TryProgressObjectiveByName(name, amount)
	for _, objective in ipairs(self.Objectives) do
		if objective.Id == name or objective.DisplayName == name or (objective.Instance and objective.Instance.Name == name) then
			return self:ProgressObjective(objective, amount)
		end
	end
	
	return false
end

function ObjectiveService:ProgressObjective(objective, amount)
	if not objective or objective.IsComplete then
		return false
	end
	
	local succeeded = objective:AddProgress(amount)
	if not succeeded then
		return false
	end

	local currentProgressStep = math.floor(objective.Progress)
	if currentProgressStep > (objective.LastLoggedProgressStep or -1) then
		objective.LastLoggedProgressStep = currentProgressStep
		DebugLog:Log("ObjectiveProgress", string.format(
			"[ObjectiveService] %s progress: %1.f / %1.f",
			objective.DisplayName,
			objective.Progress,
			objective.MaxProgress
		))
	end
	
	if objective.IsComplete then
		DebugLog:Log("Objectives", "[ObjectiveService] Completed objective:", objective.DisplayName)
		
		local roundManager = self.Services.RoundManager
		if roundManager and roundManager.OnObjectiveCompleted then
			roundManager:OnObjectiveCompleted(objective)
		end
	end
	
	return true
end

return ObjectiveService
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="48">
          <Properties>
            <string name="Name">PlayerService</string>
            <string name="Source"><![CDATA[local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local PlayerService = {}
PlayerService.Name = "PlayerService"

function PlayerService:Init()
	self.PlayerStates = {}
end

function PlayerService:Start()
	for _, player in ipairs(Players:GetPlayers()) do
		self:_onPlayerAdded(player)
	end
	
	Players.PlayerAdded:Connect(function(player)
		self:_onPlayerAdded(player)
	end)
	
	Players.PlayerRemoving:Connect(function(player)
		self:_onPlayerRemoving(player)
	end)
	
	DebugLog:Log("Player", "[PlayerService] Started")
end

function PlayerService:_onPlayerAdded(player)
	self.PlayerStates[player] = {
		IsAlive = true,
		HasEscaped = false,
		IsLoaded = true,
	}
	DebugLog:Log("Player", "[PlayerService] Added", player.Name)
end

function PlayerService:_onPlayerRemoving(player)
	self.PlayerStates[player] = nil
	DebugLog:Log("Player", "[PlayerService] Removed", player.Name)
end

function PlayerService:GetPlayerState(player)
	return self.PlayerStates[player]
end

function PlayerService:GetPlayers()
	local players = {}
	
	for player in pairs(self.PlayerStates) do
		table.insert(players, player)
	end
	
	return players
end

function PlayerService:SetAlive(player, isAlive)
	local state = self.PlayerStates[player]
	if state then
		state.IsAlive = isAlive
	end
end

return PlayerService
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="49">
          <Properties>
            <string name="Name">RemoteRegistry</string>
            <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")

local RemoteNames = require(ReplicatedStorage.Shared.Constants.RemoteNames)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local RemoteRegistry = {}
RemoteRegistry.Name = "RemoteRegistry"

function RemoteRegistry:Init()
	local sharedFolder = ReplicatedStorage:WaitForChild("Shared")
	local remotesFolder = sharedFolder:FindFirstChild("Remotes")
	if not remotesFolder then
		remotesFolder = Instance.new("Folder")
		remotesFolder.Name = "Remotes"
		remotesFolder.Parent = sharedFolder
	end
	
	for _, remoteName in pairs(RemoteNames) do
		if not remotesFolder:FindFirstChild(remoteName) then
			local remote = Instance.new("RemoteEvent")
			remote.Name = remoteName
			remote.Parent = remotesFolder
		end
	end
	
	self.RemotesFolder = remotesFolder
end

function RemoteRegistry:Start()
	DebugLog:Log("Boot", "[RemoteRegistry] Started")
end

function RemoteRegistry:GetRemote(name)
	return self.RemotesFolder:FindFirstChild(name)
end

return RemoteRegistry
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="50">
          <Properties>
            <string name="Name">SpawnService</string>
            <string name="Source"><![CDATA[local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local SpawnService = {}
SpawnService.Name = "SpawnService"

function SpawnService:Init(services)
	self.Services = services
	
	local spawnsFolder = Workspace:WaitForChild("Spawns")
	self.LobbySpawn = spawnsFolder:WaitForChild("LobbySpawn")
	self.ReceptionSpawnsFolder = spawnsFolder:WaitForChild("ReceptionSpawns")
end

function SpawnService:Start()
	DebugLog:Log("Spawn", "[SpawnService] Started")
end

function SpawnService:TeleportPlayerToLobby(player)
	local character = self.Services.CharacterService:GetCharacterByPlayer(player)
	if not character or not character.RootPart then
		return
	end
	
	character.RootPart.CFrame = self.LobbySpawn.CFrame + Vector3.new(0,3,0)
end

function SpawnService:TeleportPlayerToReception(player)
	local character = self.Services.CharacterService:GetCharacterByPlayer(player)
	if not character or not character.RootPart then
		return
	end
	
	local spawnPart = self:GetRandomReceptionSpawn()
	if not spawnPart then
		warn("[SpawnService] No reception spawn found!")
		return
	end
	
	character.RootPart.CFrame = spawnPart.CFrame + Vector3.new(0, 3, 0)
end

function SpawnService:GetRandomReceptionSpawn()
	local spawns = self.ReceptionSpawnsFolder:GetChildren()
	if #spawns == 0 then
		return nil
	end
	
	return spawns[math.random(1, #spawns)]
end

function SpawnService:TeleportPlayersToLobby(players)
	for _, player in ipairs(players) do
		self:TeleportPlayerToLobby(player)
	end
end

function SpawnService:TeleportPlayersToReception(players)
	for _, player in ipairs(players) do
		self:TeleportPlayerToReception(player)
	end
end

function SpawnService:TeleportAllPlayersToLobby()
	for player in pairs(self.Services.PlayerService.PlayerStates) do
		self:TeleportPlayerToLobby(player)
	end
end

function SpawnService:TeleportAllPlayersToReception()
	for player in pairs(self.Services.PlayerService.PlayerStates) do
		self:TeleportPlayerToReception(player)
	end
end

return SpawnService
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="51">
          <Properties>
            <string name="Name">WeaponService</string>
            <string name="Source"><![CDATA[local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local RemoteNames = require(ReplicatedStorage.Shared.Constants.RemoteNames)
local WeaponDefinitions = require(ReplicatedStorage.Shared.Data.WeaponDefinitions)
local WeaponAction = require(ReplicatedStorage.Shared.Enums.WeaponAction)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local WeaponService = {}
WeaponService.Name = "WeaponService"

function WeaponService:Init(services)
	self.Services = services
	self.PlayerWeapons = {}
end

function WeaponService:Start()
	self.RequestWeaponActionRemote = self.Services.RemoteRegistry:GetRemote(RemoteNames.RequestWeaponAction)
	self.WeaponStateChangedRemote = self.Services.RemoteRegistry:GetRemote(RemoteNames.WeaponStateChanged)

	self.RequestWeaponActionRemote.OnServerEvent:Connect(function(player, actionName)
		self:HandleWeaponAction(player, actionName)
	end)

	for _, player in ipairs(Players:GetPlayers()) do
		self:EquipDefaultWeapon(player)
	end

	Players.PlayerAdded:Connect(function(player)
		self:EquipDefaultWeapon(player)
	end)

	Players.PlayerRemoving:Connect(function(player)
		self.PlayerWeapons[player] = nil
	end)

	DebugLog:Log("Weapon", "[WeaponService] Started")
end

function WeaponService:HandleWeaponAction(player, actionName)
	local weaponState = self.PlayerWeapons[player]
	if not weaponState then
		return
	end

	local playerState = self.Services.PlayerService and self.Services.PlayerService:GetPlayerState(player)
	if not playerState or not playerState.IsAlive then
		DebugLog:Log("Weapon", string.format("[WeaponService] Ignored %s from %s: player not alive", tostring(actionName), player.Name))
		return
	end

	if actionName == WeaponAction.Fire then
		self:FireWeapon(player, weaponState)
	elseif actionName == WeaponAction.Reload then
		self:ReloadWeapon(player, weaponState)
	end
end

function WeaponService:EquipDefaultWeapon(player)
	local definition = WeaponDefinitions.Glock45
	if not definition then
		return
	end

	self.PlayerWeapons[player] = {
		WeaponId = definition.Id,
		AmmoInMagazine = definition.MagazineSize,
		ReserveAmmo = definition.ReserveAmmo,
		IsReloading = false,
		LastFireTime = 0,
		ReloadToken = 0,
	}

	self:SendWeaponState(player)
	DebugLog:Log("Weapon", string.format("[WeaponService] Equipped %s for %s", definition.Id, player.Name))
end

function WeaponService:FireWeapon(player, weaponState)
	local definition = WeaponDefinitions[weaponState.WeaponId]
	if not definition then
		return
	end

	if weaponState.IsReloading then
		DebugLog:Log("Weapon", string.format("[WeaponService] Ignored fire from %s: reload in progress", player.Name))
		return
	end

	local now = os.clock()
	if now - weaponState.LastFireTime < definition.FireCooldown then
		return
	end

	if weaponState.AmmoInMagazine <= 0 then
		DebugLog:Log("Weapon", string.format("[WeaponService] Ignored fire from %s: empty magazine", player.Name))
		return
	end

	weaponState.LastFireTime = now
	weaponState.AmmoInMagazine -= 1

	-- Hit detection and damage stay server-owned and can be layered in here later.
	self:SendWeaponState(player)
	DebugLog:Log(
		"Weapon",
		string.format(
			"[WeaponService] %s fired %s (%d/%d)",
			player.Name,
			weaponState.WeaponId,
			weaponState.AmmoInMagazine,
			weaponState.ReserveAmmo
		)
	)
end

function WeaponService:ReloadWeapon(player, weaponState)
	local definition = WeaponDefinitions[weaponState.WeaponId]
	if not definition then
		return
	end

	if weaponState.IsReloading then
		return
	end

	if weaponState.AmmoInMagazine >= definition.MagazineSize then
		return
	end

	if weaponState.ReserveAmmo <= 0 then
		return
	end

	weaponState.IsReloading = true
	weaponState.ReloadToken += 1
	local reloadToken = weaponState.ReloadToken

	self:SendWeaponState(player)
	DebugLog:Log("Weapon", string.format("[WeaponService] %s started reload for %s", player.Name, weaponState.WeaponId))

	task.delay(definition.ReloadDuration, function()
		local liveWeaponState = self.PlayerWeapons[player]
		if not liveWeaponState or liveWeaponState.ReloadToken ~= reloadToken then
			return
		end

		local missingAmmo = definition.MagazineSize - liveWeaponState.AmmoInMagazine
		local ammoToLoad = math.min(missingAmmo, liveWeaponState.ReserveAmmo)
		liveWeaponState.AmmoInMagazine += ammoToLoad
		liveWeaponState.ReserveAmmo -= ammoToLoad
		liveWeaponState.IsReloading = false

		self:SendWeaponState(player)
		DebugLog:Log("Weapon", string.format("[WeaponService] %s completed reload for %s", player.Name, liveWeaponState.WeaponId))
	end)
end

function WeaponService:SendWeaponState(player)
	local weaponState = self.PlayerWeapons[player]
	if not weaponState then
		return
	end

	self.WeaponStateChangedRemote:FireClient(player, {
		WeaponId = weaponState.WeaponId,
		AmmoInMagazine = weaponState.AmmoInMagazine,
		ReserveAmmo = weaponState.ReserveAmmo,
		IsReloading = weaponState.IsReloading,
	})
end

return WeaponService
]]></string>
          </Properties>
        </Item>
      </Item>
    </Item>
