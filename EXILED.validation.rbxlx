            <string name="Name">Controllers</string>
          </Properties>
          <Item class="ModuleScript" referent="115">
            <Properties>
              <string name="Name">ActionDispatcher</string>
              <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")

local ActionName = require(ReplicatedStorage.Shared.Enums.ActionName)
local RemoteNames = require(ReplicatedStorage.Shared.Constants.RemoteNames)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local ActionDispatcher = {}
ActionDispatcher.Name = "ActionDispatcher"

function ActionDispatcher:Init()
	self.Shared = ReplicatedStorage:WaitForChild("Shared")
	self.RemotesFolder = self.Shared:WaitForChild("Remotes")
	self.RequestInteractRemote = self.RemotesFolder:WaitForChild(RemoteNames.RequestInteract)
	self.LocalActionState = {
		Sprint = false,
		Crouch = false,
		Inventory = false,
		RadialMenu = false,
	}
end

function ActionDispatcher:Dispatch(actionName, phase)
	if actionName == ActionName.Interact then
		if phase == "Begin" then
			self.RequestInteractRemote:FireServer(true)
		elseif phase == "End" then
			self.RequestInteractRemote:FireServer(false)
		end
	elseif actionName == ActionName.Sprint then
		self.LocalActionState.Sprint = (phase == "Begin")
		DebugLog:Log("ClientInteraction", string.format("[ActionDispatcher] Sprint %s", self.LocalActionState.Sprint and "enabled" or "disabled"))
	elseif actionName == ActionName.Crouch then
		if phase == "Begin" then
			self.LocalActionState.Crouch = not self.LocalActionState.Crouch
			DebugLog:Log("ClientInteraction", string.format("[ActionDispatcher] Crouch %s", self.LocalActionState.Crouch and "enabled" or "disabled"))
		end
	elseif actionName == ActionName.Inventory then
		if phase == "Begin" then
			self.LocalActionState.Inventory = not self.LocalActionState.Inventory
			DebugLog:Log("ClientInteraction", string.format("[ActionDispatcher] Inventory %s", self.LocalActionState.Inventory and "enabled" or "disabled"))
		end
	elseif actionName == ActionName.RadialMenu then
		self.LocalActionState.RadialMenu = (phase == "Begin")
		DebugLog:Log("ClientInteraction", string.format("[ActionDispatcher] Radial menu %s", self.LocalActionState.RadialMenu and "enabled" or "disabled"))
	elseif phase == "Begin" then
		DebugLog:Log("ClientInteraction", string.format("[ActionDispatcher] %s triggered", tostring(actionName)))
	
	end
end

return ActionDispatcher
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="116">
            <Properties>
              <string name="Name">ActionResolver</string>
              <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")

local ActionResolutionRules = require(ReplicatedStorage.Shared.Data.ActionResolutionRules)

local ActionResolver = {}
ActionResolver.Name = "ActionResolver"

function ActionResolver:ResolveCandidate(candidateToken, contextSnapshot)
	local rules = ActionResolutionRules[candidateToken]
	if not rules then
		return nil
	end
	
	local bestRule = nil
	local bestPriority = -math.huge
	
	for _, rule in ipairs(rules) do
		local matchesContext = rule.context == nil or contextSnapshot[rule.context] == true
		if matchesContext and rule.priority > bestPriority then
			bestPriority = rule.priority
			bestRule = rule
		end
	end
	
	return bestRule and bestRule.action or nil
end

function ActionResolver:ResolveCandidates(candidateTokens, contextSnapshot)
	for _, candidateToken in ipairs(candidateTokens) do
		local resolvedAction = self:ResolveCandidate(candidateToken, contextSnapshot)
		if resolvedAction then
			return resolvedAction
		end
	end
	
	return nil
end

return ActionResolver
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="117">
            <Properties>
              <string name="Name">AuraRevealController</string>
              <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")

local RemoteNames = require(ReplicatedStorage.Shared.Constants.RemoteNames)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local COLORS = {
	Entity = Color3.fromRGB(99, 176, 255),
	Objective = Color3.fromRGB(108, 248, 255),
	Remnant = Color3.fromRGB(118, 255, 174),
	Loot = Color3.fromRGB(255, 223, 112),
}

local AuraRevealController = {}
AuraRevealController.Name = "AuraRevealController"

function AuraRevealController:Init()
	self.PlayerGui = self.World.PlayerGui
	self.Camera = self.World.Camera
	self.Remotes = self.World.Remotes
	self.Active = {}
end

function AuraRevealController:Start()
	self.Remote = self.Remotes:WaitForChild(RemoteNames.AuraRevealStateChanged)
	self.Remote.OnClientEvent:Connect(function(snapshot)
		self:_applySnapshot(snapshot or {})
	end)

	task.spawn(function()
		while true do
			self:_refresh()
			task.wait(0.1)
		end
	end)

	DebugLog:Log("ClientRemnant", "[AuraRevealController] Started")
end

function AuraRevealController:_applySnapshot(snapshot)
	local seen = {}
	local now = os.clock()

	for _, entry in ipairs(snapshot) do
		local instance = entry.Instance
		if instance and instance.Parent then
			seen[instance] = true
			local active = self.Active[instance]
			if not active then
				active = self:_createReveal(entry)
				self.Active[instance] = active
			end

			active.Type = entry.Type
			active.DisplayName = entry.DisplayName or instance.Name
			active.ExpiresAt = now + math.max(0, entry.Duration or 0)
			self:_styleReveal(active)
		end
	end

	for instance, active in pairs(self.Active) do
		if not seen[instance] then
			self:_destroyReveal(active)
			self.Active[instance] = nil
		end
	end
end

function AuraRevealController:_createReveal(entry)
	local instance = entry.Instance
	local highlight = Instance.new("Highlight")
	highlight.Name = "AuraReveal"
	highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
	highlight.FillTransparency = 0.78
	highlight.OutlineTransparency = 0.15
	highlight.Adornee = instance
	highlight.Parent = self.Camera or self.PlayerGui

	local billboard = Instance.new("BillboardGui")
	billboard.Name = "AuraRevealLabel"
	billboard.AlwaysOnTop = true
	billboard.Size = UDim2.new(0, 120, 0, 24)
	billboard.StudsOffset = Vector3.new(0, 3.5, 0)
	billboard.Adornee = self:_resolveAdornee(instance)
	billboard.Parent = self.PlayerGui

	local label = Instance.new("TextLabel")
	label.BackgroundTransparency = 1
	label.Size = UDim2.new(1, 0, 1, 0)
	label.Font = Enum.Font.GothamBold
	label.TextSize = 12
	label.TextStrokeTransparency = 0.55
	label.TextColor3 = Color3.fromRGB(255, 255, 255)
	label.Text = entry.DisplayName or instance.Name
	label.Parent = billboard

	return {
		Instance = instance,
		Highlight = highlight,
		Billboard = billboard,
		Label = label,
		Type = entry.Type,
		DisplayName = entry.DisplayName or instance.Name,
		ExpiresAt = os.clock(),
	}
end

function AuraRevealController:_resolveAdornee(instance)
	if instance:IsA("Model") then
		return instance.PrimaryPart or instance:FindFirstChild("HumanoidRootPart") or instance:FindFirstChildWhichIsA("BasePart")
	end

	if instance:IsA("BasePart") then
		return instance
	end

	return nil
end

function AuraRevealController:_styleReveal(active)
	local color = COLORS[active.Type] or Color3.fromRGB(180, 220, 255)
	active.Highlight.FillColor = color
	active.Highlight.OutlineColor = color
	active.Label.TextColor3 = color
	active.Label.Text = string.upper(active.DisplayName or "Reveal")
	active.Billboard.Adornee = self:_resolveAdornee(active.Instance)
end

function AuraRevealController:_refresh()
	local now = os.clock()
	for instance, active in pairs(self.Active) do
		if active.ExpiresAt <= now or instance == nil or instance.Parent == nil then
			self:_destroyReveal(active)
			self.Active[instance] = nil
		end
	end
end

function AuraRevealController:_destroyReveal(active)
	if active.Highlight then
		active.Highlight:Destroy()
	end

	if active.Billboard then
		active.Billboard:Destroy()
	end
end

return AuraRevealController
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="118">
            <Properties>
              <string name="Name">BreathHoldController</string>
              <string name="Source"><![CDATA[local TweenService = game:GetService("TweenService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local RemoteNames = require(ReplicatedStorage.Shared.Constants.RemoteNames)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local BreathHoldController = {}
BreathHoldController.Name = "BreathHoldController"

function BreathHoldController:Init()
	self.Active = false
	self.Mode = "Idle"
	self.IsHolding = false
	self.RemainingDuration = 0
	self.Breath = 1
	self.IndicatorToken = 0
	self.Remote = self.World.Remotes:WaitForChild(RemoteNames.BreathHoldStateChanged)
	self.RequestRemote = self.World.Remotes:WaitForChild(RemoteNames.RequestBreathHoldState)
end

function BreathHoldController:Start()
	self:_createUI()

	self.Remote.OnClientEvent:Connect(function(payload)
		self:_handleRemote(payload)
	end)

	task.spawn(function()
		while true do
			self:_updateUi(0.05)
			task.wait(0.05)
		end
	end)

	DebugLog:Log("ClientInteraction", "[BreathHoldController] Started")
end

function BreathHoldController:IsActive()
	return self.Active
end

function BreathHoldController:RequiresHoldInput()
	return self.Active and self.Mode == "Challenge"
end

function BreathHoldController:SetHolding(isHolding)
	if not self.Active or self.IsHolding == isHolding then
		return
	end

	self.IsHolding = isHolding
	self.RequestRemote:FireServer(isHolding)
	self:_refreshVisuals()
end

function BreathHoldController:_handleRemote(payload)
	local state = payload and payload.State
	if state == "Indicator" then
		self.Active = true
		self.Mode = "Indicator"
		self.IsHolding = false
		self.RemainingDuration = payload.Duration or 0
		self.Breath = 1
		self.UI.Root.Enabled = true
		self.UI.Label.Text = payload.Prompt or "Breathless Hunt"
		self.UI.SubLabel.Text = payload.SubPrompt or "Be ready to hold your breath"
		self.UI.KeyLabel.Text = payload.RequiredKey or "GET READY"
		self:_playIndicatorVfx(self.RemainingDuration)
		self:_refreshVisuals()
	elseif state == "Start" or state == "Update" then
		self.Active = true
		self.Mode = "Challenge"
		self.RemainingDuration = payload.Duration or self.RemainingDuration
		self.Breath = payload.Breath or self.Breath
		self.UI.Root.Enabled = true
		self.UI.Label.Text = payload.Prompt or "Hold your breath"
		self.UI.SubLabel.Text = payload.SubPrompt or "Conserve your breath"
		self.UI.KeyLabel.Text = payload.RequiredKey or "SPACE"
		self:_refreshVisuals()
	else
		self.Active = false
		self.Mode = "Idle"
		self.IsHolding = false
		self.RemainingDuration = 0
		self.Breath = 1
		self.IndicatorToken += 1
		self:_setIndicatorVisible(false)
		self.UI.Root.Enabled = false
	end
end

function BreathHoldController:_updateUi(deltaTime)
	if not self.Active then
		return
	end

	self.RemainingDuration = math.max(0, self.RemainingDuration - deltaTime)
	self.UI.Duration.Text = string.format("%.1fs", self.RemainingDuration)
	local urgent = self.RemainingDuration <= 1
	self.UI.Duration.TextColor3 = urgent and Color3.fromRGB(228, 112, 112) or Color3.fromRGB(220, 230, 236)
end

function BreathHoldController:_refreshVisuals()
	local ratio = math.clamp(self.Breath or 0, 0, 1)
	self.UI.Bar.Size = UDim2.new(ratio, 0, 1, 0)

	if self.Mode == "Indicator" then
		self.UI.ProgressLabel.Text = "Warning"
		self.UI.KeyLabel.BackgroundColor3 = Color3.fromRGB(88, 103, 122)
		self.UI.KeyLabel.TextColor3 = Color3.fromRGB(220, 230, 236)
		self.UI.Bar.BackgroundColor3 = Color3.fromRGB(176, 188, 198)
		self.UI.Duration.TextColor3 = Color3.fromRGB(220, 230, 236)
		return
	end

	self.UI.ProgressLabel.Text = string.format("Breath %d%%", math.floor((ratio * 100) + 0.5))
	self.UI.KeyLabel.BackgroundColor3 = self.IsHolding and Color3.fromRGB(132, 183, 150) or Color3.fromRGB(61, 72, 84)
	self.UI.KeyLabel.TextColor3 = self.IsHolding and Color3.fromRGB(18, 19, 24) or Color3.fromRGB(220, 230, 236)
	if ratio <= 0.2 then
		self.UI.Bar.BackgroundColor3 = Color3.fromRGB(222, 108, 108)
	elseif ratio <= 0.45 then
		self.UI.Bar.BackgroundColor3 = Color3.fromRGB(226, 177, 90)
	else
		self.UI.Bar.BackgroundColor3 = Color3.fromRGB(132, 183, 150)
	end
end

function BreathHoldController:_createUI()
	local screenGui = Instance.new("ScreenGui")
	screenGui.Name = "BreathHoldUI"
	screenGui.Enabled = false
	screenGui.ResetOnSpawn = false
	screenGui.DisplayOrder = 20
	screenGui.Parent = self.World.PlayerGui

	local fogOverlay = Instance.new("Frame")
	fogOverlay.Name = "FogOverlay"
	fogOverlay.Size = UDim2.fromScale(1, 1)
	fogOverlay.BackgroundColor3 = Color3.fromRGB(190, 204, 214)
	fogOverlay.BackgroundTransparency = 1
	fogOverlay.BorderSizePixel = 0
	fogOverlay.Visible = false
	fogOverlay.Parent = screenGui

	local fogBand = Instance.new("Frame")
	fogBand.Name = "FogBand"
	fogBand.AnchorPoint = Vector2.new(0.5, 0)
	fogBand.Position = UDim2.fromScale(0.5, -0.55)
	fogBand.Size = UDim2.fromScale(1.4, 0.42)
	fogBand.BackgroundColor3 = Color3.fromRGB(214, 224, 232)
	fogBand.BackgroundTransparency = 0.35
	fogBand.BorderSizePixel = 0
	fogBand.Visible = false
	fogBand.Parent = screenGui

	local fogGradient = Instance.new("UIGradient")
	fogGradient.Rotation = 90
	fogGradient.Transparency = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 1),
		NumberSequenceKeypoint.new(0.18, 0.55),
		NumberSequenceKeypoint.new(0.5, 0.2),
		NumberSequenceKeypoint.new(0.82, 0.55),
		NumberSequenceKeypoint.new(1, 1),
	})
	fogGradient.Parent = fogBand

	local container = Instance.new("Frame")
	container.Name = "Container"
	container.AnchorPoint = Vector2.new(0.5, 0.32)
	container.Position = UDim2.new(0.5, 0, 0.32, 0)
	container.Size = UDim2.new(0, 340, 0, 96)
	container.BackgroundColor3 = Color3.fromRGB(14, 18, 24)
	container.BackgroundTransparency = 0.08
	container.BorderSizePixel = 0
	container.Parent = screenGui

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 10)
	corner.Parent = container

	local label = Instance.new("TextLabel")
	label.Name = "Label"
	label.Position = UDim2.new(0, 14, 0, 10)
	label.Size = UDim2.new(1, -28, 0, 20)
	label.BackgroundTransparency = 1
	label.Font = Enum.Font.GothamBold
	label.TextColor3 = Color3.fromRGB(220, 230, 236)
	label.TextSize = 17
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.Text = "Hold your breath"
	label.Parent = container

	local subLabel = Instance.new("TextLabel")
	subLabel.Name = "SubLabel"
	subLabel.Position = UDim2.new(0, 14, 0, 32)
	subLabel.Size = UDim2.new(1, -110, 0, 18)
	subLabel.BackgroundTransparency = 1
	subLabel.Font = Enum.Font.Gotham
	subLabel.TextColor3 = Color3.fromRGB(162, 176, 187)
	subLabel.TextSize = 12
	subLabel.TextXAlignment = Enum.TextXAlignment.Left
	subLabel.Text = "Jiangshi is listening for breath"
	subLabel.Parent = container

	local duration = Instance.new("TextLabel")
	duration.Name = "Duration"
	duration.Position = UDim2.new(1, -78, 0, 12)
	duration.Size = UDim2.new(0, 64, 0, 20)
	duration.BackgroundTransparency = 1
	duration.Font = Enum.Font.GothamBold
	duration.TextColor3 = Color3.fromRGB(220, 230, 236)
	duration.TextSize = 14
	duration.TextXAlignment = Enum.TextXAlignment.Right
	duration.Text = "0.0s"
	duration.Parent = container

	local keyLabel = Instance.new("TextLabel")
	keyLabel.Name = "KeyLabel"
	keyLabel.Position = UDim2.new(0, 14, 0, 58)
	keyLabel.Size = UDim2.new(0, 84, 0, 26)
	keyLabel.BackgroundColor3 = Color3.fromRGB(61, 72, 84)
	keyLabel.BorderSizePixel = 0
	keyLabel.Font = Enum.Font.GothamBold
	keyLabel.TextColor3 = Color3.fromRGB(220, 230, 236)
	keyLabel.TextSize = 15
	keyLabel.Text = "SPACE"
	keyLabel.Parent = container

	local keyCorner = Instance.new("UICorner")
	keyCorner.CornerRadius = UDim.new(0, 8)
	keyCorner.Parent = keyLabel

	local progressLabel = Instance.new("TextLabel")
	progressLabel.Name = "ProgressLabel"
	progressLabel.Position = UDim2.new(1, -116, 0, 60)
	progressLabel.Size = UDim2.new(0, 102, 0, 18)
	progressLabel.BackgroundTransparency = 1
	progressLabel.Font = Enum.Font.GothamBold
	progressLabel.TextColor3 = Color3.fromRGB(188, 210, 218)
	progressLabel.TextSize = 12
	progressLabel.TextXAlignment = Enum.TextXAlignment.Right
	progressLabel.Text = "Release = fail"
	progressLabel.Parent = container

	local barBackground = Instance.new("Frame")
	barBackground.Name = "BarBackground"
	barBackground.Position = UDim2.new(0, 108, 0, 64)
	barBackground.Size = UDim2.new(1, -122, 0, 10)
	barBackground.BackgroundColor3 = Color3.fromRGB(44, 53, 63)
	barBackground.BorderSizePixel = 0
	barBackground.Parent = container

	local bgCorner = Instance.new("UICorner")
	bgCorner.CornerRadius = UDim.new(0, 6)
	bgCorner.Parent = barBackground

	local bar = Instance.new("Frame")
	bar.Name = "Bar"
	bar.Size = UDim2.new(0, 0, 1, 0)
	bar.BackgroundColor3 = Color3.fromRGB(132, 183, 150)
	bar.BorderSizePixel = 0
	bar.Parent = barBackground

	local barCorner = Instance.new("UICorner")
	barCorner.CornerRadius = UDim.new(0, 6)
	barCorner.Parent = bar

	self.UI = {
		Root = screenGui,
		FogOverlay = fogOverlay,
		FogBand = fogBand,
		Label = label,
		SubLabel = subLabel,
		Duration = duration,
		KeyLabel = keyLabel,
		ProgressLabel = progressLabel,
		Bar = bar,
	}
end

function BreathHoldController:_playIndicatorVfx(duration)
	self.IndicatorToken += 1
	local token = self.IndicatorToken
	local fogOverlay = self.UI.FogOverlay
	local fogBand = self.UI.FogBand

	if not fogOverlay or not fogBand then
		return
	end

	self:_setIndicatorVisible(true)
	fogOverlay.BackgroundTransparency = 1
	fogBand.BackgroundTransparency = 0.35
	fogBand.Position = UDim2.fromScale(0.5, -0.55)

	local overlayIn = TweenService:Create(fogOverlay, TweenInfo.new(math.min(0.2, duration * 0.2), Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {
		BackgroundTransparency = 0.88,
	})
	local bandSweep = TweenService:Create(fogBand, TweenInfo.new(duration, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
		Position = UDim2.fromScale(0.5, 1.08),
		BackgroundTransparency = 0.65,
	})
	local overlayOut = TweenService:Create(fogOverlay, TweenInfo.new(math.min(0.35, duration * 0.25), Enum.EasingStyle.Sine, Enum.EasingDirection.In), {
		BackgroundTransparency = 1,
	})

	overlayIn:Play()
	bandSweep:Play()

	task.spawn(function()
		task.wait(math.max(0, duration - 0.3))
		if self.IndicatorToken ~= token then
			return
		end

		overlayOut:Play()
	end)

	task.spawn(function()
		bandSweep.Completed:Wait()
		if self.IndicatorToken ~= token then
			return
		end

		self:_setIndicatorVisible(false)
	end)
end

function BreathHoldController:_setIndicatorVisible(isVisible)
	if not self.UI then
		return
	end

	self.UI.FogOverlay.Visible = isVisible
	self.UI.FogBand.Visible = isVisible
end

return BreathHoldController
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="119">
            <Properties>
              <string name="Name">CameraInputController</string>
              <string name="Source"><![CDATA[local ContextActionService = game:GetService("ContextActionService")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local GamePhase = require(ReplicatedStorage.Shared.Enums.GamePhase)
local PerspectiveMode = require(ReplicatedStorage.Shared.Enums.PerspectiveMode)
local RemoteNames = require(ReplicatedStorage.Shared.Constants.RemoteNames)
local FirearmAim = require(ReplicatedStorage.Shared.Utility.FirearmAim)
local WeaponDefinitions = require(ReplicatedStorage.Shared.Data.WeaponDefinitions)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)
local WorldModeResolver = require(ReplicatedStorage.Shared.Utility.WorldModeResolver)

local CameraInputController = {}
CameraInputController.Name = "CameraInputController"
CameraInputController.Dependencies = {
	"RoundController",
	"DevMenuController",
	"ContextController",
	"CombatController",
}

local FREE_MOUSE_ACTION = "CameraInputController.FreeMouse"
local CAMERA_BIND_NAME = "CameraInputController.UpdateCamera"
local CAMERA_SENSITIVITY = 0.0056
local CAMERA_PITCH_LIMIT = math.rad(75)
local CAMERA_DISTANCE = 14
local CAMERA_HEIGHT = 2.45
local CAMERA_SHOULDER_OFFSET = 2.15
local CAMERA_FOCUS_FORWARD = 2.4
local CAMERA_FIELD_OF_VIEW = 70
local FIRST_PERSON_HEAD_OFFSET = Vector3.new(0, 0.55, 0)
local FIRST_PERSON_FOCUS_DISTANCE = 1.5

function CameraInputController:Init()
	self.FreeMouseHeld = false
	self.IsLocked = false
	self.IsUsingCustomCamera = false
	self.Yaw = 0
	self.Pitch = math.rad(-8)
	self.ActiveCameraCue = nil
	self.DefaultFieldOfView = CAMERA_FIELD_OF_VIEW
	self.CurrentFieldOfView = CAMERA_FIELD_OF_VIEW
	self.CurrentCameraDistance = CAMERA_DISTANCE
	self.CurrentShoulderOffset = CAMERA_SHOULDER_OFFSET
	self.CurrentFocusForward = CAMERA_FOCUS_FORWARD
	self.RecoilPitchOffset = 0
	self.RecoilYawOffset = 0
	self.RecoilRecoverySpeed = 10
	self.PerspectiveMode = PerspectiveMode.ThirdPerson
end

function CameraInputController:Start()
	self.PlayCutsceneRemote = self.World.Remotes:WaitForChild(RemoteNames.PlayCutscene)
	self.DefaultFieldOfView = self.World.Camera.FieldOfView
	self.CurrentFieldOfView = self.DefaultFieldOfView

	ContextActionService:BindActionAtPriority(
		FREE_MOUSE_ACTION,
		function(_, inputState)
			if inputState == Enum.UserInputState.Begin then
				self.FreeMouseHeld = true
			elseif inputState == Enum.UserInputState.End or inputState == Enum.UserInputState.Cancel then
				self.FreeMouseHeld = false
			end

			self:_applyCameraMode()
			return Enum.ContextActionResult.Pass
		end,
		false,
		Enum.ContextActionPriority.High.Value,
		Enum.KeyCode.LeftAlt
	)

	RunService:BindToRenderStep(CAMERA_BIND_NAME, Enum.RenderPriority.Camera.Value + 1, function(deltaTime)
		self:_update(deltaTime)
	end)

	self.PlayCutsceneRemote.OnClientEvent:Connect(function(payload)
		self:_handleCameraCue(payload)
	end)

	DebugLog:Log("ClientMovement", "[CameraInputController] Started")
end

function CameraInputController:_update(deltaTime)
	if self:_updateCameraCue() then
		return
	end

	local shouldLock = self:_shouldLockMouse()
	self:_applyCameraMode(shouldLock)
	if shouldLock then
		self:_updateCustomCamera(deltaTime)
	end
end

function CameraInputController:GetPerspectiveMode()
	return self.PerspectiveMode
end

function CameraInputController:IsFirstPerson()
	return self.PerspectiveMode == PerspectiveMode.FirstPerson
end

function CameraInputController:TogglePerspective()
	if self.PerspectiveMode == PerspectiveMode.FirstPerson then
		self.PerspectiveMode = PerspectiveMode.ThirdPerson
	else
		self.PerspectiveMode = PerspectiveMode.FirstPerson
	end
end

function CameraInputController:_resolveCueTarget(targetNames)
	for _, targetName in ipairs(targetNames or {}) do
		local target = Workspace:FindFirstChild(targetName, true)
		if target then
			if target:IsA("BasePart") then
				return target.CFrame.Position
			end

			if target:IsA("Model") then
				local adornee = target.PrimaryPart or target:FindFirstChild("HumanoidRootPart") or target:FindFirstChildWhichIsA("BasePart")
				if adornee then
					return adornee.Position
				end
			end
		end
	end

	return nil
end

function CameraInputController:_handleCameraCue(payload)
	if type(payload) ~= "table" or payload.Type ~= "FocusTarget" then
		return
	end

	local focusPosition = self:_resolveCueTarget(payload.TargetNames)
	if not focusPosition then
		return
	end

	local cameraOffset = payload.CameraOffset or {}
	local lookOffset = payload.LookOffset or {}
	local currentCFrame = self.World.Camera.CFrame
	local targetLookPosition = focusPosition + Vector3.new(
		tonumber(lookOffset.X) or 0,
		tonumber(lookOffset.Y) or 0,
		tonumber(lookOffset.Z) or 0
	)
	local targetCameraPosition = focusPosition + Vector3.new(
		tonumber(cameraOffset.X) or 0,
		tonumber(cameraOffset.Y) or 0,
		tonumber(cameraOffset.Z) or 0
	)

	self.ActiveCameraCue = {
		StartedAt = os.clock(),
		TweenTime = math.max(0.01, tonumber(payload.TweenTime) or 0.35),
		ExpiresAt = os.clock() + math.max(0.1, tonumber(payload.Duration) or 1.2),
		FromCFrame = currentCFrame,
		TargetCFrame = CFrame.lookAt(targetCameraPosition, targetLookPosition),
	}
end

function CameraInputController:_updateCameraCue()
	local cue = self.ActiveCameraCue
	if not cue then
		return false
	end

	local now = os.clock()
	if now >= cue.ExpiresAt then
		self.ActiveCameraCue = nil
		self:_applyCameraMode(self:_shouldLockMouse())
		return false
	end

	local alpha = math.clamp((now - cue.StartedAt) / cue.TweenTime, 0, 1)
	self.World.Camera.CameraType = Enum.CameraType.Scriptable
	self.World.Camera.CFrame = cue.FromCFrame:Lerp(cue.TargetCFrame, alpha)
	self.World.Camera.FieldOfView = self.DefaultFieldOfView
	self.IsUsingCustomCamera = false
	self.IsLocked = false
	UserInputService.MouseBehavior = Enum.MouseBehavior.Default
	UserInputService.MouseIconEnabled = true
	return true
end

function CameraInputController:_shouldLockMouse()
	if self.FreeMouseHeld then
		return false
	end

	if UserInputService:GetFocusedTextBox() then
		return false
	end

	if self.DevMenuController and self.DevMenuController:IsVisible() then
		return false
	end

	local contextSnapshot = self.ContextController and self.ContextController:GetSnapshot() or {}
	if contextSnapshot.InventoryOpen or contextSnapshot.RadialMenuOpen then
		return false
	end

	local roundState = self.RoundController and self.RoundController:GetState() or nil
	local phase = roundState and roundState.Phase or "Unknown"
	if not WorldModeResolver.IsWeaponLab() and phase ~= GamePhase.Preparation and phase ~= GamePhase.Reception then
		return false
	end

	local character = self.World:GetCharacter()
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if not character or not humanoid or humanoid.Health <= 0 then
		return false
	end

	return true
end

function CameraInputController:_applyCameraMode(shouldLock)
	shouldLock = shouldLock == true
	local camera = self.World.Camera
	local character = self.World:GetCharacter()
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")

	if self.IsLocked == shouldLock and self.IsUsingCustomCamera == shouldLock then
		return
	end

	self.IsLocked = shouldLock
	UserInputService.MouseBehavior = shouldLock and Enum.MouseBehavior.LockCenter or Enum.MouseBehavior.Default
	UserInputService.MouseIconEnabled = not shouldLock

	if shouldLock then
		self:_syncAnglesFromCamera()
		camera.CameraType = Enum.CameraType.Scriptable
		self.IsUsingCustomCamera = true
	else
		camera.CameraType = Enum.CameraType.Custom
		camera.FieldOfView = self.DefaultFieldOfView
		self.CurrentFieldOfView = self.DefaultFieldOfView
		self.CurrentCameraDistance = CAMERA_DISTANCE
		self.CurrentShoulderOffset = CAMERA_SHOULDER_OFFSET
		self.CurrentFocusForward = CAMERA_FOCUS_FORWARD
		if humanoid then
			camera.CameraSubject = humanoid
		end
		self.IsUsingCustomCamera = false
	end
end

function CameraInputController:_syncAnglesFromCamera()
	local lookVector = self.World.Camera.CFrame.LookVector
	self.Yaw = math.atan2(-lookVector.X, -lookVector.Z)
	self.Pitch = math.clamp(math.asin(lookVector.Y), -CAMERA_PITCH_LIMIT, CAMERA_PITCH_LIMIT)
end

function CameraInputController:_getFirearmHandlingState()
	local combatState = self.CombatController and self.CombatController:GetState() or nil
	if not combatState or combatState.WeaponKind ~= "Firearm" then
		return nil, combatState, self.CombatController and self.CombatController:GetEquippedDefinition() or nil
	end

	return FirearmAim.GetHandlingData(WeaponDefinitions[combatState.EquippedWeaponId]), combatState, WeaponDefinitions[combatState.EquippedWeaponId]
end

function CameraInputController:AddFirearmKick(kickPitch, kickYaw, recoilRecovery)
	self.RecoilPitchOffset += math.rad(tonumber(kickPitch) or 0)
	local yawMagnitude = math.rad(tonumber(kickYaw) or 0)
	if yawMagnitude > 0 then
		local direction = math.random(0, 1) == 0 and -1 or 1
		self.RecoilYawOffset += yawMagnitude * direction
	end
	if tonumber(recoilRecovery) and recoilRecovery > 0 then
		self.RecoilRecoverySpeed = recoilRecovery
	end
end

function CameraInputController:_updateCustomCamera(deltaTime)
	local character = self.World:GetCharacter()
	if not character then
		return
	end

	local humanoid = character:FindFirstChildOfClass("Humanoid")
	local rootPart = character:FindFirstChild("HumanoidRootPart")
	if not humanoid or not rootPart or humanoid.Health <= 0 then
		return
	end

	local delta = UserInputService:GetMouseDelta()
	self.Yaw -= delta.X * CAMERA_SENSITIVITY
	self.Pitch = math.clamp(self.Pitch - delta.Y * CAMERA_SENSITIVITY, -CAMERA_PITCH_LIMIT, CAMERA_PITCH_LIMIT)

	local handling, combatState, equippedDefinition = self:_getFirearmHandlingState()
	local isAimingFirearm = handling ~= nil and combatState and combatState.IsAiming == true
	local isFirstPerson = self:IsFirstPerson()
	local targetDistance = isAimingFirearm and handling.AimCameraDistance or CAMERA_DISTANCE
	local targetShoulderOffset = isAimingFirearm and handling.AimShoulderOffset or CAMERA_SHOULDER_OFFSET
	local targetFocusForward = isAimingFirearm and handling.AimFocusForward or CAMERA_FOCUS_FORWARD
	local targetFieldOfView = isAimingFirearm and handling.AimFov or self.DefaultFieldOfView
	local blendSpeed = isAimingFirearm and 12 or 9

	if isFirstPerson then
		targetDistance = 0
		targetShoulderOffset = 0
		targetFocusForward = FIRST_PERSON_FOCUS_DISTANCE
		targetFieldOfView = isAimingFirearm
			and (handling.FirstPersonAimFov or handling.AimFov or self.DefaultFieldOfView)
			or ((equippedDefinition and equippedDefinition.FirstPersonFov) or (handling and handling.FirstPersonFov) or self.DefaultFieldOfView)
	end

	self.CurrentCameraDistance += (targetDistance - self.CurrentCameraDistance) * math.clamp(deltaTime * blendSpeed, 0, 1)
	self.CurrentShoulderOffset += (targetShoulderOffset - self.CurrentShoulderOffset) * math.clamp(deltaTime * blendSpeed, 0, 1)
	self.CurrentFocusForward += (targetFocusForward - self.CurrentFocusForward) * math.clamp(deltaTime * blendSpeed, 0, 1)
	self.CurrentFieldOfView += (targetFieldOfView - self.CurrentFieldOfView) * math.clamp(deltaTime * blendSpeed, 0, 1)
	self.RecoilPitchOffset += (0 - self.RecoilPitchOffset) * math.clamp(deltaTime * self.RecoilRecoverySpeed, 0, 1)
	self.RecoilYawOffset += (0 - self.RecoilYawOffset) * math.clamp(deltaTime * self.RecoilRecoverySpeed, 0, 1)

	local yawCFrame = CFrame.Angles(0, self.Yaw, 0)
	local pitchCFrame = CFrame.Angles(
		math.clamp(self.Pitch + self.RecoilPitchOffset, -CAMERA_PITCH_LIMIT, CAMERA_PITCH_LIMIT),
		0,
		0
	)
	local recoilYawCFrame = CFrame.Angles(0, self.RecoilYawOffset, 0)
	local lookCFrame = yawCFrame * recoilYawCFrame * pitchCFrame
	local lookVector = lookCFrame.LookVector
	local rightVector = yawCFrame.RightVector

	local focusOrigin = rootPart.Position + Vector3.new(0, CAMERA_HEIGHT, 0)
	local cameraPosition = nil
	local focusPoint = nil
	if isFirstPerson then
		local head = character:FindFirstChild("Head")
		local headPosition = head and head.Position or (rootPart.Position + Vector3.new(0, 1.55, 0))
		cameraPosition = headPosition + (rightVector * FIRST_PERSON_HEAD_OFFSET.X) + Vector3.new(0, FIRST_PERSON_HEAD_OFFSET.Y, 0)
		focusPoint = cameraPosition + (lookVector * self.CurrentFocusForward)
	else
		focusPoint = focusOrigin + (lookVector * self.CurrentFocusForward)
		cameraPosition = focusPoint - (lookVector * self.CurrentCameraDistance) + (rightVector * self.CurrentShoulderOffset)
	end

	self.World.Camera.CFrame = CFrame.lookAt(cameraPosition, focusPoint)
	self.World.Camera.FieldOfView = self.CurrentFieldOfView
end

return CameraInputController
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="120">
            <Properties>
              <string name="Name">CombatController</string>
              <string name="Source"><![CDATA[local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local ActionName = require(ReplicatedStorage.Shared.Enums.ActionName)
local GamePhase = require(ReplicatedStorage.Shared.Enums.GamePhase)
local RemoteNames = require(ReplicatedStorage.Shared.Constants.RemoteNames)
local ItemDefinitions = require(ReplicatedStorage.Shared.Data.ItemDefinitions)
local WeaponDefinitions = require(ReplicatedStorage.Shared.Data.WeaponDefinitions)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local CombatController = {}
CombatController.Name = "CombatController"
CombatController.Dependencies = {
	"QTEController",
	"BreathHoldController",
}

local SLOT_HEIGHT = 54
local SLOT_PADDING = 6
local SLOT_WIDTH = 150
local BASE_CONTAINER_OFFSET_Y = -18
local SLOT_STACK_GAP = 12

function CombatController:Init()
	self.PlayerGui = self.World.PlayerGui
	self.Remotes = self.World.Remotes
	self.RequestPrimaryAttackRemote = self.Remotes:WaitForChild(RemoteNames.RequestPrimaryAttack)
	self.RequestMovementStateRemote = self.Remotes:WaitForChild(RemoteNames.RequestMovementState)
	self.RequestReloadRemote = self.Remotes:WaitForChild(RemoteNames.RequestReload)
	self.RequestEquipWeaponRemote = self.Remotes:WaitForChild(RemoteNames.RequestEquipWeapon)
	self.RequestUseInventoryItemRemote = self.Remotes:WaitForChild(RemoteNames.RequestUseInventoryItem)
	self.CombatStateChangedRemote = self.Remotes:WaitForChild(RemoteNames.CombatStateChanged)
	self.CombatHitConfirmedRemote = self.Remotes:WaitForChild(RemoteNames.CombatHitConfirmed)
	self.State = {
		EquippedWeaponId = nil,
		EquippedSlot = 1,
		DisplayName = "Unarmed",
		Durability = 0,
		MaxDurability = 0,
		CurrentAmmo = 0,
		MaxAmmo = 0,
		ReserveAmmo = 0,
		WeaponKind = nil,
		Cooldown = 0,
		MaxCooldown = 0,
		IsReloading = false,
		ReloadRemaining = 0,
		ReloadDuration = 0,
		IsBroken = false,
		Weapons = {},
		IsUsingItem = false,
		ItemUseDisplayName = nil,
		ItemUseRemaining = 0,
		ItemUseDuration = 0,
		IsAiming = false,
	}
	self.LastHitAt = 0
	self.LastHitTargetName = nil
	self.LocalAimHeld = false
end

function CombatController:Start()
	self:_createUI()

	self.CombatStateChangedRemote.OnClientEvent:Connect(function(payload)
		self.State = payload or self.State
		self:_refreshUi()
	end)

	self.CombatHitConfirmedRemote.OnClientEvent:Connect(function(payload)
		self.LastHitAt = os.clock()
		self.LastHitTargetName = payload and payload.TargetName or "Entity"
		self:_refreshUi()
	end)

	UserInputService.InputBegan:Connect(function(input, gameProcessedEvent)
		if gameProcessedEvent then
			return
		end

		if UserInputService:GetFocusedTextBox() then
			return
		end

		if input.UserInputType == Enum.UserInputType.MouseButton2 then
			if self:_canAim() then
				self.LocalAimHeld = true
				self.RequestMovementStateRemote:FireServer(ActionName.Aim, true)
			end
			return
		end

		if input.UserInputType ~= Enum.UserInputType.MouseButton1 then
			if self.State.IsUsingItem and (self.State.ItemUseRemaining or 0) > 0 then
				return
			end

			if self.QTEController and self.QTEController:IsActive() then
				return
			end

			if self.BreathHoldController and self.BreathHoldController:RequiresHoldInput() then
				return
			end

			local requestedSlot = self:_getRequestedSlotFromInput(input)
			if requestedSlot then
				local slotState = self.State.Weapons and self.State.Weapons[requestedSlot]
				if slotState and slotState.EntryType == "Item" then
					self.RequestUseInventoryItemRemote:FireServer(requestedSlot)
				else
					self.RequestEquipWeaponRemote:FireServer(requestedSlot)
				end
			elseif input.KeyCode == Enum.KeyCode.R then
				self.RequestReloadRemote:FireServer()
			end
			return
		end

		if self.QTEController and self.QTEController:IsActive() then
			return
		end

		if self.BreathHoldController and self.BreathHoldController:RequiresHoldInput() then
			return
		end

		if self.State.IsBroken then
			return
		end

		if self.State.IsUsingItem and (self.State.ItemUseRemaining or 0) > 0 then
			return
		end

		self.RequestPrimaryAttackRemote:FireServer({
			Origin = self.World.Camera.CFrame.Position,
			Direction = self.World.Camera.CFrame.LookVector,
			IsAiming = self.State.IsAiming == true,
		})
	end)

	UserInputService.InputEnded:Connect(function(input, gameProcessedEvent)
		if gameProcessedEvent and input.UserInputType ~= Enum.UserInputType.MouseButton2 then
			return
		end

		if input.UserInputType == Enum.UserInputType.MouseButton2 then
			self.LocalAimHeld = false
			self.RequestMovementStateRemote:FireServer(ActionName.Aim, false)
		end
	end)

	RunService:BindToRenderStep("CombatController.AimFacing", Enum.RenderPriority.Character.Value + 1, function()
		self:_updateAimFacing()
	end)

	task.spawn(function()
		while true do
			if self.State.Cooldown and self.State.Cooldown > 0 then
				self.State.Cooldown = math.max(0, self.State.Cooldown - 0.05)
			end
			if self.State.ReloadRemaining and self.State.ReloadRemaining > 0 then
				self.State.ReloadRemaining = math.max(0, self.State.ReloadRemaining - 0.05)
				if self.State.ReloadRemaining <= 0 then
					self.State.IsReloading = false
				end
			end
			if self.State.ItemUseRemaining and self.State.ItemUseRemaining > 0 then
				self.State.ItemUseRemaining = math.max(0, self.State.ItemUseRemaining - 0.05)
			end

			self:_refreshUi()

			task.wait(0.05)
		end
	end)

	DebugLog:Log("ClientCombat", "[CombatController] Started")
end

function CombatController:_releaseAim()
	if not self.LocalAimHeld and not self.State.IsAiming then
		return
	end

	self.LocalAimHeld = false
	self.RequestMovementStateRemote:FireServer(ActionName.Aim, false)
end

function CombatController:_canAim()
	return self.State.WeaponKind == "Firearm"
		and not self.State.IsBroken
		and not (self.State.IsUsingItem and (self.State.ItemUseRemaining or 0) > 0)
		and not (self.QTEController and self.QTEController:IsActive())
		and not (self.BreathHoldController and self.BreathHoldController:RequiresHoldInput())
end

function CombatController:GetState()
	return self.State
end

function CombatController:GetEquippedWeaponDefinition()
	if not self.State or not self.State.EquippedWeaponId then
		return nil
	end

	return WeaponDefinitions[self.State.EquippedWeaponId]
end

function CombatController:GetEquippedEntryState()
	if not self.State or not self.State.Weapons then
		return nil
	end

	return self.State.Weapons[self.State.EquippedSlot or 1]
end

function CombatController:GetEquippedDefinition()
	local entry = self:GetEquippedEntryState()
	if not entry then
		return nil
	end

	if entry.EntryType == "Weapon" then
		return WeaponDefinitions[entry.WeaponId]
	elseif entry.EntryType == "Item" then
		return ItemDefinitions[entry.WeaponId]
	end

	return nil
end

function CombatController:IsRecentHit()
	return (os.clock() - (self.LastHitAt or 0)) <= 0.2
end

function CombatController:_updateAimFacing()
	if not self.State.IsAiming then
		return
	end

	local character = self.World:GetCharacter()
	if not character then
		return
	end

	local rootPart = character:FindFirstChild("HumanoidRootPart")
	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if not rootPart or not humanoid or humanoid.Health <= 0 then
		return
	end

	local cameraLook = self.World.Camera.CFrame.LookVector
	local flatLook = Vector3.new(cameraLook.X, 0, cameraLook.Z)
	if flatLook.Magnitude <= 0.001 then
		return
	end

	local position = rootPart.Position
	rootPart.CFrame = CFrame.lookAt(position, position + flatLook.Unit)
end

function CombatController:_getRequestedSlotFromInput(input)
	local keyCode = input.KeyCode
	if keyCode == Enum.KeyCode.One then
		return 1
	elseif keyCode == Enum.KeyCode.Two then
		return 2
	elseif keyCode == Enum.KeyCode.Three then
		return 3
	elseif keyCode == Enum.KeyCode.Four then
		return 4
	elseif keyCode == Enum.KeyCode.Five then
		return 5
	elseif keyCode == Enum.KeyCode.Six then
		return 6
	elseif keyCode == Enum.KeyCode.Seven then
		return 7
	elseif keyCode == Enum.KeyCode.Eight then
		return 8
	elseif keyCode == Enum.KeyCode.Nine then
		return 9
	end

	return nil
end

function CombatController:_createUI()
	local screenGui = Instance.new("ScreenGui")
	screenGui.Name = "CombatUI"
	screenGui.ResetOnSpawn = false
	screenGui.Parent = self.PlayerGui

	local container = Instance.new("Frame")
	container.Name = "Container"
	container.AnchorPoint = Vector2.new(1, 1)
	container.Position = UDim2.new(1, -12, 1, BASE_CONTAINER_OFFSET_Y)
	container.Size = UDim2.new(0, 170, 0, 82)
	container.BackgroundColor3 = Color3.fromRGB(18, 19, 24)
	container.BackgroundTransparency = 0.08
	container.BorderSizePixel = 0
	container.Parent = screenGui

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 10)
	corner.Parent = container

	local nameLabel = Instance.new("TextLabel")
	nameLabel.Name = "NameLabel"
	nameLabel.Position = UDim2.new(0, 12, 0, 10)
	nameLabel.Size = UDim2.new(1, -24, 0, 18)
	nameLabel.BackgroundTransparency = 1
	nameLabel.Font = Enum.Font.GothamBold
	nameLabel.TextSize = 14
	nameLabel.TextColor3 = Color3.fromRGB(240, 240, 240)
	nameLabel.TextXAlignment = Enum.TextXAlignment.Center
	nameLabel.Text = "Bushman Knife"
	nameLabel.Parent = container

	local durabilityLabel = Instance.new("TextLabel")
	durabilityLabel.Name = "DurabilityLabel"
	durabilityLabel.Position = UDim2.new(0, 12, 0, 30)
	durabilityLabel.Size = UDim2.new(1, -24, 0, 14)
	durabilityLabel.BackgroundTransparency = 1
	durabilityLabel.Font = Enum.Font.Gotham
	durabilityLabel.TextSize = 11
	durabilityLabel.TextColor3 = Color3.fromRGB(197, 197, 204)
	durabilityLabel.TextXAlignment = Enum.TextXAlignment.Center
	durabilityLabel.Text = "Durability 10/10"
	durabilityLabel.Parent = container

	local statusLabel = Instance.new("TextLabel")
	statusLabel.Name = "StatusLabel"
	statusLabel.Position = UDim2.new(0, 12, 0, 46)
	statusLabel.Size = UDim2.new(1, -24, 0, 14)
	statusLabel.BackgroundTransparency = 1
	statusLabel.Font = Enum.Font.GothamBold
	statusLabel.TextSize = 12
	statusLabel.TextColor3 = Color3.fromRGB(214, 180, 64)
	statusLabel.TextXAlignment = Enum.TextXAlignment.Center
	statusLabel.Text = "READY"
	statusLabel.Parent = container

	local hitLabel = Instance.new("TextLabel")
	hitLabel.Name = "HitLabel"
	hitLabel.Position = UDim2.new(0, 12, 0, 60)
	hitLabel.Size = UDim2.new(1, -24, 0, 14)
	hitLabel.BackgroundTransparency = 1
	hitLabel.Font = Enum.Font.Gotham
	hitLabel.TextSize = 10
	hitLabel.TextColor3 = Color3.fromRGB(164, 224, 176)
	hitLabel.TextXAlignment = Enum.TextXAlignment.Center
	hitLabel.Text = ""
	hitLabel.Parent = container

	local cooldownBackground = Instance.new("Frame")
	cooldownBackground.Name = "CooldownBackground"
	cooldownBackground.Position = UDim2.new(0, 12, 1, -10)
	cooldownBackground.Size = UDim2.new(1, -24, 0, 5)
	cooldownBackground.BackgroundColor3 = Color3.fromRGB(48, 51, 60)
	cooldownBackground.BorderSizePixel = 0
	cooldownBackground.Parent = container

	local cooldownCorner = Instance.new("UICorner")
	cooldownCorner.CornerRadius = UDim.new(0, 999)
	cooldownCorner.Parent = cooldownBackground

	local cooldownBar = Instance.new("Frame")
	cooldownBar.Name = "CooldownBar"
	cooldownBar.Size = UDim2.new(0, 0, 1, 0)
	cooldownBar.BackgroundColor3 = Color3.fromRGB(214, 180, 64)
	cooldownBar.BorderSizePixel = 0
	cooldownBar.Parent = cooldownBackground

	local cooldownBarCorner = Instance.new("UICorner")
	cooldownBarCorner.CornerRadius = UDim.new(0, 999)
	cooldownBarCorner.Parent = cooldownBar

	local slotsFrame = Instance.new("Frame")
	slotsFrame.Name = "SlotsFrame"
	slotsFrame.AnchorPoint = Vector2.new(1, 1)
	slotsFrame.Position = UDim2.new(1, 0, 0, -(SLOT_STACK_GAP + 8))
	slotsFrame.Size = UDim2.new(0, SLOT_WIDTH, 0, 0)
	slotsFrame.BackgroundTransparency = 1
	slotsFrame.Parent = container

	local slotsLayout = Instance.new("UIListLayout")
	slotsLayout.FillDirection = Enum.FillDirection.Vertical
	slotsLayout.HorizontalAlignment = Enum.HorizontalAlignment.Left
	slotsLayout.Padding = UDim.new(0, 6)
	slotsLayout.Parent = slotsFrame

	self.UI = {
		Root = screenGui,
		Container = container,
		NameLabel = nameLabel,
		DurabilityLabel = durabilityLabel,
		StatusLabel = statusLabel,
		HitLabel = hitLabel,
		CooldownBar = cooldownBar,
		SlotsFrame = slotsFrame,
		SlotButtons = {},
	}

	self:_refreshUi()
end

function CombatController:_refreshSlots()
	local slotsFrame = self.UI and self.UI.SlotsFrame
	if not slotsFrame then
		return
	end

	local weaponCount = math.max(1, #(self.State.Weapons or {}))
	for index = 1, weaponCount do
		local slotButton = self.UI.SlotButtons[index]
		if not slotButton then
			slotButton = Instance.new("Frame")
			slotButton.Name = "Slot" .. tostring(index)
			slotButton.LayoutOrder = index
			slotButton.Size = UDim2.new(1, 0, 0, SLOT_HEIGHT)
			slotButton.BackgroundColor3 = Color3.fromRGB(18, 19, 24)
			slotButton.BackgroundTransparency = 0.12
			slotButton.BorderSizePixel = 0
			slotButton.Parent = slotsFrame

			local slotCorner = Instance.new("UICorner")
			slotCorner.CornerRadius = UDim.new(0, 8)
			slotCorner.Parent = slotButton

			local keyBadge = Instance.new("TextLabel")
			keyBadge.Name = "KeyBadge"
			keyBadge.Position = UDim2.new(0, 8, 0, 8)
			keyBadge.Size = UDim2.new(0, 20, 0, 20)
			keyBadge.BackgroundColor3 = Color3.fromRGB(240, 240, 240)
			keyBadge.BackgroundTransparency = 0.08
			keyBadge.BorderSizePixel = 0
			keyBadge.Font = Enum.Font.GothamBold
			keyBadge.TextSize = 11
			keyBadge.TextColor3 = Color3.fromRGB(20, 22, 28)
			keyBadge.Text = tostring(index)
			keyBadge.Parent = slotButton

			local keyCorner = Instance.new("UICorner")
			keyCorner.CornerRadius = UDim.new(0, 5)
			keyCorner.Parent = keyBadge

			local nameLabel = Instance.new("TextLabel")
			nameLabel.Name = "NameLabel"
			nameLabel.Position = UDim2.new(0, 36, 0, 0)
			nameLabel.Size = UDim2.new(1, -44, 1, 0)
			nameLabel.BackgroundTransparency = 1
			nameLabel.Font = Enum.Font.GothamBold
			nameLabel.TextSize = 11
			nameLabel.TextXAlignment = Enum.TextXAlignment.Left
			nameLabel.TextWrapped = true
			nameLabel.Parent = slotButton

			self.UI.SlotButtons[index] = slotButton
		end

		local slotState = self.State.Weapons[index]
		local isEquipped = (self.State.EquippedSlot or 1) == index
		local isBroken = slotState and slotState.IsBroken
		local isItem = slotState and slotState.EntryType == "Item"
		local keyBadge = slotButton:FindFirstChild("KeyBadge")
		local nameLabel = slotButton:FindFirstChild("NameLabel")
		slotButton.Visible = true
		slotButton.BackgroundColor3 = isEquipped and Color3.fromRGB(214, 180, 64) or (isItem and Color3.fromRGB(58, 86, 68) or Color3.fromRGB(34, 36, 44))
		if keyBadge then
			keyBadge.Text = tostring(index)
			keyBadge.BackgroundColor3 = isEquipped and Color3.fromRGB(20, 22, 28) or Color3.fromRGB(240, 240, 240)
			keyBadge.TextColor3 = isEquipped and Color3.fromRGB(242, 212, 103) or Color3.fromRGB(20, 22, 28)
		end

		if nameLabel then
			nameLabel.TextColor3 = isEquipped and Color3.fromRGB(20, 22, 28) or (isBroken and Color3.fromRGB(214, 94, 94) or Color3.fromRGB(224, 226, 232))
			nameLabel.Text = slotState and string.format("%s%s", slotState.ShortDisplayName or slotState.DisplayName, isItem and (" x" .. tostring(slotState.Count or 0)) or "") or "-"
		end
	end

	for index = weaponCount + 1, #self.UI.SlotButtons do
		self.UI.SlotButtons[index].Visible = false
	end

	local visibleSlotCount = #(self.State.Weapons or {})
	local slotsHeight = visibleSlotCount > 0 and ((visibleSlotCount * SLOT_HEIGHT) + (math.max(0, visibleSlotCount - 1) * SLOT_PADDING)) or 0
	slotsFrame.Size = UDim2.new(0, SLOT_WIDTH, 0, slotsHeight)
	slotsFrame.Position = UDim2.new(1, 0, 0, -SLOT_STACK_GAP)
end

function CombatController:_refreshUi()
	if not self.UI then
		return
	end

	local roundState = self.World:GetRoundState()
	local phase = roundState and roundState.Phase or "Unknown"
	local shouldShow = phase == GamePhase.Preparation or phase == GamePhase.Reception
	self.UI.Root.Enabled = shouldShow
	if not shouldShow then
		return
	end

	local maxDurability = math.max(0, self.State.MaxDurability or 0)
	local durability = math.max(0, self.State.Durability or 0)
	self.UI.NameLabel.Text = self.State.DisplayName or "Unarmed"
	if self.State.WeaponKind == "Firearm" then
		self.UI.DurabilityLabel.Text = string.format("Ammo %d/%d  |  Reserve %d", self.State.CurrentAmmo or 0, self.State.MaxAmmo or 0, self.State.ReserveAmmo or 0)
	else
		self.UI.DurabilityLabel.Text = string.format("Durability %d/%d", durability, maxDurability)
	end

	local statusText = "READY"
	local statusColor = Color3.fromRGB(214, 180, 64)
	local recentHit = (os.clock() - self.LastHitAt) <= 0.2
	if self.State.IsUsingItem and (self.State.ItemUseRemaining or 0) > 0 then
		statusText = "USE"
		statusColor = Color3.fromRGB(103, 194, 255)
	elseif self.State.IsReloading and (self.State.ReloadRemaining or 0) > 0 then
		statusText = "RELOAD"
		statusColor = Color3.fromRGB(103, 194, 255)
	elseif self.State.IsAiming and self.State.WeaponKind == "Firearm" then
		statusText = "AIM"
		statusColor = Color3.fromRGB(103, 194, 255)
	elseif self.State.IsBroken then
		statusText = "BROKEN"
		statusColor = Color3.fromRGB(214, 94, 94)
	elseif (self.State.Cooldown or 0) > 0 then
		statusText = "SWING"
		statusColor = Color3.fromRGB(240, 240, 240)
	end

	if recentHit then
		statusText = "HIT"
		statusColor = Color3.fromRGB(118, 208, 144)
	end

	self.UI.StatusLabel.Text = statusText
	self.UI.StatusLabel.TextColor3 = statusColor
	if self.State.IsUsingItem and (self.State.ItemUseRemaining or 0) > 0 then
		self.UI.HitLabel.Text = string.format("Using %s", self.State.ItemUseDisplayName or "Item")
	elseif self.State.IsReloading and (self.State.ReloadRemaining or 0) > 0 then
		self.UI.HitLabel.Text = string.format("Reloading %.1fs", self.State.ReloadRemaining or 0)
	else
		self.UI.HitLabel.Text = recentHit and string.format("Hit %s", self.LastHitTargetName or "Entity") or ""
	end

	local maxCooldown = self.State.MaxCooldown or 0
	local remaining = self.State.Cooldown or 0
	local maxProgressDuration = maxCooldown
	local progressRemaining = remaining
	if self.State.IsUsingItem and (self.State.ItemUseRemaining or 0) > 0 then
		maxProgressDuration = self.State.ItemUseDuration or 0
		progressRemaining = self.State.ItemUseRemaining or 0
	elseif self.State.IsReloading and (self.State.ReloadRemaining or 0) > 0 then
		maxProgressDuration = self.State.ReloadDuration or 0
		progressRemaining = self.State.ReloadRemaining or 0
	end

	local ratio = maxProgressDuration > 0 and math.clamp(1 - (progressRemaining / maxProgressDuration), 0, 1) or 1
	self.UI.CooldownBar.Size = UDim2.new(ratio, 0, 1, 0)
	self.UI.CooldownBar.BackgroundColor3 = ((self.State.IsUsingItem and (self.State.ItemUseRemaining or 0) > 0) or (self.State.IsReloading and (self.State.ReloadRemaining or 0) > 0)) and Color3.fromRGB(103, 194, 255)
		or (recentHit and Color3.fromRGB(118, 208, 144) or ((self.State.IsAiming and self.State.WeaponKind == "Firearm") and Color3.fromRGB(103, 194, 255) or (self.State.IsBroken and Color3.fromRGB(214, 94, 94) or Color3.fromRGB(214, 180, 64))))
	self.UI.Container.BackgroundColor3 = recentHit and Color3.fromRGB(28, 44, 33) or Color3.fromRGB(18, 19, 24)

	if self.LocalAimHeld and not self:_canAim() then
		self:_releaseAim()
	end

	if self.LocalAimHeld and ((self.QTEController and self.QTEController:IsActive()) or (self.BreathHoldController and self.BreathHoldController:RequiresHoldInput())) then
		self:_releaseAim()
	end

	self:_refreshSlots()
end

return CombatController
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="121">
            <Properties>
              <string name="Name">ContextController</string>
              <string name="Source"><![CDATA[local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local UserInputService = game:GetService("UserInputService")

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local InputContext = require(ReplicatedStorage.Shared.Enums.InputContext)

local ContextController = {}
ContextController.Name = "ContextController"

function ContextController:Init()
	self.Player = Players.LocalPlayer
	self.PlayerGui = self.Player:WaitForChild("PlayerGui")
end

function ContextController:GetSnapshot()
	return {
		[InputContext.SkillCheck] = self:_isSkillCheckActive(),
		[InputContext.DoorSlam] = false,
		[InputContext.NearObjective] = self:_isNearObjective(),
		[InputContext.NearToolboxObjective] = self:_isNearToolboxObjective(),
		[InputContext.InventoryOpen] = self:_isGuiEnabled("InventoryUI"),
		[InputContext.RadialMenuOpen] = self:_isGuiEnabled("RadialMenuUI"),
		[InputContext.ChatFocused] = UserInputService:GetFocusedTextBox() ~= nil,
	}
end

function ContextController:_isNearObjective()
	local character = self.Player.Character
	if not character then
		return false
	end

	local rootPart = character:FindFirstChild("HumanoidRootPart")
	if not rootPart then
		return false
	end

	local objectivesFolder = Workspace:FindFirstChild("Objectives")
	if not objectivesFolder then
		return false
	end

	for _, objective in ipairs(objectivesFolder:GetChildren()) do
		if objective:IsA("BasePart") then
			local distance = (objective.Position - rootPart.Position).Magnitude
			if distance <= 12 then
				return true
			end
		elseif objective:IsA("Model") and objective.PrimaryPart then
			local distance = (objective.PrimaryPart.Position - rootPart.Position).Magnitude
			if distance <= 12 then
				return true
			end
		end
	end

	return false
end

function ContextController:_isNearToolboxObjective()
	return false
end

function ContextController:_isSkillCheckActive()
	return self:_isGuiEnabled("SkillCheckUI")
end

function ContextController:_isGuiEnabled(guiName)
	local gui = self.PlayerGui:FindFirstChild(guiName)
	return gui ~= nil and gui.Enabled == true
end

return ContextController
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="122">
            <Properties>
              <string name="Name">CrosshairController</string>
              <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")

local GamePhase = require(ReplicatedStorage.Shared.Enums.GamePhase)
local FirearmAim = require(ReplicatedStorage.Shared.Utility.FirearmAim)
local WeaponDefinitions = require(ReplicatedStorage.Shared.Data.WeaponDefinitions)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local CrosshairController = {}
CrosshairController.Name = "CrosshairController"
CrosshairController.Dependencies = {
	"CombatController",
	"CameraInputController",
	"FirearmPresentationController",
	"RoundController",
}

function CrosshairController:Init()
	self.PlayerGui = self.World.PlayerGui
	self.Camera = self.World.Camera
end

function CrosshairController:Start()
	self:_createUi()

	task.spawn(function()
		while true do
			self:_refresh()
			task.wait(0.05)
		end
	end)

	DebugLog:Log("ClientCombat", "[CrosshairController] Started")
end

function CrosshairController:_createUi()
	local screenGui = Instance.new("ScreenGui")
	screenGui.Name = "CrosshairUI"
	screenGui.ResetOnSpawn = false
	screenGui.IgnoreGuiInset = true
	screenGui.Parent = self.PlayerGui

	local root = Instance.new("Frame")
	root.Name = "Root"
	root.AnchorPoint = Vector2.new(0.5, 0.5)
	root.Position = UDim2.fromScale(0.5, 0.5)
	root.Size = UDim2.new(0, 40, 0, 40)
	root.BackgroundTransparency = 1
	root.Parent = screenGui

	local center = Instance.new("Frame")
	center.Name = "Center"
	center.AnchorPoint = Vector2.new(0.5, 0.5)
	center.Position = UDim2.fromScale(0.5, 0.5)
	center.Size = UDim2.new(0, 4, 0, 4)
	center.BackgroundColor3 = Color3.fromRGB(240, 240, 240)
	center.BorderSizePixel = 0
	center.Parent = root

	local centerCorner = Instance.new("UICorner")
	centerCorner.CornerRadius = UDim.new(1, 0)
	centerCorner.Parent = center

	local top = Instance.new("Frame")
	top.Name = "Top"
	top.AnchorPoint = Vector2.new(0.5, 1)
	top.Position = UDim2.fromScale(0.5, 0.42)
	top.Size = UDim2.new(0, 2, 0, 8)
	top.BackgroundColor3 = center.BackgroundColor3
	top.BorderSizePixel = 0
	top.Parent = root

	local bottom = top:Clone()
	bottom.Name = "Bottom"
	bottom.AnchorPoint = Vector2.new(0.5, 0)
	bottom.Position = UDim2.fromScale(0.5, 0.58)
	bottom.Parent = root

	local left = Instance.new("Frame")
	left.Name = "Left"
	left.AnchorPoint = Vector2.new(1, 0.5)
	left.Position = UDim2.fromScale(0.42, 0.5)
	left.Size = UDim2.new(0, 8, 0, 2)
	left.BackgroundColor3 = center.BackgroundColor3
	left.BorderSizePixel = 0
	left.Parent = root

	local right = left:Clone()
	right.Name = "Right"
	right.AnchorPoint = Vector2.new(0, 0.5)
	right.Position = UDim2.fromScale(0.58, 0.5)
	right.Parent = root

	self.UI = {
		Root = screenGui,
		Container = root,
		Center = center,
		Top = top,
		Bottom = bottom,
		Left = left,
		Right = right,
	}
end

function CrosshairController:_refresh()
	local roundState = self.RoundController and self.RoundController:GetState() or nil
	local inRound = roundState and (roundState.Phase == GamePhase.Preparation or roundState.Phase == GamePhase.Reception)
	local cameraLocked = self.CameraInputController and self.CameraInputController.IsLocked
	local combatState = self.CombatController and self.CombatController:GetState() or nil
	local hasFirearmEquipped = combatState and combatState.WeaponKind == "Firearm"
	local isAimingFirearm = hasFirearmEquipped and combatState.IsAiming
	local isFirstPerson = self.CameraInputController and self.CameraInputController:IsFirstPerson()
	local show = inRound and cameraLocked and hasFirearmEquipped

	self.UI.Root.Enabled = show
	if not show then
		return
	end

	local color = isAimingFirearm and Color3.fromRGB(103, 194, 255) or Color3.fromRGB(240, 240, 240)
	local alpha = 0
	local rootPosition = self:_getProjectedReticlePosition() or UDim2.fromScale(0.5, 0.5)
	if self.CombatController and self.CombatController:IsRecentHit() then
		color = Color3.fromRGB(124, 214, 166)
	end

	local weaponDefinition = self.CombatController and self.CombatController:GetEquippedWeaponDefinition() or nil
	local handling = FirearmAim.GetHandlingData(weaponDefinition)
	local expansion = self.FirearmPresentationController and self.FirearmPresentationController:GetReticleExpansion() or 0
	local baseGap = isAimingFirearm
		and (6 + math.floor((handling.AimSpread or 0.5) * 3))
		or (8 + math.floor((handling.HipfireSpread or 3.5) * 2))
	if isFirstPerson then
		baseGap = math.max(5, baseGap - (isAimingFirearm and 2 or 3))
	end
	local gap = baseGap + math.floor(expansion * (isAimingFirearm and 8 or 14))
	local lineLength = isAimingFirearm and 8 or 10
	local lineThickness = isAimingFirearm and 2 or 3
	local rootSize = 24 + (gap * 2) + lineLength

	self.UI.Container.Position = rootPosition
	self.UI.Container.Size = UDim2.fromOffset(rootSize, rootSize)
	self.UI.Center.Size = UDim2.fromOffset(isAimingFirearm and 4 or 5, isAimingFirearm and 4 or 5)
	self.UI.Top.Position = UDim2.new(0.5, 0, 0.5, -gap)
	self.UI.Top.Size = UDim2.fromOffset(lineThickness, lineLength)
	self.UI.Bottom.Position = UDim2.new(0.5, 0, 0.5, gap)
	self.UI.Bottom.Size = UDim2.fromOffset(lineThickness, lineLength)
	self.UI.Left.Position = UDim2.new(0.5, -gap, 0.5, 0)
	self.UI.Left.Size = UDim2.fromOffset(lineLength, lineThickness)
	self.UI.Right.Position = UDim2.new(0.5, gap, 0.5, 0)
	self.UI.Right.Size = UDim2.fromOffset(lineLength, lineThickness)

	for _, key in ipairs({ "Center", "Top", "Bottom", "Left", "Right" }) do
		self.UI[key].BackgroundColor3 = color
		self.UI[key].BackgroundTransparency = alpha
	end
end

function CrosshairController:_getProjectedReticlePosition()
	local character = self.World:GetCharacter()
	if not character then
		return nil
	end

	local rootPart = character:FindFirstChild("HumanoidRootPart")
	if not rootPart then
		return nil
	end

	local combatState = self.CombatController and self.CombatController:GetState() or nil
	local equippedWeaponId = combatState and combatState.EquippedWeaponId or nil
	local weaponDefinition = equippedWeaponId and WeaponDefinitions[equippedWeaponId] or nil
	local range = weaponDefinition and weaponDefinition.Range or 220
	local lookVector = FirearmAim.ResolveLookVector(rootPart.CFrame.LookVector, self.Camera.CFrame.LookVector)

	local raycastParams = RaycastParams.new()
	raycastParams.FilterType = Enum.RaycastFilterType.Exclude
	local filter = { character }
	local mapBounds = Workspace:FindFirstChild("MapBounds")
	if mapBounds then
		table.insert(filter, mapBounds)
	end
	raycastParams.FilterDescendantsInstances = filter

	local worldPoint = FirearmAim.ResolveAimPoint(self.Camera.CFrame.Position, lookVector, range, raycastParams, Workspace)
	local screenPoint, onScreen = self.Camera:WorldToViewportPoint(worldPoint)
	if not onScreen then
		return nil
	end

	return UDim2.fromOffset(screenPoint.X, screenPoint.Y)
end

return CrosshairController
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="123">
            <Properties>
              <string name="Name">DevMenuController</string>
              <string name="Source"><![CDATA[local ContextActionService = game:GetService("ContextActionService")
local Workspace = game:GetService("Workspace")
local UserInputService = game:GetService("UserInputService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local DebugFlags = require(ReplicatedStorage.Shared.Data.DebugFlags)
local EntityDefinitions = require(ReplicatedStorage.Shared.Data.EntityDefinitions)
local ItemDefinitions = require(ReplicatedStorage.Shared.Data.ItemDefinitions)
local RemoteNames = require(ReplicatedStorage.Shared.Constants.RemoteNames)
local WeaponDefinitions = require(ReplicatedStorage.Shared.Data.WeaponDefinitions)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local DevMenuController = {}
DevMenuController.Name = "DevMenuController"
DevMenuController.Dependencies = {
	"EntityDebugController",
	"InteractableDebugController",
	"ViewmodelController",
}

local TOGGLE_KEY = Enum.KeyCode.RightShift
local TOGGLE_ACTION = "ToggleDevMenu"

local function _buildUniqueEntityIds()
	local ids = {}
	local seen = {}
	for _, definition in pairs(EntityDefinitions) do
		if definition.Id and not seen[definition.Id] then
			seen[definition.Id] = true
			table.insert(ids, definition.Id)
		end
	end
	table.sort(ids)
	return ids
end

local function _buildSortedIds(definitions)
	local ids = {}
	for id in pairs(definitions) do
		table.insert(ids, id)
	end
	table.sort(ids)
	return ids
end

function DevMenuController:Init()
	self.PlayerGui = self.World.PlayerGui
	self.Remotes = self.World.Remotes
	self.RequestRemote = self.Remotes:WaitForChild(RemoteNames.RequestDevCommand)
	self.StateRemote = self.Remotes:WaitForChild(RemoteNames.DevStateChanged)
	self.Visible = false
	self.PlacementMode = nil
	self.EntityIds = _buildUniqueEntityIds()
	self.ItemIds = _buildSortedIds(ItemDefinitions)
	self.WeaponIds = _buildSortedIds(WeaponDefinitions)
	self.SelectedEntityIndex = 1
	self.SelectedItemIndex = 1
	self.SelectedWeaponIndex = 1
	self.DevState = {
		Phase = "Unknown",
		TimeLeft = 0,
		EscapeEnabled = true,
		GodMode = false,
		DebugUiEnabled = true,
		Message = "",
	}
	self.PlacementRaycastParams = RaycastParams.new()
	self.PlacementRaycastParams.FilterType = Enum.RaycastFilterType.Exclude
end

function DevMenuController:Start()
	if not DebugFlags.Enabled or not DebugFlags.DevMenu then
		return
	end

	self:_createUI()
	self:_refreshUi()

	self.StateRemote.OnClientEvent:Connect(function(payload)
		self.DevState = payload or self.DevState
		self:_refreshUi()
	end)

	UserInputService.InputBegan:Connect(function(input, gameProcessed)
		if gameProcessed or not self.Visible then
			return
		end

		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			self:_handlePlacementClick()
		end
	end)

	ContextActionService:BindActionAtPriority(
		TOGGLE_ACTION,
		function(_, inputState)
			if inputState ~= Enum.UserInputState.Begin then
				return Enum.ContextActionResult.Pass
			end

			if UserInputService:GetFocusedTextBox() then
				return Enum.ContextActionResult.Sink
			end

			self:_toggleVisible()
			return Enum.ContextActionResult.Sink
		end,
		false,
		Enum.ContextActionPriority.High.Value,
		TOGGLE_KEY
	)

	DebugLog:Log("ClientCombat", "[DevMenuController] Started")
end

function DevMenuController:_toggleVisible()
	self.Visible = not self.Visible

	if self.UI and self.UI.Panel then
		self.UI.Panel.Visible = self.Visible
	end

	if self.Visible then
		self:_request("Refresh")
	end
end

function DevMenuController:IsVisible()
	return self.Visible == true
end

function DevMenuController:_applyDebugUiState()
	local enabled = self.DevState.DebugUiEnabled ~= false
	for _, controllerName in ipairs({
		"EntityDebugController",
		"InteractableDebugController",
	}) do
		local controller = self[controllerName] or (self.Controllers and self.Controllers[controllerName]) or (self.Ring and self.Ring[controllerName])
		if controller and controller.SetDebugUiEnabled then
			controller:SetDebugUiEnabled(enabled)
		end
	end
end

function DevMenuController:_request(command, payload)
	self.RequestRemote:FireServer(payload or {
		Command = command,
	})
end

function DevMenuController:_setPlacementMode(mode)
	self.PlacementMode = mode
	self:_refreshUi()
end

function DevMenuController:_serializePosition(position)
	return {
		X = position.X,
		Y = position.Y,
		Z = position.Z,
	}
end

function DevMenuController:_getPlacementPosition()
	local ignoreList = {}
	local character = self.World:GetCharacter()
	if character then
		table.insert(ignoreList, character)
	end

	local mapBounds = Workspace:FindFirstChild("MapBounds")
	if mapBounds then
		table.insert(ignoreList, mapBounds)
	end

	self.PlacementRaycastParams.FilterDescendantsInstances = ignoreList

	local mouseLocation = UserInputService:GetMouseLocation()
	local ray = self.World.Camera:ViewportPointToRay(mouseLocation.X, mouseLocation.Y)
	local result = Workspace:Raycast(ray.Origin, ray.Direction * 1000, self.PlacementRaycastParams)
	if not result then
		return nil
	end

	return result.Position
end

function DevMenuController:_handlePlacementClick()
	if not self.PlacementMode then
		return false
	end

	local mouseLocation = UserInputService:GetMouseLocation()
	local hoveredGui = self.PlayerGui:GetGuiObjectsAtPosition(mouseLocation.X, mouseLocation.Y)
	for _, guiObject in ipairs(hoveredGui) do
		if self.UI and self.UI.Root and guiObject:IsDescendantOf(self.UI.Root) then
			return false
		end
	end

	local position = self:_getPlacementPosition()
	if not position then
		self.DevState.Message = "No valid ground clicked"
		self:_refreshUi()
		return true
	end

	if self.PlacementMode == "Entity" then
		self:_request("SpawnEntityAt", {
			Command = "SpawnEntityAt",
			EntityId = self:_getSelectedEntityId(),
			Position = self:_serializePosition(position),
		})
	elseif self.PlacementMode == "WeaponPickup" then
		self:_request("PlaceWeaponPickup", {
			Command = "PlaceWeaponPickup",
			WeaponId = self:_getSelectedWeaponId(),
			Position = self:_serializePosition(position),
		})
	elseif self.PlacementMode == "ItemPickup" then
		self:_request("PlaceItemPickup", {
			Command = "PlaceItemPickup",
			ItemId = self:_getSelectedItemId(),
			Quantity = 1,
			Position = self:_serializePosition(position),
		})
	end

	self.PlacementMode = nil
	self:_refreshUi()
	return true
end

function DevMenuController:_getSelectedWeaponId()
	return self.WeaponIds[self.SelectedWeaponIndex]
end

function DevMenuController:_getSelectedItemId()
	return self.ItemIds[self.SelectedItemIndex]
end

function DevMenuController:_getSelectedEntityId()
	return self.EntityIds[self.SelectedEntityIndex]
end

function DevMenuController:_cycleIndex(current, delta, list)
	local count = #list
	if count <= 0 then
		return 1
	end

	local nextIndex = current + delta
	if nextIndex < 1 then
		nextIndex = count
	elseif nextIndex > count then
		nextIndex = 1
	end
	return nextIndex
end

function DevMenuController:_createButton(parent, text, position, size, onClick)
	local button = Instance.new("TextButton")
	button.Position = position
	button.Size = size
	button.BackgroundColor3 = Color3.fromRGB(40, 44, 54)
	button.BorderSizePixel = 0
	button.Font = Enum.Font.GothamBold
	button.TextSize = 12
	button.TextColor3 = Color3.fromRGB(240, 240, 240)
	button.Text = text
	button.Parent = parent

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 8)
	corner.Parent = button

	button.MouseButton1Click:Connect(onClick)
	return button
end

function DevMenuController:_createSectionLabel(parent, text, y)
	local label = Instance.new("TextLabel")
	label.BackgroundTransparency = 1
	label.Position = UDim2.new(0, 12, 0, y)
	label.Size = UDim2.new(1, -24, 0, 16)
	label.Font = Enum.Font.GothamBold
	label.TextSize = 12
	label.TextColor3 = Color3.fromRGB(242, 212, 103)
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.Text = text
	label.Parent = parent
	return label
end

