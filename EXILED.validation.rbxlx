      <Item class="Folder" referent="70">
        <Properties>
          <string name="Name">World</string>
        </Properties>
        <Item class="ModuleScript" referent="71">
          <Properties>
            <string name="Name">ClientWorld</string>
            <string name="Source"><![CDATA[local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local WorldModeResolver = require(ReplicatedStorage.Shared.Utility.WorldModeResolver)

local ClientWorld = {}
ClientWorld.__index = ClientWorld

function ClientWorld.new(controllers)
	local self = setmetatable({}, ClientWorld)

	self.Controllers = controllers
	self.Player = Players.LocalPlayer
	self.PlayerGui = self.Player:WaitForChild("PlayerGui")
	self.Camera = Workspace.CurrentCamera
	self.Shared = ReplicatedStorage:WaitForChild("Shared")
	self.Remotes = self.Shared:WaitForChild("Remotes")
	self.WorldMode = WorldModeResolver.GetWorldMode()

	return self
end

function ClientWorld:GetContextSnapshot()
	local contextController = self.Controllers.ContextController
	return contextController and contextController:GetSnapshot() or {}
end

function ClientWorld:GetCharacter()
	return self.Player.Character
end

function ClientWorld:GetWorldMode()
	return self.WorldMode
end

function ClientWorld:GetRoundState()
	local roundController = self.Controllers.RoundController
	return roundController and roundController:GetState() or nil
end

function ClientWorld:DispatchAction(actionName, phase)
	local actionDispatcher = self.Controllers.ActionDispatcher
	if actionDispatcher then
		actionDispatcher:Dispatch(actionName, phase)
	end
end

return ClientWorld
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="72">
          <Properties>
            <string name="Name">ServerWorld</string>
            <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")
local WorldModeResolver = require(ReplicatedStorage.Shared.Utility.WorldModeResolver)

local ServerWorld = {}
ServerWorld.__index = ServerWorld

function ServerWorld.new(services)
	local self = setmetatable({}, ServerWorld)

	self.Services = services
	self.PlayerService = services.PlayerService
	self.CharacterService = services.CharacterService
	self.RoundManager = services.RoundManager
	self.StatusEffectService = services.StatusEffectService
	self.InteractionService = services.InteractionService
	self.ObjectiveService = services.ObjectiveService
	self.WorldMode = WorldModeResolver.GetWorldMode()

	return self
end

function ServerWorld:GetCharacter(player)
	return self.CharacterService and self.CharacterService:GetCharacterByPlayer(player) or nil
end

function ServerWorld:GetRoundState(player)
	return self.RoundManager and self.RoundManager:GetRoundState(player) or nil
end

function ServerWorld:GetActivePlayers()
	return self.RoundManager and self.RoundManager:GetActivePlayers() or {}
end

function ServerWorld:GetWorldMode()
	return self.WorldMode
end

function ServerWorld:ApplyStatus(target, statusId, params)
	if not self.StatusEffectService then
		return nil
	end

	return self.StatusEffectService:ApplyStatus(target, statusId, params)
end

function ServerWorld:RemoveStatus(target, statusId)
	if not self.StatusEffectService then
		return false
	end

	return self.StatusEffectService:RemoveStatus(target, statusId)
end

function ServerWorld:CanUseAbilities(target)
	return not self.StatusEffectService or self.StatusEffectService:CanUseAbilities(target)
end

function ServerWorld:CanInteract(target)
	return not self.StatusEffectService or self.StatusEffectService:CanInteract(target)
end

function ServerWorld:IsInteracting(player)
	return self.InteractionService and self.InteractionService:IsInteracting(player) or false
end

function ServerWorld:InterruptInteraction(player, reason)
	if not self.InteractionService then
		return false
	end

	return self.InteractionService:InterruptInteraction(player, reason)
end

return ServerWorld
]]></string>
          </Properties>
        </Item>
      </Item>
    </Item>
  </Item>
  <Item class="ServerScriptService" referent="73">
    <Properties>
      <string name="Name">ServerScriptService</string>
    </Properties>
    <Item class="Folder" referent="74">
      <Properties>
        <string name="Name">Server</string>
      </Properties>
      <Item class="Script" referent="75">
        <Properties>
          <string name="Name">Boot</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[local ServerScriptService = game:GetService("ServerScriptService")

local ServerFolder = ServerScriptService:WaitForChild("Server")
local ServicesFolder = ServerFolder:WaitForChild("Services")
local ManagersFolder = ServerFolder:WaitForChild("Managers")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local WorldMode = require(ReplicatedStorage.Shared.Enums.WorldMode)
local WorldModeResolver = require(ReplicatedStorage.Shared.Utility.WorldModeResolver)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)
local RingWrapper = require(ReplicatedStorage.Shared.Utility.RingWrapper)
local ServerWorld = require(ReplicatedStorage.Shared.World.ServerWorld)

local function _buildGameplayBootOrder()
	return {
		require(ServicesFolder.RemoteRegistry),
		require(ServicesFolder.DevService),
		require(ServicesFolder.PlayerService),
		require(ServicesFolder.CharacterService),
		require(ServicesFolder.StimulusService),
		require(ServicesFolder.StaminaService),
		require(ServicesFolder.MovementService),
		require(ServicesFolder.StatusEffectService),
		require(ServicesFolder.InventoryService),
		require(ServicesFolder.CombatService),
		require(ServicesFolder.WeaponPickupService),
		require(ServicesFolder.ItemPickupService),
		require(ServicesFolder.EnvironmentalHazardService),
		require(ServicesFolder.QTEService),
		require(ServicesFolder.StruggleService),
		require(ServicesFolder.BreathHoldService),
		require(ServicesFolder.SpawnService),
		require(ServicesFolder.ObjectiveService),
		require(ServicesFolder.RoundHookService),
		require(ServicesFolder.InteractionService),
		require(ServicesFolder.EntityService),
		require(ServicesFolder.RemnantService),
		require(ServicesFolder.EscapeService),
		require(ServicesFolder.VotingService),
		require(ManagersFolder.RoundManager),
	}
end
local bootOrder = {
	require(ServicesFolder.RemoteRegistry),
	require(ServicesFolder.PlayerService),
	require(ServicesFolder.CharacterService),
	require(ServicesFolder.WeaponService),
	require(ServicesFolder.SpawnService),
	require(ServicesFolder.ObjectiveService),
	require(ServicesFolder.InteractionService),
	require(ServicesFolder.EntityService),
	require(ServicesFolder.EscapeService),
	require(ManagersFolder.RoundManager),
}

local Services = {}

local function _buildWeaponLabBootOrder()
	return {
		require(ServicesFolder.RemoteRegistry),
		require(ServicesFolder.PlayerService),
		require(ServicesFolder.StatusEffectService),
		require(ServicesFolder.CharacterService),
		require(ServicesFolder.InventoryService),
		require(ServicesFolder.StaminaService),
		require(ServicesFolder.MovementService),
		require(ServicesFolder.CombatService),
		require(ServicesFolder.WeaponLabService),
	}
end

local bootOrder = WorldModeResolver.GetWorldMode() == WorldMode.WeaponLab
	and _buildWeaponLabBootOrder()
	or _buildGameplayBootOrder()

local Services = RingWrapper.CreateRing(bootOrder)
RingWrapper.Attach(bootOrder, Services, "Services")

local World = ServerWorld.new(Services)
RingWrapper.AttachField(bootOrder, "World", World)

for _, service in ipairs(bootOrder) do
	if service.Init then
		service:Init(Services)
	end
end

for _, service in ipairs(bootOrder) do
	if service.Start then
		service:Start()
	end
end

DebugLog:Log("Boot", "[Boot] Server boot complete.")
]]></string>
        </Properties>
      </Item>
      <Item class="Folder" referent="76">
        <Properties>
          <string name="Name">Classes</string>
        </Properties>
        <Item class="ModuleScript" referent="77">
          <Properties>
            <string name="Name">BaseCharacter</string>
            <string name="Source"><![CDATA[local BaseCharacter = {}
BaseCharacter.__index = BaseCharacter

function BaseCharacter.new(player, model, services)
	local self = setmetatable({}, BaseCharacter)
	
	self.Player = player
	self.Model = model
	self.Services = services
	self.Humanoid = model:WaitForChild("Humanoid")
	self.RootPart = model:WaitForChild("HumanoidRootPart")
	
	self.IsFrozen = false
	self.DefaultWalkSpeed = self.Humanoid.WalkSpeed
	self.DefaultJumpPower = self.Humanoid.JumpPower
	self.DefaultHipHeight = self.Humanoid.HipHeight
	self.IsInvincible = false
	self.IsSprintHeld = false
	self.IsSprinting = false
	self.IsRunning = false
	self.IsFatigued = false
	self.IsCrouching = false
	self.IsAiming = false
	
	self.SpeedMultipliers = {}
	self.SpeedModifierToken = 0
	self.SprintMultiplier = 1.5
	self.RunMultiplier = 1.25
	self.FatigueRunMultiplier = 1.1
	self.CrouchMultiplier = 0.5
	self.AimMultiplier = 0.82
	self.CrouchHipHeightMultiplier = 0.6
	
	return self
end

function BaseCharacter:_getCombinedSpeedMultiplier()
	local boostMultiplier = 1
	local slowMultiplier = 1
	
	for key, value in pairs(self.SpeedMultipliers) do
		if key == "OnHitHaste" and value > 1 then
			boostMultiplier = math.max(boostMultiplier, value)
		elseif value > 1 then
			boostMultiplier *= value
		else
			slowMultiplier *= value
		end
	end
	
	if self.SpeedMultipliers.OnHitHaste then
		slowMultiplier = 1
	end
	
	return boostMultiplier * slowMultiplier
end

function BaseCharacter:_getStatusModifier(modifierName)
	local statusService = self.Services and self.Services.StatusEffectService
	if not statusService then
		return 0
	end

	return statusService:GetModifier(self.Player, modifierName)
end

function BaseCharacter:_hasStatusFlag(flagName)
	local statusService = self.Services and self.Services.StatusEffectService
	if not statusService then
		return false
	end

	return statusService:HasFlag(self.Player, flagName)
end

function BaseCharacter:_refreshMovement()
	if not self.Humanoid then
		return
	end
	
	if self.IsFrozen or self:_hasStatusFlag("Stunned") then
		self.Humanoid.WalkSpeed = 0
		self.Humanoid.JumpPower = 0
		self.Humanoid.HipHeight = self.DefaultHipHeight
		self.Humanoid.AutoRotate = false
		return
	end

	local movementMultiplier = self:_getCombinedSpeedMultiplier()
	if self.IsSprinting then
		movementMultiplier *= self.SprintMultiplier
	elseif self.IsRunning then
		movementMultiplier *= self.IsFatigued and self.FatigueRunMultiplier or self.RunMultiplier
	end

	if self.IsCrouching then
		movementMultiplier *= self.CrouchMultiplier
		self.Humanoid.JumpPower = 0
		self.Humanoid.HipHeight = self.DefaultHipHeight * self.CrouchHipHeightMultiplier
	else
		self.Humanoid.JumpPower = self.DefaultJumpPower
		self.Humanoid.HipHeight = self.DefaultHipHeight
	end

	if self.IsAiming then
		movementMultiplier *= self.AimMultiplier
	end

	movementMultiplier *= (1 + self:_getStatusModifier("Haste"))
	movementMultiplier *= math.max(0, 1 - self:_getStatusModifier("Hinder"))

	self.Humanoid.WalkSpeed = self.DefaultWalkSpeed * movementMultiplier
	self.Humanoid.AutoRotate = not self.IsAiming
end

function BaseCharacter:SetWalkSpeed(speed)
	if self.Humanoid then
		self.DefaultWalkSpeed = speed
		self:_refreshMovement()
	end
end

function BaseCharacter:SetJumpPower(jumpPower)
	if self.Humanoid then
		self.DefaultJumpPower = jumpPower
		self:_refreshMovement()
	end
end

function BaseCharacter:SetSpeedMultiplier(key, multiplier)
	if multiplier == nil then
		self.SpeedMultipliers[key] = nil
	else
		self.SpeedMultipliers[key] = multiplier
	end
	
	self:_refreshMovement()
end

function BaseCharacter:SetSprintHeld(state)
	state = state == true
	if self.IsSprintHeld == state then
		return
	end

	if state then
		self.IsCrouching = false
	else
		self.IsSprinting = false
		self.IsRunning = false
		self.IsFatigued = false
	end
	self.IsSprintHeld = state

	self:_refreshMovement()
end

function BaseCharacter:SetSprintMode(mode)
	mode = mode or "Walk"
	local isSprinting = mode == "Sprint"
	local isRunning = mode == "Run" or mode == "Fatigue"
	local isFatigued = mode == "Fatigue"

	if self.IsSprinting == isSprinting and self.IsRunning == isRunning and self.IsFatigued == isFatigued then
		return
	end

	self.IsSprinting = isSprinting
	self.IsRunning = isRunning
	self.IsFatigued = isFatigued
	self:_refreshMovement()
end

function BaseCharacter:SetCrouching(state)
	state = state == true
	if self.IsCrouching == state then
		return
	end

	self.IsCrouching = state
	if state then
		self.IsSprintHeld = false
		self.IsSprinting = false
		self.IsRunning = false
		self.IsFatigued = false
	end

	self:_refreshMovement()
end

function BaseCharacter:ApplyTemporarySpeedMultiplier(key, multiplier, duration)
	self.SpeedModifierToken += 1
	local token = self.SpeedModifierToken
	
	self:SetSpeedMultiplier(key, multiplier)
	
	task.delay(duration, function()
		if self.SpeedModifierToken ~= token then
			return
		end
		
		self:SetSpeedMultiplier(key, nil)
	end)
end

function BaseCharacter:Freeze()
	if not self.Humanoid or self.IsFrozen then
		return
	end
	
	self.IsFrozen = true
	self:_refreshMovement()
end

function BaseCharacter:Unfreeze()
	if not self.Humanoid or not self.IsFrozen then
		return
	end

	self.IsFrozen = false
	self:_refreshMovement()
end

function BaseCharacter:IsAlive()
	return self.Humanoid and self.Humanoid.Health > 0
end

function BaseCharacter:SetInvincible(state)
	if self.IsInvincible == state then
		return
	end
	
	self.IsInvincible = state
	
	if self.Humanoid then
		if state then
			self.Humanoid.Health = self.Humanoid.MaxHealth
		end
	end
end

function BaseCharacter:ApplyDamage(amount, options)
	options = options or {}
	if self.IsInvincible and not options.IgnoreInvincible then
		return false
	end
	
	if self.Humanoid then
		local finalAmount = amount
		if not options.IsStatusEffect then
			finalAmount *= (1 + self:_getStatusModifier("Fragility"))
			finalAmount *= math.max(0, 1 - self:_getStatusModifier("Resistance"))
		end

		finalAmount = math.max(0, finalAmount)
		if finalAmount <= 0 then
			return false
		end

		if options.CanFatal == false then
			local minimumHealth = options.MinimumHealth or 1
			finalAmount = math.min(finalAmount, math.max(0, self.Humanoid.Health - minimumHealth))
			if finalAmount <= 0 then
				return false
			end
		end

		self.Humanoid:TakeDamage(finalAmount)
		return true
	end
	
	return false
end

function BaseCharacter:Heal(amount, options)
	options = options or {}
	if not self.Humanoid or amount <= 0 then
		return false
	end

	if not self:IsAlive() then
		return false
	end

	local currentHealth = self.Humanoid.Health
	local maxHealth = self.Humanoid.MaxHealth
	if currentHealth >= maxHealth then
		return false
	end

	local healAmount = math.min(amount, maxHealth - currentHealth)
	if healAmount <= 0 then
		return false
	end

	self.Humanoid.Health = currentHealth + healAmount
	return true
end

function BaseCharacter:RefreshFromStatusEffects()
	self:_refreshMovement()
end

function BaseCharacter:SetAiming(state)
	state = state == true
	if self.IsAiming == state then
		return
	end

	self.IsAiming = state
	if state then
		self.IsSprintHeld = false
		self.IsSprinting = false
		self.IsRunning = false
		self.IsFatigued = false
	end

	self:_refreshMovement()
end

function BaseCharacter:Destroy()
	self.Player = nil
	self.Model = nil
	self.Services = nil
	self.Humanoid = nil
	self.RootPart = nil
end

return BaseCharacter
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="78">
          <Properties>
            <string name="Name">BaseEntity</string>
            <string name="Source"><![CDATA[local BaseEntity = {}
BaseEntity.__index = BaseEntity

local ENTITY_STATE = {
	Dormant = "Dormant",
	Patrol = "Patrol",
	Scout = "Scout",
	Chase = "Chase",
	Casting = "Casting",
	Stunned = "Stunned",
	Rage = "Rage",
}

function BaseEntity.new(model, definition, services, runtimeData)
	local self = setmetatable({}, BaseEntity)
	
	self.Model = model
	self.Definition = definition or {}
	self.Services = services
	self.RuntimeData = runtimeData or {}
	self.RootPart = model.PrimaryPart or model:WaitForChild("HumanoidRootPart")
	
	self.Id = self.Definition.Id or model.Name
	self.DisplayName = self.Definition.DisplayName or model.Name
	self.StarRating = self.Definition.StarRating or self.Definition.StarRation or 1
	self.Weight = self.Definition.Weight or self.StarRating
	self.TemplateName = self.RuntimeData.TemplateName or self.Definition.TemplateName or self.Id
	self.IsRuntimeEntity = self.RuntimeData.IsRuntimeEntity == true
	self.IsSummon = self.RuntimeData.IsSummon == true
	self.OwnerEntity = self.RuntimeData.OwnerEntity
	self.ExpiresAt = self.RuntimeData.ExpiresAt
	
	self.Attributes = self.Definition.Attributes or {}
	
	local stats = self.Definition.Stats or {}
	local perception = self.Definition.Perception or {}
	local targeting = self.Definition.Targeting or {}
	local navigation = self.Definition.Navigation or {}
	local actions = self.Definition.Actions or {}
	local absorption = self.Definition.Absorption or {}
	
	self.IsActive = false
	self.MaxHealth = stats.Health or 100
	self.Health = self.MaxHealth
	self.Damage = stats.Damage or 10
	self.AttackRange = stats.AttackRange or 10
	self.AttackInterval = stats.AttackInterval or 1.5
	self.WalkSpeed = stats.WalkSpeed or stats.MoveSpeed or 10
	self.ChaseSpeed = stats.ChaseSpeed or self.WalkSpeed
	self.TerrorRadius = perception.TerrorRadius or stats.TerrorRadius or 80
	self.DetectionRadius = perception.DetectionRadius or stats.DetectionRadius or 60
	self.AttentionDuration = perception.AttentionDuration or stats.AttentionLevel or 2
	self.ChaseLostSightGraceDuration = perception.ChaseLostSightGraceDuration or math.min(self.AttentionDuration, 0.3)
	self.MemoryDuration = perception.MemoryDuration or (self.AttentionDuration + (navigation.ScoutLingerDuration or 1.25) + 2)
	self.InvestigationSpeedMultiplier = perception.InvestigationSpeedMultiplier or 0.85
	self.SearchDetectionRadiusMultiplier = perception.SearchDetectionRadiusMultiplier or 1
	self.IgnoreLineOfSightForDetection = perception.IgnoreLineOfSightForDetection == true
	self.IgnoreLineOfSightForInterest = perception.IgnoreLineOfSightForInterest == true
	self.IgnoreLineOfSightForAttacks = perception.IgnoreLineOfSightForAttacks == true
	self.StimulusInvestigationRadiusMultiplier = perception.StimulusInvestigationRadiusMultiplier or 2.5
	self.SearchStimulusRadiusMultiplier = perception.SearchStimulusRadiusMultiplier or 3
	self.InvestigateIntentDuration = perception.InvestigateIntentDuration or 4
	self.SearchIntentDuration = perception.SearchIntentDuration or (self.AttentionDuration + 1.5)
	self.StimulusReinvestigateCooldown = perception.StimulusReinvestigateCooldown or 2.5
	self.TargetRetentionBonus = targeting.CurrentTargetBonus or 18
	self.LineOfSightBonus = targeting.LineOfSightBonus or 25
	self.MemoryBonus = targeting.MemoryBonus or 12
	self.DistanceWeight = targeting.DistanceWeight or 1
	self.StopDistance = targeting.StopDistance or math.max(self.AttackRange * 0.5, 2)
	self.PatrolRadius = navigation.PatrolRadius or 28
	self.PatrolPointMinDistance = navigation.PatrolPointMinDistance or 8
	self.PatrolPauseDuration = navigation.PatrolPauseDuration or 1.2
	self.GlobalPatrolRelocateChance = navigation.GlobalPatrolRelocateChance or 0.3
	self.RoamAnchorMaxDuration = navigation.RoamAnchorMaxDuration or 8
	self.ScoutLingerDuration = navigation.ScoutLingerDuration or 1.25
	self.ScoutPointRadius = navigation.ScoutPointRadius or math.max(6, self.PatrolPointMinDistance)
	self.ScoutPointMinDistance = navigation.ScoutPointMinDistance or math.max(3, self.PatrolPointMinDistance * 0.5)
	self.ScoutPointCount = navigation.ScoutPointCount or 2
	self.SearchSpeedMultiplier = navigation.SearchSpeedMultiplier or 1.5
	self.BasicAttack = actions.BasicAttack or {
		Id = "BasicAttack",
		Kind = "BasicAttack",
		Cooldown = self.AttackInterval,
	}
	self.Abilities = actions.Abilities or {}
	self.AbilityOrder = actions.AbilityOrder or {}
	self.Passives = actions.Passives or {}
	self.RoundHooks = actions.RoundHooks or {}
	self.AttackInterval = self.BasicAttack.Cooldown or self.AttackInterval
	self.AbsorptionResistancePerAbility = absorption.ResistancePerAbility or 0
	self.AbsorptionMaxResistance = absorption.MaxResistance or 0.75
	self.AbsorptionFullThreshold = absorption.FullThreshold or 0
	self.AbsorptionRelinquishDamageThreshold = absorption.RelinquishDamageThreshold or 0
	self.AbsorptionProfiles = absorption.Profiles or {}
	
	self.LastAttackTime = 0
	self.LastStateChangeTime = os.clock()
	self.PreviousState = ENTITY_STATE.Dormant
	self.CurrentState = ENTITY_STATE.Dormant
	self.Random = Random.new()
	self.TargetPlayer = nil
	self.TargetLastKnownPosition = nil
	self.TargetLastSeenAt = nil
	self.TargetLastVisibleAt = nil
	self.TargetMemory = {}
	self.CurrentIntent = nil
	self.IntentTargetPosition = nil
	self.IntentSourceStimulus = nil
	self.IntentExpiresAt = nil
	self.IntentConfidence = 0
	self.IntentMetadata = nil
	self.InvestigatedStimulusKeys = {}
	self.CurrentSearchCenter = nil
	self.PatrolDestination = nil
	self.PatrolPauseUntil = 0
	self.ScoutArrivalTime = nil
	self.ScoutOrigin = nil
	self.ScoutPointsRemaining = 0
	self.SearchMode = nil
	self.ConditionStates = {}
	self.DownedPlayers = {}
	self.Cooldowns = {}
	self.ActiveEffects = {}
	self.ActiveCast = nil
	self.ActionSequenceId = 0
	self.SpecialMovementLockUntil = 0
	self.BasicAttackVariantIndex = 1
	self.AbsorbedAbilityCount = 0
	self.AbsorbedAbilitiesByPlayer = {}
	self.AbsorbedProfilesByPlayer = {}
	self.AbsorptionDamageProgress = 0
	self.PersistentModifiers = {
		Power = 0,
		Haste = 0,
		Resistance = 0,
	}
	
	self.SpawnCFrame = self.RootPart.CFrame
	self.RoamAnchor = self:GetSpawnPosition()
	self.RoamAnchorAssignedAt = os.clock()
	
	return self
end

function BaseEntity:SetActive(state)
	self.IsActive = state
	
	if state then
		self:EnterState(ENTITY_STATE.Patrol)
	else
		self:ResetRuntimeState()
		self:EnterState(ENTITY_STATE.Dormant)
	end
end

function BaseEntity:HasAttribute(attributeName)
	for _, value in ipairs(self.Attributes) do
		if value == attributeName then
			return true
		end
	end
	
	return false
end

function BaseEntity:GetState()
	return self.CurrentState
end

function BaseEntity:EnterState(stateName)
	if self.CurrentState == stateName then
		return
	end

	self.PreviousState = self.CurrentState
	self.CurrentState = stateName
	self.LastStateChangeTime = os.clock()

	if stateName == ENTITY_STATE.Patrol then
		self.ScoutArrivalTime = nil
		self.ScoutOrigin = nil
		self.ScoutPointsRemaining = 0
	elseif stateName == ENTITY_STATE.Scout then
		self.PatrolDestination = nil
		self.PatrolPauseUntil = 0
		self.ScoutOrigin = self.TargetLastKnownPosition
		self.ScoutPointsRemaining = 0
	elseif stateName == ENTITY_STATE.Chase then
		self.ScoutArrivalTime = nil
	end
end

function BaseEntity:GetStateDuration()
	return os.clock() - self.LastStateChangeTime
end

function BaseEntity:JustEnteredState(stateName, window)
	window = window or 0.4
	return self.CurrentState == stateName and self:GetStateDuration() <= window
end

function BaseEntity:EnteredCurrentStateFrom(stateName)
	return self.PreviousState == stateName
end

function BaseEntity:CanAttack()
	return os.clock() - self.LastAttackTime >= self.AttackInterval
end

function BaseEntity:MarkAttack(cooldown)
	self.LastAttackTime = os.clock()
	self:SetCooldown(self.BasicAttack.Id or "BasicAttack", cooldown or self.AttackInterval)
end

function BaseEntity:SetCooldown(key, duration)
	if duration == nil then
		self.Cooldowns[key] = nil
		return
	end

	self.Cooldowns[key] = os.clock() + duration
end

function BaseEntity:IsCooldownReady(key)
	local readyAt = self.Cooldowns[key]
	return readyAt == nil or os.clock() >= readyAt
end

function BaseEntity:UpdateActiveEffects()
	local now = os.clock()
	for index = #self.ActiveEffects, 1, -1 do
		local effect = self.ActiveEffects[index]
		if effect.ExpiresAt <= now then
			table.remove(self.ActiveEffects, index)
		end
	end
end

function BaseEntity:GetAbilityDefinitions()
	return self.Abilities
end

function BaseEntity:GetAbilityOrder()
	return self.AbilityOrder
end

function BaseEntity:GetPassiveDefinitions()
	return self.Passives
end

function BaseEntity:TriggerPassives(triggerName, context)
	for _, passive in pairs(self.Passives) do
		if passive.Trigger ~= triggerName then
			continue
		end

		for _, step in ipairs(passive.Effects or {}) do
			if step.Type == "ApplyPersistentModifierSelf" and step.Modifier and step.Amount then
				self:ApplyPersistentModifier(step.Modifier, step.Amount)
			end
		end
	end
end

function BaseEntity:GetActionCooldown(actionId)
	local readyAt = self.Cooldowns[actionId]
	if readyAt == nil then
		return 0
	end

	return math.max(0, readyAt - os.clock())
end

function BaseEntity:CanUseAbility(abilityId)
	local ability = self.Abilities[abilityId]
	if not ability then
		return false
	end

	if not self.IsActive or self.ActiveCast then
		return false
	end

	return self:IsCooldownReady(abilityId)
end

function BaseEntity:BeginCast(actionId, actionDefinition, targetPlayer)
	local castTime = actionDefinition.CastTime or 0
	self.ActiveCast = {
		Id = actionId,
		Definition = actionDefinition,
		TargetPlayer = targetPlayer,
		StartedAt = os.clock(),
		EndsAt = os.clock() + castTime,
	}

	self:EnterState(ENTITY_STATE.Casting)
end

function BaseEntity:GetActiveCast()
	return self.ActiveCast
end

function BaseEntity:IsCasting()
	return self.ActiveCast ~= nil
end

function BaseEntity:CompleteCast()
	local activeCast = self.ActiveCast
	self.ActiveCast = nil
	return activeCast
end

function BaseEntity:CancelCast()
	self.ActiveCast = nil
end

function BaseEntity:LockSpecialMovement(duration)
	self.SpecialMovementLockUntil = math.max(self.SpecialMovementLockUntil or 0, os.clock() + math.max(0, duration or 0))
end

function BaseEntity:IsSpecialMovementLocked()
	return os.clock() < (self.SpecialMovementLockUntil or 0)
end

function BaseEntity:ApplyPersistentModifier(modifierName, amount)
	if self.PersistentModifiers[modifierName] == nil then
		self.PersistentModifiers[modifierName] = 0
	end

	self.PersistentModifiers[modifierName] += amount
end

function BaseEntity:ApplyTimedModifier(modifierName, amount, duration, sourceKey)
	table.insert(self.ActiveEffects, {
		Modifier = modifierName,
		Amount = amount,
		ExpiresAt = os.clock() + duration,
		SourceKey = sourceKey,
	})
end

function BaseEntity:GetModifierValue(modifierName)
	local total = self.PersistentModifiers[modifierName] or 0

	for _, effect in ipairs(self.ActiveEffects) do
		if effect.Modifier == modifierName then
			total += effect.Amount
		end
	end

	return total
end

function BaseEntity:GetScaledDamage(baseAmount)
	local amount = baseAmount or self.Damage
	local statusService = self.Services and self.Services.StatusEffectService
	local statusPower = statusService and statusService:GetModifier(self, "Power") or 0
	local weakness = statusService and statusService:GetModifier(self, "Weakness") or 0
	return math.max(0, math.floor((amount * (1 + self:GetModifierValue("Power") + statusPower) * math.max(0, 1 - weakness)) + 0.5))
end

function BaseEntity:Heal(amount)
	self.Health = math.clamp(self.Health + amount, 0, self.MaxHealth)
	return self.Health
end

function BaseEntity:HealPercent(percent)
	return self:Heal(self.MaxHealth * percent)
end

function BaseEntity:GetPosition()
	if self.RootPart then
		return self.RootPart.Position
	end
	
	return nil
end

function BaseEntity:SetTarget(player, lastKnownPosition, wasVisible)
	self.TargetPlayer = player
	if player and lastKnownPosition then
		self:RememberTarget(player, lastKnownPosition, wasVisible)
	elseif not player then
		self.TargetLastKnownPosition = nil
		self.TargetLastSeenAt = nil
		self.TargetLastVisibleAt = nil
	end
end

function BaseEntity:GetTarget()
	return self.TargetPlayer
end

function BaseEntity:SetIntent(intentName, targetPosition, options)
	options = options or {}
	self.CurrentIntent = intentName
	self.IntentTargetPosition = targetPosition
	self.IntentSourceStimulus = options.SourceStimulus
	self.IntentExpiresAt = options.Duration and (os.clock() + math.max(0, options.Duration)) or options.ExpiresAt or nil
	self.IntentConfidence = options.Confidence or 0
	self.IntentMetadata = options.Metadata

	if options.SearchCenter ~= nil then
		self.CurrentSearchCenter = options.SearchCenter
	end
end

function BaseEntity:GetIntentName()
	return self.CurrentIntent
end

function BaseEntity:GetIntentTargetPosition()
	return self.IntentTargetPosition
end

function BaseEntity:GetIntentSourceStimulus()
	return self.IntentSourceStimulus
end

function BaseEntity:GetIntentConfidence()
	return self.IntentConfidence or 0
end

function BaseEntity:GetIntentMetadata()
	return self.IntentMetadata
end

function BaseEntity:GetCurrentSearchCenter()
	return self.CurrentSearchCenter
end

function BaseEntity:SetCurrentSearchCenter(position)
	self.CurrentSearchCenter = position
end

function BaseEntity:HasIntent()
	return self.CurrentIntent ~= nil
end

function BaseEntity:IsIntentExpired()
	return self.IntentExpiresAt ~= nil and os.clock() >= self.IntentExpiresAt
end

function BaseEntity:ClearIntent()
	self.CurrentIntent = nil
	self.IntentTargetPosition = nil
	self.IntentSourceStimulus = nil
	self.IntentExpiresAt = nil
	self.IntentConfidence = 0
	self.IntentMetadata = nil
	self.CurrentSearchCenter = nil
end

function BaseEntity:MarkStimulusInvestigated(stimulusKey, duration)
	if not stimulusKey then
		return
	end

	self.InvestigatedStimulusKeys[stimulusKey] = os.clock() + math.max(0, duration or self.StimulusReinvestigateCooldown)
end

function BaseEntity:HasInvestigatedStimulus(stimulusKey)
	if not stimulusKey then
		return false
	end

	local expiresAt = self.InvestigatedStimulusKeys[stimulusKey]
	if not expiresAt then
		return false
	end

	if os.clock() >= expiresAt then
		self.InvestigatedStimulusKeys[stimulusKey] = nil
		return false
	end

	return true
end

function BaseEntity:ClearExpiredInvestigatedStimuli()
	local now = os.clock()
	for stimulusKey, expiresAt in pairs(self.InvestigatedStimulusKeys) do
		if now >= expiresAt then
			self.InvestigatedStimulusKeys[stimulusKey] = nil
		end
	end
end

function BaseEntity:GetTargetLastKnownPosition()
	return self.TargetLastKnownPosition
end

function BaseEntity:GetSpawnPosition()
	return self.SpawnCFrame and self.SpawnCFrame.Position or self:GetPosition()
end

function BaseEntity:GetRoamAnchor()
	return self.RoamAnchor or self:GetSpawnPosition()
end

function BaseEntity:SetRoamAnchor(position)
	if not position then
		return
	end

	self.RoamAnchor = position
	self.RoamAnchorAssignedAt = os.clock()
end

function BaseEntity:ShouldRelocateRoamAnchor()
	return (os.clock() - (self.RoamAnchorAssignedAt or 0)) >= self.RoamAnchorMaxDuration
end

function BaseEntity:RememberTarget(player, position, wasVisible)
	if not player or not position then
		return
	end

	local timestamp = os.clock()
	local previousMemory = self.TargetMemory[player]
	local attentionExpiresAt = previousMemory and previousMemory.AttentionExpiresAt or nil
	if wasVisible == true then
		attentionExpiresAt = timestamp + self.AttentionDuration
	end

	self.TargetMemory[player] = {
		LastKnownPosition = position,
		LastSeenAt = timestamp,
		LastVisibleAt = wasVisible == true and timestamp or (previousMemory and previousMemory.LastVisibleAt) or nil,
		WasVisible = wasVisible == true,
		AttentionExpiresAt = attentionExpiresAt,
	}

	if self.TargetPlayer == player then
		self.TargetLastKnownPosition = position
		self.TargetLastSeenAt = timestamp
		if wasVisible == true then
			self.TargetLastVisibleAt = timestamp
		end
	end
end

function BaseEntity:GetTargetMemory(player)
	local memory = self.TargetMemory[player]
	if not memory then
		return nil
	end

	if os.clock() - memory.LastSeenAt > self.MemoryDuration then
		self.TargetMemory[player] = nil
		return nil
	end

	return memory
end

function BaseEntity:HasTargetMemory(player)
	return self:GetTargetMemory(player) ~= nil
end

function BaseEntity:ClearExpiredMemory()
	local now = os.clock()
	for player, memory in pairs(self.TargetMemory) do
		if now - memory.LastSeenAt > self.MemoryDuration then
			self.TargetMemory[player] = nil
		end
	end
end

function BaseEntity:HasAttentionOnTarget(player)
	local memory = self:GetTargetMemory(player)
	if not memory or not memory.AttentionExpiresAt then
		return false
	end

	return os.clock() < memory.AttentionExpiresAt
end

function BaseEntity:SetTrackedTarget(player)
	self.TargetPlayer = player

	if not player then
		self.TargetLastKnownPosition = nil
		self.TargetLastSeenAt = nil
		return
	end

	local memory = self:GetTargetMemory(player)
	if memory then
		self.TargetLastKnownPosition = memory.LastKnownPosition
		self.TargetLastSeenAt = memory.LastSeenAt
		self.TargetLastVisibleAt = memory.LastVisibleAt
	end
end

function BaseEntity:ForgetTarget(player)
	if not player then
		return
	end

	self.TargetMemory[player] = nil

	if self.TargetPlayer == player then
		self.TargetPlayer = nil
		self.TargetLastKnownPosition = nil
		self.TargetLastSeenAt = nil
		self.TargetLastVisibleAt = nil
	end
end

function BaseEntity:GetTimeSinceTargetWasVisible(player)
	local memory = self:GetTargetMemory(player)
	local lastVisibleAt = memory and memory.LastVisibleAt
	if not lastVisibleAt then
		return math.huge
	end

	return math.max(0, os.clock() - lastVisibleAt)
end

function BaseEntity:SetConditionActive(key, isActive)
	if not key then
		return
	end

	local now = os.clock()
	local conditionState = self.ConditionStates[key]
	if isActive then
		if not conditionState or not conditionState.IsActive then
			self.ConditionStates[key] = {
				IsActive = true,
				StartedAt = now,
			}
			return
		end

		conditionState.IsActive = true
		return
	end

	if conditionState then
		conditionState.IsActive = false
		conditionState.StartedAt = nil
	end
end

function BaseEntity:GetConditionDuration(key)
	local conditionState = key and self.ConditionStates[key]
	if not conditionState or not conditionState.IsActive or not conditionState.StartedAt then
		return 0
	end

	return math.max(0, os.clock() - conditionState.StartedAt)
end

function BaseEntity:GetPatrolDestination()
	return self.PatrolDestination
end

function BaseEntity:GetPatrolDestinationReason()
	return self.PatrolDestinationReason
end

function BaseEntity:SetPatrolDestination(position, reason)
	self.PatrolDestination = position
	self.PatrolDestinationReason = reason
end

function BaseEntity:ClearPatrolDestination()
	self.PatrolDestination = nil
	self.PatrolDestinationReason = nil
end

function BaseEntity:IsNearPosition(position, range)
	local entityPosition = self:GetPosition()
	if not entityPosition or not position then
		return false
	end

	return (position - entityPosition).Magnitude <= (range or self.StopDistance)
end

function BaseEntity:HasReachedPatrolDestination()
	return self.PatrolDestination ~= nil and self:IsNearPosition(self.PatrolDestination, self.StopDistance + 0.5)
end

function BaseEntity:HasReachedScoutDestination()
	return self.TargetLastKnownPosition ~= nil and self:IsNearPosition(self.TargetLastKnownPosition, self.StopDistance + 0.5)
end

function BaseEntity:MarkPatrolPause(duration)
	self.PatrolPauseUntil = os.clock() + (duration or self.PatrolPauseDuration)
end

function BaseEntity:IsPatrolPaused()
	return os.clock() < (self.PatrolPauseUntil or 0)
end

function BaseEntity:MarkScoutArrival()
	if not self.ScoutArrivalTime then
		self.ScoutArrivalTime = os.clock()
	end
end

function BaseEntity:ClearScoutArrival()
	self.ScoutArrivalTime = nil
end

function BaseEntity:HasFinishedScoutLinger()
	return self.ScoutArrivalTime ~= nil and (os.clock() - self.ScoutArrivalTime) >= self.ScoutLingerDuration
end

function BaseEntity:BeginScoutSweep(origin)
	self.ScoutOrigin = origin or self.TargetLastKnownPosition or self:GetPosition()
	self.ScoutPointsRemaining = math.max(0, self.ScoutPointCount or 0)
	self.ScoutArrivalTime = nil
	self.PatrolDestination = nil
end

function BaseEntity:HasScoutSweepRemaining()
	return (self.ScoutPointsRemaining or 0) > 0
end

function BaseEntity:PickScoutDestination()
	local origin = self.ScoutOrigin or self.TargetLastKnownPosition or self:GetPosition()
	if not origin then
		return nil
	end

	for _ = 1, 8 do
		local angle = self.Random:NextNumber(0, math.pi * 2)
		local distance = self.Random:NextNumber(self.ScoutPointMinDistance, self.ScoutPointRadius)
		local candidate = origin + Vector3.new(math.cos(angle) * distance, 0, math.sin(angle) * distance)
		if not self:IsNearPosition(candidate, self.ScoutPointMinDistance * 0.75) then
			self.PatrolDestination = candidate
			self.PatrolDestinationReason = "Scout"
			self.ScoutPointsRemaining = math.max(0, (self.ScoutPointsRemaining or 0) - 1)
			return candidate
		end
	end

	self.PatrolDestination = origin
	self.PatrolDestinationReason = "Scout"
	self.ScoutPointsRemaining = math.max(0, (self.ScoutPointsRemaining or 0) - 1)
	return origin
end

function BaseEntity:PickPatrolDestination()
	local origin = self:GetRoamAnchor()
	if not origin then
		return nil
	end

	for _ = 1, 8 do
		local angle = self.Random:NextNumber(0, math.pi * 2)
		local distance = self.Random:NextNumber(self.PatrolPointMinDistance, self.PatrolRadius)
		local candidate = origin + Vector3.new(math.cos(angle) * distance, 0, math.sin(angle) * distance)
		if not self:IsNearPosition(candidate, self.PatrolPointMinDistance * 0.75) then
			self.PatrolDestination = candidate
			self.PatrolDestinationReason = "Patrol"
			return candidate
		end
	end

	self.PatrolDestination = origin
	self.PatrolDestinationReason = "Patrol"
	return origin
end

function BaseEntity:GetMoveSpeed()
	local haste = self:GetModifierValue("Haste")
	local statusService = self.Services and self.Services.StatusEffectService
	if statusService then
		if statusService:HasFlag(self, "Stunned") then
			return 0
		end

		haste += statusService:GetModifier(self, "Haste")
	end

	local hinder = statusService and statusService:GetModifier(self, "Hinder") or 0
	if self.SearchMode then
		return (self.ChaseSpeed * self.SearchSpeedMultiplier) * (1 + haste) * math.max(0, 1 - hinder)
	end

	if self.CurrentState == ENTITY_STATE.Chase or self.CurrentState == ENTITY_STATE.Rage then
		return self.ChaseSpeed * (1 + haste) * math.max(0, 1 - hinder)
	end

	if self.CurrentState == ENTITY_STATE.Scout then
		return (self.ChaseSpeed * self.InvestigationSpeedMultiplier) * (1 + haste) * math.max(0, 1 - hinder)
	end

	return self.WalkSpeed * (1 + haste) * math.max(0, 1 - hinder)
end

function BaseEntity:GetSearchHeightOffset()
	if not self.SearchMode then
		return 0
	end

	return self.SearchMode.HeightOffset or 0
end

function BaseEntity:GetCurrentBasicAttackDefinition()
	local basicAttack = self.BasicAttack or {}
	local variants = basicAttack.Variants
	if not variants or #variants == 0 then
		return basicAttack
	end

	local index = math.clamp(self.BasicAttackVariantIndex or 1, 1, #variants)
	local variant = variants[index]
	local merged = table.clone(basicAttack)
	for key, value in pairs(variant) do
		merged[key] = value
	end

	return merged
end

function BaseEntity:AdvanceBasicAttackVariant()
	local variants = self.BasicAttack and self.BasicAttack.Variants
	if not variants or #variants == 0 then
		return
	end

	self.BasicAttackVariantIndex += 1
	if self.BasicAttackVariantIndex > #variants then
		self.BasicAttackVariantIndex = 1
	end
end

function BaseEntity:AbsorbAbilityFromPlayer(player, count)
	if not player then
		return 0
	end

	count = count or 1
	local previousCount = self.AbsorbedAbilitiesByPlayer[player] or 0
	self.AbsorbedAbilitiesByPlayer[player] = previousCount + count
	self.AbsorbedAbilityCount += count
	self:_refreshAbsorptionResistance()

	local profiles = self.AbsorptionProfiles
	if profiles and #profiles > 0 then
		local playerProfiles = self.AbsorbedProfilesByPlayer[player] or {}
		for absorbIndex = previousCount + 1, self.AbsorbedAbilitiesByPlayer[player] do
			local profile = profiles[((absorbIndex - 1) % #profiles) + 1]
			if profile then
				table.insert(playerProfiles, profile)
			end
		end
		self.AbsorbedProfilesByPlayer[player] = playerProfiles
	end

	return self.AbsorbedAbilitiesByPlayer[player]
end

function BaseEntity:_refreshAbsorptionResistance()
	self.PersistentModifiers.Resistance = math.min(self.AbsorptionMaxResistance, self.AbsorbedAbilityCount * self.AbsorptionResistancePerAbility)
end

function BaseEntity:GetAbsorbedAbilityCount()
	return self.AbsorbedAbilityCount or 0
end

function BaseEntity:GetAbsorbedAbilityCountForPlayer(player)
	return player and (self.AbsorbedAbilitiesByPlayer[player] or 0) or 0
end

function BaseEntity:IsPlayerFullyAbsorbed(player)
	if not player or self.AbsorptionFullThreshold <= 0 then
		return false
	end

	return self:GetAbsorbedAbilityCountForPlayer(player) >= self.AbsorptionFullThreshold
end

function BaseEntity:GetInheritedBasicAttackEffects()
	local effects = {}

	for _, profiles in pairs(self.AbsorbedProfilesByPlayer) do
		for _, profile in ipairs(profiles) do
			for _, step in ipairs(profile.Effects or {}) do
				table.insert(effects, step)
			end
		end
	end

	return effects
end

function BaseEntity:RelinquishRandomAbsorbedAbility()
	if self.AbsorbedAbilityCount <= 0 then
		return nil
	end

	local candidates = {}
	for player, count in pairs(self.AbsorbedAbilitiesByPlayer) do
		if count and count > 0 then
			table.insert(candidates, player)
		end
	end

	if #candidates <= 0 then
		return nil
	end

	local targetPlayer = candidates[self.Random:NextInteger(1, #candidates)]
	self.AbsorbedAbilitiesByPlayer[targetPlayer] -= 1
	self.AbsorbedAbilityCount = math.max(0, self.AbsorbedAbilityCount - 1)

	local playerProfiles = self.AbsorbedProfilesByPlayer[targetPlayer]
	local removedProfile = nil
	if playerProfiles and #playerProfiles > 0 then
		removedProfile = table.remove(playerProfiles)
		if #playerProfiles <= 0 then
			self.AbsorbedProfilesByPlayer[targetPlayer] = nil
		end
	end

	if self.AbsorbedAbilitiesByPlayer[targetPlayer] <= 0 then
		self.AbsorbedAbilitiesByPlayer[targetPlayer] = nil
	end

	self:_refreshAbsorptionResistance()

	return {
		Player = targetPlayer,
		Profile = removedProfile,
		RemainingOnTarget = self.AbsorbedAbilitiesByPlayer[targetPlayer] or 0,
		TotalRemaining = self.AbsorbedAbilityCount,
	}
end

function BaseEntity:RegisterIncomingDamage(amount)
	if not amount or amount <= 0 then
		return {}
	end

	if self.AbsorptionRelinquishDamageThreshold <= 0 then
		return {}
	end

	self.AbsorptionDamageProgress += amount
	local released = {}
	while self.AbsorptionDamageProgress >= self.AbsorptionRelinquishDamageThreshold and self.AbsorbedAbilityCount > 0 do
		self.AbsorptionDamageProgress -= self.AbsorptionRelinquishDamageThreshold
		local relinquished = self:RelinquishRandomAbsorbedAbility()
		if not relinquished then
			self.AbsorptionDamageProgress = 0
			break
		end

		table.insert(released, relinquished)
	end

	return released
end

function BaseEntity:GetDetectionRange()
	if self.SearchMode then
		local multiplier = self.SearchMode.DetectionRadiusMultiplier or self.SearchDetectionRadiusMultiplier
		return self.DetectionRadius * multiplier
	end

	return self.DetectionRadius
end

function BaseEntity:GetStopDistance()
	return self.StopDistance
end

function BaseEntity:MoveToward(position, deltaTime)
	if not self.RootPart or not position then
		return
	end
	
	local currentPosition = self.RootPart.Position
	local offset = position - currentPosition
	local distance = offset.Magnitude
	
	if distance <= 0.01 then
		return
	end
	
	local stopDistance = self:GetStopDistance()
	if distance <= stopDistance then
		return
	end
	
	local direction = offset.Unit
	local moveStep = math.min(distance - stopDistance, self:GetMoveSpeed() * deltaTime)
	if moveStep <= 0 then
		return
	end
	
	local nextPosition = currentPosition + direction * moveStep

	if self.SearchMode and self.SearchMode.HeightOffset then
		nextPosition = Vector3.new(nextPosition.X, self.SearchMode.BaseY + self.SearchMode.HeightOffset, nextPosition.Z)
		position = Vector3.new(position.X, self.SearchMode.BaseY + self.SearchMode.HeightOffset, position.Z)
	end
	
	self.RootPart.CFrame = CFrame.new(nextPosition, position)
end

function BaseEntity:IsInRange(position, range)
	local entityPosition = self:GetPosition()
	if not entityPosition or not position then
		return false
	end

	return (position - entityPosition).Magnitude <= range
end

function BaseEntity:ResetRuntimeState()
	self.PreviousState = ENTITY_STATE.Dormant
	self.TargetPlayer = nil
	self.TargetLastKnownPosition = nil
	self.TargetLastSeenAt = nil
	self.TargetLastVisibleAt = nil
	self.TargetMemory = {}
	self.CurrentIntent = nil
	self.IntentTargetPosition = nil
	self.IntentSourceStimulus = nil
	self.IntentExpiresAt = nil
	self.IntentConfidence = 0
	self.IntentMetadata = nil
	self.InvestigatedStimulusKeys = {}
	self.CurrentSearchCenter = nil
	self.PatrolDestination = nil
	self.PatrolDestinationReason = nil
	self.PatrolPauseUntil = 0
	self.ScoutArrivalTime = nil
	self.ScoutOrigin = nil
	self.ScoutPointsRemaining = 0
	self.RoamAnchor = self:GetSpawnPosition()
	self.RoamAnchorAssignedAt = os.clock()
	self.SearchMode = nil
	self.ConditionStates = {}
	self.DownedPlayers = {}
	self.RegisteredRoundHookIds = {}
	self.Cooldowns = {}
	self.ActiveEffects = {}
	self.ActiveCast = nil
	self.ActionSequenceId = 0
	self.SpecialMovementLockUntil = 0
	self.BasicAttackVariantIndex = 1
	self.AbsorbedAbilityCount = 0
	self.AbsorbedAbilitiesByPlayer = {}
	self.AbsorbedProfilesByPlayer = {}
	self.AbsorptionDamageProgress = 0
	self.LastAttackTime = 0
end

function BaseEntity:ResetToSpawn()
	if self.RootPart then
		self.RootPart.CFrame = self.SpawnCFrame
	end
	
	self.Health = self.MaxHealth
	self.PersistentModifiers.Power = 0
	self.PersistentModifiers.Haste = 0
	self.PersistentModifiers.Resistance = 0
	self:ResetRuntimeState()
	self:EnterState(self.IsActive and ENTITY_STATE.Patrol or ENTITY_STATE.Dormant)
end

function BaseEntity:Destroy()
	self.Model = nil
	self.Definition = nil
	self.RootPart = nil
	self.TargetPlayer = nil
end

function BaseEntity:SetLifetime(duration)
	if duration == nil then
		self.ExpiresAt = nil
		return
	end

	self.ExpiresAt = os.clock() + duration
end

function BaseEntity:HasExpired()
	return self.ExpiresAt ~= nil and os.clock() >= self.ExpiresAt
end

function BaseEntity:BeginSearchMode(searchId, duration, options)
	options = options or {}
	self.SearchMode = {
		Id = searchId,
		EndsAt = duration and (os.clock() + duration) or nil,
		HeightOffset = options.HeightOffset,
		BaseY = (self.RootPart and self.RootPart.Position.Y) or 0,
		IgnoreMovementBlockers = options.IgnoreMovementBlockers == true,
		DetectionRadiusMultiplier = options.DetectionRadiusMultiplier,
	}
end

function BaseEntity:IsSearchModeActive(searchId)
	if not self.SearchMode then
		return false
	end

	if searchId ~= nil and self.SearchMode.Id ~= searchId then
		return false
	end

	if self.SearchMode.EndsAt == nil then
		return true
	end

	return os.clock() < self.SearchMode.EndsAt
end

function BaseEntity:EndSearchMode(searchId)
	if not self.SearchMode then
		return
	end

	if searchId ~= nil and self.SearchMode.Id ~= searchId then
		return
	end

	if self.RootPart and self.SearchMode.BaseY then
		local currentPosition = self.RootPart.Position
		local lookVector = self.RootPart.CFrame.LookVector
		local groundedPosition = Vector3.new(currentPosition.X, self.SearchMode.BaseY, currentPosition.Z)
		self.RootPart.CFrame = CFrame.new(groundedPosition, groundedPosition + Vector3.new(lookVector.X, 0, lookVector.Z))
	end

	self.SearchMode = nil
end

return BaseEntity
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="79">
          <Properties>
            <string name="Name">BaseObjective</string>
            <string name="Source"><![CDATA[local BaseObjective = {}
BaseObjective.__index = BaseObjective

function BaseObjective.new(instance, definition)
	local self = setmetatable({}, BaseObjective)
	
	self.Instance = instance
	self.Definition = definition or {}
	
	self.Id = self.Definition.Id or instance.Name
	self.DisplayName = self.Definition.DisplayName or instance.Name
	self.Type = self.Definition.Type or "Unknown"
	self.Phase = self.Definition.Phase or "None"
	self.Shared = self.Definition.Shared == true
	self.StartsEnabled = self.Definition.StartsEnabled == true
	self.MaxProgress = self.Definition.MaxProgress or 1
	self.ChargeRate = self.Definition.ChargeRate or 1
	
	self.Progress = 0
	self.LastLoggedProgressStep = -1
	self.IsComplete = false
	self.IsEnabled = self.StartsEnabled
	
	return self
end

function BaseObjective:SetEnabled(state)
	self.IsEnabled = state
end

function BaseObjective:CanInteract()
	return self.IsEnabled and not self.IsComplete
end

function BaseObjective:AddProgress(amount)
	if not self:CanInteract() then
		return false
	end
	
	self.Progress += amount
	
	if self.Progress >= self.MaxProgress then
		self.Progress = self.MaxProgress
		self.IsComplete = true
	end
	
	return true
end

function BaseObjective:GetProgressAlpha()
	if self.MaxProgress <= 0 then
		return 0
	end
	
	return self.Progress / self.MaxProgress
end

function BaseObjective:Destroy()
	self.Instance = nil
	self.Definition = nil
end

return BaseObjective
]]></string>
          </Properties>
        </Item>
      </Item>
      <Item class="Folder" referent="80">
        <Properties>
          <string name="Name">Managers</string>
        </Properties>
        <Item class="ModuleScript" referent="81">
          <Properties>
            <string name="Name">RoundManager</string>
            <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")

local GamePhase = require(ReplicatedStorage.Shared.Enums.GamePhase)
local RoundOutcome = require(ReplicatedStorage.Shared.Enums.RoundOutcome)
local RoundConfig = require(ReplicatedStorage.Shared.Data.RoundConfig)
local RemoteNames = require(ReplicatedStorage.Shared.Constants.RemoteNames)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local RoundManager = {}
RoundManager.Name = "RoundManager"

function RoundManager:Init(services)
	self.Services = services
	self.CurrentPhase = GamePhase.Lobby
	self.CurrentOutcome = RoundOutcome.None
	self.TimeLeft = 0
	self.IsRunning = false
	self.SkipPhase = false

	self.ActivePlayers = {}
	self.RoundStates = {}
	self.SelectedEntityLineup = {}
	self.CurrentReceptionDuration = RoundConfig.ReceptionDuration
end

function RoundManager:Start()
	DebugLog:Log("Round", "[RoundManager] Started")

	if self.IsRunning then
		return
	end

	self.IsRunning = true

	task.spawn(function()
		self:RunLoop()
	end)
end

function RoundManager:SetPhase(phase, duration)
	self.CurrentPhase = phase
	self.TimeLeft = duration or 0

	DebugLog:Log("Round", string.format("[RoundManager] Phase -> %s (%ds)", phase, self.TimeLeft))

	if phase == GamePhase.Lobby then
		if self.Services.InteractionService then
			self.Services.InteractionService:StopAllInteractions("LobbyReset")
		end
		if self.Services.ObjectiveService then
			self.Services.ObjectiveService:ResetObjectives()
		end
		if self.Services.VotingService then
			self.Services.VotingService:ResetDraft()
		end
		if self.Services.EntityService then
			self.Services.EntityService:SetRoundLineup(nil)
		end
		self:ClearRound()
		for _, player in ipairs(self.Services.PlayerService:GetPlayers()) do
			self:ApplyCurrentPhaseStateToPlayer(player)
		end
		self.Services.SpawnService:TeleportAllPlayersToLobby()
		self.Services.EntityService:SetAllEntitiesActive(false, {
			ResetRound = true,
		})

	elseif phase == GamePhase.Preparation then
		self:BuildRoundRoster()
		self.Services.SpawnService:TeleportPlayersToReception(self.ActivePlayers)
		self.Services.EntityService:SetAllEntitiesActive(false)
		for _, player in ipairs(self.ActivePlayers) do
			self:ApplyCurrentPhaseStateToPlayer(player)
		end

	elseif phase == GamePhase.Reception then
		self.Services.EntityService:SetAllEntitiesActive(true)
		for _, player in ipairs(self.ActivePlayers) do
			self:ApplyCurrentPhaseStateToPlayer(player)
		end

	elseif phase == GamePhase.Results then
		if self.Services.InteractionService then
			self.Services.InteractionService:StopAllInteractions("Results")
		end
		self.Services.EntityService:SetAllEntitiesActive(false)
		for _, player in ipairs(self.ActivePlayers) do
			self:ApplyCurrentPhaseStateToPlayer(player)
		end
		
	end

	local roundStateChanged = self.Services.RemoteRegistry:GetRemote(RemoteNames.RoundStateChanged)
	if roundStateChanged then
		roundStateChanged:FireAllClients({
			Phase = self.CurrentPhase,
			TimeLeft = self.TimeLeft,
			Outcome = self.CurrentOutcome,
		})
	end

	self:BroadcastTimer()

	if self.Services.RoundHookService then
		self.Services.RoundHookService:RaisePhaseChanged(self.CurrentPhase, self.TimeLeft)
	end
end

function RoundManager:BroadcastTimer()
	local roundTimerUpdated = self.Services.RemoteRegistry:GetRemote(RemoteNames.RoundTimerUpdated)
	if roundTimerUpdated then
		roundTimerUpdated:FireAllClients({
			Phase = self.CurrentPhase,
			TimeLeft = self.TimeLeft,
			Outcome = self.CurrentOutcome,
		})
	end
end

function RoundManager:RunPhase(phase, duration)
	self.SkipPhase = false
	self:SetPhase(phase, duration)

	while self.TimeLeft > 0 do
		if self.SkipPhase then
			self.TimeLeft = 0
			self:BroadcastTimer()
			break
		end

		task.wait(1)
		self.TimeLeft -= 1
		self:BroadcastTimer()
		if self.Services.RoundHookService then
			self.Services.RoundHookService:RaiseTimerTick(phase, self.TimeLeft)
		end
	end

	if phase == GamePhase.Reception and not self.SkipPhase then
		self:OnReceptionTimerExpired()
	end
end

function RoundManager:RunLoop()
	while true do
		self:RunPhase(GamePhase.Lobby, RoundConfig.IntermissionDuration)
		self:RunVotingPhase()
		self:RunPhase(GamePhase.Preparation, RoundConfig.PreparationDuration)
		self:RunPhase(GamePhase.Reception, self.CurrentReceptionDuration or RoundConfig.ReceptionDuration)
		self:RunPhase(GamePhase.Results, RoundConfig.ResultsDuration)
	end
end

function RoundManager:RunVotingPhase()
	local votingService = self.Services.VotingService
	if not votingService then
		self.SelectedEntityLineup = {}
		self.CurrentReceptionDuration = RoundConfig.ReceptionDuration
		self:RunPhase(GamePhase.Voting, RoundConfig.VotingDuration)
		return
	end

	self.SkipPhase = false
	self:SetPhase(GamePhase.Voting, votingService:GetRoundDuration())

	local draftResult = votingService:RunDraft()
	self.SelectedEntityLineup = draftResult.SelectedEntityIds or {}
	self.CurrentReceptionDuration = draftResult.ReceptionDuration or RoundConfig.ReceptionDuration

	if self.Services.EntityService then
		self.Services.EntityService:SetRoundLineup(self.SelectedEntityLineup)
	end

	self.TimeLeft = 0
	self:BroadcastTimer()
end

function RoundManager:BuildRoundRoster()
	table.clear(self.ActivePlayers)
	table.clear(self.RoundStates)

	local players = self.Services.PlayerService:GetPlayers()

	for _, player in ipairs(players) do
		local character = self.Services.CharacterService:GetCharacterByPlayer(player)

		if character and character:IsAlive() then
			table.insert(self.ActivePlayers, player)

			self.RoundStates[player] = {
				IsActive = true,
				IsAlive = true,
				HasEscaped = false,
				IsEliminated = false,
			}
		end
	end

	DebugLog:Log("Round", string.format("[RoundManager] Built roster with %d active players", #self.ActivePlayers))
end

function RoundManager:ClearRound()
	table.clear(self.ActivePlayers)
	table.clear(self.RoundStates)
	table.clear(self.SelectedEntityLineup)
	self.CurrentOutcome = RoundOutcome.None
	self.CurrentReceptionDuration = RoundConfig.ReceptionDuration
	if self.Services.StimulusService then
		self.Services.StimulusService:Reset()
	end
	if self.Services.RoundHookService then
		self.Services.RoundHookService:ResetHooks()
	end
end

function RoundManager:GetRoundState(player)
	return self.RoundStates[player]
end

function RoundManager:GetActivePlayers()
	return self.ActivePlayers
end

function RoundManager:IsPlayerActive(player)
	local roundState = self.RoundStates[player]
	return roundState ~= nil and roundState.IsActive == true
end

function RoundManager:IsReceptionActive()
	return self.CurrentPhase == GamePhase.Reception
end

function RoundManager:GetCurrentPhase()
	return self.CurrentPhase
end

function RoundManager:IsInvinciblePhase(phase)
	return phase == GamePhase.Preparation or phase == GamePhase.Results
end

function RoundManager:ApplyCurrentPhaseStateToPlayer(player)
	local character = self.Services.CharacterService:GetCharacterByPlayer(player)
	if not character then
		return
	end
	
	local isActivePlayer = self:IsPlayerActive(player)
	local shouldBeInvincible = isActivePlayer and self:IsInvinciblePhase(self.CurrentPhase)
	local shouldBeFrozen = isActivePlayer and (self.CurrentPhase == GamePhase.Results)
	
	character:SetInvincible(shouldBeInvincible)
	
	if shouldBeFrozen then
		character:Freeze()
	else
		character:Unfreeze()
	end
end

function RoundManager:FreezeActivePlayers()
	for _, player in ipairs(self.ActivePlayers) do
		local character = self.Services.CharacterService:GetCharacterByPlayer(player)
		if character then
			character:Freeze()
		end
	end
end

function RoundManager:UnfreezeActivePlayers()
	for _, player in ipairs(self.ActivePlayers) do
		local character = self.Services.CharacterService:GetCharacterByPlayer(player)
		if character then
			character:Unfreeze()
		end
	end
end

function RoundManager:SetPlayerEliminated(player)
	if not self:IsReceptionActive() then
		return
	end

	local roundState = self.RoundStates[player]
	if not roundState then
		return
	end

	roundState.IsAlive = false
	roundState.IsEliminated = true

	DebugLog:Log("Round", "[RoundManager] Eliminated", player.Name)
	DebugLog:Log("Round", "[RoundManager] Alive remaining:", self:GetAliveCount())

	self:CheckRoundEnd()
end

function RoundManager:SetPlayerEscaped(player)
	if not self:IsReceptionActive() then
		return
	end
	
	local roundState = self.RoundStates[player]
	if not roundState then
		return
	end

	roundState.IsAlive = false
	roundState.HasEscaped = true

	DebugLog:Log("Round", "[RoundManager] Escaped", player.Name)
	DebugLog:Log("Round", "[RoundManager] Escaped count:", self:GetEscapedCount(), "/", self:GetRequiredEscapeCount())
	DebugLog:Log("Round", "[RoundManager] Alive remaining:", self:GetAliveCount())

	self:CheckRoundEnd()
end

function RoundManager:GetActivePlayerCount()
	return #self.ActivePlayers
end

function RoundManager:GetRequiredEscapeCount()
	local total = self:GetActivePlayerCount()
	return math.floor(total / 2) + 1
end

function RoundManager:GetAliveCount()
	local count = 0

	for _, roundState in pairs(self.RoundStates) do
		if roundState.IsAlive then
			count += 1
		end
	end

	return count
end

function RoundManager:GetEscapedCount()
	local count = 0

	for _, roundState in pairs(self.RoundStates) do
		if roundState.HasEscaped then
			count += 1
		end
	end

	return count
end

function RoundManager:GetEliminatedCount()
	local count = 0

	for _, roundState in pairs(self.RoundStates) do
		if roundState.IsEliminated then
			count += 1
		end
	end

	return count
end

function RoundManager:CheckRoundEnd()
	if not self:IsReceptionActive() then
		return
	end

	local aliveCount = self:GetAliveCount()
	local escapedCount = self:GetEscapedCount()
	local requiredEscapeCount = self:GetRequiredEscapeCount()
	
	if escapedCount >= requiredEscapeCount then
		DebugLog:Log("Round", "[RoundManager] Escape threshold reached, Remnants win")
		self:EndReception(RoundOutcome.RemnantsWin)
		return
	end

	if aliveCount <= 0 then
		local escapedCount = self:GetEscapedCount()
		local outcome = escapedCount > 0 and RoundOutcome.RemnantsWin or RoundOutcome.EntitiesWin
		DebugLog:Log("Round", "[RoundManager] No active players remain, ending round early.")
		self:EndReception(outcome)
	end
end

function RoundManager:EndReception(outcome)
	if not self:IsReceptionActive() then
		return
	end

	self.CurrentOutcome = outcome or RoundOutcome.None
	self.SkipPhase = true

	DebugLog:Log("Round", "[RoundManager] Reception ended with outcome:", self.CurrentOutcome)
end

function RoundManager:OnReceptionTimerExpired()
	DebugLog:Log("Round", "[RoundManager] Reception timer expired")

	local aliveCount = self:GetAliveCount()
	local escapedCount = self:GetEscapedCount()

	if aliveCount > 0 then
		self:EndReception(RoundOutcome.Draw)
	elseif escapedCount > 0 then
		self:EndReception(RoundOutcome.RemnantsWin)
	else
		self:EndReception(RoundOutcome.EntitiesWin)
	end
end

function RoundManager:OnObjectiveCompleted(objective)
	if self.Services.RoundHookService then
		self.Services.RoundHookService:RaiseObjectiveCompleted(objective)
	end
end

return RoundManager
]]></string>
          </Properties>
        </Item>
      </Item>
      <Item class="Folder" referent="82">
        <Properties>
          <string name="Name">Services</string>
        </Properties>
        <Item class="ModuleScript" referent="83">
          <Properties>
            <string name="Name">BreathHoldService</string>
            <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")

local RemoteNames = require(ReplicatedStorage.Shared.Constants.RemoteNames)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local BreathHoldService = {}
BreathHoldService.Name = "BreathHoldService"
BreathHoldService.Dependencies = {
	"RemoteRegistry",
	"RoundManager",
	"CharacterService",
	"StatusEffectService",
}

function BreathHoldService:Init(services)
	self.Services = services
	self.ActiveChallenges = {}
	self.UpdateInterval = 0.1
end

function BreathHoldService:Start()
	self.BreathHoldStateRemote = self.RemoteRegistry:GetRemote(RemoteNames.BreathHoldStateChanged)
	local requestBreathHoldState = self.RemoteRegistry:GetRemote(RemoteNames.RequestBreathHoldState)

	requestBreathHoldState.OnServerEvent:Connect(function(player, isHolding)
		self:HandleHoldState(player, isHolding)
	end)

	task.spawn(function()
		self:_runLoop()
	end)

	DebugLog:Log("Interaction", "[BreathHoldService] Started")
end

function BreathHoldService:BeginChallenge(entity, params)
	if not entity or not self.RoundManager or not self.RoundManager:IsReceptionActive() then
		return false
	end

	local activePlayers = self.RoundManager:GetActivePlayers()
	if #activePlayers <= 0 then
		return false
	end

	local challengeId = tostring(os.clock())
	local duration = params.Duration or 3
	local indicatorDuration = params.IndicatorDuration or 2.5
	local reactionWindow = params.ReactionWindow or 1
	local entityPosition = entity:GetPosition()
	local radius = params.Radius
	local challenge = {
		Id = challengeId,
		Entity = entity,
		StartedAt = os.clock(),
		ActiveAt = os.clock() + indicatorDuration,
		EndsAt = os.clock() + indicatorDuration + duration,
		Duration = duration,
		IndicatorDuration = indicatorDuration,
		ReactionWindow = reactionWindow,
		Phase = "Indicator",
		HastePerFailure = params.HastePerFailure or 0.15,
		BaseHasteDuration = params.HasteDuration or 5,
		FailDrainRate = params.FailDrainRate or (reactionWindow > 0 and (1 / reactionWindow) or 1),
		HoldDrainRate = params.HoldDrainRate or 0.05,
		Radius = radius,
		Participants = {},
	}

	for _, player in ipairs(activePlayers) do
		local roundState = self.RoundManager:GetRoundState(player)
		if roundState and roundState.IsAlive then
			local character = self.CharacterService and self.CharacterService:GetCharacterByPlayer(player)
			local isInRange = true
			if radius and entityPosition and character and character.RootPart then
				isInRange = (character.RootPart.Position - entityPosition).Magnitude <= radius
			end

			if isInRange then
				challenge.Participants[player] = {
					IsHolding = false,
					BreathRemaining = 1,
				}

				self.BreathHoldStateRemote:FireClient(player, {
					State = "Indicator",
					Duration = indicatorDuration,
					Prompt = "Breathless Hunt",
					SubPrompt = "Mist gathers. Be ready to hold your breath.",
					RequiredKey = "GET READY",
				})
			end
		end
	end

	if next(challenge.Participants) == nil then
		return false
	end

	self.ActiveChallenges[challengeId] = challenge
	DebugLog:Log("Interaction", string.format("[BreathHoldService] %s began Breathless Hunt", entity.DisplayName))
	return true
end

function BreathHoldService:HandleHoldState(player, isHolding)
	for _, challenge in pairs(self.ActiveChallenges) do
		local participant = challenge.Participants[player]
		if participant and challenge.Phase == "Challenge" then
			participant.IsHolding = isHolding == true
		end
	end
end

function BreathHoldService:CancelChallengesForEntity(entity, reason)
	if not entity then
		return 0
	end

	local cancelledCount = 0
	for challengeId, challenge in pairs(self.ActiveChallenges) do
		if challenge.Entity == entity then
			for player in pairs(challenge.Participants) do
				self.BreathHoldStateRemote:FireClient(player, {
					State = "Stop",
					Reason = reason or "Interrupted",
				})
			end

			self.ActiveChallenges[challengeId] = nil
			cancelledCount += 1
		end
	end

	return cancelledCount
end

function BreathHoldService:_runLoop()
	while true do
		self:_updateChallenges()
		task.wait(self.UpdateInterval)
	end
end

function BreathHoldService:_updateChallenges()
	local now = os.clock()

	for challengeId, challenge in pairs(self.ActiveChallenges) do
		if challenge.Phase == "Indicator" and now >= challenge.ActiveAt then
			challenge.Phase = "Challenge"
			for player in pairs(challenge.Participants) do
				self.BreathHoldStateRemote:FireClient(player, {
					State = "Start",
					Duration = challenge.Duration,
					RequiredKey = "SPACE",
					Prompt = "Hold Space to stay silent",
					SubPrompt = string.format("Your breath will give you away in %.1fs if you do not react", challenge.ReactionWindow),
					Breath = 1,
				})
			end
		end

		if challenge.Phase == "Challenge" then
			for player, participant in pairs(challenge.Participants) do
				local drainRate = participant.IsHolding and challenge.HoldDrainRate or challenge.FailDrainRate
				participant.BreathRemaining = math.max(0, participant.BreathRemaining - (drainRate * self.UpdateInterval))

				self.BreathHoldStateRemote:FireClient(player, {
					State = "Update",
					Duration = math.max(0, challenge.EndsAt - now),
					RequiredKey = "SPACE",
					Breath = participant.BreathRemaining,
					Prompt = "Hold Space to stay silent",
					SubPrompt = string.format("Your breath will give you away in %.1fs if you do not react", challenge.ReactionWindow),
				})
			end
		end

		if now >= challenge.EndsAt then
			self:_resolveChallenge(challengeId, challenge)
		end
	end
end

function BreathHoldService:_resolveChallenge(challengeId, challenge)
	local failedPlayers = {}
	local entityPosition = challenge.Entity:GetPosition()

	for player, participant in pairs(challenge.Participants) do
		self.BreathHoldStateRemote:FireClient(player, {
			State = "Stop",
		})

		if participant.BreathRemaining <= 0 then
			table.insert(failedPlayers, player)
		end
	end

	if #failedPlayers > 0 then
		self.StatusEffectService:ApplyStatus(challenge.Entity, "Haste", {
			Duration = challenge.BaseHasteDuration * #failedPlayers,
			Magnitude = challenge.HastePerFailure * #failedPlayers,
			Source = "BreathlessHunt",
		})

		local bestTarget = nil
		local bestDistance = math.huge

		for _, player in ipairs(failedPlayers) do
			local character = self.CharacterService:GetCharacterByPlayer(player)
			if character and character.RootPart and entityPosition then
				challenge.Entity:RememberTarget(player, character.RootPart.Position, true)

				local distance = (character.RootPart.Position - entityPosition).Magnitude
				if distance < bestDistance then
					bestDistance = distance
					bestTarget = {
						Player = player,
						Position = character.RootPart.Position,
					}
				end
			end
		end

		if bestTarget then
			challenge.Entity:SetTarget(bestTarget.Player, bestTarget.Position, true)
			challenge.Entity:EnterState("Chase")
		end
	end

	self.ActiveChallenges[challengeId] = nil
end

return BreathHoldService
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="84">
          <Properties>
            <string name="Name">CharacterService</string>
            <string name="Source"><![CDATA[local Players = game:GetService("Players")
local ServerScriptService = game:GetService("ServerScriptService")

local BaseCharacter = require(ServerScriptService.Server.Classes.BaseCharacter)
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local CharacterService = {}
CharacterService.Name = "CharacterService"
CharacterService.Dependencies = {
	"PlayerService",
	"RoundManager",
	"StatusEffectService",
}

function CharacterService:Init(services)
	self.Services = services
	self.CharactersByPlayer = {}
	self.CharactersByModel = {}
end

function CharacterService:Start()
	for _, player in ipairs(Players:GetPlayers()) do
		self:_connectPlayer(player)
		
		if player.Character then
			self:_onCharacterAdded(player, player.Character)
		end
	end
	
	Players.PlayerAdded:Connect(function(player: Player)
		self:_connectPlayer(player)
	end)
	
	Players.PlayerRemoving:Connect(function(player)
		self:_cleanupPlayer(player)
	end)
	
	DebugLog:Log("Character", "[CharacterService] Started")
end

function CharacterService:_connectPlayer(player)
	player.CharacterAdded:Connect(function(characterModel)
		self:_onCharacterAdded(player, characterModel)
	end)
	
	player.CharacterRemoving:Connect(function(characterModel)
		self:_onCharacterRemoving(player, characterModel)
	end)
end

function CharacterService:_onCharacterAdded(player, characterModel)
	local oldCharacter = self.CharactersByPlayer[player]
	if oldCharacter then
		self:_removeCharacter(player, oldCharacter.Model)
	end

	self:_disableDefaultCharacterScripts(characterModel)
	
	local character = BaseCharacter.new(player, characterModel, self.Services)
	self.CharactersByPlayer[player] = character
	self.CharactersByModel[characterModel] = character
	
	local playerService = self.PlayerService
	if playerService then
		playerService:SetAlive(player, true)
		playerService:SetMovementState(player, "IsSprinting", false)
		playerService:SetMovementState(player, "IsCrouching", false)
		playerService:SetMovementState(player, "IsAiming", false)
	end

	local roundManager = self.RoundManager
	if roundManager then
		roundManager:ApplyCurrentPhaseStateToPlayer(player)
	end

	if self.Services.StaminaService then
		self.Services.StaminaService:ResetPlayer(player)
	end
	
	character.Humanoid.Died:Connect(function()
		if character.IsInvincible then
			DebugLog:Log("Character", "[CharacterService] Ignoring death for invincible character", player.Name)
			return
		end
		local livePlayerService = self.PlayerService
		if livePlayerService then
			livePlayerService:SetAlive(player, false)
			livePlayerService:SetMovementState(player, "IsSprinting", false)
			livePlayerService:SetMovementState(player, "IsCrouching", false)
			livePlayerService:SetMovementState(player, "IsAiming", false)
		end
		
		local liveRoundManager = self.RoundManager
		if liveRoundManager and liveRoundManager:IsPlayerActive(player) then
			liveRoundManager:SetPlayerEliminated(player)
		end
		DebugLog:Log("Character", "[CharacterService] Character died for", player.Name)
	end)
	
	DebugLog:Log("Character", "[CharacterService] Registered character for", player.Name)
end

function CharacterService:_disableDefaultCharacterScripts(characterModel)
	local healthScript = characterModel:FindFirstChild("Health")
	if healthScript and healthScript:IsA("Script") then
		healthScript:Destroy()
	end

	characterModel.ChildAdded:Connect(function(child)
		if child.Name == "Health" and child:IsA("Script") then
			child:Destroy()
		end
	end)
end

function CharacterService:_onCharacterRemoving(player, characterModel)
	self:_removeCharacter(player, characterModel)
end

function CharacterService:_removeCharacter(player, characterModel)
	local character = self.CharactersByPlayer[player]
	
	if character then
		character:Destroy()
	end
	
	self.CharactersByPlayer[player] = nil
	
	if characterModel then
		self.CharactersByModel[characterModel] = nil
	end
	
	local playerService = self.PlayerService
	if playerService then
		playerService:SetAlive(player, false)
		playerService:SetMovementState(player, "IsSprinting", false)
		playerService:SetMovementState(player, "IsCrouching", false)
		playerService:SetMovementState(player, "IsAiming", false)
	end

	local statusEffectService = self.StatusEffectService
	if statusEffectService then
		statusEffectService:ClearStatuses(player)
	end
	
	DebugLog:Log("Character", "[CharacterService] Removed character for", player.Name)
end

function CharacterService:FreezeAll()
	for _, character in pairs(self.CharactersByPlayer) do
		character:Freeze()
	end
end

function CharacterService:UnfreezeAll()
	for _, character in pairs(self.CharactersByPlayer) do
		character:Unfreeze()
	end
end

function CharacterService:_cleanupPlayer(player)
	local character = self.CharactersByPlayer[player]
	if character then
		self:_removeCharacter(player, character.Model)
	end
end

function CharacterService:GetCharacterByPlayer(player)
	return self.CharactersByPlayer[player]
end

function CharacterService:GetCharacterByModel(model)
	return self.CharactersByModel[model]
end

return CharacterService
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="85">
          <Properties>
            <string name="Name">CombatService</string>
            <string name="Source"><![CDATA[local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")

local GamePhase = require(ReplicatedStorage.Shared.Enums.GamePhase)
local ItemDefinitions = require(ReplicatedStorage.Shared.Data.ItemDefinitions)
local RemoteNames = require(ReplicatedStorage.Shared.Constants.RemoteNames)
local FirearmAim = require(ReplicatedStorage.Shared.Utility.FirearmAim)
local WeaponDefinitions = require(ReplicatedStorage.Shared.Data.WeaponDefinitions)
local WorldModeResolver = require(ReplicatedStorage.Shared.Utility.WorldModeResolver)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local CombatService = {}
CombatService.Name = "CombatService"
CombatService.Dependencies = {
	"RemoteRegistry",
	"CharacterService",
	"EntityService",
	"InventoryService",
	"RoundManager",
	"RoundHookService",
	"StatusEffectService",
	"StruggleService",
	"EnvironmentalHazardService",
}

function CombatService:Init(services)
	self.Services = services
	self.PlayerCombatStates = {}
end

function CombatService:Start()
	self.RequestPrimaryAttackRemote = self.RemoteRegistry:GetRemote(RemoteNames.RequestPrimaryAttack)
	self.RequestReloadRemote = self.RemoteRegistry:GetRemote(RemoteNames.RequestReload)
	self.RequestEquipWeaponRemote = self.RemoteRegistry:GetRemote(RemoteNames.RequestEquipWeapon)
	self.RequestUseInventoryItemRemote = self.RemoteRegistry:GetRemote(RemoteNames.RequestUseInventoryItem)
	self.CombatStateChangedRemote = self.RemoteRegistry:GetRemote(RemoteNames.CombatStateChanged)
	self.CombatHitConfirmedRemote = self.RemoteRegistry:GetRemote(RemoteNames.CombatHitConfirmed)
	self.CombatShotVisualRemote = self.RemoteRegistry:GetRemote(RemoteNames.CombatShotVisual)

	for _, player in ipairs(Players:GetPlayers()) do
		self:_initializePlayer(player)
	end

	Players.PlayerAdded:Connect(function(player)
		self:_initializePlayer(player)
	end)

	Players.PlayerRemoving:Connect(function(player)
		self.PlayerCombatStates[player] = nil
	end)

	self.RequestPrimaryAttackRemote.OnServerEvent:Connect(function(player, attackData)
		self:HandlePrimaryAttack(player, attackData)
	end)

	if self.RequestReloadRemote then
		self.RequestReloadRemote.OnServerEvent:Connect(function(player)
			self:HandleReload(player)
		end)
	end

	if self.RequestEquipWeaponRemote then
		self.RequestEquipWeaponRemote.OnServerEvent:Connect(function(player, requestedSlot)
			self:HandleEquipWeapon(player, requestedSlot)
		end)
	end

	if self.RequestUseInventoryItemRemote then
		self.RequestUseInventoryItemRemote.OnServerEvent:Connect(function(player, requestedSlot)
			self:HandleUseInventoryItem(player, requestedSlot)
		end)
	end

	if self.RoundHookService then
		self.RoundHookService:RegisterHook({
			Id = "CombatService.ResetOnLobby",
			Trigger = "PhaseChanged",
			Phase = GamePhase.Lobby,
			Callback = function()
				self:_resetAllPlayerCombatForRound()
			end,
		})
	end

	DebugLog:Log("Combat", "[CombatService] Started")
end

function CombatService:_initializePlayer(player)
	self:_resetPlayerCombatState(player)

	player.CharacterAdded:Connect(function()
		self:_resetPlayerCombatState(player)
	end)
end

function CombatService:_resetPlayerCombatState(player)
	local character = self.CharacterService and self.CharacterService:GetCharacterByPlayer(player)
	if character then
		character:SetAiming(false)
	end

	self.PlayerCombatStates[player] = {
		EquippedSlot = 1,
		LastAttackAt = 0,
		ActiveItemUse = nil,
		ItemUseToken = 0,
		ReloadToken = 0,
		ActiveReload = nil,
	}

	self:_syncCombatState(player)
end

function CombatService:_resetAllPlayerCombatForRound()
	for _, player in ipairs(Players:GetPlayers()) do
		if self.InventoryService then
			self.InventoryService:ResetPlayerInventory(player)
		end
		self:_resetPlayerCombatState(player)
	end
end

function CombatService:GetEquippedWeaponState(player)
	local combatState = self.PlayerCombatStates[player]
	if not combatState then
		return nil
	end

	return self:_getEquippedWeaponState(player, combatState)
end

function CombatService:GiveWeapon(player, weaponId)
	local slotIndex = self.InventoryService:AddWeapon(player, weaponId)
	self:_syncCombatState(player)
	task.defer(function()
		if self.PlayerCombatStates[player] then
			self:_syncCombatState(player)
		end
	end)
	return slotIndex
end

function CombatService:RefreshCombatState(player)
	self:_syncCombatState(player)
	task.defer(function()
		if self.PlayerCombatStates[player] then
			self:_syncCombatState(player)
		end
	end)
end

function CombatService:_isCombatEnabled()
	if WorldModeResolver.IsWeaponLab() then
		return true
	end

	local roundManager = self.RoundManager
	return roundManager ~= nil and roundManager:IsReceptionActive()
end

function CombatService:ForceStopAim(player)
	local combatState = self.PlayerCombatStates[player]
	local character = self.CharacterService and self.CharacterService:GetCharacterByPlayer(player)
	if character and character.IsAiming then
		character:SetAiming(false)
	end

	if combatState then
		self:_syncCombatState(player)
	end
end

function CombatService:GetEquippedWeaponDefinition(player)
	local equippedState = self:GetEquippedWeaponState(player)
	if not equippedState or equippedState.EntryType ~= "Weapon" then
		return nil, equippedState
	end

	return WeaponDefinitions[equippedState.ItemId], equippedState
end

function CombatService:EmitShotVisual(player, origin, endPosition, didHit)
	if not self.CombatShotVisualRemote or typeof(origin) ~= "Vector3" or typeof(endPosition) ~= "Vector3" then
		return
	end

	self.CombatShotVisualRemote:FireClient(player, {
		Origin = origin,
		EndPosition = endPosition,
		Hit = didHit == true,
	})
end

function CombatService:HandleEquipWeapon(player, requestedSlot)
	local combatState = self.PlayerCombatStates[player]
	if not combatState then
		return false
	end

	if combatState.ActiveItemUse then
		return false
	end

	if combatState.ActiveReload then
		combatState.ReloadToken += 1
		combatState.ActiveReload = nil
	end

	local slotIndex = tonumber(requestedSlot)
	if not slotIndex then
		return false
	end

	local weaponState = self.InventoryService:GetEntry(player, slotIndex)
	if not weaponState then
		return false
	end

	local character = self.CharacterService:GetCharacterByPlayer(player)
	local definition = weaponState.EntryType == "Weapon" and WeaponDefinitions[weaponState.ItemId] or ItemDefinitions[weaponState.ItemId]
	if character and (weaponState.EntryType ~= "Weapon" or (definition and definition.Kind ~= "Firearm")) then
		character:SetAiming(false)
	end

	combatState.EquippedSlot = slotIndex
	self:_syncCombatState(player)
	return true
end

function CombatService:HandleUseInventoryItem(player, requestedSlot)
	local combatState = self.PlayerCombatStates[player]
	if not combatState then
		return false
	end

	if combatState.ActiveItemUse then
		return false
	end

	if combatState.ActiveReload then
		return false
	end

	if not self:_isCombatEnabled() then
		return false
	end

	local slotIndex = tonumber(requestedSlot)
	if not slotIndex then
		return false
	end

	local entry = self.InventoryService:GetEntry(player, slotIndex)
	if not entry or entry.EntryType ~= "Item" then
		return false
	end

	local itemDefinition = ItemDefinitions[entry.ItemId]
	if not itemDefinition then
		return false
	end

	local character = self.CharacterService:GetCharacterByPlayer(player)
	if not character or not character:IsAlive() then
		return false
	end

	if not self:_canUseInventoryItem(player, entry, itemDefinition, character) then
		return false
	end

	local useDuration = math.max(0, itemDefinition.UseDuration or 0)
	if useDuration <= 0 then
		return self:_completeInventoryItemUse(player, slotIndex, entry, itemDefinition, character)
	end

	character:SetAiming(false)
	combatState.ItemUseToken += 1
	local useToken = combatState.ItemUseToken
	combatState.ActiveItemUse = {
		Slot = slotIndex,
		ItemId = entry.ItemId,
		EndsAt = os.clock() + useDuration,
	}
	character:SetSpeedMultiplier("ItemUseSlow", 0.72)
	self:_syncCombatState(player)

	task.delay(useDuration, function()
		local liveState = self.PlayerCombatStates[player]
		local liveCharacter = self.CharacterService:GetCharacterByPlayer(player)
		if not liveState or liveState.ItemUseToken ~= useToken then
			return
		end

		liveState.ActiveItemUse = nil
		if liveCharacter then
			liveCharacter:SetSpeedMultiplier("ItemUseSlow", nil)
		end

		local liveEntry = self.InventoryService:GetEntry(player, slotIndex)
		if not liveEntry or liveEntry.EntryType ~= "Item" or liveEntry.ItemId ~= entry.ItemId then
			self:_syncCombatState(player)
			return
		end

		if not liveCharacter or not liveCharacter:IsAlive() then
			self:_syncCombatState(player)
			return
		end

		self:_completeInventoryItemUse(player, slotIndex, liveEntry, itemDefinition, liveCharacter)
	end)

	DebugLog:Log("Combat", string.format("[CombatService] %s started using item %s", player.Name, entry.ItemId))
	return true
end

function CombatService:_canUseInventoryItem(player, entry, itemDefinition, character)
	if not entry or not itemDefinition or not character then
		return false
	end

	for _, effect in ipairs(itemDefinition.Effects or {}) do
		if effect.Type == "Status" then
			return true
		elseif effect.Type == "HealSelf" then
			if self.StatusEffectService and not self.StatusEffectService:CanBeHealed(player) then
				continue
			end

			if character.Humanoid and character.Humanoid.Health < character.Humanoid.MaxHealth then
				return true
			end
		end
	end

	return false
end

function CombatService:_completeInventoryItemUse(player, slotIndex, entry, itemDefinition, character)
	local usedSuccessfully = false

	for _, effect in ipairs(itemDefinition.Effects or {}) do
		if effect.Type == "Status" and self.StatusEffectService then
			local statusInstance = self.StatusEffectService:ApplyStatus(player, effect.StatusId, {
				Duration = effect.Duration,
				Magnitude = effect.Magnitude,
			})
			if statusInstance then
				usedSuccessfully = true
			end
		elseif effect.Type == "HealSelf" then
			if self.StatusEffectService and not self.StatusEffectService:CanBeHealed(player) then
				continue
			end

			if character:Heal(effect.Amount or 0) then
				usedSuccessfully = true
			end
		end
	end

	if not usedSuccessfully then
		self:_syncCombatState(player)
		return false
	end

	self.InventoryService:ConsumeItem(player, slotIndex, 1)
	self:_syncCombatState(player)
	DebugLog:Log("Combat", string.format("[CombatService] %s used item %s", player.Name, entry.ItemId))
	return true
end

function CombatService:HandlePrimaryAttack(player, attackData)
	local combatState = self.PlayerCombatStates[player]
	if not combatState then
		return false
	end

	if combatState.ActiveItemUse or combatState.ActiveReload then
		return false
	end

	if not self:_isCombatEnabled() then
		return false
	end

	local character = self.CharacterService:GetCharacterByPlayer(player)
	if not character or not character:IsAlive() or not character.RootPart then
		return false
	end

	local equippedWeaponState = self:_getEquippedWeaponState(player, combatState)
	local weapon = equippedWeaponState and equippedWeaponState.EntryType == "Weapon" and WeaponDefinitions[equippedWeaponState.ItemId] or nil
	if not weapon or not equippedWeaponState or (weapon.Kind == "Melee" and equippedWeaponState.Durability <= 0) then
		self:_syncCombatState(player)
		return false
	end

	local now = os.clock()
	if now - (combatState.LastAttackAt or 0) < (weapon.AttackCooldown or 0.5) then
		return false
	end

	combatState.LastAttackAt = now

	if weapon.Kind == "Firearm" then
		if (equippedWeaponState.CurrentAmmo or 0) <= 0 then
			self:_syncCombatState(player)
			return false
		end

		equippedWeaponState.CurrentAmmo = math.max(0, (equippedWeaponState.CurrentAmmo or 0) - 1)
	else
		equippedWeaponState.Durability = math.max(0, equippedWeaponState.Durability - (weapon.DurabilityCostPerSwing or 1))
	end

	local hitEntity = nil
	local shotEndPosition = nil
	local shotOrigin = nil
	if weapon.Kind == "Firearm" then
		hitEntity, shotEndPosition, shotOrigin = self:_findRangedAttackTarget(character, weapon, attackData)
	else
		hitEntity = self:_findAttackTarget(character, weapon)
	end
	if weapon.Kind == "Firearm" and self.CombatShotVisualRemote and shotEndPosition then
		self.CombatShotVisualRemote:FireClient(player, {
			Origin = shotOrigin or (character.RootPart.Position + Vector3.new(0, 1.5, 0)),
			EndPosition = shotEndPosition,
			Hit = hitEntity ~= nil,
			WeaponId = weapon.Id,
			IsAiming = type(attackData) == "table" and attackData.IsAiming == true,
		})
	end
	if hitEntity then
		local didDamage = self.EntityService and self.EntityService:DamageEntity(hitEntity, weapon.Damage, {
			SourcePlayer = player,
			WeaponId = weapon.Id,
		})

		if didDamage and self.CombatHitConfirmedRemote then
			self.CombatHitConfirmedRemote:FireClient(player, {
				TargetName = hitEntity.DisplayName,
				Damage = weapon.Damage,
				WeaponId = weapon.Id,
			})
		end

		DebugLog:Log("Combat", string.format("[CombatService] %s hit %s with %s for %d", player.Name, hitEntity.DisplayName, weapon.DisplayName, weapon.Damage))
	else
		DebugLog:Log("Combat", string.format("[CombatService] %s swung %s and missed", player.Name, weapon.DisplayName))
	end

	self:_syncCombatState(player)
	return true
end

function CombatService:HandleReload(player)
	local combatState = self.PlayerCombatStates[player]
	if not combatState or combatState.ActiveItemUse or combatState.ActiveReload then
		return false
	end

	if not self:_isCombatEnabled() then
		return false
	end

	local character = self.CharacterService:GetCharacterByPlayer(player)
	if not character or not character:IsAlive() then
		return false
	end

	if self.StruggleService and self.StruggleService:IsPlayerStruggling(player) then
		return self.EnvironmentalHazardService and self.EnvironmentalHazardService:TriggerNearestHazard(player, 12) or false
	end

	local equippedWeaponState = self:_getEquippedWeaponState(player, combatState)
	local weapon = equippedWeaponState and equippedWeaponState.EntryType == "Weapon" and WeaponDefinitions[equippedWeaponState.ItemId] or nil
	if not weapon or weapon.Kind ~= "Firearm" then
		return false
	end

	local currentAmmo = equippedWeaponState.CurrentAmmo or 0
	local maxAmmo = equippedWeaponState.MaxAmmo or weapon.MagazineSize or 0
	local reserveAmmo = equippedWeaponState.ReserveAmmo or 0
	if currentAmmo >= maxAmmo or reserveAmmo <= 0 then
		return false
	end

	combatState.ReloadToken += 1
	local reloadToken = combatState.ReloadToken
	local reloadDuration = weapon.ReloadDuration or 0
	character:SetAiming(false)
	combatState.ActiveReload = {
		EndsAt = os.clock() + reloadDuration,
	}
	self:_syncCombatState(player)

	task.delay(reloadDuration, function()
		local liveState = self.PlayerCombatStates[player]
		if not liveState or liveState.ReloadToken ~= reloadToken then
			return
		end

		local liveWeaponState = self:_getEquippedWeaponState(player, liveState)
		local liveWeapon = liveWeaponState and liveWeaponState.EntryType == "Weapon" and WeaponDefinitions[liveWeaponState.ItemId] or nil
		if not liveWeapon or liveWeapon.Kind ~= "Firearm" then
			liveState.ActiveReload = nil
			self:_syncCombatState(player)
			return
		end

		local liveCharacter = self.CharacterService:GetCharacterByPlayer(player)
		if not liveCharacter or not liveCharacter:IsAlive() then
			liveState.ActiveReload = nil
			self:_syncCombatState(player)
			return
		end

		local magazineSize = liveWeaponState.MaxAmmo or liveWeapon.MagazineSize or 0
		local current = liveWeaponState.CurrentAmmo or 0
		local reserve = liveWeaponState.ReserveAmmo or 0
		local needed = math.max(0, magazineSize - current)
		local loaded = math.min(needed, reserve)
		liveWeaponState.CurrentAmmo = current + loaded
		liveWeaponState.ReserveAmmo = reserve - loaded
		liveState.ActiveReload = nil
		self:_syncCombatState(player)
	end)

	return true
end

function CombatService:_getEquippedWeaponState(player, combatState)
	if not combatState then
		return nil
	end

	local equippedSlot = combatState.EquippedSlot or 1
	return self.InventoryService:GetEntry(player, equippedSlot)
end

function CombatService:_findAttackTarget(character, weapon)
	local rootPart = character.RootPart
	local origin = rootPart.Position
	local lookVector = rootPart.CFrame.LookVector
	local bestEntity = nil
	local bestDistance = math.huge

	local entityService = self.EntityService
	for _, entity in ipairs((entityService and entityService.Entities) or {}) do
		if entity.IsActive and entity.Health > 0 then
			local entityPosition = entity:GetPosition()
			if entityPosition then
				local offset = entityPosition - origin
				local distance = offset.Magnitude
				if distance <= (weapon.Range or 0) then
					local direction = distance > 0 and offset.Unit or lookVector
					local dot = lookVector:Dot(direction)
					if dot >= (weapon.ArcDotThreshold or 0) and distance < bestDistance then
						bestDistance = distance
						bestEntity = entity
					end
				end
			end
		end
	end

	return bestEntity
end

function CombatService:_findRangedAttackTarget(character, weapon, attackData)
	local rootPart = character.RootPart
	local requestedDirection = type(attackData) == "table" and attackData.Direction or nil
	local requestedOrigin = type(attackData) == "table" and attackData.Origin or nil
	local isAiming = type(attackData) == "table" and attackData.IsAiming == true
	local cameraLookVector = FirearmAim.ResolveLookVector(rootPart.CFrame.LookVector, requestedDirection)
	local spreadAngle = FirearmAim.GetSpreadAngle(weapon, isAiming)
	local spreadLookVector = FirearmAim.ApplySpread(cameraLookVector, spreadAngle, Random.new())
	local raycastParams = RaycastParams.new()
	raycastParams.FilterType = Enum.RaycastFilterType.Exclude
	local filter = { character.Model }
	local mapBounds = Workspace:FindFirstChild("MapBounds")
	if mapBounds then
		table.insert(filter, mapBounds)
	end
	raycastParams.FilterDescendantsInstances = filter
	local cameraOrigin = (typeof(requestedOrigin) == "Vector3" and (requestedOrigin - rootPart.Position).Magnitude <= 30)
		and requestedOrigin
		or (rootPart.Position + Vector3.new(0, 2, 0))
	local aimPoint = FirearmAim.ResolveAimPoint(cameraOrigin, spreadLookVector, weapon.Range or 0, raycastParams, Workspace)
	local origin = FirearmAim.GetMuzzleOrigin(rootPart.CFrame, cameraLookVector)
	local shotDirection = aimPoint - origin
	if shotDirection.Magnitude <= 0.001 then
		shotDirection = cameraLookVector * (weapon.Range or 0)
	end
	local normalizedShotDirection = shotDirection.Unit
	local shotEndPosition = origin + (normalizedShotDirection * (weapon.Range or 0))
	local result = Workspace:Raycast(origin, normalizedShotDirection * (weapon.Range or 0), raycastParams)
	if result then
		shotEndPosition = result.Position
		local entityService = self.EntityService
		for _, entity in ipairs((entityService and entityService.Entities) or {}) do
			if entity.IsActive and entity.Health > 0 and entity.Model and result.Instance:IsDescendantOf(entity.Model) then
				return entity, shotEndPosition, origin
			end
		end
	end

	return nil, shotEndPosition, origin
end

function CombatService:_syncCombatState(player)
	if not self.CombatStateChangedRemote then
		return
	end

	local combatState = self.PlayerCombatStates[player]
	if not combatState then
		return
	end

	local equippedWeaponState = self:_getEquippedWeaponState(player, combatState)
	local weapon = equippedWeaponState and equippedWeaponState.EntryType == "Weapon" and WeaponDefinitions[equippedWeaponState.ItemId] or nil
	local character = self.CharacterService and self.CharacterService:GetCharacterByPlayer(player)
	local cooldownRemaining = 0
	if weapon then
		cooldownRemaining = math.max(0, (combatState.LastAttackAt + (weapon.AttackCooldown or 0)) - os.clock())
	end
	local reloadRemaining = combatState.ActiveReload and math.max(0, combatState.ActiveReload.EndsAt - os.clock()) or 0
	local itemUseRemaining = combatState.ActiveItemUse and math.max(0, combatState.ActiveItemUse.EndsAt - os.clock()) or 0
	local activeItemUseDefinition = combatState.ActiveItemUse and ItemDefinitions[combatState.ActiveItemUse.ItemId] or nil

	local payloadWeapons = {}
	for slotIndex, weaponState in ipairs(self.InventoryService:GetEntries(player) or {}) do
		local definition = weaponState.EntryType == "Weapon" and WeaponDefinitions[weaponState.ItemId] or ItemDefinitions[weaponState.ItemId]
		if definition then
			local isBroken = weaponState.EntryType == "Weapon"
				and definition.Kind == "Melee"
				and (weaponState.Durability or 0) <= 0
			table.insert(payloadWeapons, {
				Slot = slotIndex,
				WeaponId = weaponState.ItemId,
				DisplayName = definition.DisplayName,
				ShortDisplayName = definition.ShortDisplayName or definition.DisplayName,
				EntryType = weaponState.EntryType,
				Durability = weaponState.Durability,
				MaxDurability = definition.Durability,
				CurrentAmmo = weaponState.CurrentAmmo,
				MaxAmmo = weaponState.MaxAmmo,
				ReserveAmmo = weaponState.ReserveAmmo,
				Count = weaponState.Count,
				IsBroken = isBroken,
			})
		end
	end

	local isBroken = weapon ~= nil
		and weapon.Kind == "Melee"
		and equippedWeaponState ~= nil
		and (equippedWeaponState.Durability or 0) <= 0

	self.CombatStateChangedRemote:FireClient(player, {
		EquippedWeaponId = equippedWeaponState and equippedWeaponState.ItemId or nil,
		EquippedSlot = combatState.EquippedSlot or 1,
		DisplayName = weapon and weapon.DisplayName or (equippedWeaponState and ItemDefinitions[equippedWeaponState.ItemId] and ItemDefinitions[equippedWeaponState.ItemId].DisplayName or (equippedWeaponState and equippedWeaponState.ItemId or "Unarmed")),
		Durability = weapon and equippedWeaponState and equippedWeaponState.Durability or 0,
		MaxDurability = weapon and weapon.Durability or 0,
		CurrentAmmo = equippedWeaponState and equippedWeaponState.CurrentAmmo or 0,
		MaxAmmo = equippedWeaponState and equippedWeaponState.MaxAmmo or 0,
		ReserveAmmo = equippedWeaponState and equippedWeaponState.ReserveAmmo or 0,
		WeaponKind = weapon and weapon.Kind or nil,
		Cooldown = cooldownRemaining,
		MaxCooldown = weapon and weapon.AttackCooldown or 0,
		IsReloading = combatState.ActiveReload ~= nil,
		ReloadRemaining = reloadRemaining,
		ReloadDuration = weapon and weapon.ReloadDuration or 0,
		IsUsingItem = combatState.ActiveItemUse ~= nil,
		ItemUseItemId = combatState.ActiveItemUse and combatState.ActiveItemUse.ItemId or nil,
		ItemUseDisplayName = activeItemUseDefinition and activeItemUseDefinition.DisplayName or nil,
		ItemUseRemaining = itemUseRemaining,
		ItemUseDuration = activeItemUseDefinition and activeItemUseDefinition.UseDuration or 0,
		IsBroken = isBroken,
		IsAiming = character and character.IsAiming or false,
		Weapons = payloadWeapons,
	})
end

return CombatService
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="86">
          <Properties>
            <string name="Name">DevService</string>
            <string name="Source"><![CDATA[local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")

local DebugFlags = require(ReplicatedStorage.Shared.Data.DebugFlags)
local EntityDefinitions = require(ReplicatedStorage.Shared.Data.EntityDefinitions)
local ItemDefinitions = require(ReplicatedStorage.Shared.Data.ItemDefinitions)
local RemoteNames = require(ReplicatedStorage.Shared.Constants.RemoteNames)
local WeaponDefinitions = require(ReplicatedStorage.Shared.Data.WeaponDefinitions)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local DevService = {}
DevService.Name = "DevService"
DevService.Dependencies = {
	"RemoteRegistry",
	"CharacterService",
	"CombatService",
	"InventoryService",
	"EntityService",
	"RoundManager",
	"EscapeService",
	"WeaponPickupService",
	"ItemPickupService",
}

local function _isValidDefinitionId(definitions, id)
	return id ~= nil and definitions[id] ~= nil
end

function DevService:Init(services)
	self.Services = services
	self.GodModeByPlayer = {}
	self.DebugUiEnabledByPlayer = {}
end

function DevService:Start()
	if not DebugFlags.Enabled or not DebugFlags.DevMenu then
		return
	end

	Workspace:SetAttribute("DebugUiEnabled", true)

	self.RequestRemote = self.RemoteRegistry:GetRemote(RemoteNames.RequestDevCommand)
	self.StateRemote = self.RemoteRegistry:GetRemote(RemoteNames.DevStateChanged)
	self.PlacementStateRemote = self.RemoteRegistry:GetRemote(RemoteNames.DevPlacementStateChanged)

	if self.RequestRemote then
		self.RequestRemote.OnServerEvent:Connect(function(player, payload)
			self:_handleCommand(player, payload)
		end)
	end

	Players.PlayerAdded:Connect(function(player)
		self:_sendState(player)
		player.CharacterAdded:Connect(function()
			task.defer(function()
				local character = self.CharacterService:GetCharacterByPlayer(player)
				if character and self.GodModeByPlayer[player] == true then
					character:SetInvincible(true)
				end
				self:_sendState(player)
			end)
		end)
	end)

	for _, player in ipairs(Players:GetPlayers()) do
		player.CharacterAdded:Connect(function()
			task.defer(function()
				local character = self.CharacterService:GetCharacterByPlayer(player)
				if character and self.GodModeByPlayer[player] == true then
					character:SetInvincible(true)
				end
				self:_sendState(player)
			end)
		end)
		self:_sendState(player)
	end

	DebugLog:Log("Boot", "[DevService] Started")
end

function DevService:_handleCommand(player, payload)
	if type(payload) ~= "table" then
		return
	end

	local command = payload.Command
	if command == "GiveWeapon" then
		self:_giveWeapon(player, payload.WeaponId)
	elseif command == "GiveItem" then
		self:_giveItem(player, payload.ItemId, payload.Count)
	elseif command == "SpawnEntity" then
		self:_spawnEntity(player, payload.EntityId)
	elseif command == "SpawnEntityAt" then
		self:_spawnEntityAt(player, payload.EntityId, payload.Position)
	elseif command == "AdjustTimer" then
		self:_adjustTimer(player, payload.Delta)
	elseif command == "SetTimer" then
		self:_setTimer(player, payload.TimeLeft)
	elseif command == "ToggleEscape" then
		self:_toggleEscape(player)
	elseif command == "PlaceWeaponPickup" then
		self:_placeWeaponPickup(player, payload.WeaponId, payload.Position)
	elseif command == "PlaceItemPickup" then
		self:_placeItemPickup(player, payload.ItemId, payload.Position, payload.Quantity)
	elseif command == "ToggleGodMode" then
		self:_toggleGodMode(player)
	elseif command == "ToggleDebugUi" then
		self:_toggleDebugUi(player)
	elseif command == "SetHealth" then
		self:_setHealth(player, payload.Health)
	elseif command == "Refresh" then
		self:_sendState(player)
	end
end

function DevService:_giveWeapon(player, weaponId)
	if not _isValidDefinitionId(WeaponDefinitions, weaponId) then
		self:_sendState(player, "Unknown weapon")
		return
	end

	local slotIndex = self.CombatService:GiveWeapon(player, weaponId)
	if not slotIndex then
		self:_sendState(player, "Failed to give weapon")
		return
	end

	self.CombatService:RefreshCombatState(player)
	self:_sendState(player, string.format("Gave %s", WeaponDefinitions[weaponId].DisplayName))
end

function DevService:_giveItem(player, itemId, count)
	if not _isValidDefinitionId(ItemDefinitions, itemId) then
		self:_sendState(player, "Unknown item")
		return
	end

	self.InventoryService:AddItem(player, itemId, tonumber(count) or 1)
	self.CombatService:RefreshCombatState(player)
	self:_sendState(player, string.format("Gave %s", ItemDefinitions[itemId].DisplayName))
end

function DevService:_spawnEntity(player, entityId)
	if not _isValidDefinitionId(EntityDefinitions, entityId) then
		self:_sendState(player, "Unknown entity")
		return
	end

	local character = self.CharacterService:GetCharacterByPlayer(player)
	if not character or not character.RootPart then
		self:_sendState(player, "No character root")
		return
	end

	local origin = character.RootPart.CFrame
	local spawnPosition = origin.Position + (origin.LookVector * 16) + Vector3.new(0, 2, 0)
	local spawnCFrame = CFrame.new(spawnPosition, origin.Position)
	local entity = self.EntityService:SpawnEntity(entityId, {
		CFrame = spawnCFrame,
		Activate = true,
		IsSummon = false,
	})

	if not entity then
		self:_sendState(player, "Failed to spawn entity")
		return
	end

	self:_sendState(player, string.format("Spawned %s", entity.DisplayName))
end

function DevService:_resolvePosition(payloadPosition)
	if type(payloadPosition) ~= "table" then
		return nil
	end

	local x = tonumber(payloadPosition.X)
	local y = tonumber(payloadPosition.Y)
	local z = tonumber(payloadPosition.Z)
	if not x or not y or not z then
		return nil
	end

	return Vector3.new(x, y, z)
end

function DevService:_spawnEntityAt(player, entityId, payloadPosition)
	if not _isValidDefinitionId(EntityDefinitions, entityId) then
		self:_sendState(player, "Unknown entity")
		return
	end

	local position = self:_resolvePosition(payloadPosition)
	if not position then
		self:_sendState(player, "Invalid placement position")
		return
	end

	local character = self.CharacterService:GetCharacterByPlayer(player)
	local lookAt = character and character.RootPart and character.RootPart.Position or (position + Vector3.new(0, 0, -1))
	local entity = self.EntityService:SpawnEntity(entityId, {
		CFrame = CFrame.new(position + Vector3.new(0, 2, 0), lookAt),
		Activate = true,
		IsSummon = false,
	})

	if not entity then
		self:_sendState(player, "Failed to spawn entity")
		return
	end

	self:_sendState(player, string.format("Spawned %s", entity.DisplayName))
end

function DevService:_adjustTimer(player, delta)
	local amount = tonumber(delta)
	if not amount then
		self:_sendState(player, "Invalid timer delta")
		return
	end

	self.RoundManager.TimeLeft = math.max(0, self.RoundManager.TimeLeft + amount)
	self.RoundManager:BroadcastTimer()
	self:_sendState(player, string.format("Adjusted timer by %ds", amount))
end

function DevService:_setTimer(player, timeLeft)
	local amount = tonumber(timeLeft)
	if amount == nil then
		self:_sendState(player, "Invalid timer value")
		return
	end

	self.RoundManager.TimeLeft = math.max(0, amount)
	self.RoundManager:BroadcastTimer()
	self:_sendState(player, string.format("Set timer to %ds", self.RoundManager.TimeLeft))
end

function DevService:_toggleEscape(player)
	local escapeService = self.EscapeService
	escapeService:SetEscapeEnabled(not escapeService:IsEscapeEnabled())
	self:_sendState(player, escapeService:IsEscapeEnabled() and "Escape enabled" or "Escape disabled")
end

function DevService:_placeWeaponPickup(player, weaponId, payloadPosition)
	if not _isValidDefinitionId(WeaponDefinitions, weaponId) then
		self:_sendState(player, "Unknown weapon")
		return
	end

	local position = self:_resolvePosition(payloadPosition)
	if not position then
		self:_sendState(player, "Invalid placement position")
		return
	end

	local instance = self.WeaponPickupService and self.WeaponPickupService:CreateDevPickup(weaponId, position)
	if not instance then
		self:_sendState(player, "Failed to place weapon pickup")
		return
	end

	self:_sendState(player, string.format("Placed %s pickup", WeaponDefinitions[weaponId].DisplayName))
end

function DevService:_placeItemPickup(player, itemId, payloadPosition, quantity)
	if not _isValidDefinitionId(ItemDefinitions, itemId) then
		self:_sendState(player, "Unknown item")
		return
	end

	local position = self:_resolvePosition(payloadPosition)
	if not position then
		self:_sendState(player, "Invalid placement position")
		return
	end

	local instance = self.ItemPickupService and self.ItemPickupService:CreateDevPickup(itemId, position, quantity)
	if not instance then
		self:_sendState(player, "Failed to place item pickup")
		return
	end

	self:_sendState(player, string.format("Placed %s pickup", ItemDefinitions[itemId].DisplayName))
end

function DevService:_toggleGodMode(player)
	local nextState = not (self.GodModeByPlayer[player] == true)
	self.GodModeByPlayer[player] = nextState

	local character = self.CharacterService:GetCharacterByPlayer(player)
	if character then
		character:SetInvincible(nextState)
	end

	self:_sendState(player, nextState and "God mode enabled" or "God mode disabled")
end

function DevService:_toggleDebugUi(player)
	local nextState = not (self.DebugUiEnabledByPlayer[player] ~= false)
	self.DebugUiEnabledByPlayer[player] = nextState
	Workspace:SetAttribute("DebugUiEnabled", nextState)
	self:_sendState(player, nextState and "Debug UI enabled" or "Debug UI disabled")
end

function DevService:_setHealth(player, healthValue)
	local targetHealth = tonumber(healthValue)
	if targetHealth == nil then
		self:_sendState(player, "Invalid health value")
		return
	end

	local character = self.CharacterService:GetCharacterByPlayer(player)
	if not character or not character.Humanoid then
		self:_sendState(player, "No active character")
		return
	end

	local humanoid = character.Humanoid
	humanoid.Health = math.clamp(targetHealth, 1, humanoid.MaxHealth)
	self:_sendState(player, string.format("Set health to %d", math.floor(humanoid.Health + 0.5)))
end

function DevService:_sendState(player, message)
	if not self.StateRemote then
		return
	end

	self.StateRemote:FireClient(player, {
		Message = message,
		Phase = self.RoundManager and self.RoundManager:GetCurrentPhase() or "Unknown",
		TimeLeft = self.RoundManager and self.RoundManager.TimeLeft or 0,
		EscapeEnabled = self.EscapeService and self.EscapeService:IsEscapeEnabled() or false,
		GodMode = self.GodModeByPlayer[player] == true,
		DebugUiEnabled = self.DebugUiEnabledByPlayer[player] ~= false,
	})
end

return DevService
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="87">
          <Properties>
            <string name="Name">EntityService</string>
            <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")
local ServerStorage = game:GetService("ServerStorage")
local ServerScriptService = game:GetService("ServerScriptService")
local Debris = game:GetService("Debris")

local BaseEntity = require(ServerScriptService.Server.Classes.BaseEntity)
local DebugFlags = require(ReplicatedStorage.Shared.Data.DebugFlags)
local EntityDefinitions = require(ReplicatedStorage.Shared.Data.EntityDefinitions)
local RemoteNames = require(ReplicatedStorage.Shared.Constants.RemoteNames)
local EntityAttributes = require(ReplicatedStorage.Shared.Enums.EntityAttributes)
local StatusEffectId = require(ReplicatedStorage.Shared.Enums.StatusEffectId)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local EntityService = {}
EntityService.Name = "EntityService"
EntityService.Dependencies = {
	"RoundManager",
	"RoundHookService",
	"CharacterService",
	"StimulusService",
	"SpawnService",
	"StaminaService",
	"StatusEffectService",
	"InteractionService",
	"StruggleService",
	"BreathHoldService",
	"RemoteRegistry",
}

local ENTITY_STATE = {
	Dormant = "Dormant",
	Patrol = "Patrol",
	Scout = "Scout",
	Chase = "Chase",
	Casting = "Casting",
	Stunned = "Stunned",
	Rage = "Rage",
}

local RECENT_HIT_DEBUG_DURATION = 0.75
local LUNGE_DEBUG_VISUAL_DURATION = 2.5

function EntityService:Init(services)
	self.Services = services
	self.Entities = {}
	self.ActiveProjectiles = {}
	self.EntityTemplates = {}
	self.UpdateInterval = 0.2
	self.NextRoundHookRuntimeId = 0

	self.EntitiesFolder = Workspace:WaitForChild("Entities")
	self.MapBounds = Workspace:FindFirstChild("MapBounds")
	self.TemplateSourceFolder = ServerStorage:FindFirstChild("EntityTemplates")
	if not self.TemplateSourceFolder then
		self.TemplateSourceFolder = Instance.new("Folder")
		self.TemplateSourceFolder.Name = "EntityTemplates"
		self.TemplateSourceFolder.Parent = ServerStorage
	end

	self.TemplateStorage = Instance.new("Folder")
	self.TemplateStorage.Name = "EntityTemplateCache"
	self.TemplateStorage.Parent = ServerStorage
	self.SelectedRoundEntityIds = {}
	self.RaycastParams = RaycastParams.new()
	self.RaycastParams.FilterType = Enum.RaycastFilterType.Exclude
end

function EntityService:Start()
	self:_registerExistingTemplates()
	self:_registerExistingEntities()
	self.EntityAbilityVisualRemote = self.RemoteRegistry and self.RemoteRegistry:GetRemote(RemoteNames.EntityAbilityVisual)

	task.spawn(function()
		self:_runEntityLoop()
	end)

	DebugLog:Log("Entity", "[EntityService] Started")
end

function EntityService:_registerExistingTemplates()
	for _, model in ipairs(self.TemplateSourceFolder:GetChildren()) do
		if model:IsA("Model") and model.PrimaryPart then
			local definition = EntityDefinitions[model.Name]
			self:_cacheEntityTemplate(model, definition)
		end
	end
end

function EntityService:_registerExistingEntities()
	for _,model in ipairs(self.EntitiesFolder:GetChildren()) do
		if model:IsA("Model") and model.PrimaryPart then
			self:_registerEntityModel(model)
		end
	end
end

function EntityService:_cacheEntityTemplate(model, definition)
	local templateName = (definition and definition.TemplateName) or (definition and definition.Id) or model.Name
	if self.EntityTemplates[templateName] then
		return
	end

	local template = model:Clone()
	template.Name = templateName
	template.Parent = self.TemplateStorage

	local aliases = {
		templateName,
		model.Name,
		definition and definition.Id or nil,
		definition and definition.TemplateName or nil,
	}

	for _, alias in ipairs(aliases) do
		if alias and not self.EntityTemplates[alias] then
			self.EntityTemplates[alias] = template
		end
	end
end

function EntityService:_registerEntityModel(model, runtimeData)
	local definition = EntityDefinitions[model.Name] or EntityDefinitions[(runtimeData and runtimeData.EntityId) or model.Name]
	local entity = BaseEntity.new(model, definition, self.Services, runtimeData)

	self:_cacheEntityTemplate(model, definition)
	table.insert(self.Entities, entity)
	self:_syncDebugAttributes(entity)

	DebugLog:Log("Entity", string.format(
		"[EntityService] Registered entity: %s | Stars: %d | Weight: %d",
		entity.DisplayName,
		entity.StarRating,
		entity.Weight
	))

	return entity
end

function EntityService:_runEntityLoop()
	while true do
		self:_updateProjectiles(self.UpdateInterval)

		for index = #self.Entities, 1, -1 do
			local entity = self.Entities[index]
			if entity:HasExpired() then
				self:_despawnEntity(entity, "Expired")
			elseif entity.IsActive then
				self:_updateEntity(entity, self.UpdateInterval)
			end
		end

		task.wait(self.UpdateInterval)
	end
end

function EntityService:_updateEntity(entity, deltaTime)
	entity:ClearExpiredMemory()
	entity:ClearExpiredInvestigatedStimuli()
	entity:UpdateActiveEffects()
	if entity:IsIntentExpired() then
		entity:ClearIntent()
	end

	local candidates = self:_collectTargetCandidates(entity)
	self:_pushPerceptionStimuli(entity, candidates)
	local bestCandidate = self:_selectBestCandidate(entity, candidates)
	self:_updateTargetSelection(entity, bestCandidate)
	self:_solveEntityIntent(entity, bestCandidate)
	self:_updateCasting(entity)
	self:_updateEntityState(entity)
	self:_tickEntityPassives(entity, deltaTime)
	self:_tryUseAbility(entity, candidates)
	self:_updateEntityMovement(entity, deltaTime)
	self:_tryBasicAttack(entity)
	self:_syncDebugAttributes(entity)
end

function EntityService:_collectTargetCandidates(entity)
	local roundManager = self.RoundManager
	local characterService = self.CharacterService

	if not roundManager or not characterService then
		return {}
	end

	local entityPosition = entity:GetPosition()
	if not entityPosition then
		return {}
	end

	local candidates = {}

	for _, player in ipairs(roundManager:GetActivePlayers()) do
		local roundState = roundManager:GetRoundState(player)
		if roundState and roundState.IsAlive then
			local character = characterService:GetCharacterByPlayer(player)
			if character and character.RootPart then
				local livePosition = character.RootPart.Position
				local distance = (livePosition - entityPosition).Magnitude
				local isFullyAbsorbed = entity.IsPlayerFullyAbsorbed and entity:IsPlayerFullyAbsorbed(player)
				local canSenseTarget = entity.IgnoreLineOfSightForDetection or self:_hasLineOfSight(entity, character)
				local isVisible = distance <= entity:GetDetectionRange() and canSenseTarget
				local isDetected = isVisible or isFullyAbsorbed
				local memory = entity:GetTargetMemory(player)
				local candidatePosition = livePosition
				local candidateDistance = distance

				if not isDetected and memory then
					candidatePosition = memory.LastKnownPosition
					candidateDistance = (candidatePosition - entityPosition).Magnitude
				end

				if isDetected or memory then
					table.insert(candidates, {
						Player = player,
						Character = character,
						Position = candidatePosition,
						Distance = candidateDistance,
						IsVisible = isVisible,
						IsDetected = isDetected,
						IsFullyAbsorbed = isFullyAbsorbed,
						Memory = memory,
					})
				end
			end
		end
	end

	return candidates
end

function EntityService:_selectBestCandidate(entity, candidates)
	local bestCandidate = nil
	local bestScore = -math.huge

	for _, candidate in ipairs(candidates) do
		local score = self:_scoreTargetCandidate(entity, candidate)
		candidate.Score = score

		if score > bestScore then
			bestScore = score
			bestCandidate = candidate
		end
	end

	return bestCandidate
end

function EntityService:_scoreTargetCandidate(entity, candidate)
	local score = 0
	local effectiveRange = math.max(entity:GetDetectionRange() * 1.25, entity.AttackRange)

	score += math.max(0, effectiveRange - candidate.Distance) * entity.DistanceWeight

	if candidate.IsVisible then
		score += entity.LineOfSightBonus
	end

	if candidate.Memory then
		score += entity.MemoryBonus
	end

	if candidate.IsDetected and not candidate.IsVisible then
		score += 22
	end

	if candidate.IsFullyAbsorbed then
		score += 36
	end

	if entity:GetTarget() == candidate.Player then
		score += entity.TargetRetentionBonus
	end

	return score
end

function EntityService:_updateTargetSelection(entity, bestCandidate)
	if not bestCandidate then
		entity:SetTarget(nil)
		return
	end

	if bestCandidate.IsVisible then
		entity:SetTarget(bestCandidate.Player, bestCandidate.Position, true)
		entity:EndSearchMode()
	else
		entity:SetTrackedTarget(bestCandidate.Player)
	end
end

function EntityService:_pushPerceptionStimuli(entity, candidates)
	local stimulusService = self.StimulusService
	if not stimulusService then
		return
	end

	for _, candidate in ipairs(candidates) do
		if candidate.IsVisible then
			stimulusService:PushStimulus({
				Key = string.format("VisualSighting:%s:%d", tostring(entity.Id), candidate.Player.UserId),
				Type = "VisualSighting",
				Position = candidate.Position,
				SourcePlayer = candidate.Player,
				Strength = 1.2,
				Confidence = 1,
				Duration = math.max(0.6, entity.AttentionDuration),
				Tags = {
					Visual = true,
					Direct = true,
				},
			})
		elseif candidate.Memory then
			stimulusService:PushStimulus({
				Key = string.format("LastKnownPosition:%s:%d", tostring(entity.Id), candidate.Player.UserId),
				Type = "LastKnownPosition",
				Position = candidate.Memory.LastKnownPosition,
				SourcePlayer = candidate.Player,
				Strength = 0.9,
				Confidence = math.clamp(1 - (entity:GetTimeSinceTargetWasVisible(candidate.Player) / math.max(0.1, entity.MemoryDuration)), 0.1, 0.95),
				Duration = math.max(0.75, entity.SearchIntentDuration),
				Tags = {
					Memory = true,
					Search = true,
				},
			})
		end
	end
end

function EntityService:_solveEntityIntent(entity, bestCandidate)
	local now = os.clock()
	local currentIntent = entity:GetIntentName()

	if bestCandidate and bestCandidate.IsVisible then
		entity:SetIntent("Chase", bestCandidate.Position, {
			Confidence = 1,
			Duration = 0.5,
			Metadata = {
				Reason = "VisibleTarget",
				TargetPlayer = bestCandidate.Player,
			},
		})
		entity:SetCurrentSearchCenter(bestCandidate.Position)
		return
	end

	if bestCandidate and bestCandidate.Memory then
		local lastKnownPosition = bestCandidate.Memory.LastKnownPosition or bestCandidate.Position
		entity:SetIntent("Search", lastKnownPosition, {
			Confidence = math.clamp(1 - (entity:GetTimeSinceTargetWasVisible(bestCandidate.Player) / math.max(0.1, entity.MemoryDuration)), 0.2, 0.95),
			Duration = entity.SearchIntentDuration,
			Metadata = {
				Reason = "TargetMemory",
				TargetPlayer = bestCandidate.Player,
				LastSeenAt = bestCandidate.Memory.LastSeenAt,
			},
			SearchCenter = lastKnownPosition,
		})
		return
	end

	local stimulus = self:_selectIntentStimulus(entity)
	if stimulus then
		local intentTarget = self:_resolveStimulusIntentTarget(entity, stimulus)
		entity:SetIntent("Investigate", intentTarget, {
			SourceStimulus = stimulus,
			Confidence = stimulus.Confidence or 0.5,
			Duration = math.min(entity.InvestigateIntentDuration, math.max(0.75, stimulus.ExpiresAt - now)),
			Metadata = {
				Reason = stimulus.Type,
				StimulusKey = stimulus.Key,
			},
		})
		return
	end

	if currentIntent ~= "Roam" then
		entity:SetIntent("Roam", entity:GetRoamAnchor(), {
			Confidence = 0.25,
			Duration = entity.RoamAnchorMaxDuration,
			Metadata = {
				Reason = "NoStrongStimulus",
			},
		})
	end
end

function EntityService:_selectIntentStimulus(entity)
	local stimulusService = self.StimulusService
	if not stimulusService then
		return nil
	end

	return stimulusService:GetBestStimulusForEntity(entity, {
		Radius = entity.DetectionRadius * (entity.StimulusInvestigationRadiusMultiplier or 2.5),
		WeightByDirection = true,
		PreferPlayer = entity:GetTarget(),
		ExcludeKeys = entity.InvestigatedStimulusKeys,
	})
end

function EntityService:_getTopStimuliForDebug(entity, limit)
	local stimulusService = self.StimulusService
	if not stimulusService then
		return {}
	end

	local stimuli = stimulusService:GetStimuliNearPosition(
		entity:GetPosition(),
		entity.DetectionRadius * (entity.SearchStimulusRadiusMultiplier or 3),
		{
			WeightByDirection = true,
			PreferPlayer = entity:GetTarget(),
		}
	)

	local topStimuli = {}
	for index = 1, math.min(limit or 3, #stimuli) do
		table.insert(topStimuli, stimuli[index])
	end

	return topStimuli
end

function EntityService:_resolveStimulusIntentTarget(entity, stimulus)
	local stimulusDestination = stimulus.Destination or stimulus.Position
	if entity.IgnoreLineOfSightForInterest or self:_hasLineOfSightToPosition(entity, stimulusDestination) then
		return self:_clampPositionToMapBounds(stimulusDestination)
	end

	local canSeeOrigin = self:_hasLineOfSightToPosition(entity, stimulus.Position)
	return self:_clampPositionToMapBounds(self:_resolveStimulusInvestigationPoint(entity, stimulus, canSeeOrigin))
end

function EntityService:_updateEntityState(entity)
	if entity:IsCasting() then
		entity:EnterState(ENTITY_STATE.Casting)
		return
	end

	local intentName = entity:GetIntentName()
	if intentName == "Chase" then
		entity:EnterState(ENTITY_STATE.Chase)
	elseif intentName == "Search" then
		entity:EnterState(ENTITY_STATE.Scout)
	else
		entity:EnterState(ENTITY_STATE.Patrol)
	end
end

function EntityService:_updateCasting(entity)
	local activeCast = entity:GetActiveCast()
	if not activeCast then
		return
	end

	local statusService = self.StatusEffectService
	if statusService and not statusService:CanUseAbilities(entity) then
		entity:CancelCast()
		self:_syncDebugAttributes(entity)
		return
	end

	if os.clock() < activeCast.EndsAt then
		return
	end

	entity:CompleteCast()
	self:_resolveAbility(entity, activeCast.Definition, activeCast.TargetPlayer)
end

function EntityService:_tickEntityPassives(entity, deltaTime)
	for passiveId, passive in pairs(entity:GetPassiveDefinitions()) do
		if passive.Trigger ~= "Tick" then
			continue
		end

		if not self:_passiveCanRun(entity, passive) then
			continue
		end

		local cooldownKey = string.format("Passive:%s", passiveId)
		local tickInterval = passive.TickInterval or deltaTime
		if not entity:IsCooldownReady(cooldownKey) then
			continue
		end

		local context = self:_createEffectContext(entity, entity:GetTarget(), nil, deltaTime, passive)
		self:_executeEffectSteps(entity, passive, context)
		entity:SetCooldown(cooldownKey, tickInterval)
	end
end

function EntityService:_passiveCanRun(entity, passive)
	if passive.RequireState then
		local currentState = entity:GetState()
		local requiredState = passive.RequireState
		if type(requiredState) == "table" then
			local matches = false
			for _, stateName in ipairs(requiredState) do
				if currentState == stateName then
					matches = true
					break
				end
			end

			if not matches then
				return false
			end
		elseif currentState ~= requiredState then
			return false
		end
	end

	return true
end

function EntityService:_tryUseAbility(entity, candidates)
	if entity:IsCasting() then
		return
	end

	local abilityId, ability = self:_selectAbility(entity, candidates)
	if not abilityId or not ability then
		return
	end

	local targetPlayer = self:_selectAbilityTarget(entity, ability, candidates)
	self:_playEntityAbilityCastVisual(entity, abilityId, targetPlayer)
	entity:BeginCast(abilityId, ability, targetPlayer)
	entity:SetCooldown(abilityId, ability.Cooldown or 0)

	DebugLog:Log("Entity", string.format("[EntityService] %s began %s", entity.DisplayName, abilityId))
	self:_markLastAbility(entity, abilityId)
end

function EntityService:_selectAbility(entity, candidates)
	local abilities = entity:GetAbilityDefinitions()
	local available = {}
	local orderIndexById = {}

	for index, abilityId in ipairs(entity:GetAbilityOrder()) do
		orderIndexById[abilityId] = index
	end

	for abilityId, ability in pairs(abilities) do
		if entity:CanUseAbility(abilityId) and self:_canUseAbility(entity, ability, candidates) then
			table.insert(available, {
				Id = abilityId,
				Ability = ability,
				Weight = self:_scoreAbilitySelection(entity, abilityId, ability, candidates),
				OrderIndex = orderIndexById[abilityId] or math.huge,
			})
		end
	end

	if #available == 0 then
		return nil, nil
	end

	return self:_pickWeightedAbility(entity, available)
end

function EntityService:_canUseAbility(entity, ability, candidates)
	local statusService = self.StatusEffectService
	if statusService and not statusService:CanUseAbilities(entity) then
		return false
	end

	if ability.RequireState then
		local currentState = entity:GetState()
		local requireState = ability.RequireState
		if type(requireState) == "table" then
			local matches = false
			for _, stateName in ipairs(requireState) do
				if currentState == stateName then
					matches = true
					break
				end
			end
			if not matches then
				return false
			end
		elseif currentState ~= requireState then
			return false
		end
	end

	if ability.MinStateDuration then
		local currentState = entity:GetState()
		local requiredState = ability.MinStateDuration.State
		local minimumDuration = ability.MinStateDuration.Duration or 0
		if requiredState and currentState ~= requiredState then
			-- This condition only applies while the entity is in the specified state.
		elseif entity:GetStateDuration() < minimumDuration then
			return false
		end
	end

	if ability.RequireTarget and not entity:GetTarget() then
		return false
	end

	if self.StruggleService and self:_abilityStartsStruggle(ability) then
		local struggleTarget = self:_selectAbilityTarget(entity, ability, candidates)
		if not struggleTarget then
			return false
		end

		if not self.StruggleService:CanBeginStruggle(entity, struggleTarget) then
			return false
		end
	end

	if ability.RequireVisibleTarget and self:_countVisibleTargets(entity) <= 0 then
		return false
	end

	if ability.MinVisibleTargets and self:_countVisibleTargets(entity) < ability.MinVisibleTargets then
		return false
	end

	if ability.MaxVisibleTargets and self:_countVisibleTargets(entity) > ability.MaxVisibleTargets then
		return false
	end

	if ability.Range then
		local targetPlayer = entity:GetTarget()
		if not targetPlayer then
			return false
		end

		local targetCharacter = self.CharacterService:GetCharacterByPlayer(targetPlayer)
		if not targetCharacter or not targetCharacter.RootPart then
			return false
		end

		if not entity:IsInRange(targetCharacter.RootPart.Position, ability.Range) then
			return false
		end
	end

	local targetDistance = self:_getTargetDistance(entity, entity:GetTarget())
	if ability.MinTargetDistance and (targetDistance == nil or targetDistance < ability.MinTargetDistance) then
		return false
	end

	if ability.MaxTargetDistance and (targetDistance == nil or targetDistance > ability.MaxTargetDistance) then
		return false
	end

	if ability.RequireSearchMode and not entity:IsSearchModeActive(ability.RequireSearchMode == true and nil or ability.RequireSearchMode) then
		return false
	end

	if ability.ForbidSearchMode and entity.SearchMode then
		return false
	end

	if ability.RequireTargetMemory and not entity:GetTargetMemory(entity:GetTarget()) then
		return false
	end

	if ability.RequireStateEntry then
		local stateName = ability.RequireStateEntry.State or ability.RequireStateEntry
		local window = type(ability.RequireStateEntry) == "table" and ability.RequireStateEntry.Window or nil
		if not entity:JustEnteredState(stateName, window) then
			return false
		end
	end

	if ability.RequireEnteredChase and not entity:JustEnteredState(ENTITY_STATE.Chase, ability.RequireEnteredChaseWindow or 0.5) then
		return false
	end

	if ability.Chance and entity.Random:NextNumber() > ability.Chance then
		return false
	end

	if ability.RequireAnyCandidate == true and #candidates <= 0 then
		return false
	end

	if ability.RequirePlayersInRadius and self:_countPlayersInRadius(entity, ability.RequirePlayersInRadius) <= 0 then
		return false
	end

	if ability.RequirePlayersInRadiusForDuration then
		local radius = ability.RequirePlayersInRadius or ability.PlayerPresenceRadius
		if not radius then
			return false
		end

		local hasNearbyPlayers = self:_countPlayersInRadius(entity, radius) > 0
		local conditionKey = string.format("PlayersInRadius:%s:%s", tostring(ability.Id or "Ability"), tostring(radius))
		entity:SetConditionActive(conditionKey, hasNearbyPlayers)
		if not hasNearbyPlayers then
			return false
		end

		if entity:GetConditionDuration(conditionKey) < ability.RequirePlayersInRadiusForDuration then
			return false
		end
	end

	return true
end

function EntityService:_scoreAbilitySelection(entity, abilityId, ability, candidates)
	local weight = ability.Weight or 1
	local targetDistance = self:_getTargetDistance(entity, entity:GetTarget())

	if ability.Priority then
		weight += ability.Priority
	end

	if ability.PreferOnChaseEntry and entity:JustEnteredState(ENTITY_STATE.Chase, ability.ChaseEntryWindow or 0.5) then
		weight += ability.PreferOnChaseEntry
	end

	if ability.PreferVisibleTargets and self:_countVisibleTargets(entity) > 0 then
		weight += ability.PreferVisibleTargets
	end

	if ability.PreferDistanceBelow and targetDistance and targetDistance <= ability.PreferDistanceBelow then
		weight += ability.PreferDistanceBelowBonus or 1
	end

	if ability.PreferDistanceAbove and targetDistance and targetDistance >= ability.PreferDistanceAbove then
		weight += ability.PreferDistanceAboveBonus or 1
	end

	if ability.PreferSearchMode and entity.SearchMode then
		weight += ability.PreferSearchMode
	end

	if ability.PreferNoTarget and not entity:GetTarget() then
		weight += ability.PreferNoTarget
	end

	return math.max(0.01, weight)
end

function EntityService:_abilityStartsStruggle(ability)
	for _, step in ipairs(self:_getEffectSteps(ability)) do
		if step.Type == "StartStruggle" or step.Type == "BlindHungerLunge" then
			return true
		end
	end

	return false
end

function EntityService:_pickWeightedAbility(entity, available)
	table.sort(available, function(a, b)
		if a.Weight == b.Weight then
			return a.OrderIndex < b.OrderIndex
		end
		return a.Weight > b.Weight
	end)

	local totalWeight = 0
	for _, entry in ipairs(available) do
		totalWeight += entry.Weight
	end

	local roll = entity.Random:NextNumber(0, totalWeight)
	local cursor = 0
	for _, entry in ipairs(available) do
		cursor += entry.Weight
		if roll <= cursor then
			return entry.Id, entry.Ability
		end
	end

	local fallback = available[1]
	return fallback.Id, fallback.Ability
end

function EntityService:_getTargetDistance(entity, targetPlayer)
	if not targetPlayer then
		return nil
	end

	local targetCharacter = self.CharacterService:GetCharacterByPlayer(targetPlayer)
	local entityPosition = entity:GetPosition()
	if not targetCharacter or not targetCharacter.RootPart or not entityPosition then
		return nil
	end

	return (targetCharacter.RootPart.Position - entityPosition).Magnitude
end

function EntityService:_selectAbilityTarget(entity, ability, candidates)
	if not ability.Targeting or ability.Targeting == "CurrentTarget" then
		return entity:GetTarget()
	end

	if ability.Targeting == "NearestVisible" then
		local bestPlayer = nil
		local bestDistance = math.huge
		for _, candidate in ipairs(candidates) do
			if candidate.IsVisible and candidate.Distance < bestDistance then
				bestDistance = candidate.Distance
				bestPlayer = candidate.Player
			end
		end
		return bestPlayer
	end

	return entity:GetTarget()
end

function EntityService:_resolveAbility(entity, ability, targetPlayer)
	local context = self:_createEffectContext(entity, targetPlayer, nil, nil, ability)
	self:_executeEffectSteps(entity, ability, context)
	self:_playEntityAbilityResolveVisual(entity, ability.Id, targetPlayer)

	DebugLog:Log("Entity", string.format("[EntityService] %s resolved %s", entity.DisplayName, ability.Id or "Ability"))
	self:_syncDebugAttributes(entity)
end

function EntityService:_updateEntityMovement(entity, deltaTime)
	if entity:IsCasting() then
		return
	end

	if entity.IsSpecialMovementLocked and entity:IsSpecialMovementLocked() then
		return
	end

	if not entity:HasAttribute(EntityAttributes.Chase) then
		return
	end

	local state = entity:GetState()
	if state == ENTITY_STATE.Patrol then
		self:_updatePatrolMovement(entity, deltaTime)
	elseif state == ENTITY_STATE.Scout then
		self:_updateScoutMovement(entity, deltaTime)
	elseif state == ENTITY_STATE.Chase or state == ENTITY_STATE.Rage then
		local destination = entity:GetTargetLastKnownPosition()
		if destination then
			entity:MoveToward(destination, deltaTime)
		end
	end
end

function EntityService:_updatePatrolMovement(entity, deltaTime)
	if entity.SearchMode and not entity:IsSearchModeActive() then
		entity:EndSearchMode()
	end

	if entity:GetIntentName() == "Investigate" then
		self:_updateInvestigateMovement(entity, deltaTime)
		return
	end

	if entity:ShouldRelocateRoamAnchor() then
		entity:ClearPatrolDestination()
		self:_maybeRelocateRoamAnchor(entity, true)
	end

	if entity:IsPatrolPaused() then
		return
	end

	local destination = entity:GetPatrolDestination()
	if not destination then
		self:_maybeRelocateRoamAnchor(entity, true)
		destination = self:_pickReachablePatrolDestination(entity)
	end

	if not destination then
		return
	end

	if entity:HasReachedPatrolDestination() then
		entity:SetRoamAnchor(self:_clampPositionToMapBounds(entity:GetPosition()))
		entity:ClearPatrolDestination()
		if entity.SearchMode then
			self:_maybeRelocateRoamAnchor(entity, true)
			self:_pickReachablePatrolDestination(entity)
			destination = entity:GetPatrolDestination()
			if not destination then
				return
			end
		else
			entity:MarkPatrolPause()
			self:_maybeRelocateRoamAnchor(entity, false)
			self:_pickReachablePatrolDestination(entity)
			return
		end
	end

	if self:_isMovementStepBlocked(entity, destination) then
		entity:ClearPatrolDestination()
		self:_maybeRelocateRoamAnchor(entity, true)
		self:_pickReachablePatrolDestination(entity)
		return
	end

	entity:MoveToward(destination, deltaTime)
end

function EntityService:_updateScoutMovement(entity, deltaTime)
	local destination = entity:GetCurrentSearchCenter() or entity:GetTargetLastKnownPosition() or entity:GetIntentTargetPosition()
	if not destination then
		entity:ClearScoutArrival()
		entity:SetTarget(nil)
		entity:ClearIntent()
		entity:EnterState(ENTITY_STATE.Patrol)
		entity:ClearPatrolDestination()
		entity.PatrolPauseUntil = 0
		self:_pickReachablePatrolDestination(entity)
		return
	end

	local scoutDestination = entity:GetPatrolDestination()
	if scoutDestination then
		if entity:IsNearPosition(scoutDestination, entity:GetStopDistance() + 0.5) then
			entity:ClearPatrolDestination()
			if entity:HasScoutSweepRemaining() then
				self:_pickReachableScoutDestination(entity)
			else
				self:_completeSearchIntent(entity, destination)
			end
			return
		end

		if self:_isMovementStepBlocked(entity, scoutDestination) then
			entity:ClearPatrolDestination()
			self:_pickReachableScoutDestination(entity)
			return
		end

		entity:MoveToward(scoutDestination, deltaTime)
		return
	end

	if entity:HasReachedScoutDestination() then
		entity:BeginScoutSweep(destination)
		if entity:HasScoutSweepRemaining() then
			self:_pickReachableScoutDestination(entity)
		else
			self:_completeSearchIntent(entity, destination)
		end
		return
	end

	entity:ClearScoutArrival()
	if self:_isMovementStepBlocked(entity, destination) then
		entity:BeginScoutSweep(destination)
		if entity:HasScoutSweepRemaining() then
			self:_pickReachableScoutDestination(entity)
		end
		return
	end

	entity:MoveToward(destination, deltaTime)
end

function EntityService:_completeSearchIntent(entity, destination)
	local targetPlayer = entity:GetTarget()
	entity:SetRoamAnchor(self:_clampPositionToMapBounds(entity.ScoutOrigin or destination))
	entity:ClearScoutArrival()

	local intentStimulus = entity:GetIntentSourceStimulus()
	if intentStimulus and intentStimulus.Key then
		entity:MarkStimulusInvestigated(intentStimulus.Key)
	end

	entity:ClearIntent()
	if targetPlayer then
		entity:ForgetTarget(targetPlayer)
	else
		entity:SetTarget(nil)
	end

	entity:EnterState(ENTITY_STATE.Patrol)
	entity.PatrolPauseUntil = 0
	self:_pickReachablePatrolDestination(entity)
end

function EntityService:_updateInvestigateMovement(entity, deltaTime)
	local intentTarget = entity:GetIntentTargetPosition()
	if not intentTarget or entity:IsIntentExpired() then
		local intentStimulus = entity:GetIntentSourceStimulus()
		if intentStimulus and intentStimulus.Key then
			entity:MarkStimulusInvestigated(intentStimulus.Key)
		end
		entity:ClearIntent()
		entity:ClearPatrolDestination()
		return
	end

	local destination = entity:GetPatrolDestination()
	if not destination or entity:GetPatrolDestinationReason() ~= "Investigate" then
		destination = self:_resolveStimulusIntentTarget(entity, entity:GetIntentSourceStimulus() or {
			Position = intentTarget,
			Destination = intentTarget,
		})
		entity:SetPatrolDestination(destination, "Investigate")
	end

	if entity:IsNearPosition(destination, entity:GetStopDistance() + 0.5) then
		local intentStimulus = entity:GetIntentSourceStimulus()
		if intentStimulus and intentStimulus.Key then
			entity:MarkStimulusInvestigated(intentStimulus.Key)
		end
		entity:SetRoamAnchor(self:_clampPositionToMapBounds(entity:GetPosition()))
		entity:ClearPatrolDestination()
		entity:MarkPatrolPause(0.4)
		entity:ClearIntent()
		return
	end

	if self:_isMovementStepBlocked(entity, destination) then
		local adjustedDestination = self:_resolveStimulusIntentTarget(entity, entity:GetIntentSourceStimulus() or {
			Position = intentTarget,
			Destination = intentTarget,
		})
		entity:SetPatrolDestination(adjustedDestination, "Investigate")
		destination = adjustedDestination
	end

	entity:MoveToward(destination, deltaTime)
end

function EntityService:_maybeRelocateRoamAnchor(entity, forceRelocate)
	if not self.MapBounds or not self.MapBounds:IsA("BasePart") then
		return false
	end

	if not forceRelocate and entity.Random:NextNumber() > entity.GlobalPatrolRelocateChance then
		return false
	end

	local anchor = self:_pickRandomPointInMapBounds(entity)
	if not anchor then
		return false
	end

	entity:SetRoamAnchor(self:_clampPositionToMapBounds(anchor))
	return true
end

function EntityService:_pickRandomPointInMapBounds(entity)
	local boundsPart = self.MapBounds
	if not boundsPart or not boundsPart:IsA("BasePart") then
		return nil
	end

	local size = boundsPart.Size
	local center = boundsPart.Position
	local currentPosition = entity:GetPosition() or center
	local y = currentPosition.Y

	for _ = 1, 12 do
		local x = center.X + entity.Random:NextNumber(-size.X * 0.5, size.X * 0.5)
		local z = center.Z + entity.Random:NextNumber(-size.Z * 0.5, size.Z * 0.5)
		local candidate = Vector3.new(x, y, z)
		if not entity:IsNearPosition(candidate, entity.PatrolPointMinDistance * 2) then
			return self:_clampPositionToMapBounds(candidate)
		end
	end

	return self:_clampPositionToMapBounds(Vector3.new(center.X, y, center.Z))
end

function EntityService:_pickReachablePatrolDestination(entity)
	local currentDestination = entity:GetPatrolDestination()
	if currentDestination
		and not entity:IsNearPosition(currentDestination, entity:GetStopDistance() + 0.5)
		and self:_isNavigationDestinationReachable(entity, currentDestination)
	then
		return currentDestination
	end

	for _ = 1, 8 do
		local destination = self:_clampPositionToMapBounds(entity:PickPatrolDestination())
		if destination then
			entity:SetPatrolDestination(destination, "Patrol")
		end
		if not destination or self:_isNavigationDestinationReachable(entity, destination) then
			return destination
		end
	end

	return entity:GetPatrolDestination()
end

function EntityService:_pickReachableScoutDestination(entity)
	local currentDestination = entity:GetPatrolDestination()
	if currentDestination
		and not entity:IsNearPosition(currentDestination, entity:GetStopDistance() + 0.5)
		and self:_isNavigationDestinationReachable(entity, currentDestination)
	then
		return currentDestination
	end

	for _ = 1, 8 do
		local destination = self:_clampPositionToMapBounds(entity:PickScoutDestination())
		if destination then
			entity:SetPatrolDestination(destination, "Scout")
		end
		if not destination or self:_isNavigationDestinationReachable(entity, destination) then
			return destination
		end
	end

	return entity:GetPatrolDestination()
end

function EntityService:_clampPositionToMapBounds(position)
	local boundsPart = self.MapBounds
	if not position or not boundsPart or not boundsPart:IsA("BasePart") then
		return position
	end

	local size = boundsPart.Size
	local center = boundsPart.Position
	local halfX = math.max(0, (size.X * 0.5) - 2)
	local halfZ = math.max(0, (size.Z * 0.5) - 2)

	return Vector3.new(
		math.clamp(position.X, center.X - halfX, center.X + halfX),
		position.Y,
		math.clamp(position.Z, center.Z - halfZ, center.Z + halfZ)
	)
end

function EntityService:_isNavigationDestinationReachable(entity, destination)
	local origin = entity:GetPosition()
	if not origin or not destination then
		return true
	end

	local direction = destination - origin
	if direction.Magnitude <= entity:GetStopDistance() then
		return true
	end

	self.RaycastParams.FilterDescendantsInstances = {
		entity.Model,
		self.EntitiesFolder,
		self.MapBounds,
	}

	local start = origin + Vector3.new(0, 2, 0)
	local result = Workspace:Raycast(start, direction, self.RaycastParams)
	if not result then
		return true
	end

	return (result.Position - start).Magnitude >= (direction.Magnitude - 1)
end

function EntityService:_isMovementStepBlocked(entity, destination)
	if entity.SearchMode and entity.SearchMode.IgnoreMovementBlockers then
		return false
	end

	local origin = entity:GetPosition()
	if not origin or not destination then
		return false
	end

	local direction = destination - origin
	local distance = direction.Magnitude
	if distance <= entity:GetStopDistance() then
		return false
	end

	local moveDistance = math.min(distance - entity:GetStopDistance(), entity:GetMoveSpeed() * self.UpdateInterval)
	if moveDistance <= 0 then
		return false
	end

	self.RaycastParams.FilterDescendantsInstances = {
		entity.Model,
		self.EntitiesFolder,
		self.MapBounds,
	}

	local start = origin + Vector3.new(0, 2, 0)
	local result = Workspace:Raycast(start, direction.Unit * moveDistance, self.RaycastParams)
	return result ~= nil
end

function EntityService:_tryBasicAttack(entity)
	local targetPlayer = entity:GetTarget()
	if not targetPlayer or not entity:CanAttack() or entity:IsCasting() then
		return
	end

	local attackDefinition = entity:GetCurrentBasicAttackDefinition()

	local statusService = self.StatusEffectService
	if statusService and not statusService:CanUseAbilities(entity) then
		return
	end

	local characterService = self.CharacterService
	if not characterService then
		return
	end

	local targetCharacter = characterService:GetCharacterByPlayer(targetPlayer)
	if not targetCharacter or not targetCharacter.RootPart then
		return
	end

	local attackRange = attackDefinition.AttackRange or entity.AttackRange
	if not entity:IsInRange(targetCharacter.RootPart.Position, attackRange) then
		return
	end

	if not entity.IgnoreLineOfSightForAttacks and not self:_hasLineOfSight(entity, targetCharacter) then
		return
	end

	local damageAmount = entity:GetScaledDamage(attackDefinition.Damage or entity.Damage)
	local didDamage = targetCharacter:ApplyDamage(damageAmount)
	if didDamage then
		if statusService then
			statusService:ApplyStatus(targetPlayer, StatusEffectId.Haste, {
				Duration = 1.5,
				Magnitude = 0.45,
				Source = "OnHitHaste",
			})
		end
		
		local interactionService = self.InteractionService
		if interactionService and interactionService:IsInteracting(targetPlayer) then
			interactionService:InterruptInteraction(targetPlayer, "Damaged")
		end

		self:_executeBasicAttackEffects(entity, targetPlayer, attackDefinition)
		self:_handleTargetDowned(entity, targetPlayer, targetCharacter)
	end

	entity:MarkAttack(attackDefinition.Cooldown or entity.AttackInterval)
	entity:AdvanceBasicAttackVariant()

	DebugLog:Log("Entity", string.format(
		"[EntityService] %s hit %s for %d",
		entity.Model.Name,
		targetPlayer.Name,
		damageAmount
	))
end

function EntityService:_executeBasicAttackEffects(entity, targetPlayer, attackDefinition)
	local basicAttack = attackDefinition or entity:GetCurrentBasicAttackDefinition()
	if not basicAttack then
		return
	end

	local context = self:_createEffectContext(entity, targetPlayer, nil, nil)
	local effectSteps = {}
	for _, step in ipairs(basicAttack.Effects or {}) do
		table.insert(effectSteps, step)
	end

	if entity.GetInheritedBasicAttackEffects then
		for _, step in ipairs(entity:GetInheritedBasicAttackEffects()) do
			table.insert(effectSteps, step)
		end
	end

	if #effectSteps <= 0 then
		return
	end

	for _, step in ipairs(effectSteps) do
		self:_executeEffectStep(entity, step, context)
	end
end

function EntityService:_createEffectContext(entity, targetPlayer, sourceStep, deltaTime, definition)
	return {
		Entity = entity,
		TargetPlayer = targetPlayer,
		SourceStep = sourceStep,
		DeltaTime = deltaTime,
		Definition = definition,
	}
end

function EntityService:_executeEffectSteps(entity, definition, context)
	for _, step in ipairs(self:_getEffectSteps(definition)) do
		self:_executeEffectStep(entity, step, context)
	end
end

function EntityService:_getEffectSteps(definition)
	if definition.Effects then
		return definition.Effects
	end

	local legacyEffect = definition.Effect
	if not legacyEffect then
		return {}
	end

	if legacyEffect == "SelfBuff" then
		return {
			{
				Type = "ApplyPersistentModifierSelf",
				Modifier = definition.Modifier,
				Amount = definition.Amount,
			},
		}
	elseif legacyEffect == "DamageTarget" then
		return {
			{
				Type = "DamageTargets",
				Targets = definition.Targeting or "CurrentTarget",
				Amount = definition.Damage,
				Range = definition.Range,
			},
		}
	elseif legacyEffect == "RefreshTargetMemory" then
		return {
			{
				Type = "RefreshTargetMemory",
				Targets = definition.Targeting or "CurrentTarget",
			},
		}
	elseif legacyEffect == "SelfBuffFromVisibleTargets" then
		return {
			{
				Type = "ApplyTimedModifierSelfPerTarget",
				Targets = "VisibleTargets",
				Modifier = definition.Modifier,
				Amount = definition.AmountPerTarget,
				Duration = definition.Duration or 1,
			},
		}
	end

	return {}
end

function EntityService:_executeEffectStep(entity, step, context)
	local stepType = step.Type

	if stepType == "DamageTargets" then
		for _, player in ipairs(self:_resolveEffectTargets(entity, step, context)) do
			self:_damageTargetFromEffect(entity, player, step)
		end
	elseif stepType == "RepeatDamageTargets" then
		self:_repeatDamageTargetsFromEffect(entity, step, context)
	elseif stepType == "HealSelfPercent" then
		entity:HealPercent(step.Amount or 0)
	elseif stepType == "ApplyPersistentModifierSelf" then
		if step.Modifier and step.Amount then
			entity:ApplyPersistentModifier(step.Modifier, step.Amount)
		end
	elseif stepType == "ApplyTimedModifierSelf" then
		if step.Modifier and step.Amount and step.Duration then
			entity:ApplyTimedModifier(step.Modifier, step.Amount, step.Duration, step.SourceKey or step.Modifier)
		end
	elseif stepType == "ApplyTimedModifierSelfPerTarget" then
		local targets = self:_resolveEffectTargets(entity, step, context)
		for _ = 1, #targets do
			entity:ApplyTimedModifier(step.Modifier, step.Amount or 0, step.Duration or 0, step.SourceKey or step.Modifier)
		end
	elseif stepType == "RefreshTargetMemory" then
		for _, player in ipairs(self:_resolveEffectTargets(entity, step, context)) do
			local character = self.CharacterService:GetCharacterByPlayer(player)
			if character and character.RootPart then
				entity:RememberTarget(player, character.RootPart.Position, true)
			end
		end
	elseif stepType == "InterruptInteraction" then
		local interactionService = self.InteractionService
		if interactionService then
			for _, player in ipairs(self:_resolveEffectTargets(entity, step, context)) do
				interactionService:InterruptInteraction(player, step.Reason or "EntityEffect")
			end
		end
	elseif stepType == "ApplyCharacterSpeedMultiplier" then
		for _, player in ipairs(self:_resolveEffectTargets(entity, step, context)) do
			local character = self.CharacterService:GetCharacterByPlayer(player)
			if character then
				character:ApplyTemporarySpeedMultiplier(step.Key or "EntityEffectSlow", step.Multiplier or 1, step.Duration or 0)
			end
		end
	elseif stepType == "ApplyStatusPlaceholder" then
		for _, player in ipairs(self:_resolveEffectTargets(entity, step, context)) do
			DebugLog:Log("Entity", string.format("[EntityService] Placeholder status %s applied to %s", tostring(step.StatusId), player.Name))
		end
	elseif stepType == "ApplyStatus" then
		local statusService = self.StatusEffectService
		if not statusService then
			return
		end

		for _, target in ipairs(self:_resolveEffectTargets(entity, step, context)) do
			statusService:ApplyStatus(target, step.StatusId, {
				Duration = step.Duration,
				Magnitude = step.Magnitude,
				Tier = step.Tier,
				Source = entity.DisplayName,
			})
		end
	elseif stepType == "ApplyStatusSelfPerTargetCount" then
		local statusService = self.StatusEffectService
		if not statusService then
			return
		end

		local targets = self:_resolveEffectTargets(entity, {
			Targets = step.CountTargets or "VisibleTargets",
		}, context)

		if #targets > 0 then
			statusService:ApplyStatus(entity, step.StatusId, {
				Duration = step.Duration,
				Magnitude = (step.Magnitude or 0) * #targets,
				Tier = step.Tier,
				Source = entity.DisplayName,
			})
		end
	elseif stepType == "DrainStaminaTargets" then
		if not self.StaminaService then
			return
		end

		for _, target in ipairs(self:_resolveEffectTargets(entity, step, context)) do
			self.StaminaService:DrainStamina(target, step.Amount or 0, step.Reason or entity.DisplayName)
		end
	elseif stepType == "StartStruggle" then
		self:_startStruggleFromEffect(entity, step, context)
	elseif stepType == "BlindHungerLunge" then
		self:_startBlindHungerLungeFromEffect(entity, step, context)
	elseif stepType == "StartBreathHoldChallenge" then
		if not self.BreathHoldService then
			return
		end

		self.BreathHoldService:BeginChallenge(entity, step)
	elseif stepType == "StartSearchMode" then
		local searchId = step.SearchId or "SearchMode"
		local duration = step.Duration
		entity:BeginSearchMode(searchId, duration, {
			HeightOffset = step.HeightOffset,
			IgnoreMovementBlockers = step.IgnoreMovementBlockers,
			DetectionRadiusMultiplier = step.DetectionRadiusMultiplier,
		})
		self:_pickReachablePatrolDestination(entity)
	elseif stepType == "LaunchProjectileStatus" then
		self:_launchProjectileStatusFromEffect(entity, step, context)
	elseif stepType == "SpawnEntity" then
		self:_spawnEntitiesFromEffect(entity, step, context)
	elseif stepType == "AbsorbAbility" then
		for _, player in ipairs(self:_resolveEffectTargets(entity, step, context)) do
			local totalAbsorbed = entity:AbsorbAbilityFromPlayer(player, step.Count or 1)
			DebugLog:Log("Entity", string.format("[EntityService] %s absorbed from %s (%d total on target)", entity.DisplayName, player.Name, totalAbsorbed))
		end
	elseif stepType == "ExtendReceptionTime" then
		local roundHookService = self.RoundHookService
		if not roundHookService then
			return
		end

		roundHookService:ExtendReceptionTime(step.Amount or 0, step.Reason or entity.DisplayName)
	elseif stepType == "SetReceptionTime" then
		local roundHookService = self.RoundHookService
		if not roundHookService then
			return
		end

		roundHookService:SetReceptionTime(step.TimeLeft or 0, step.Reason or entity.DisplayName)
	elseif stepType == "LogMessage" then
		local message = step.Message or "[EntityService] Round hook triggered"
		local hookContext = context and context.RoundHookContext
		if hookContext and hookContext.Phase then
			message = string.gsub(message, "{Phase}", tostring(hookContext.Phase))
		end
		if hookContext and hookContext.TimeLeft ~= nil then
			message = string.gsub(message, "{TimeLeft}", tostring(hookContext.TimeLeft))
		end
		if hookContext and hookContext.Objective and hookContext.Objective.Name then
			message = string.gsub(message, "{ObjectiveName}", tostring(hookContext.Objective.Name))
		end

		DebugLog:Log("Entity", string.format("[EntityService] %s %s", entity.DisplayName, message))
	end
end

function EntityService:_launchProjectileStatusFromEffect(entity, step, context)
	local targets = self:_resolveEffectTargets(entity, step, context)
	for _, player in ipairs(targets) do
		local character = self.CharacterService:GetCharacterByPlayer(player)
		if character and character.RootPart and character:IsAlive() then
			self:_spawnEntityProjectile(entity, player, step)
		end
	end
end

function EntityService:_spawnEntityProjectile(entity, targetPlayer, step)
	if not entity or not entity.RootPart then
		return
	end

	local origin = entity.RootPart.Position + Vector3.new(0, step.HeightOffset or 3, 0)
	local targetCharacter = self.CharacterService:GetCharacterByPlayer(targetPlayer)
	local targetPosition = targetCharacter and targetCharacter.RootPart and targetCharacter.RootPart.Position or (origin + entity.RootPart.CFrame.LookVector * 4)
	local forwardDirection = entity.RootPart.CFrame.LookVector
	local initialDirection = (forwardDirection * (step.ForwardBiasDistance or 18)) + ((targetPosition - origin) * (step.InitialTrackingWeight or 0.35))
	if initialDirection.Magnitude <= 0.01 then
		initialDirection = forwardDirection
	end

	local projectilePart = Instance.new("Part")
	projectilePart.Name = step.VisualName or "EntityProjectile"
	projectilePart.Anchored = true
	projectilePart.CanCollide = false
	projectilePart.CanQuery = false
	projectilePart.CanTouch = false
	projectilePart.CastShadow = false
	projectilePart.Material = Enum.Material.Neon
	projectilePart.Color = step.Color or Color3.fromRGB(236, 224, 178)
	projectilePart.Size = step.VisualSize or Vector3.new(0.45, 1.1, 0.18)
	projectilePart.CFrame = CFrame.lookAt(origin, origin + initialDirection.Unit)
	projectilePart.Parent = Workspace

	local projectile = {
		Entity = entity,
		TargetPlayer = targetPlayer,
		Part = projectilePart,
		Direction = initialDirection.Unit,
		Speed = step.Speed or 42,
		TurnRate = step.TurnRate or 0.22,
		HitRadius = step.HitRadius or 1,
		ExpiresAt = os.clock() + (step.Lifetime or 2.5),
		StatusId = step.StatusId,
		StatusDuration = step.Duration,
		StatusMagnitude = step.Magnitude,
		StatusTier = step.Tier,
		StickDuration = step.StickDuration or step.Duration or 0,
		StickName = step.StickName or "QiSealTalisman",
		HomingWeight = step.HomingWeight or 0.18,
		ForwardBiasDistance = step.ForwardBiasDistance or 18,
	}

	table.insert(self.ActiveProjectiles, projectile)
end

function EntityService:_updateProjectiles(deltaTime)
	for index = #self.ActiveProjectiles, 1, -1 do
		local projectile = self.ActiveProjectiles[index]
		if self:_updateProjectile(projectile, deltaTime) ~= true then
			self:_destroyProjectile(projectile)
			table.remove(self.ActiveProjectiles, index)
		end
	end
end

function EntityService:_updateProjectile(projectile, deltaTime)
	if not projectile or not projectile.Part or not projectile.Part.Parent then
		return false
	end

	if os.clock() >= (projectile.ExpiresAt or 0) then
		return false
	end

	local entity = projectile.Entity
	if not entity or not entity.IsActive or entity.Health <= 0 then
		return false
	end

	local targetCharacter = self.CharacterService:GetCharacterByPlayer(projectile.TargetPlayer)
	if not targetCharacter or not targetCharacter.RootPart or not targetCharacter:IsAlive() then
		return false
	end

	local currentPosition = projectile.Part.Position
	local targetPosition = targetCharacter.RootPart.Position + Vector3.new(0, 1.6, 0)
	local desiredDirection = targetPosition - currentPosition
	if desiredDirection.Magnitude <= 0.01 then
		desiredDirection = projectile.Direction
	end

	local currentDirection = projectile.Direction or desiredDirection.Unit
	local forwardBiasDirection = currentDirection
	local homingWeight = projectile.HomingWeight or 0.18
	local weightedDesiredDirection = (forwardBiasDirection * math.max(0, 1 - homingWeight)) + (desiredDirection.Unit * homingWeight)
	local turnAlpha = math.clamp((projectile.TurnRate or 0.22) * math.max(1, deltaTime * 60), 0, 1)
	local blendedDirection = currentDirection:Lerp(weightedDesiredDirection.Unit, turnAlpha)
	if blendedDirection.Magnitude <= 0.001 then
		blendedDirection = desiredDirection.Unit
	end
	projectile.Direction = blendedDirection.Unit

	local moveDistance = (projectile.Speed or 42) * deltaTime
	local nextPosition = currentPosition + (projectile.Direction * moveDistance)
	projectile.Part.CFrame = CFrame.lookAt(nextPosition, nextPosition + projectile.Direction)

	local hitRadius = projectile.HitRadius or 2.25
	local closestPoint = self:_getClosestPointOnSegment(currentPosition, nextPosition, targetPosition)
	if (targetPosition - closestPoint).Magnitude <= hitRadius then
		self:_resolveProjectileHit(projectile, targetCharacter)
		return false
	end

	return true
end

function EntityService:_getClosestPointOnSegment(segmentStart, segmentEnd, point)
	local segment = segmentEnd - segmentStart
	local segmentLengthSquared = segment:Dot(segment)
	if segmentLengthSquared <= 0.0001 then
		return segmentStart
	end

	local alpha = math.clamp((point - segmentStart):Dot(segment) / segmentLengthSquared, 0, 1)
	return segmentStart + (segment * alpha)
end

function EntityService:_resolveProjectileHit(projectile, targetCharacter)
	if not projectile or not targetCharacter or not targetCharacter.Player then
		return
	end

	if self.StatusEffectService and projectile.StatusId then
		self.StatusEffectService:ApplyStatus(targetCharacter.Player, projectile.StatusId, {
			Duration = projectile.StatusDuration,
			Magnitude = projectile.StatusMagnitude,
			Tier = projectile.StatusTier,
			Source = projectile.Entity and projectile.Entity.DisplayName or "Projectile",
		})
	end

	local characterModel = targetCharacter.Model
	local head = characterModel and characterModel:FindFirstChild("Head")
	if head then
		local talisman = Instance.new("Part")
		talisman.Name = projectile.StickName or "ProjectileSeal"
		talisman.Anchored = false
		talisman.CanCollide = false
		talisman.CanQuery = false
		talisman.CanTouch = false
		talisman.CastShadow = false
		talisman.Material = Enum.Material.Neon
		talisman.Color = projectile.Part and projectile.Part.Color or Color3.fromRGB(236, 224, 178)
		talisman.Size = Vector3.new(0.55, 0.75, 0.08)
		talisman.CFrame = head.CFrame * CFrame.new(0, 0.05, -0.52)
		talisman.Parent = characterModel

		local weld = Instance.new("WeldConstraint")
		weld.Part0 = talisman
		weld.Part1 = head
		weld.Parent = talisman

		task.delay(math.max(0.1, projectile.StickDuration or 0), function()
			if talisman and talisman.Parent then
				talisman:Destroy()
			end
		end)
	end
end

function EntityService:_destroyProjectile(projectile)
	if projectile and projectile.Part and projectile.Part.Parent then
		projectile.Part:Destroy()
	end
end

function EntityService:_startStruggleFromEffect(entity, step, context)
	if not self.StruggleService then
		return
	end

	for _, target in ipairs(self:_resolveEffectTargets(entity, step, context)) do
		local targetCharacter = self.CharacterService:GetCharacterByPlayer(target)
		if targetCharacter and targetCharacter.RootPart and targetCharacter:IsAlive() then
			local originCFrame = entity.RootPart and entity.RootPart.CFrame or nil
			local struggleParams = table.clone(step)
			struggleParams.LungeOriginCFrame = originCFrame
			struggleParams.ReturnEntityOnBreakFree = step.ReturnEntityOnBreakFree == true

			local hasLunge = (step.LungeDuration or 0) > 0 or (step.LungeSpeed or 0) > 0
			if hasLunge then
				if not step.RequireLineOfSight or entity.IgnoreLineOfSightForAttacks or self:_hasLineOfSight(entity, targetCharacter) then
					self:_performStruggleLunge(entity, target, targetCharacter, struggleParams)
				end
			elseif self:_canResolveStruggleTarget(entity, targetCharacter, step) then
				self:_applyStruggleLunge(entity, targetCharacter, step)
				local started = self.StruggleService:BeginStruggle(entity, target, struggleParams)
				if started and context and context.Definition and context.Definition.Id == "SeekingWisdom" then
					self:_playStruggleLatchVisual(entity, targetCharacter)
				end
			end
		end
	end
end

function EntityService:_startBlindHungerLungeFromEffect(entity, step, context)
	if not self.StruggleService then
		return
	end

	for _, target in ipairs(self:_resolveEffectTargets(entity, step, context)) do
		local targetCharacter = self.CharacterService:GetCharacterByPlayer(target)
		if targetCharacter and targetCharacter.RootPart and targetCharacter:IsAlive() then
			local originCFrame = entity.RootPart and entity.RootPart.CFrame or nil
			local struggleParams = table.clone(step)
			struggleParams.LungeOriginCFrame = originCFrame
			struggleParams.ReturnEntityOnBreakFree = step.ReturnEntityOnBreakFree == true

			if not step.RequireLineOfSight or entity.IgnoreLineOfSightForAttacks or self:_hasLineOfSight(entity, targetCharacter) then
				self:_performBlindHungerLunge(entity, target, targetCharacter, struggleParams)
			end
		end
	end
end

function EntityService:_performBlindHungerLunge(entity, targetPlayer, targetCharacter, struggleParams)
	if not entity or not entity.RootPart or not targetCharacter or not targetCharacter.RootPart then
		return
	end

	local startPosition = entity.RootPart.Position
	local targetGroundPosition = self:_getStruggleLungeGroundPosition(startPosition, targetCharacter, struggleParams)
	if not targetGroundPosition then
		return
	end

	local dashOffset = targetGroundPosition - startPosition
	local dashDistance = dashOffset.Magnitude
	if dashDistance <= 0.05 then
		return
	end

	local lungeDuration
	if (struggleParams.LungeSpeed or 0) > 0 then
		lungeDuration = dashDistance / struggleParams.LungeSpeed
		lungeDuration = math.max(struggleParams.MinLungeDuration or 0.1, lungeDuration)
		if struggleParams.MaxLungeDuration then
			lungeDuration = math.min(struggleParams.MaxLungeDuration, lungeDuration)
		end
	else
		lungeDuration = math.max(0.05, struggleParams.LungeDuration or 0.12)
	end

	entity.ActionSequenceId = (entity.ActionSequenceId or 0) + 1
	local actionSequenceId = entity.ActionSequenceId
	entity:LockSpecialMovement(lungeDuration + math.max(0, struggleParams.ImpactDelay or 0.05) + 0.1)

	local dashDirection = dashOffset.Unit
	local contactRadius = math.max(0.5, struggleParams.GrabRange or 3.2)
	local minTravelFractionBeforeHit = math.clamp(struggleParams.MinTravelFractionBeforeHit or 0.85, 0, 0.98)

	self:_showEntityAbilityVisual("BlindHungerLunge", {
		EntityModel = entity.Model,
		EntityId = entity.Id,
		StartPosition = startPosition,
		EndPosition = targetGroundPosition,
		Duration = lungeDuration,
		LeapHeight = struggleParams.LeapHeight or 0,
		ContactRadius = contactRadius,
	})
	self:_spawnStruggleLungeDebugVisual(startPosition, targetGroundPosition, contactRadius)

	task.spawn(function()
		local elapsed = 0
		local finalPosition = targetGroundPosition

		while elapsed < lungeDuration do
			if not entity or not entity.RootPart or not entity.IsActive or entity.Health <= 0 then
				return
			end

			if (entity.ActionSequenceId or 0) ~= actionSequenceId then
				return
			end

			local deltaTime = RunService.Heartbeat:Wait()
			elapsed += deltaTime

			local alpha = math.clamp(elapsed / lungeDuration, 0, 1)
			local currentPosition = startPosition:Lerp(targetGroundPosition, alpha)
			entity.RootPart.CFrame = CFrame.lookAt(
				Vector3.new(currentPosition.X, entity.RootPart.Position.Y, currentPosition.Z),
				Vector3.new(currentPosition.X, entity.RootPart.Position.Y, currentPosition.Z) + Vector3.new(dashDirection.X, 0, dashDirection.Z)
			)

			if alpha >= minTravelFractionBeforeHit then
				local liveCharacter = self.CharacterService:GetCharacterByPlayer(targetPlayer)
				if liveCharacter and liveCharacter.RootPart and liveCharacter:IsAlive() then
					local liveOffset = liveCharacter.RootPart.Position - entity.RootPart.Position
					local planarLiveOffset = Vector3.new(liveOffset.X, 0, liveOffset.Z)
					if planarLiveOffset.Magnitude <= contactRadius then
						finalPosition = entity.RootPart.Position
						break
					end
				end
			end
		end

		if (entity.ActionSequenceId or 0) ~= actionSequenceId then
			return
		end

		local endPosition = Vector3.new(finalPosition.X, entity.RootPart.Position.Y, finalPosition.Z)
		entity.RootPart.CFrame = CFrame.lookAt(endPosition, endPosition + Vector3.new(dashDirection.X, 0, dashDirection.Z))

		local liveCharacter = self.CharacterService:GetCharacterByPlayer(targetPlayer)
		if not liveCharacter or not liveCharacter.RootPart or not liveCharacter:IsAlive() then
			return
		end

		local liveOffset = liveCharacter.RootPart.Position - entity.RootPart.Position
		local planarLiveOffset = Vector3.new(liveOffset.X, 0, liveOffset.Z)
		if planarLiveOffset.Magnitude > contactRadius then
			return
		end

		local impactDelay = math.max(0, struggleParams.ImpactDelay or 0.05)
		if impactDelay > 0 then
			task.wait(impactDelay)
		end

		if (entity.ActionSequenceId or 0) ~= actionSequenceId then
			return
		end

		self.StruggleService:BeginStruggle(entity, targetPlayer, struggleParams)
	end)
end

function EntityService:_canResolveStruggleTarget(entity, targetCharacter, step)
	if not entity or not targetCharacter or not targetCharacter.RootPart or not targetCharacter:IsAlive() then
		return false
	end

	local startRange = step.StartRange or step.Range or 0
	if startRange > 0 and not entity:IsInRange(targetCharacter.RootPart.Position, startRange) then
		return false
	end

	if step.RequireLineOfSight and not (entity.IgnoreLineOfSightForAttacks or self:_hasLineOfSight(entity, targetCharacter)) then
		return false
	end

	return true
end

function EntityService:_applyStruggleLunge(entity, targetCharacter, step)
	if not entity or not entity.RootPart or not targetCharacter or not targetCharacter.RootPart then
		return
	end

	local landingCFrame = self:_getStruggleLungeCFrame(entity, targetCharacter, step)
	if not landingCFrame then
		return
	end

	entity.RootPart.CFrame = landingCFrame
end

function EntityService:_getStruggleLungeCFrame(entity, targetCharacter, step)
	if not entity or not entity.RootPart or not targetCharacter or not targetCharacter.RootPart then
		return nil
	end

	local origin = entity.RootPart.Position
	local targetPosition = targetCharacter.RootPart.Position
	local offset = targetPosition - origin
	local planarOffset = Vector3.new(offset.X, 0, offset.Z)
	if planarOffset.Magnitude <= 0.05 then
		return nil
	end

	local lungeStopDistance = step.LungeStopDistance or math.max(entity:GetStopDistance(), 2.25)
	local lungeDistance = math.min(
		planarOffset.Magnitude,
		math.max(0, planarOffset.Magnitude - lungeStopDistance),
		step.LungeDistance or planarOffset.Magnitude
	)
	if lungeDistance <= 0 then
		return nil
	end

	local newPosition = origin + (planarOffset.Unit * lungeDistance)
	newPosition = Vector3.new(newPosition.X, entity.RootPart.Position.Y, newPosition.Z)
	local lookTarget = Vector3.new(targetPosition.X, entity.RootPart.Position.Y, targetPosition.Z)
	return CFrame.lookAt(newPosition, lookTarget)
end

function EntityService:_performStruggleLunge(entity, targetPlayer, targetCharacter, struggleParams)
	if not entity or not entity.RootPart or not targetCharacter or not targetCharacter.RootPart then
		return
	end

	local startCFrame = entity.RootPart.CFrame
	local startPosition = startCFrame.Position
	local targetGroundPosition = self:_getStruggleLungeGroundPosition(startPosition, targetCharacter, struggleParams)
	if not targetGroundPosition then
		return
	end

	local dashOffset = targetGroundPosition - startPosition
	local dashDistance = dashOffset.Magnitude
	if dashDistance <= 0.05 then
		return
	end

	local useConstantSpeed = (struggleParams.LungeSpeed or 0) > 0
	local lungeDuration
	if useConstantSpeed then
		lungeDuration = dashDistance / struggleParams.LungeSpeed
		lungeDuration = math.max(struggleParams.MinLungeDuration or 0.1, lungeDuration)
		if struggleParams.MaxLungeDuration then
			lungeDuration = math.min(struggleParams.MaxLungeDuration, lungeDuration)
		end
	else
		lungeDuration = math.max(0.05, struggleParams.LungeDuration or 0.12)
	end

	entity.ActionSequenceId = (entity.ActionSequenceId or 0) + 1
	local actionSequenceId = entity.ActionSequenceId
	entity:LockSpecialMovement(lungeDuration + math.max(0, struggleParams.ImpactDelay or 0.05) + 0.05)

	task.spawn(function()
		local leapHeight = struggleParams.LeapHeight or 0
		local leapSharpness = struggleParams.LeapSharpness or 1.6
		local resolveStep = table.clone(struggleParams)
		resolveStep.StartRange = 0

		local dashDirection = dashOffset.Unit
		local dashLookTarget = startPosition + Vector3.new(dashDirection.X, 0, dashDirection.Z)
		local previousPosition = startPosition
		local contactRadius = math.max(0.5, struggleParams.GrabRange or 3.2)
		local minTravelBeforeHit = math.max(0, struggleParams.MinTravelBeforeHit or 0)
		local minTravelFractionBeforeHit = math.clamp(struggleParams.MinTravelFractionBeforeHit or 0, 0, 0.95)
		local requiredTravelBeforeHit = math.max(
			math.min(minTravelBeforeHit, dashDistance * 0.9),
			dashDistance * minTravelFractionBeforeHit
		)
		self:_showEntityAbilityVisual("BlindHungerLunge", {
			EntityModel = entity.Model,
			EntityId = entity.Id,
			StartPosition = startPosition,
			EndPosition = targetGroundPosition,
			Duration = lungeDuration,
			LeapHeight = leapHeight,
			ContactRadius = contactRadius,
		})
		self:_spawnStruggleLungeDebugVisual(startPosition, targetGroundPosition, contactRadius)

		local elapsed = 0
		while elapsed < lungeDuration do
			if not entity or not entity.RootPart or not entity.IsActive or entity.Health <= 0 then
				return
			end

			if (entity.ActionSequenceId or 0) ~= actionSequenceId then
				return
			end

			local liveCharacter = self.CharacterService:GetCharacterByPlayer(targetPlayer)
			if not liveCharacter or not liveCharacter.RootPart or not liveCharacter:IsAlive() then
				return
			end

			local alpha = math.clamp(elapsed / lungeDuration, 0, 1)
			local travelAlpha = useConstantSpeed and alpha or (1 - math.pow(1 - alpha, math.max(1, leapSharpness)))
			local blendedPosition = startPosition + (dashDirection * dashDistance * travelAlpha)
			local traveledDistance = (Vector3.new(blendedPosition.X, 0, blendedPosition.Z) - Vector3.new(startPosition.X, 0, startPosition.Z)).Magnitude

			local closestPoint = self:_getClosestPointOnSegment(previousPosition, blendedPosition, liveCharacter.RootPart.Position)
			local hitOffset = liveCharacter.RootPart.Position - closestPoint
			local planarHitOffset = Vector3.new(hitOffset.X, 0, hitOffset.Z)
			if traveledDistance >= requiredTravelBeforeHit and planarHitOffset.Magnitude <= contactRadius and self:_canResolveStruggleTarget(entity, liveCharacter, resolveStep) then
				local impactPosition = Vector3.new(closestPoint.X, entity.RootPart.Position.Y, closestPoint.Z)
				entity.RootPart.CFrame = CFrame.lookAt(impactPosition, impactPosition + Vector3.new(dashDirection.X, 0, dashDirection.Z))
				if self:_commitStruggleImpact(entity, targetPlayer, struggleParams, resolveStep, actionSequenceId) then
					return
				end
			end

			previousPosition = blendedPosition
			elapsed += RunService.Heartbeat:Wait()
		end

		if (entity.ActionSequenceId or 0) ~= actionSequenceId then
			return
		end

		if entity and entity.RootPart then
			local endPosition = Vector3.new(targetGroundPosition.X, entity.RootPart.Position.Y, targetGroundPosition.Z)
			entity.RootPart.CFrame = CFrame.lookAt(endPosition, endPosition + Vector3.new(dashDirection.X, 0, dashDirection.Z))
		end
	end)
end

function EntityService:_showEntityAbilityVisual(visualType, payload)
	if not self.EntityAbilityVisualRemote then
		return
	end

	local finalPayload = {
		Type = visualType,
	}

	for key, value in pairs(payload or {}) do
		finalPayload[key] = value
	end

	self.EntityAbilityVisualRemote:FireAllClients(finalPayload)
end

function EntityService:_createTemporaryAbilityPart(properties, duration)
	local part = Instance.new("Part")
	part.Name = properties.Name or "EntityAbilityVisual"
	part.Anchored = true
	part.CanCollide = false
	part.CanQuery = false
	part.CanTouch = false
	part.CastShadow = false
	part.Material = properties.Material or Enum.Material.Neon
	part.Color = properties.Color or Color3.fromRGB(255, 206, 143)
	part.Transparency = properties.Transparency or 0.15
	part.Size = properties.Size or Vector3.new(1, 1, 1)
	part.Shape = properties.Shape or Enum.PartType.Ball
	part.CFrame = properties.CFrame or CFrame.new()
	part.Parent = Workspace

	Debris:AddItem(part, duration or 0.25)
	return part
end

function EntityService:_spawnEntityPulseRing(position, color, startRadius, endRadius, duration, yOffset, thickness)
	local ring = self:_createTemporaryAbilityPart({
		Name = "EntityAbilityRing",
		Shape = Enum.PartType.Cylinder,
		Size = Vector3.new(thickness or 0.12, startRadius * 2, startRadius * 2),
		CFrame = CFrame.new(position + Vector3.new(0, yOffset or 0, 0)) * CFrame.Angles(0, 0, math.rad(90)),
		Color = color,
		Material = Enum.Material.ForceField,
		Transparency = 0.15,
	}, duration)

	local startedAt = os.clock()
	task.spawn(function()
		while ring and ring.Parent do
			local alpha = math.clamp((os.clock() - startedAt) / duration, 0, 1)
			local radius = startRadius + ((endRadius - startRadius) * alpha)
			ring.Size = Vector3.new(thickness or 0.12, radius * 2, radius * 2)
			ring.Transparency = 0.15 + (alpha * 0.8)
			task.wait()
		end
	end)
end

function EntityService:_spawnEntityBurst(position, color, startSize, endSize, duration)
	local burst = self:_createTemporaryAbilityPart({
		Name = "EntityAbilityBurst",
		Shape = Enum.PartType.Ball,
		Size = Vector3.new(startSize, startSize, startSize),
		CFrame = CFrame.new(position),
		Color = color,
		Transparency = 0.08,
	}, duration)

	local light = Instance.new("PointLight")
	light.Color = color
	light.Range = endSize * 2
	light.Brightness = 2.5
	light.Parent = burst

	local startedAt = os.clock()
	task.spawn(function()
		while burst and burst.Parent do
			local alpha = math.clamp((os.clock() - startedAt) / duration, 0, 1)
			local size = startSize + ((endSize - startSize) * alpha)
			burst.Size = Vector3.new(size, size, size)
			burst.Transparency = 0.08 + (alpha * 0.86)
			light.Brightness = 2.5 * (1 - alpha)
			task.wait()
		end
	end)
end

function EntityService:_spawnEntityBeamLine(startPosition, endPosition, color, width, duration)
	local offset = endPosition - startPosition
	local distance = offset.Magnitude
	if distance <= 0.05 then
		return
	end

	self:_createTemporaryAbilityPart({
		Name = "EntityAbilityBeam",
		Size = Vector3.new(width or 0.2, width or 0.2, distance),
		CFrame = CFrame.lookAt(startPosition, endPosition) * CFrame.new(0, 0, -(distance * 0.5)),
		Color = color,
		Transparency = 0.12,
	}, duration)
end

function EntityService:_playEntityAbilityCastVisual(entity, abilityId, targetPlayer)
	if not entity or not entity.RootPart or entity.Id ~= "SearchingForWisdom" then
		return
	end

	local rootPosition = entity.RootPart.Position
	local targetCharacter = targetPlayer and self.CharacterService:GetCharacterByPlayer(targetPlayer)
	local targetPosition = targetCharacter and targetCharacter.RootPart and targetCharacter.RootPart.Position or nil

	if abilityId == "RakingWisdom" then
		self:_spawnEntityBurst(rootPosition + Vector3.new(0, 2.4, 0), Color3.fromRGB(214, 132, 94), 0.8, 3.2, 0.18)
		self:_spawnEntityPulseRing(rootPosition, Color3.fromRGB(178, 96, 76), 2.5, 12, 0.35, -2.8, 0.1)
		if targetPosition then
			local planarTarget = Vector3.new(targetPosition.X, rootPosition.Y, targetPosition.Z)
			self:_spawnEntityBeamLine(rootPosition + Vector3.new(0, 0.8, 0), planarTarget, Color3.fromRGB(191, 102, 76), 0.16, 0.18)
		end
	elseif abilityId == "SeekingWisdom" then
		self:_spawnEntityBurst(rootPosition + Vector3.new(0, 3.3, 0), Color3.fromRGB(236, 220, 162), 0.6, 2.4, 0.22)
		self:_spawnEntityPulseRing(rootPosition, Color3.fromRGB(184, 154, 104), 1.5, 7.5, 0.28, -2.8, 0.08)
		if targetPosition then
			self:_spawnEntityBeamLine(rootPosition + Vector3.new(0, 3.2, 0), targetPosition + Vector3.new(0, 1.8, 0), Color3.fromRGB(222, 206, 142), 0.12, 0.22)
		end
	elseif abilityId == "Harvest" then
		self:_spawnEntityBurst(rootPosition + Vector3.new(0, 1.6, 0), Color3.fromRGB(205, 88, 88), 0.9, 3.8, 0.2)
		self:_spawnEntityPulseRing(rootPosition, Color3.fromRGB(166, 64, 64), 2.2, 9.5, 0.3, -2.8, 0.1)
		if targetPosition then
			local planarTarget = Vector3.new(targetPosition.X, rootPosition.Y, targetPosition.Z)
			self:_spawnEntityBeamLine(rootPosition + Vector3.new(0, 1.1, 0), planarTarget, Color3.fromRGB(202, 96, 96), 0.18, 0.16)
		end
	end
end

function EntityService:_playEntityAbilityResolveVisual(entity, abilityId, targetPlayer)
	if not entity or entity.Id ~= "SearchingForWisdom" then
		return
	end

	local targetCharacter = targetPlayer and self.CharacterService:GetCharacterByPlayer(targetPlayer)
	local targetPosition = targetCharacter and targetCharacter.RootPart and targetCharacter.RootPart.Position or nil
	if not targetPosition then
		return
	end

	if abilityId == "RakingWisdom" then
		self:_spawnEntityBurst(targetPosition + Vector3.new(0, 2.1, 0), Color3.fromRGB(198, 88, 72), 0.7, 2.6, 0.18)
		self:_spawnEntityPulseRing(targetPosition, Color3.fromRGB(188, 92, 74), 1.5, 6, 0.24, -2.8, 0.08)
	elseif abilityId == "Harvest" then
		self:_spawnEntityBurst(targetPosition + Vector3.new(0, 1.6, 0), Color3.fromRGB(224, 96, 96), 1.1, 4.4, 0.22)
		self:_spawnEntityPulseRing(targetPosition, Color3.fromRGB(176, 62, 62), 2.2, 7.5, 0.28, -2.8, 0.12)
	end
end

function EntityService:_playStruggleLatchVisual(entity, targetCharacter)
	if not entity or entity.Id ~= "SearchingForWisdom" or not entity.RootPart or not targetCharacter or not targetCharacter.RootPart then
		return
	end

	local origin = entity.RootPart.Position + Vector3.new(0, 3.1, 0)
	local targetPosition = targetCharacter.RootPart.Position + Vector3.new(0, 1.8, 0)
	self:_spawnEntityBeamLine(origin, targetPosition, Color3.fromRGB(236, 218, 164), 0.16, 0.32)
	self:_spawnEntityBurst(targetPosition, Color3.fromRGB(240, 226, 178), 0.55, 2.1, 0.18)
	self:_spawnEntityPulseRing(targetCharacter.RootPart.Position, Color3.fromRGB(212, 190, 132), 1.2, 4.4, 0.22, -1.8, 0.08)
end

function EntityService:_spawnStruggleLungeDebugVisual(startPosition, targetPosition, contactRadius)
	if not DebugFlags.Enabled or not DebugFlags.Entity or Workspace:GetAttribute("DebugUiEnabled") == false then
		return
	end

	local visualsFolder = Workspace:FindFirstChild("EntityDebugVisuals")
	if not visualsFolder then
		visualsFolder = Instance.new("Folder")
		visualsFolder.Name = "EntityDebugVisuals"
		visualsFolder.Parent = Workspace
	end

	local dashOffset = targetPosition - startPosition
	local dashDistance = dashOffset.Magnitude
	if dashDistance <= 0.05 then
		return
	end

	local linePart = Instance.new("Part")
	linePart.Name = "BlindHungerPath"
	linePart.Anchored = true
	linePart.CanCollide = false
	linePart.CanQuery = false
	linePart.CanTouch = false
	linePart.Material = Enum.Material.Neon
	linePart.Color = Color3.fromRGB(255, 168, 76)
	linePart.Transparency = 0.05
	linePart.Size = Vector3.new(0.7, 0.7, dashDistance)
	linePart.CFrame = CFrame.lookAt(startPosition, targetPosition) * CFrame.new(0, 0, -(dashDistance * 0.5))
	linePart.Parent = visualsFolder

	local radiusPart = Instance.new("Part")
	radiusPart.Name = "BlindHungerRadius"
	radiusPart.Anchored = true
	radiusPart.CanCollide = false
	radiusPart.CanQuery = false
	radiusPart.CanTouch = false
	radiusPart.Shape = Enum.PartType.Ball
	radiusPart.Material = Enum.Material.Neon
	radiusPart.Color = Color3.fromRGB(255, 225, 125)
	radiusPart.Transparency = 0.45
	radiusPart.Size = Vector3.new(contactRadius * 2, contactRadius * 2, contactRadius * 2)
	radiusPart.Position = targetPosition
	radiusPart.Parent = visualsFolder

	task.delay(LUNGE_DEBUG_VISUAL_DURATION, function()
		if linePart.Parent then
			linePart:Destroy()
		end
		if radiusPart.Parent then
			radiusPart:Destroy()
		end
	end)
end

function EntityService:_commitStruggleImpact(entity, targetPlayer, struggleParams, resolveStep, actionSequenceId)
	local liveCharacter = self.CharacterService:GetCharacterByPlayer(targetPlayer)
	if not liveCharacter or not self:_canResolveStruggleTarget(entity, liveCharacter, resolveStep) then
		return false
	end

	local grabCFrame = self:_getStruggleGrabCFrame(entity, liveCharacter, struggleParams)
	if grabCFrame and entity.RootPart then
		local currentPosition = entity.RootPart.Position
		local targetPosition = grabCFrame.Position
		local planarOffset = Vector3.new(targetPosition.X - currentPosition.X, 0, targetPosition.Z - currentPosition.Z)
		local maxGrabSnapDistance = math.max(0, struggleParams.MaxGrabSnapDistance or 0)

		if maxGrabSnapDistance > 0 and planarOffset.Magnitude > maxGrabSnapDistance then
			local limitedPosition = currentPosition + (planarOffset.Unit * maxGrabSnapDistance)
			local lookTarget = Vector3.new(liveCharacter.RootPart.Position.X, limitedPosition.Y, liveCharacter.RootPart.Position.Z)
			entity.RootPart.CFrame = CFrame.lookAt(limitedPosition, lookTarget)
		else
			entity.RootPart.CFrame = grabCFrame
		end
	end

	local impactDelay = math.max(0, struggleParams.ImpactDelay or 0.05)
	if impactDelay > 0 then
		task.wait(impactDelay)
	end

	if actionSequenceId ~= nil and (entity.ActionSequenceId or 0) ~= actionSequenceId then
		return false
	end

	local finalCharacter = self.CharacterService:GetCharacterByPlayer(targetPlayer)
	if not finalCharacter or not self:_canResolveStruggleTarget(entity, finalCharacter, resolveStep) then
		return false
	end

	return self.StruggleService:BeginStruggle(entity, targetPlayer, struggleParams) == true
end

function EntityService:_getStruggleLungeGroundPosition(startPosition, targetCharacter, step)
	if not startPosition or not targetCharacter or not targetCharacter.RootPart then
		return nil
	end

	local targetPosition = targetCharacter.RootPart.Position
	local predictionSeconds = step.TargetPredictionSeconds or 0.18
	local predictedTargetPosition = targetPosition + (targetCharacter.RootPart.AssemblyLinearVelocity * predictionSeconds)
	local planarOffset = Vector3.new(predictedTargetPosition.X - startPosition.X, 0, predictedTargetPosition.Z - startPosition.Z)
	if planarOffset.Magnitude <= 0.05 then
		return nil
	end

	local lungeStopDistance = step.LungeStopDistance or 0.6
	local overshootDistance = math.max(0, step.OvershootDistance or 0)
	local lungeDistance = math.min(
		planarOffset.Magnitude + overshootDistance,
		math.max(0, (planarOffset.Magnitude - lungeStopDistance) + overshootDistance),
		step.LungeDistance or planarOffset.Magnitude
	)
	if lungeDistance <= 0 then
		return nil
	end

	return startPosition + Vector3.new(planarOffset.Unit.X * lungeDistance, 0, planarOffset.Unit.Z * lungeDistance)
end

function EntityService:_getStruggleGrabCFrame(entity, targetCharacter, step)
	if not entity or not entity.RootPart or not targetCharacter or not targetCharacter.RootPart then
		return nil
	end

	local targetPosition = targetCharacter.RootPart.Position
	local entityPosition = entity.RootPart.Position
	local planarOffset = Vector3.new(targetPosition.X - entityPosition.X, 0, targetPosition.Z - entityPosition.Z)
	if planarOffset.Magnitude <= 0.05 then
		return nil
	end

	local grabStopDistance = step.GrabStopDistance or 0.55
	local targetFloorPosition = Vector3.new(targetPosition.X, entity.RootPart.Position.Y, targetPosition.Z)
	local newPosition = targetFloorPosition - (planarOffset.Unit * grabStopDistance)
	return CFrame.lookAt(newPosition, targetFloorPosition)
end

function EntityService:_repeatDamageTargetsFromEffect(entity, step, context)
	local targets = self:_resolveEffectTargets(entity, step, context)
	local hits = math.max(1, step.Hits or 1)
	local interval = math.max(0, step.Interval or 0)
	local actionSequenceId = entity.ActionSequenceId or 0

	for _, player in ipairs(targets) do
		if interval <= 0 then
			for _ = 1, hits do
				if (entity.ActionSequenceId or 0) ~= actionSequenceId then
					return
				end
				self:_damageTargetFromEffect(entity, player, step)
			end
		else
			task.spawn(function()
				for hitIndex = 1, hits do
					if not entity or not entity.IsActive or entity.Health <= 0 then
						return
					end

					if (entity.ActionSequenceId or 0) ~= actionSequenceId then
						return
					end

					local statusService = self.StatusEffectService
					if statusService and not statusService:CanUseAbilities(entity) then
						return
					end

					self:_damageTargetFromEffect(entity, player, step)

					if hitIndex < hits then
						task.wait(interval)
					end
				end
			end)
		end
	end
end

function EntityService:InterruptEntityAbilities(entity, reason)
	if not entity then
		return false
	end

	entity.ActionSequenceId = (entity.ActionSequenceId or 0) + 1
	entity:CancelCast()

	if self.StruggleService then
		self.StruggleService:InterruptStrugglesForEntity(entity, reason or "Interrupted")
	end

	if self.BreathHoldService then
		self.BreathHoldService:CancelChallengesForEntity(entity, reason or "Interrupted")
	end

	self:_syncDebugAttributes(entity)
	DebugLog:Log("Entity", string.format("[EntityService] %s interrupted (%s)", entity.DisplayName, tostring(reason or "Unknown")))
	return true
end

function EntityService:_spawnEntitiesFromEffect(entity, step, context)
	local entityId = step.EntityId
	if not entityId then
		return
	end

	local count = math.max(1, step.Count or 1)
	local spawnCFrames = self:_buildSpawnCFrames(entity, step, context, count)
	for _, spawnCFrame in ipairs(spawnCFrames) do
		self:SpawnEntity(entityId, {
			CFrame = spawnCFrame,
			OwnerEntity = entity,
			Lifetime = step.Lifetime,
			IsSummon = step.IsSummon ~= false,
			Activate = step.Activate ~= false,
		})
	end
end

function EntityService:_buildSpawnCFrames(entity, step, context, count)
	local spawnCFrames = {}
	local origin = self:_resolveSpawnOrigin(entity, step, context)
	if not origin then
		return spawnCFrames
	end

	local radius = step.Radius or 0
	local heightOffset = step.HeightOffset or 0
	local random = entity.Random
	for index = 1, count do
		local offset = Vector3.zero
		if radius > 0 then
			local angle = random:NextNumber(0, math.pi * 2)
			local distance = count == 1 and radius or random:NextNumber(math.max(0, radius * 0.35), radius)
			offset = Vector3.new(math.cos(angle) * distance, 0, math.sin(angle) * distance)
		end

		local position = origin.Position + offset + Vector3.new(0, heightOffset, 0)
		local lookAt = position + origin.LookVector
		if step.FaceOrigin == true then
			lookAt = origin.Position
		end

		spawnCFrames[index] = CFrame.new(position, lookAt)
	end

	return spawnCFrames
end

function EntityService:_resolveSpawnOrigin(entity, step, context)
	local mode = step.SpawnAt or "Self"
	if mode == "Self" then
		return entity.RootPart and entity.RootPart.CFrame or nil
	end

	if mode == "Target" or mode == "CurrentTarget" then
		local targetPlayer = context and context.TargetPlayer
		local targetCharacter = targetPlayer and self.CharacterService:GetCharacterByPlayer(targetPlayer)
		return targetCharacter and targetCharacter.RootPart and targetCharacter.RootPart.CFrame or nil
	end

	if mode == "Position" and step.Position then
		return CFrame.new(step.Position)
	end

	return entity.RootPart and entity.RootPart.CFrame or nil
end

function EntityService:SpawnEntity(entityId, params)
	params = params or {}

	local definition = EntityDefinitions[entityId]
	if not definition then
		warn(string.format("[EntityService] Missing entity definition for summon '%s'", tostring(entityId)))
		return nil
	end

	local templateName = definition.TemplateName or definition.Id or entityId
	local sourceDefinition = EntityDefinitions[templateName]
	if sourceDefinition then
		templateName = sourceDefinition.TemplateName or sourceDefinition.Id or templateName
	end

	local template = self.EntityTemplates[templateName]
	if not template then
		local liveModel = self.EntitiesFolder:FindFirstChild(templateName)
			or self.EntitiesFolder:FindFirstChild(entityId)
			or (sourceDefinition and sourceDefinition.Id and self.EntitiesFolder:FindFirstChild(sourceDefinition.Id))
		if liveModel and liveModel:IsA("Model") then
			self:_cacheEntityTemplate(liveModel, sourceDefinition or definition)
			template = self.EntityTemplates[templateName]
		end
	end

	if not template then
		local sourceModel = self.TemplateSourceFolder:FindFirstChild(templateName)
			or self.TemplateSourceFolder:FindFirstChild(entityId)
			or (sourceDefinition and sourceDefinition.Id and self.TemplateSourceFolder:FindFirstChild(sourceDefinition.Id))
		if sourceModel and sourceModel:IsA("Model") and sourceModel.PrimaryPart then
			self:_cacheEntityTemplate(sourceModel, sourceDefinition or definition)
			template = self.EntityTemplates[templateName]
		end
	end

	if not template then
		for _, existingEntity in ipairs(self.Entities) do
			local matchesTemplate = existingEntity.TemplateName == templateName
				or existingEntity.Id == templateName
				or (existingEntity.Definition and existingEntity.Definition.Id == templateName)
				or (sourceDefinition and existingEntity.Definition == sourceDefinition)
				or (existingEntity.Model and existingEntity.Model.Name == templateName)

			if matchesTemplate and existingEntity.Model then
				self:_cacheEntityTemplate(existingEntity.Model, sourceDefinition or existingEntity.Definition)
				template = self.EntityTemplates[templateName]
				if template then
					break
				end
			end
		end
	end

	if not template then
		warn(string.format("[EntityService] Missing entity template for summon '%s'", tostring(entityId)))
		return nil
	end

	local model = template:Clone()
	if not model then
		warn(string.format("[EntityService] Failed to clone entity template '%s' for summon '%s'", tostring(templateName), tostring(entityId)))
		return nil
	end

	model.Name = entityId
	self:_applyRuntimeEntityAppearance(model, definition, params)
	model.Parent = self.EntitiesFolder

	local targetCFrame = params.CFrame
	if targetCFrame then
		model:PivotTo(targetCFrame)
	end

	local runtimeData = {
		EntityId = entityId,
		TemplateName = templateName,
		IsRuntimeEntity = true,
		IsSummon = params.IsSummon ~= false,
		OwnerEntity = params.OwnerEntity,
		ExpiresAt = params.Lifetime and (os.clock() + params.Lifetime) or nil,
	}

	local entity = self:_registerEntityModel(model, runtimeData)
	if params.Activate ~= false then
		entity:SetActive(true)
	end

	self:_registerRoundHooksForEntity(entity)

	DebugLog:Log("Entity", string.format("[EntityService] Spawned runtime entity: %s using template %s", entity.DisplayName, tostring(templateName)))

	return entity
end

function EntityService:SetRoundLineup(entityIds)
	self.SelectedRoundEntityIds = {}

	for _, entityId in ipairs(entityIds or {}) do
		self.SelectedRoundEntityIds[entityId] = true
	end

	self:_ensureRoundLineupEntities(entityIds or {})

	DebugLog:Log("Entity", string.format(
		"[EntityService] Round lineup set: %s",
		#(entityIds or {}) > 0 and table.concat(entityIds, ", ") or "None"
	))
end

function EntityService:_ensureRoundLineupEntities(entityIds)
	for _, entityId in ipairs(entityIds or {}) do
		if not self:_findRoundEntityById(entityId) then
			local spawnPart = self.SpawnService and self.SpawnService:GetRandomEntitySpawn()
			local targetCFrame = spawnPart and (spawnPart.CFrame + Vector3.new(0, 3, 0)) or nil
			self:SpawnEntity(entityId, {
				CFrame = targetCFrame,
				Activate = false,
				IsSummon = false,
			})
		end
	end
end

function EntityService:_findRoundEntityById(entityId)
	for _, entity in ipairs(self.Entities) do
		if entity.Id == entityId and entity.OwnerEntity == nil then
			return entity
		end
	end

	return nil
end

function EntityService:_applyRuntimeEntityAppearance(model, definition, params)
	local appearance = (params and params.RuntimeAppearance) or (definition and definition.RuntimeAppearance)
	if not appearance then
		return
	end

	for _, descendant in ipairs(model:GetDescendants()) do
		if descendant:IsA("BasePart") then
			if appearance.Color then
				descendant.Color = appearance.Color
			end

			if appearance.Material then
				descendant.Material = appearance.Material
			end

			if appearance.Transparency ~= nil then
				descendant.Transparency = appearance.Transparency
			end
		elseif descendant:IsA("ParticleEmitter") and appearance.DisableParticles == true then
			descendant.Enabled = false
		end
	end
end

function EntityService:_despawnEntity(entity, reason)
	self:_clearRoundHooksForEntity(entity)

	local statusEffectService = self.StatusEffectService
	if statusEffectService then
		statusEffectService:ClearStatuses(entity)
	end

	for index = #self.Entities, 1, -1 do
		if self.Entities[index] == entity then
			table.remove(self.Entities, index)
			break
		end
	end

	if entity.Model then
		entity.Model:Destroy()
	end

	DebugLog:Log("Entity", string.format("[EntityService] Despawned %s (%s)", entity.DisplayName, tostring(reason or "Unknown")))
	entity:Destroy()
end

function EntityService:_markLastAbility(entity, abilityId)
	if not entity or not entity.Model then
		return
	end

	entity.Model:SetAttribute("DebugLastAbility", tostring(abilityId or "None"))
end

function EntityService:_markRecentHit(entity, amount, sourceLabel)
	if not entity or not entity.Model then
		return
	end

	entity.Model:SetAttribute("DebugRecentHitDamage", math.floor((amount or 0) + 0.5))
	entity.Model:SetAttribute("DebugRecentHitSource", tostring(sourceLabel or "Unknown"))
	entity.Model:SetAttribute("DebugRecentHitExpiresAt", Workspace:GetServerTimeNow() + RECENT_HIT_DEBUG_DURATION)
end

function EntityService:_formatDebugStimulusText(stimulus)
	if not stimulus then
		return "None"
	end

	local sourcePlayer = stimulus.SourcePlayer and stimulus.SourcePlayer.Name or nil
	local sourceLabel = sourcePlayer and ("@" .. sourcePlayer) or ""
	return string.format(
		"%s%s %.2f",
		tostring(stimulus.Type or "Unknown"),
		sourceLabel and sourceLabel ~= "" and (" " .. sourceLabel) or "",
		tonumber(stimulus.Score or stimulus.Confidence or 0) or 0
	)
end

function EntityService:_syncDebugAttributes(entity)
	if not entity or not entity.Model then
		return
	end

	local topStimuli = self:_getTopStimuliForDebug(entity, 3)
	local topStimulusLabels = {}
	for _, stimulus in ipairs(topStimuli) do
		table.insert(topStimulusLabels, self:_formatDebugStimulusText(stimulus))
	end

	local intentName = entity:GetIntentName() or "None"
	local intentStimulus = entity:GetIntentSourceStimulus()
	local intentMetadata = entity:GetIntentMetadata() or {}
	local searchCenter = entity:GetCurrentSearchCenter()
	local searchCenterText = searchCenter and string.format("%d,%d", math.floor(searchCenter.X + 0.5), math.floor(searchCenter.Z + 0.5)) or ""
	local targetPlayer = entity:GetTarget()
	local targetMemoryAge = targetPlayer and entity:GetTargetMemory(targetPlayer) and entity:GetTimeSinceTargetWasVisible(targetPlayer) or math.huge

	entity.Model:SetAttribute("EntityId", entity.Id)
	entity.Model:SetAttribute("EntityDisplayName", entity.DisplayName)
	entity.Model:SetAttribute("EntityState", entity:GetState())
	entity.Model:SetAttribute("EntityTarget", entity:GetTarget() and entity:GetTarget().Name or "")
	entity.Model:SetAttribute("EntityTerrorRadius", entity.TerrorRadius or 0)
	entity.Model:SetAttribute("DebugEntityName", entity.DisplayName)
	entity.Model:SetAttribute("DebugState", entity:GetState())
	entity.Model:SetAttribute("DebugIntent", intentName)
	entity.Model:SetAttribute("DebugIntentConfidence", string.format("%.2f", entity:GetIntentConfidence() or 0))
	entity.Model:SetAttribute("DebugIntentReason", tostring(intentMetadata.Reason or (intentStimulus and intentStimulus.Type) or "None"))
	entity.Model:SetAttribute("DebugTopStimuli", table.concat(topStimulusLabels, " | "))
	entity.Model:SetAttribute("DebugSearchCenter", searchCenterText)
	entity.Model:SetAttribute("DebugMemoryAge", targetMemoryAge < math.huge and string.format("%.1fs", targetMemoryAge) or "")
	entity.Model:SetAttribute("DebugHealth", math.floor((entity.Health or 0) + 0.5))
	entity.Model:SetAttribute("DebugMaxHealth", math.floor((entity.MaxHealth or 0) + 0.5))
	entity.Model:SetAttribute("DebugTarget", entity:GetTarget() and entity:GetTarget().Name or "")
	entity.Model:SetAttribute("DebugAbsorbedCount", entity.GetAbsorbedAbilityCount and entity:GetAbsorbedAbilityCount() or 0)
end

function EntityService:DamageEntity(entity, amount, options)
	options = options or {}
	if not entity or not amount or amount <= 0 or entity.Health <= 0 then
		return false
	end

	local finalAmount = amount
	local statusService = self.StatusEffectService
	if statusService and not options.IsStatusEffect then
		finalAmount *= (1 + statusService:GetModifier(entity, "Fragility"))
		finalAmount *= math.max(0, 1 - statusService:GetModifier(entity, "Resistance"))
	end

	finalAmount *= math.max(0, 1 - (entity:GetModifierValue("Resistance") or 0))
	finalAmount = math.max(0, finalAmount)
	if finalAmount <= 0 then
		return false
	end

	entity.Health = math.clamp(entity.Health - finalAmount, 0, entity.MaxHealth)
	self:_markRecentHit(entity, finalAmount, options.SourcePlayer and options.SourcePlayer.Name or options.WeaponId or "Unknown")
	local relinquished = entity:RegisterIncomingDamage(finalAmount)
	for _, release in ipairs(relinquished) do
		DebugLog:Log("Entity", string.format(
			"[EntityService] %s relinquished an absorbed ability back to %s (%d remaining on target)",
			entity.DisplayName,
			release.Player and release.Player.Name or "Unknown",
			release.RemainingOnTarget or 0
		))
	end

	if entity.Health <= 0 then
		entity.IsActive = false
		DebugLog:Log("Entity", string.format("[EntityService] %s reached 0 health", entity.DisplayName))
	end

	self:_syncDebugAttributes(entity)

	return true
end

function EntityService:ForceChaseTarget(entity, player, position)
	entity:SetTarget(player, position, true)
	entity:RememberTarget(player, position, true)
	entity:EnterState(ENTITY_STATE.Chase)
end

function EntityService:_resolveEffectTargets(entity, step, context)
	local targetMode = step.Targets or "CurrentTarget"
	if targetMode == "CurrentTarget" then
		return context.TargetPlayer and { context.TargetPlayer } or {}
	elseif targetMode == "Self" then
		return { entity }
	elseif targetMode == "VisibleTargets" then
		return self:_collectVisiblePlayers(entity)
	elseif targetMode == "AllCandidates" then
		return self:_collectCandidatePlayers(entity)
	elseif targetMode == "NearestVisible" then
		local nearest = self:_getNearestVisiblePlayer(entity)
		return nearest and { nearest } or {}
	elseif targetMode == "PlayersInRadius" then
		return self:_collectPlayersInRadius(entity, step.Radius or 0)
	end

	return {}
end

function EntityService:_damageTargetFromEffect(entity, player, step)
	local character = player and self.CharacterService:GetCharacterByPlayer(player)
	if not character or not character.RootPart then
		return
	end

	local range = step.Range or entity.AttackRange
	if range and not entity:IsInRange(character.RootPart.Position, range) then
		return
	end

	local amount = entity:GetScaledDamage(step.Amount or entity.Damage)
	local didDamage = character:ApplyDamage(amount)
	if not didDamage then
		return
	end

	if step.OnHitHasteMultiplier then
		local statusService = self.StatusEffectService
		if statusService then
			statusService:ApplyStatus(player, StatusEffectId.Haste, {
				Duration = step.OnHitHasteDuration or 1.5,
				Magnitude = math.max(0, (step.OnHitHasteMultiplier or 1) - 1),
				Source = step.OnHitHasteKey or "OnHitHaste",
			})
		end
	end

	self:_handleTargetDowned(entity, player, character)
end

function EntityService:_handleTargetDowned(entity, targetPlayer, targetCharacter)
	if not entity or not targetPlayer or not targetCharacter or targetCharacter:IsAlive() then
		return false
	end

	if entity.DownedPlayers[targetPlayer] then
		return false
	end

	entity.DownedPlayers[targetPlayer] = true
	entity:TriggerPassives("OnDown", {
		Player = targetPlayer,
		Character = targetCharacter,
	})

	DebugLog:Log("Entity", string.format("[EntityService] %s downed %s", entity.DisplayName, targetPlayer.Name))
	return true
end

function EntityService:_collectVisiblePlayers(entity)
	local visiblePlayers = {}
	local roundManager = self.RoundManager
	local characterService = self.CharacterService
	local entityPosition = entity:GetPosition()
	if not roundManager or not characterService or not entityPosition then
		return visiblePlayers
	end

	for _, player in ipairs(roundManager:GetActivePlayers()) do
		local roundState = roundManager:GetRoundState(player)
		if roundState and roundState.IsAlive then
			local character = characterService:GetCharacterByPlayer(player)
			if character and character.RootPart then
				local distance = (character.RootPart.Position - entityPosition).Magnitude
				if distance <= entity:GetDetectionRange() and (entity.IgnoreLineOfSightForDetection or self:_hasLineOfSight(entity, character)) then
					table.insert(visiblePlayers, player)
				end
			end
		end
	end

	return visiblePlayers
end

function EntityService:_collectCandidatePlayers(entity)
	local players = {}
	for _, candidate in ipairs(self:_collectTargetCandidates(entity)) do
		table.insert(players, candidate.Player)
	end
	return players
end

function EntityService:_getNearestVisiblePlayer(entity)
	local bestPlayer = nil
	local bestDistance = math.huge
	local entityPosition = entity:GetPosition()

	for _, player in ipairs(self:_collectVisiblePlayers(entity)) do
		local character = self.CharacterService:GetCharacterByPlayer(player)
		if character and character.RootPart then
			local distance = (character.RootPart.Position - entityPosition).Magnitude
			if distance < bestDistance then
				bestDistance = distance
				bestPlayer = player
			end
		end
	end

	return bestPlayer
end

function EntityService:_collectPlayersInRadius(entity, radius)
	local players = {}
	local roundManager = self.RoundManager
	local characterService = self.CharacterService
	local entityPosition = entity:GetPosition()
	if not roundManager or not characterService or not entityPosition then
		return players
	end

	for _, player in ipairs(roundManager:GetActivePlayers()) do
		local roundState = roundManager:GetRoundState(player)
		if roundState and roundState.IsAlive then
			local character = characterService:GetCharacterByPlayer(player)
			if character and character.RootPart then
				if (character.RootPart.Position - entityPosition).Magnitude <= radius then
					table.insert(players, player)
				end
			end
		end
	end

	return players
end

function EntityService:_countVisibleTargets(entity)
	return #self:_collectVisiblePlayers(entity)
end

function EntityService:_countPlayersInRadius(entity, radius)
	return #self:_collectPlayersInRadius(entity, radius)
end

function EntityService:_hasLineOfSight(entity, character)
	local origin = entity:GetPosition()
	if not origin or not character or not character.RootPart then
		return false
	end

	self.RaycastParams.FilterDescendantsInstances = {
		entity.Model,
		self.EntitiesFolder,
		self.MapBounds,
	}

	local direction = character.RootPart.Position - origin
	local result = Workspace:Raycast(origin, direction, self.RaycastParams)
	if not result then
		return true
	end

	return result.Instance and result.Instance:IsDescendantOf(character.Model)
end

function EntityService:_hasLineOfSightToPosition(entity, position)
	local origin = entity:GetPosition()
	if not origin or not position then
		return false
	end

	self.RaycastParams.FilterDescendantsInstances = {
		entity.Model,
		self.EntitiesFolder,
		self.MapBounds,
	}

	local direction = position - origin
	local result = Workspace:Raycast(origin, direction, self.RaycastParams)
	return result == nil
end

function EntityService:_resolveStimulusInvestigationPoint(entity, stimulus, canSeeOrigin)
	local entityPosition = entity:GetPosition()
	local originPoint = stimulus.Position
	if canSeeOrigin then
		return originPoint
	end

	local aroundPoint = self:_findAroundObstaclePoint(entity, originPoint)
	if aroundPoint then
		return aroundPoint
	end

	return self:_projectTowardVisibleInterest(entityPosition, originPoint)
end

function EntityService:_findAroundObstaclePoint(entity, blockedPosition)
	local origin = entity:GetPosition()
	if not origin or not blockedPosition then
		return nil
	end

	local direction = blockedPosition - origin
	local planar = Vector3.new(direction.X, 0, direction.Z)
	if planar.Magnitude <= 0.01 then
		return nil
	end

	local forward = planar.Unit
	local right = Vector3.new(-forward.Z, 0, forward.X)
	local baseDistance = math.min(planar.Magnitude, math.max(entity.DetectionRadius * 0.75, 16))
	local sideDistances = { 8, 14, 20, 28 }

	for _, sideDistance in ipairs(sideDistances) do
		for _, sign in ipairs({ 1, -1 }) do
			local candidate = origin + (forward * baseDistance) + (right * sideDistance * sign)
			candidate = self:_clampPositionToMapBounds(candidate)
			if self:_hasLineOfSightToPosition(entity, candidate) and self:_isNavigationDestinationReachable(entity, candidate) then
				return candidate
			end
		end
	end

	return nil
end

function EntityService:_projectTowardVisibleInterest(origin, blockedPosition)
	if not origin or not blockedPosition then
		return blockedPosition
	end

	local direction = blockedPosition - origin
	local distance = direction.Magnitude
	if distance <= 0.01 then
		return blockedPosition
	end

	local stepBack = math.min(8, distance * 0.35)
	return blockedPosition - (direction.Unit * stepBack)
end

function EntityService:SetAllEntitiesActive(state, options)
	options = options or {}
	local resetRound = options.ResetRound == true
	local selectedRoundEntityIds = self.SelectedRoundEntityIds or {}
	local hasRoundSelection = next(selectedRoundEntityIds) ~= nil

	for index = #self.Entities, 1, -1 do
		local entity = self.Entities[index]
		local participatesInRound = (not hasRoundSelection) or selectedRoundEntityIds[entity.Id] == true

		if entity.IsRuntimeEntity and (resetRound or not participatesInRound) then
			self:_despawnEntity(entity, resetRound and "RoundReset" or "LineupReset")
			continue
		end

		if not state then
			self:_clearRoundHooksForEntity(entity)
		end

		entity:SetActive(state and participatesInRound)
		if state and participatesInRound then
			self:_registerRoundHooksForEntity(entity)
		end
		
		if not state then
			local statusEffectService = self.StatusEffectService
			if statusEffectService then
				statusEffectService:ClearStatuses(entity)
			end
			entity:ResetToSpawn()
		end
	end

	DebugLog:Log("Entity", "[EntityService] Entities active:", state)
end

function EntityService:_registerRoundHooksForEntity(entity)
	local roundHookService = self.RoundHookService
	if not roundHookService or not entity.IsActive then
		return
	end

	self:_clearRoundHooksForEntity(entity)

	for hookId, hookDefinition in pairs(entity.RoundHooks or {}) do
		self.NextRoundHookRuntimeId += 1
		local runtimeHookId = string.format("%s:%s:%d", entity.DisplayName, tostring(hookId), self.NextRoundHookRuntimeId)
		local definitionCopy = table.clone(hookDefinition)
		definitionCopy.Id = runtimeHookId
		definitionCopy.Callback = function(context)
			if not entity.IsActive then
				return
			end

			local targetPlayer = entity:GetTarget()
			local effectContext = self:_createEffectContext(entity, targetPlayer, nil, nil)
			effectContext.RoundHookContext = context
			self:_executeEffectSteps(entity, hookDefinition, effectContext)
		end

		roundHookService:RegisterHook(definitionCopy)
		table.insert(entity.RegisteredRoundHookIds, runtimeHookId)
	end
end

function EntityService:_clearRoundHooksForEntity(entity)
	local roundHookService = self.RoundHookService
	if not roundHookService then
		return
	end

	for _, hookId in ipairs(entity.RegisteredRoundHookIds or {}) do
		roundHookService:RemoveHook(hookId)
	end

	entity.RegisteredRoundHookIds = {}
end

return EntityService
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="88">
          <Properties>
            <string name="Name">EnvironmentalHazardService</string>
            <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")
local Debris = game:GetService("Debris")

local GamePhase = require(ReplicatedStorage.Shared.Enums.GamePhase)
local InteractableType = require(ReplicatedStorage.Shared.Enums.InteractableType)
local StatusEffectId = require(ReplicatedStorage.Shared.Enums.StatusEffectId)
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local EnvironmentalHazardService = {}
EnvironmentalHazardService.Name = "EnvironmentalHazardService"
EnvironmentalHazardService.Dependencies = {
	"RemoteRegistry",
	"EntityService",
	"StatusEffectService",
	"RoundHookService",
}

local DEFAULT_TRIGGER_DURATION = 0.45
local DEFAULT_STUN_DURATION = 2.5
local DEFAULT_EFFECT_RADIUS = 10
local DEFAULT_INTERACT_RANGE = 12
local RESTORE_HOOK_ID = "EnvironmentalHazardService.RestorePlacedHazards"

local function _resolveHazardPart(instance)
	if instance:IsA("BasePart") then
		return instance
	end

	if instance:IsA("Model") then
		return instance.PrimaryPart or instance:FindFirstChild("HumanoidRootPart") or instance:FindFirstChildWhichIsA("BasePart")
	end

	return nil
end

function EnvironmentalHazardService:Init(services)
	self.Services = services
	self.Hazards = {}
	self.HazardTemplates = {}
	self.HazardsFolder = Workspace:FindFirstChild("EnvironmentalHazards")
	if not self.HazardsFolder then
		self.HazardsFolder = Instance.new("Folder")
		self.HazardsFolder.Name = "EnvironmentalHazards"
		self.HazardsFolder.Parent = Workspace
	end
end

function EnvironmentalHazardService:Start()
	self.UiToastRemote = self.RemoteRegistry:GetRemote("UiToastRequested")

	if self.HazardsFolder then
		self:_registerExistingHazards()

		self.HazardsFolder.ChildAdded:Connect(function(instance)
			self:_registerHazard(instance)
		end)

		self.HazardsFolder.ChildRemoved:Connect(function(instance)
			self:_unregisterHazard(instance)
		end)
	end

	if self.RoundHookService then
		self.RoundHookService:RegisterHook({
			Id = RESTORE_HOOK_ID,
			Trigger = "PhaseChanged",
			Phase = GamePhase.Lobby,
			Callback = function()
				self:RestorePlacedHazards()
			end,
		})
	end

	DebugLog:Log("Interaction", "[EnvironmentalHazardService] Started")
end

function EnvironmentalHazardService:_registerExistingHazards()
	for _, instance in ipairs(self.HazardsFolder:GetChildren()) do
		self:_registerHazard(instance)
	end
end

function EnvironmentalHazardService:_registerHazard(instance)
	if self.Hazards[instance] then
		return
	end

	self:_cacheHazardTemplate(instance)

	local hazardPart = _resolveHazardPart(instance)
	if not hazardPart then
		DebugLog:Log("Interaction", string.format("[EnvironmentalHazardService] Ignored hazard '%s': no usable part", instance.Name))
		return
	end

	local triggerDuration = tonumber(instance:GetAttribute("TriggerDuration")) or DEFAULT_TRIGGER_DURATION
	local effectRadius = tonumber(instance:GetAttribute("EffectRadius")) or DEFAULT_EFFECT_RADIUS
	local stunDuration = tonumber(instance:GetAttribute("StunDuration")) or DEFAULT_STUN_DURATION
	local singleUse = instance:GetAttribute("SingleUse")
	if singleUse == nil then
		singleUse = true
	end

	local displayName = instance:GetAttribute("DisplayName")
	if not displayName or displayName == "" then
		displayName = "Trigger Hazard"
	end

	local hazard = {
		Type = InteractableType.EnvironmentalHazard,
		Id = instance:GetFullName(),
		HazardType = instance:GetAttribute("HazardType") or "DropLog",
		DisplayName = displayName,
		Instance = hazardPart,
		Model = instance,
		Progress = 0,
		MaxProgress = 1,
		ChargeRate = triggerDuration > 0 and (1 / triggerDuration) or 1,
		EffectRadius = effectRadius,
		StunDuration = stunDuration,
		SingleUse = singleUse == true,
		IsComplete = false,
		IsSpent = instance:GetAttribute("Spent") == true,
	}

	self.Hazards[instance] = hazard
	self:_applyHazardVisualState(hazard)

	DebugLog:Log("Interaction", string.format("[EnvironmentalHazardService] Registered hazard %s (%s)", instance.Name, hazard.HazardType))
end

function EnvironmentalHazardService:_cacheHazardTemplate(instance)
	local templateId = instance:GetAttribute("HazardTemplateId")
	if not templateId or templateId == "" then
		templateId = instance:GetFullName()
		instance:SetAttribute("HazardTemplateId", templateId)
	end

	if self.HazardTemplates[templateId] then
		return
	end

	self.HazardTemplates[templateId] = {
		TemplateId = templateId,
		Name = instance.Name,
		Clone = instance:Clone(),
	}
end

function EnvironmentalHazardService:_unregisterHazard(instance)
	self.Hazards[instance] = nil
end

function EnvironmentalHazardService:GetAvailableHazards()
	local results = {}
	for _, hazard in pairs(self.Hazards) do
		if hazard.Instance and hazard.Instance.Parent and not hazard.IsSpent and not hazard.IsComplete then
			table.insert(results, hazard)
		end
	end

	return results
end

function EnvironmentalHazardService:GetNearestAvailableHazard(player, maxDistance)
	if not player or not self.EntityService then
		return nil
	end

	local character = self.Services.CharacterService and self.Services.CharacterService:GetCharacterByPlayer(player)
	if not character or not character.RootPart then
		return nil
	end

	local playerPosition = character.RootPart.Position
	local bestHazard = nil
	local bestDistance = maxDistance or DEFAULT_INTERACT_RANGE

	for _, hazard in ipairs(self:GetAvailableHazards()) do
		local hazardInstance = hazard.Instance
		if hazardInstance then
			local distance = (hazardInstance.Position - playerPosition).Magnitude
			if distance <= bestDistance then
				bestHazard = hazard
				bestDistance = distance
			end
		end
	end

	return bestHazard
end

function EnvironmentalHazardService:TriggerNearestHazard(player, maxDistance)
	local hazard = self:GetNearestAvailableHazard(player, maxDistance)
	if not hazard then
		return false
	end

	return self:CompleteHazard(player, hazard)
end

function EnvironmentalHazardService:CompleteHazard(player, hazard)
	if not hazard or hazard.IsSpent or hazard.IsComplete then
		return false
	end

	hazard.IsComplete = true
	self:_playTriggerVisual(hazard)
	local hitCount = self:_triggerHazard(hazard)
	hazard.IsSpent = hazard.SingleUse
	hazard.Progress = hazard.MaxProgress
	self:_applyHazardVisualState(hazard)
	hazard.IsComplete = false

	if self.UiToastRemote then
		self.UiToastRemote:FireClient(player, {
			Title = "Hazard Triggered",
			Message = hitCount > 0 and string.format("%s stunned %d", hazard.DisplayName, hitCount) or (hazard.DisplayName .. " triggered"),
			Tint = "Ability",
		})
	end

	DebugLog:Log("Interaction", string.format("[EnvironmentalHazardService] %s triggered %s (%d hits)", player.Name, hazard.DisplayName, hitCount))
	return true
end

function EnvironmentalHazardService:_playTriggerVisual(hazard)
	if not hazard or not hazard.Instance then
		return
	end

	local origin = hazard.Instance.Position
	local radius = math.max(2, hazard.EffectRadius or DEFAULT_EFFECT_RADIUS)

	local burst = Instance.new("Part")
	burst.Name = "HazardTriggerBurst"
	burst.Anchored = true
	burst.CanCollide = false
	burst.CanQuery = false
	burst.CanTouch = false
	burst.CastShadow = false
	burst.Shape = Enum.PartType.Ball
	burst.Material = Enum.Material.Neon
	burst.Color = Color3.fromRGB(255, 184, 104)
	burst.Transparency = 0.2
	burst.Size = Vector3.new(1, 1, 1)
	burst.Position = origin
	burst.Parent = Workspace

	local ring = Instance.new("Part")
	ring.Name = "HazardTriggerRing"
	ring.Anchored = true
	ring.CanCollide = false
	ring.CanQuery = false
	ring.CanTouch = false
	ring.CastShadow = false
	ring.Material = Enum.Material.Neon
	ring.Color = Color3.fromRGB(255, 212, 103)
	ring.Transparency = 0.12
	ring.Size = Vector3.new(0.35, 0.35, 0.35)
	ring.CFrame = CFrame.new(origin) * CFrame.Angles(math.rad(90), 0, 0)
	ring.Parent = Workspace

	local attachment = Instance.new("Attachment")
	attachment.Parent = burst

	local pulse = Instance.new("PointLight")
	pulse.Color = Color3.fromRGB(255, 202, 140)
	pulse.Range = radius * 1.35
	pulse.Brightness = 2.8
	pulse.Parent = burst

	task.spawn(function()
		local duration = 0.2
		local startTime = os.clock()
		while true do
			local alpha = math.clamp((os.clock() - startTime) / duration, 0, 1)
			burst.Size = Vector3.new(1, 1, 1):Lerp(Vector3.new(radius * 1.4, radius * 1.4, radius * 1.4), alpha)
			burst.Transparency = 0.2 + (alpha * 0.8)
			ring.Size = Vector3.new(radius * 0.3, radius * 2, radius * 2)
			ring.Transparency = 0.12 + (alpha * 0.88)
			pulse.Brightness = 2.8 * (1 - alpha)
			if alpha >= 1 then
				break
			end
			task.wait()
		end
	end)

	Debris:AddItem(burst, 0.25)
	Debris:AddItem(ring, 0.25)
end

function EnvironmentalHazardService:_triggerHazard(hazard)
	if not hazard or not hazard.Instance then
		return 0
	end

	local hitCount = 0
	local origin = hazard.Instance.Position
	for _, entity in ipairs(self.EntityService and self.EntityService.Entities or {}) do
		if entity.IsActive and entity.RootPart and entity.Health > 0 then
			local distance = (entity.RootPart.Position - origin).Magnitude
			if distance <= hazard.EffectRadius then
				self.StatusEffectService:ApplyStatus(entity, StatusEffectId.Stunned, {
					Duration = hazard.StunDuration,
					Source = hazard.HazardType or "EnvironmentalHazard",
					InterruptAbilities = true,
				})
				hitCount += 1
			end
		end
	end

	return hitCount
end

function EnvironmentalHazardService:_applyHazardVisualState(hazard)
	if not hazard or not hazard.Model then
		return
	end

	hazard.Model:SetAttribute("Spent", hazard.IsSpent == true)

	for _, descendant in ipairs(hazard.Model:GetDescendants()) do
		if descendant:IsA("BasePart") then
			if not descendant:GetAttribute("HazardOriginalColorStored") then
				descendant:SetAttribute("HazardOriginalColorStored", true)
				descendant:SetAttribute("HazardOriginalColorR", descendant.Color.R)
				descendant:SetAttribute("HazardOriginalColorG", descendant.Color.G)
				descendant:SetAttribute("HazardOriginalColorB", descendant.Color.B)
				descendant:SetAttribute("HazardOriginalMaterial", descendant.Material.Name)
			end

			if hazard.IsSpent then
				descendant.Color = Color3.fromRGB(88, 88, 94)
				descendant.Material = Enum.Material.SmoothPlastic
			else
				local originalColor = Color3.new(
					descendant:GetAttribute("HazardOriginalColorR") or descendant.Color.R,
					descendant:GetAttribute("HazardOriginalColorG") or descendant.Color.G,
					descendant:GetAttribute("HazardOriginalColorB") or descendant.Color.B
				)
				local originalMaterialName = descendant:GetAttribute("HazardOriginalMaterial")
				descendant.Color = originalColor
				if originalMaterialName and Enum.Material[originalMaterialName] then
					descendant.Material = Enum.Material[originalMaterialName]
				end
			end
		end
	end
end

function EnvironmentalHazardService:RestorePlacedHazards()
	if not self.HazardsFolder then
		return
	end

	local activeTemplateIds = {}
	for _, child in ipairs(self.HazardsFolder:GetChildren()) do
		local templateId = child:GetAttribute("HazardTemplateId")
		if templateId and templateId ~= "" then
			activeTemplateIds[templateId] = true
		end
	end

	for templateId, templateData in pairs(self.HazardTemplates) do
		if not activeTemplateIds[templateId] then
			local restoredInstance = templateData.Clone:Clone()
			restoredInstance:SetAttribute("Spent", false)
			restoredInstance.Parent = self.HazardsFolder
		end
	end

	for _, hazard in pairs(self.Hazards) do
		hazard.IsSpent = false
		hazard.IsComplete = false
		hazard.Progress = 0
		self:_applyHazardVisualState(hazard)
	end
end

return EnvironmentalHazardService
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="89">
          <Properties>
            <string name="Name">EscapeService</string>
            <string name="Source"><![CDATA[local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local DebugLog = require(ReplicatedStorage.Shared.Utility.DebugLog)

local EscapeService = {}
EscapeService.Name = "EscapeService"

function EscapeService:Init(services)
	self.Services = services
	self.EscapeZone = Workspace:WaitForChild("EscapeZone")
	self.TouchDebounce = {}
	self.EscapeEnabled = true
end

function EscapeService:Start()
	self.EscapeZone.Touched:Connect(function(hit)
		self:_onEscapeZoneTouched(hit)
	end)
	
	DebugLog:Log("Round", "[EscapeService] Started")
end

function EscapeService:_onEscapeZoneTouched(hit)
	local characterModel = hit and hit.Parent
	if not characterModel then
		return
	end
	
	local player = Players:GetPlayerFromCharacter(characterModel)
	if not player then
		return
	end
	
	if self.TouchDebounce[player] then
		return
	end
	
	self.TouchDebounce[player] = true
	
	self:TryEscapePlayer(player)
	
	task.delay(1, function()
		self.TouchDebounce[player] = nil
	end)
end

function EscapeService:TryEscapePlayer(player)
	if not self.EscapeEnabled then
		return
	end

	local roundManager = self.Services.RoundManager
	if not roundManager then
		return
	end
	
	if not roundManager:IsReceptionActive() then
		return
	end
	
	if not roundManager:IsPlayerActive(player) then
		return
	end
	
	local roundState = roundManager:GetRoundState(player)
	if not roundState or not roundState.IsAlive then
		return
	end
	
	roundManager:SetPlayerEscaped(player)

	local character = self.Services.CharacterService:GetCharacterByPlayer(player)
	if character then
		character:Freeze()
		if character.RootPart then
			character.RootPart.CFrame = CFrame.new(0, -1000, 0) -- Temporary extraction method..
		end
	end

	DebugLog:Log("Round", "[EscapeService] Player escaped:", player.Name)
end

function EscapeService:SetEscapeEnabled(state)
	self.EscapeEnabled = state == true
	self.EscapeZone.CanTouch = self.EscapeEnabled
	self.EscapeZone:SetAttribute("DebugEscapeEnabled", self.EscapeEnabled)
	self.EscapeZone.Transparency = self.EscapeEnabled and 0 or 0.35
end

function EscapeService:IsEscapeEnabled()
	return self.EscapeEnabled == true
end

return EscapeService
]]></string>
          </Properties>
